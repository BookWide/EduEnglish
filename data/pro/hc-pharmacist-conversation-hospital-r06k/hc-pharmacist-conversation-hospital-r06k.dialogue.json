    },
    {
      "role": "teacher",
      "text": "The ambulance arrived with a sick person",
      "zh": "救護車載著病人到了",
      "ja": "救急車が病人を乗せて到着しました",
      "time": "00:00:17"
    },
    {
      "role": "teacher",
      "text": "Emergency",
      "zh": "急診",
      "ja": "緊急",
      "time": "00:00:25"
    },
    {
      "role": "teacher",
      "text": "This is an emergency room",
      "zh": "這是急診室",
      "ja": "ここは救急室です",
      "time": "00:00:30"
    },
    {
      "role": "teacher",
      "text": "Doctors perform surgery in the operating room",
      "zh": "醫生在手術室進行手術",
      "ja": "医者は手術室で手術を行います",
      "time": "00:00:41"
    },
    {
      "role": "teacher",
      "text": "Sick people are staying in the ward",
      "zh": "病人住在病房裡",
