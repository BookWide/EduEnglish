      "time": "00:01:02"
    },
    {
      "role": "teacher",
      "text": "This is a doctor",
      "zh": "這是一位醫生",
      "ja": "これは医者です",
      "time": "00:01:13"
    },
    {
      "role": "teacher",
      "text": "Doctors wear white coats",
      "zh": "醫生穿著白袍",
      "ja": "医者は白衣を着ています",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "This is a stethoscope",
      "zh": "這是聽診器",
      "ja": "これは聴診器です",
      "time": "00:01:31"
    },
    {
      "role": "teacher",
      "text": "This is a thermometer",
      "zh": "這是體溫計",
      "ja": "これは体温計です",
      "time": "00:01:39"
    },
    {
      "role": "teacher",
      "text": "This is a nurse",
      "zh": "這是一位護士",
      "ja": "これは看護師です",
      "time": "00:01:48"
    },
    {
      "role": "teacher",
      "text": "Nurses give us injections",
      "zh": "護士給我們注射",
      "ja": "看護師は注射をします",
      "time": "00:01:54"
    },
    {
      "role": "teacher",
      "text": "Patients follow doctors' instructions",
      "zh": "病人遵從醫生指示",
      "ja": "患者は医者の指示に従います",
      "time": "00:02:02"
    },
    {
      "role": "teacher",
      "text": "Doctors and nurses take good care of patients",
