{
  "meta": {
    "slug": "edu-cram-teacher-teaching-emergency-fhe7",
    "category": "pro/education/cram_teacher",
    "source_url": "https://www.youtube.com/watch?v=fhe7vQjQBxM",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "teacher",
      "text": "Three o'clock",
      "zh": "三點鐘",
      "ja": "三時です",
      "time": "00:00:17"
    },
    {
      "role": "teacher",
      "text": "Now, let's play outside",
      "zh": "現在，我們去外面玩吧",
      "ja": "さあ、外で遊びましょう",
      "time": "00:00:19"
    },
    {
      "role": "student",
      "text": "Okay",
      "zh": "好",
      "ja": "はい",
      "time": "00:00:21"
    },
    {
      "role": "student",
      "text": "Where is my music book?",
      "zh": "我的音樂書在哪裡？",
      "ja": "私の音楽の本はどこですか？",
      "time": "00:00:27"
    },
    {
      "role": "teacher",
      "text": "It's on the chair",
      "zh": "它在椅子上",
      "ja": "椅子の上にあります",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "Where is my pencil?",
      "zh": "我的鉛筆在哪裡？",
      "ja": "私の鉛筆はどこですか？",
      "time": "00:00:33"
    },
    {
      "role": "teacher",
      "text": "Oh, it is under the table",
      "zh": "喔，它在桌子下面",
      "ja": "ああ、それはテーブルの下にあります",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "Mom, where is my cap?",
      "zh": "媽媽，我的帽子在哪裡？",
      "ja": "ママ、私の帽子はどこですか？",
      "time": "00:01:01"
    },
    {
      "role": "teacher",
      "text": "It's in your bag",
      "zh": "它在你的包包裡",
      "ja": "あなたのバッグの中にあります",
      "time": "00:01:06"
    },
    {
      "role": "student",
      "text": "I don't see it. Where is it?",
      "zh": "我沒看到。它在哪裡？",
      "ja": "見えません。どこですか？",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "Well, on the desk",
      "zh": "嗯，在桌子上",
      "ja": "ええと、机の上です",
      "time": "00:01:13"
    },
    {
      "role": "student",
      "text": "Here, it's under the desk",
      "zh": "這裡，它在桌子下面",
      "ja": "ここです、机の下にあります",
      "time": "00:01:21"
    },
    {
      "role": "student",
      "text": "Mom, see you",
      "zh": "媽媽，再見",
      "ja": "ママ、またね",
      "time": "00:01:30"
    },
    {
      "role": "teacher",
      "text": "Okay, have fun",
      "zh": "好，玩得開心",
      "ja": "はい、楽しんでね",
      "time": "00:01:34"
    },
    {
      "role": "student",
      "text": "Where is my coat?",
      "zh": "我的外套在哪裡？",
      "ja": "私のコートはどこですか？",
      "time": "00:01:49"
    },
    {
      "role": "teacher",
      "text": "Look, look, it's on the desk",
      "zh": "看，看，它在桌子上",
      "ja": "見て、見て、机の上にあります",
      "time": "00:01:56"
    },
    {
      "role": "student",
      "text": "Where are my coats?",
      "zh": "我的外套們在哪裡？",
      "ja": "私のコートはどこですか？",
      "time": "00:02:06"
    },
    {
      "role": "teacher",
      "text": "Look, look, there in the box",
      "zh": "看，看，在盒子裡",
      "ja": "見て、見て、箱の中にあります",
      "time": "00:02:13"
    },
    {
      "role": "student",
      "text": "Where is my bird?",
      "zh": "我的鳥在哪裡？",
      "ja": "私の鳥はどこですか？",
      "time": "00:02:29"
    },
    {
      "role": "teacher",
      "text": "It is under the table",
      "zh": "它在桌子下面",
      "ja": "それはテーブルの下にあります",
      "time": "00:02:48"
    },
    {
      "role": "student",
      "text": "Where is my hat?",
      "zh": "我的帽子在哪裡？",
      "ja": "私の帽子はどこですか？",
      "time": "00:03:27"
    },
    {
      "role": "teacher",
      "text": "On the desk, on the desk, it's on the desk.",
      "zh": "在桌子上，在桌子上，它在桌子上。",
      "ja": "机の上に、机の上に、机の上にあります。",
      "time": "00:03:36"
    },
    {
      "role": "student",
      "text": "Where is my coat?",
      "zh": "我的外套在哪裡？",
      "ja": "私のコートはどこですか？",
      "time": "00:03:41"
    },
    {
      "role": "teacher",
      "text": "Under the chair, under the chair, it's under the chair.",
      "zh": "在椅子下面，在椅子下面，它在椅子下面。",
      "ja": "椅子の下に、椅子の下に、椅子の下にあります。",
      "time": "00:03:44"
    },
    {
      "role": "student",
      "text": "Where is my jacket?",
      "zh": "我的夾克在哪裡？",
      "ja": "私のジャケットはどこですか？",
      "time": "00:03:50"
    },
    {
      "role": "teacher",
      "text": "In the box, in the box, it's in the box.",
      "zh": "在盒子裡，在盒子裡，它在盒子裡。",
      "ja": "箱の中に、箱の中に、箱の中にあります。",
      "time": "00:03:54"
    },
    {
      "role": "student",
      "text": "Mom, I can't find my ball.",
      "zh": "媽媽，我找不到我的球。",
      "ja": "ママ、私のボールが見つかりません。",
      "time": "00:04:12"
    },
    {
      "role": "teacher",
      "text": "Where is it?",
      "zh": "它在哪裡？",
      "ja": "どこですか？",
      "time": "00:04:15"
    },
    {
      "role": "teacher",
      "text": "I don't know.",
      "zh": "我不知道。",
      "ja": "わかりません。",
      "time": "00:04:17"
    },
    {
      "role": "student",
      "text": "Look, my ball is big and yellow.",
      "zh": "看，我的球又大又黃。",
      "ja": "見て、私のボールは大きくて黄色いです。",
      "time": "00:04:30"
    },
    {
      "role": "student",
      "text": "Where is it?",
      "zh": "它在哪裡？",
      "ja": "どこですか？",
      "time": "00:04:33"
    },
    {
      "role": "teacher",
      "text": "Oh, it's under the tree.",
      "zh": "喔，它在樹下。",
      "ja": "ああ、それは木の下にあります。",
      "time": "00:04:38"
    },
    {
      "role": "student",
      "text": "No, that's not my ball.",
      "zh": "不，那不是我的球。",
      "ja": "いいえ、それは私のボールではありません。",
      "time": "00:04:41"
    },
    {
      "role": "teacher",
      "text": "Look at this ball.",
      "zh": "看看這個球。",
      "ja": "このボールを見てください。",
      "time": "00:04:51"
    },
    {
      "role": "student",
      "text": "Where is it?",
      "zh": "它在哪裡？",
      "ja": "どこですか？",
      "time": "00:04:52"
    },
    {
      "role": "teacher",
      "text": "Let's see.",
      "zh": "讓我們看看。",
      "ja": "見てみましょう。",
      "time": "00:04:53"
    },
    {
      "role": "teacher",
      "text": "Ah, it's in the zoo.",
      "zh": "啊，它在動物園裡。",
      "ja": "ああ、それは動物園にあります。",
      "time": "00:04:54"
    },
    {
      "role": "student",
      "text": "It's white.",
      "zh": "它是白色的。",
      "ja": "それは白いです。",
      "time": "00:05:05"
    },
    {
      "role": "student",
      "text": "That's not my ball.",
      "zh": "那不是我的球。",
      "ja": "それは私のボールではありません。",
      "time": "00:05:06"
    },
    {
      "role": "teacher",
      "text": "Good evening, my friend.",
      "zh": "晚上好，我的朋友。",
      "ja": "こんばんは、友よ。",
      "time": "00:05:10"
    },
    {
      "role": "student",
      "text": "Good evening.",
      "zh": "晚上好。",
      "ja": "こんばんは。",
      "time": "00:05:15"
    },
    {
      "role": "teacher",
      "text": "Are you okay?",
      "zh": "你還好嗎？",
      "ja": "大丈夫ですか？",
      "time": "00:05:17"
    },
    {
      "role": "student",
      "text": "Oh, no. I can't find my ball.",
      "zh": "喔，不。我找不到我的球。",
      "ja": "ああ、いや。私のボールが見つかりません。",
      "time": "00:05:19"
    },
    {
      "role": "teacher",
      "text": "This is my ball. Look, it's under the tree.",
      "zh": "這是我的球。看，它在樹下。",
      "ja": "これは私のボールです。見て、それは木の下にあります。",
      "time": "00:05:22"
    },
    {
      "role": "student",
      "text": "That's my ball. Thank you.",
      "zh": "那是我的球。謝謝你。",
      "ja": "それは私のボールです。ありがとう。",
      "time": "00:05:28"
    },
    {
      "role": "teacher",
      "text": "You're welcome.",
      "zh": "不客氣。",
      "ja": "どういたしまして。",
      "time": "00:05:30"
    },
    {
      "role": "student",
      "text": "Jack, where are you?",
      "zh": "傑克，你在哪裡？",
      "ja": "ジャック、どこにいるの？",
      "time": "00:05:53"
    },
    {
      "role": "student",
      "text": "Look here, Mom.",
      "zh": "媽媽，看這裡。",
      "ja": "ママ、ここを見て。",
      "time": "00:05:55"
    },
    {
      "role": "teacher",
      "text": "Oh, no. Watch out.",
      "zh": "喔，不。小心。",
      "ja": "ああ、危ない。気をつけて。",
      "time": "00:05:56"
    },
    {
      "role": "student",
      "text": "Where's my box?",
      "zh": "我的盒子在哪裡？",
      "ja": "私の箱はどこですか？",
      "time": "00:06:03"
    },
    {
      "role": "teacher",
      "text": "It's on the desk.",
      "zh": "它在桌子上。",
      "ja": "それは机の上にあります。",
      "time": "00:06:15"
    },
    {
      "role": "student",
      "text": "No, it's not on the desk.",
      "zh": "不，它不在桌子上。",
      "ja": "いいえ、それは机の上にありません。",
      "time": "00:06:17"
    },
    {
      "role": "teacher",
      "text": "Look, who's that?",
      "zh": "看，那是誰？",
      "ja": "見て、あれは誰？",
      "time": "00:06:21"
    },
    {
      "role": "student",
      "text": "Oh, you have my box. Give it to me.",
      "zh": "喔，你拿著我的盒子。把它給我。",
      "ja": "ああ、あなたが私の箱を持っています。ちょうだい。",
      "time": "00:06:24"
    },
    {
      "role": "teacher",
      "text": "Oh, no.",
      "zh": "喔，不。",
      "ja": "ああ、いや。",
      "time": "00:06:29"
    },
    {
      "role": "student",
      "text": "Mom, I'm here. Watch out, Jack.",
      "zh": "媽媽，我在這裡。小心，傑克。",
      "ja": "ママ、ここにいます。気をつけて、ジャック。",
      "time": "00:06:33"
    },
    {
      "role": "teacher",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとう。",
      "time": "00:06:37"
    },
    {
      "role": "student",
      "text": "Where's my dog?",
      "zh": "我的狗在哪裡？",
      "ja": "私の犬はどこですか？",
      "time": "00:07:04"
    },
    {
      "role": "teacher",
      "text": "It's under the table.",
      "zh": "它在桌子下面。",
      "ja": "それはテーブルの下にいます。",
      "time": "00:07:09"
    },
    {
      "role": "student",
      "text": "Mary, where's my dog?",
      "zh": "瑪麗，我的狗在哪裡？",
      "ja": "メアリー、私の犬はどこですか？",
      "time": "00:07:30"
    },
    {
      "role": "student",
      "text": "Hi, Tom.",
      "zh": "嗨，湯姆。",
      "ja": "やあ、トム。",
      "time": "00:07:46"
    },
    {
      "role": "student",
      "text": "Mom, where's my dog?",
      "zh": "媽媽，我的狗在哪裡？",
      "ja": "ママ、私の犬はどこですか？",
      "time": "00:07:54"
    },
    {
      "role": "teacher",
      "text": "It's under the table.",
      "zh": "它在桌子下面。",
      "ja": "それはテーブルの下にいます。",
      "time": "00:08:07"
    }
  ]
}