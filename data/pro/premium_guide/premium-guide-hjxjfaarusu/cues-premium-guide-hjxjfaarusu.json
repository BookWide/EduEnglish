    "ja": "もう少しです。"
  },
  {
    "time": "00:01:44",
    "en": "Can I have one more minute, please?",
    "zh": "可以再給我一分鐘嗎？",
    "ja": "もう一分待ってもらえますか？"
  },
  {
    "time": "00:01:47",
    "en": "A few moments later.",
    "zh": "幾分鐘後。",
    "ja": "数分後。"
  },
  {
    "time": "00:01:48",
    "en": "I'll have the chicken sandwich and a glass of water, please.",
