[
  {
    "time": "00:00:00",
    "en": "Good morning, Erica.",
    "zh": "早安，Erica。",
    "ja": "おはよう、エリカ。",
    "source_url": "https://www.youtube.com/watch?v=o8AFHRwLQwI"
  },
  {
    "time": "00:00:07",
    "en": "Today is the day time to get up.",
    "zh": "今天是該起床的日子。",
    "ja": "今日は起きる日だよ。"
  },
  {
    "time": "00:00:14",
    "en": "Sunny day, great.",
    "zh": "晴天，太好了。",
    "ja": "晴れの日、いいね。"
  },
  {
    "time": "00:00:26",
    "en": "Good morning, Sarah. Today is the day.",
    "zh": "早安，Sarah。今天就是那天。",
    "ja": "おはよう、サラ。今日はその日だよ。"
  },
  {
    "time": "00:00:29",
    "en": "Mr. Wang confirmed 9 a.m.",
    "zh": "王先生確認九點。",
    "ja": "ワンさんが午前9時を確認した。"
  },
  {
    "time": "00:00:32",
    "en": "Four companies competed for this.",
    "zh": "有四家公司競爭這個。",
    "ja": "4社がこれに競争した。"
  },
  {
    "time": "00:00:34",
    "en": "We need it.",
    "zh": "我們需要這個。",
    "ja": "私たちはこれが必要だ。"
  },
  {
    "time": "00:00:36",
    "en": "No problem, Erica. I'm ready.",
    "zh": "沒問題，Erica。我準備好了。",
    "ja": "問題ないよ、エリカ。準備できてる。"
  },
  {
    "time": "00:00:38",
    "en": "See you at 8.45.",
    "zh": "八點四十五見。",
    "ja": "8時45分に会おう。"
  },
  {
    "time": "00:00:42",
    "en": "Leo, shoes on.",
    "zh": "Leo，穿鞋子。",
    "ja": "レオ、靴を履いて。"
  },
  {
    "time": "00:00:44",
    "en": "We leave in three minutes.",
    "zh": "我們三分鐘後出發。",
    "ja": "3分で出発するよ。"
  },
  {
    "time": "00:00:46",
    "en": "Mom, the left one feels different.",
    "zh": "媽媽，左腳那隻感覺不一樣。",
    "ja": "ママ、左の靴が違う感じがする。"
  },
  {
    "time": "00:00:49",
    "en": "It's the same shoe it was yesterday, Leo.",
    "zh": "那是昨天穿的同一隻鞋，Leo。",
    "ja": "それは昨日のと同じ靴だよ、レオ。"
  },
  {
    "time": "00:00:53",
    "en": "But it feels different.",
    "zh": "可是感覺不一樣。",
    "ja": "でも違う感じがする。"
  },
  {
    "time": "00:00:55",
    "en": "Here, like this.",
    "zh": "這樣，像這樣。",
    "ja": "ここ、こうやって。"
  },
  {
    "time": "00:00:59",
    "en": "Good backpack.",
    "zh": "好背包。",
    "ja": "いいリュックだね。"
  },
  {
    "time": "00:01:01",
    "en": "Let's go.",
    "zh": "走吧。",
    "ja": "行こう。"
  },
  {
    "time": "00:01:03",
    "en": "Mom, it's a nice day.",
    "zh": "媽媽，今天天氣很好。",
    "ja": "ママ、いい天気だね。"
  },
  {
    "time": "00:01:05",
    "en": "It really is.",
    "zh": "真的很好。",
    "ja": "本当にいい天気だよ。"
  },
  {
    "time": "00:01:07",
    "en": "Okay, Leo.",
    "zh": "好，Leo。",
    "ja": "わかった、レオ。"
  },
  {
    "time": "00:01:09",
    "en": "Let's get you in.",
    "zh": "讓我幫你上車。",
    "ja": "車に乗せよう。"
  },
  {
    "time": "00:01:10",
    "en": "Okay, Mom.",
    "zh": "好，媽媽。",
    "ja": "うん、ママ。"
  },
  {
    "time": "00:01:13",
    "en": "All right, now for the driver's side.",
    "zh": "好了，現在換駕駛座這邊。",
    "ja": "よし、次は運転席側だ。"
  },
  {
    "time": "00:01:23",
    "en": "Mom, why are you dressed so nice today?",
    "zh": "媽媽，你今天為什麼穿得這麼漂亮？",
    "ja": "ママ、今日はどうしてそんなにおしゃれしてるの？"
  },
  {
    "time": "00:01:34",
    "en": "I have a very important meeting.",
    "zh": "我有一個非常重要的會議。",
    "ja": "とても大事な会議があるんだ。"
  },
  {
    "time": "00:01:37",
    "en": "How important?",
    "zh": "有多重要？",
    "ja": "どれくらい重要なの？"
  },
  {
    "time": "00:01:39",
    "en": "Very.",
    "zh": "非常重要。",
    "ja": "とてもだよ。"
  },
  {
    "time": "00:01:40",
    "en": "I've been preparing for three weeks.",
    "zh": "我已經準備了三個星期。",
    "ja": "3週間準備してきた。"
  },
  {
    "time": "00:01:46",
    "en": "Is he nice?",
    "zh": "他人很好嗎？",
    "ja": "彼はいい人？"
  },
  {
    "time": "00:01:47",
    "en": "The person you're meeting?",
    "zh": "你要見的那個人？",
    "ja": "会う人のこと？"
  },
  {
    "time": "00:01:50",
    "en": "Mr. Wang, I don't know yet.",
    "zh": "王先生，我還不知道。",
    "ja": "ワンさん、まだわからない。"
  },
  {
    "time": "00:01:52",
    "en": "I hope so.",
    "zh": "我希望是這樣。",
    "ja": "そうだといいな。"
  },
  {
    "time": "00:01:57",
    "en": "You're going to do great, Mom.",
    "zh": "你一定會很棒的，媽媽。",
    "ja": "ママ、うまくいくよ。"
  },
  {
    "time": "00:01:59",
    "en": "Thank you, baby.",
    "zh": "謝謝你，寶貝。",
    "ja": "ありがとう、ベイビー。"
  },
  {
    "time": "00:02:05",
    "en": "Erica, Mr. Wang's assistant just called me.",
    "zh": "Erica，王先生的助理剛打電話給我。",
    "ja": "エリカ、ワンさんのアシスタントから電話があったよ。"
  },
  {
    "time": "00:02:08",
    "en": "She said please be on time.",
    "zh": "她說請準時。",
    "ja": "時間通りに来てくださいと言ってた。"
  },
  {
    "time": "00:02:09",
    "en": "Mr. Wang doesn't like to wait.",
    "zh": "王先生不喜歡等人。",
    "ja": "ワンさんは待つのが嫌いだ。"
  },
  {
    "time": "00:02:11",
    "en": "You won't have to.",
    "zh": "你不會讓他等的。",
    "ja": "待たせることはないよ。"
  },
  {
    "time": "00:02:12",
    "en": "Mom, go!",
    "zh": "媽媽，快走！",
    "ja": "ママ、行って！"
  },
  {
    "time": "00:02:15",
    "en": "No, no, no!",
    "zh": "不，不，不！",
    "ja": "ダメ、ダメ、ダメ！"
  },
  {
    "time": "00:02:22",
    "en": "Leo, are you hurt?",
    "zh": "Leo，你受傷了嗎？",
    "ja": "レオ、怪我は？"
  },
  {
    "time": "00:02:24",
    "en": "Anywhere?",
    "zh": "哪裡痛嗎？",
    "ja": "どこか痛い？"
  },
  {
    "time": "00:02:25",
    "en": "No.",
    "zh": "沒有。",
    "ja": "いいえ。"
  },
  {
    "time": "00:02:26",
    "en": "I'm okay.",
    "zh": "我沒事。",
    "ja": "大丈夫。"
  },
  {
    "time": "00:02:31",
    "en": "Are you kidding me?",
    "zh": "你在開玩笑嗎？",
    "ja": "冗談でしょ？"
  },
  {
    "time": "00:02:33",
    "en": "Photos for the insurance?",
    "zh": "保險用的照片？",
    "ja": "保険のための写真？"
  },
  {
    "time": "00:02:35",
    "en": "Perfect.",
    "zh": "完美。",
    "ja": "完璧だ。"
  },
  {
    "time": "00:02:43",
    "en": "Mom, the screen is cracked.",
    "zh": "媽媽，螢幕裂了。",
    "ja": "ママ、画面が割れてる。"
  },
  {
    "time": "00:02:51",
    "en": "It's okay as long as you are safe.",
    "zh": "只要你安全就好。",
    "ja": "君が無事なら大丈夫だよ。"
  },
  {
    "time": "00:02:54",
    "en": "Leo, you don't have to do that.",
    "zh": "Leo，你不必這樣做。",
    "ja": "レオ、そんなことしなくていいよ。"
  },
  {
    "time": "00:02:56",
    "en": "The papers were on the floor.",
    "zh": "文件掉在地上了。",
    "ja": "書類が床に落ちてたんだ。"
  },
  {
    "time": "00:02:59",
    "en": "Leo, you are all that matters.",
    "zh": "Leo，你才是最重要的。",
    "ja": "レオ、君が一番大事だよ。"
  },
  {
    "time": "00:03:02",
    "en": "Not the car, not the computer, not my job.",
    "zh": "不是車子，不是電腦，也不是我的工作。",
    "ja": "車でもパソコンでも仕事でもない。"
  },
  {
    "time": "00:03:12",
    "en": "Are we going now?",
    "zh": "我們現在要走了嗎？",
    "ja": "もう行くの？"
  },
  {
    "time": "00:03:19",
    "en": "Yes, we're going.",
    "zh": "是的，我們要走了。",
    "ja": "うん、行くよ。"
  },
  {
    "time": "00:03:26",
    "en": "Mom, is that coffee?",
    "zh": "媽媽，那是咖啡嗎？",
    "ja": "ママ、それコーヒー？"
  },
  {
    "time": "00:03:29",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "うん。"
  },
  {
    "time": "00:03:30",
    "en": "Our coffee from this morning?",
    "zh": "我們今天早上的咖啡？",
    "ja": "今朝のコーヒー？"
  },
  {
    "time": "00:03:34",
    "en": "I put it on the roof.",
    "zh": "我放在車頂上了。",
    "ja": "車の屋根に置いたんだ。"
  },
  {
    "time": "00:03:36",
    "en": "I forgot it was there.",
    "zh": "我忘了它還在那裡。",
    "ja": "そこにあるのを忘れてた。"
  },
  {
    "time": "00:03:39",
    "en": "Today of all days.",
    "zh": "偏偏是今天。",
    "ja": "まさか今日に限って。"
  },
  {
    "time": "00:03:49",
    "en": "What is that?",
    "zh": "那是什麼？",
    "ja": "あれは何？"
  },
  {
    "time": "00:03:52",
    "en": "Mom, why are we stopping?",
    "zh": "媽媽，我們為什麼停下來？",
    "ja": "ママ、なんで止まったの？"
  },
  {
    "time": "00:03:56",
    "en": "Stay in the car.",
    "zh": "待在車裡。",
    "ja": "車の中にいて。"
  },
  {
    "time": "00:04:03",
    "en": "No.",
    "zh": "不。",
    "ja": "いや。"
  },
  {
    "time": "00:04:06",
    "en": "The tire is flat, Leo.",
    "zh": "輪胎洩氣了，Leo。",
    "ja": "タイヤがパンクしたんだ、レオ。"
  },
  {
    "time": "00:04:08",
    "en": "I need to make a call.",
    "zh": "我需要打電話。",
    "ja": "電話をかけないと。"
  },
  {
    "time": "00:04:10",
    "en": "Okay, I'm stuck here.",
    "zh": "好，我被困在這裡了。",
    "ja": "わかった、ここで立ち往生してる。"
  },
  {
    "time": "00:04:12",
    "en": "I need to call my client, Mr. Wang, now.",
    "zh": "我現在得打給我的客戶王先生。",
    "ja": "今すぐクライアントのワンさんに電話しないと。"
  },
  {
    "time": "00:04:20",
    "en": "Mr. Wang, this is Erica.",
    "zh": "王先生，我是Erica。",
    "ja": "ワンさん、エリカです。"
  },
  {
    "time": "00:04:22",
    "en": "I am so sorry to call you this early.",
    "zh": "很抱歉這麼早打給您。",
    "ja": "こんな早くに電話してすみません。"
  },
  {
    "time": "00:04:24",
    "en": "I had a car accident.",
    "zh": "我發生了車禍。",
    "ja": "車の事故に遭いました。"
  },
  {
    "time": "00:04:26",
    "en": "I am fine.",
    "zh": "我沒事。",
    "ja": "私は大丈夫です。"
  },
  {
    "time": "00:04:27",
    "en": "My son is fine.",
    "zh": "我兒子也沒事。",
    "ja": "息子も無事です。"
  },
  {
    "time": "00:04:29",
    "en": "But I need to move our meeting to 9.30.",
    "zh": "但我需要把會議改到九點半。",
    "ja": "でも会議を9時30分に変更する必要があります。"
  },
  {
    "time": "00:04:32",
    "en": "I am very sorry.",
    "zh": "非常抱歉。",
    "ja": "本当に申し訳ありません。"
  },
  {
    "time": "00:04:35",
    "en": "Car accident?",
    "zh": "車禍？",
    "ja": "事故？"
  },
  {
    "time": "00:04:36",
    "en": "Are you hurt?",
    "zh": "你受傷了嗎？",
    "ja": "怪我は？"
  },
  {
    "time": "00:04:37",
    "en": "No, just the car.",
    "zh": "沒有，只是車子。",
    "ja": "いいえ、車だけです。"
  },
  {
    "time": "00:04:39",
    "en": "9.30 is fine.",
    "zh": "九點半沒問題。",
    "ja": "9時30分で大丈夫です。"
  },
  {
    "time": "00:04:40",
    "en": "Don't rush.",
    "zh": "別急。",
    "ja": "急がなくていいよ。"
  },
  {
    "time": "00:04:45",
    "en": "Hello.",
    "zh": "你好。",
    "ja": "もしもし。"
  },
  {
    "time": "00:04:46",
    "en": "I need help.",
    "zh": "我需要幫助。",
    "ja": "助けが必要です。"
  },
  {
    "time": "00:04:47",
    "en": "My tire is flat.",
    "zh": "我的輪胎洩氣了。",
    "ja": "タイヤがパンクしました。"
  },
  {
    "time": "00:04:48",
    "en": "I cannot drive.",
    "zh": "我不能開車。",
    "ja": "運転できません。"
  },
  {
    "time": "00:04:49",
    "en": "I need someone to come now.",
    "zh": "我需要有人現在來。",
    "ja": "誰かすぐに来てほしいです。"
  },
  {
    "time": "00:04:51",
    "en": "Someone will be there in 20 to 25 minutes.",
    "zh": "有人會在20到25分鐘內到。",
    "ja": "20〜25分で誰かが来ます。"
  },
  {
    "time": "00:04:59",
    "en": "How long do we wait?",
    "zh": "我們要等多久？",
    "ja": "どのくらい待つの？"
  },
  {
    "time": "00:05:01",
    "en": "25 minutes.",
    "zh": "25分鐘。",
    "ja": "25分です。"
  },
  {
    "time": "00:05:03",
    "en": "That's okay.",
    "zh": "沒關係。",
    "ja": "大丈夫。"
  },
  {
    "time": "00:05:04",
    "en": "I can wait.",
    "zh": "我可以等。",
    "ja": "待てます。"
  },
  {
    "time": "00:05:06",
    "en": "Okay.",
    "zh": "好。",
    "ja": "わかった。"
  },
  {
    "time": "00:05:07",
    "en": "I can see the problem.",
    "zh": "我看到了問題。",
    "ja": "問題が見えました。"
  },
  {
    "time": "00:05:09",
    "en": "Give me 15 minutes.",
    "zh": "給我15分鐘。",
    "ja": "15分ちょうだい。"
  },
  {
    "time": "00:05:10",
    "en": "Can you go faster?",
    "zh": "你能快一點嗎？",
    "ja": "もっと早くできる？"
  },
  {
    "time": "00:05:12",
    "en": "15 minutes.",
    "zh": "15分鐘。",
    "ja": "15分です。"
  },
  {
    "time": "00:05:17",
    "en": "Mom, why did the tire go flat just now?",
    "zh": "媽媽，為什麼剛剛輪胎會洩氣？",
    "ja": "ママ、さっきタイヤがパンクしたのはなぜ？"
  },
  {
    "time": "00:05:21",
    "en": "Probably the tree.",
    "zh": "可能是撞到樹了。",
    "ja": "多分木にぶつかったんだ。"
  },
  {
    "time": "00:05:23",
    "en": "When we hit it, something happened to the tire.",
    "zh": "我們撞到它時，輪胎出了問題。",
    "ja": "ぶつかった時にタイヤに何かあったんだ。"
  },
  {
    "time": "00:05:25",
    "en": "It just took a few minutes to show.",
    "zh": "只是過了幾分鐘才顯現出來。",
    "ja": "すぐにはわからなかったんだ。"
  },
  {
    "time": "00:05:28",
    "en": "Oh.",
    "zh": "喔。",
    "ja": "ああ。"
  },
  {
    "time": "00:05:29",
    "en": "Mom, you still have coffee on your face?",
    "zh": "媽媽，你臉上還有咖啡？",
    "ja": "ママ、まだ顔にコーヒーついてるよ？"
  },
  {
    "time": "00:05:33",
    "en": "I know.",
    "zh": "我知道。",
    "ja": "わかってる。"
  },
  {
    "time": "00:05:40",
    "en": "All done.",
    "zh": "全部完成了。",
    "ja": "全部終わったよ。"
  },
  {
    "time": "00:05:41",
    "en": "The spare tire is on.",
    "zh": "備胎裝上了。",
    "ja": "スペアタイヤをつけた。"
  },
  {
    "time": "00:05:42",
    "en": "Don't go over 80 kilometers per hour.",
    "zh": "不要超過每小時80公里。",
    "ja": "時速80キロを超えないでね。"
  },
  {
    "time": "00:05:44",
    "en": "Thank you.",
    "zh": "謝謝你。",
    "ja": "ありがとう。"
  },
  {
    "time": "00:05:49",
    "en": "Are we late?",
    "zh": "我們遲到了嗎？",
    "ja": "遅れてる？"
  },
  {
    "time": "00:05:51",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "うん。"
  },
  {
    "time": "00:05:53",
    "en": "I'm going to be late for school.",
    "zh": "我要遲到上學了。",
    "ja": "学校に遅刻しそう。"
  },
  {
    "time": "00:05:57",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "そうだね。"
  },
  {
    "time": "00:06:00",
    "en": "You look more worried than me.",
    "zh": "你看起來比我還擔心。",
    "ja": "君の方が僕より心配そうだね。"
  },
  {
    "time": "00:06:03",
    "en": "I have something very important today, Leo.",
    "zh": "我今天有非常重要的事，Leo。",
    "ja": "今日はとても大事なことがあるんだ、レオ。"
  },
  {
    "time": "00:06:10",
    "en": "Erica, it's almost nine.",
    "zh": "Erica，快九點了。",
    "ja": "エリカ、もうすぐ9時だよ。"
  },
  {
    "time": "00:06:12",
    "en": "You're not here.",
    "zh": "你還沒到。",
    "ja": "まだ来てないね。"
  },
  {
    "time": "00:06:13",
    "en": "Is everything okay?",
    "zh": "一切都好嗎？",
    "ja": "大丈夫？"
  },
  {
    "time": "00:06:14",
    "en": "Car accident this morning, then a flat tire.",
    "zh": "今天早上車禍，然後輪胎洩氣。",
    "ja": "今朝の事故とパンクがあった。"
  },
  {
    "time": "00:06:17",
    "en": "I pushed Mr. Wang to 9.30.",
    "zh": "我把王先生的時間推到九點半。",
    "ja": "ワンさんに9時30分にしてもらった。"
  },
  {
    "time": "00:06:19",
    "en": "He agreed.",
    "zh": "他同意了。",
    "ja": "彼は了承した。"
  },
  {
    "time": "00:06:21",
    "en": "Okay.",
    "zh": "好。",
    "ja": "わかった。"
  },
  {
    "time": "00:06:22",
    "en": "The meeting room is ready.",
    "zh": "會議室準備好了。",
    "ja": "会議室は準備できてる。"
  },
  {
    "time": "00:06:23",
    "en": "What do you need?",
    "zh": "你需要什麼？",
    "ja": "何が必要？"
  },
  {
    "time": "00:06:25",
    "en": "When he arrives, coffee, small talk.",
    "zh": "他到時，咖啡和寒暄。",
    "ja": "彼が来たら、コーヒーと雑談を。"
  },
  {
    "time": "00:06:29",
    "en": "Keep him comfortable.",
    "zh": "讓他感覺舒適。",
    "ja": "彼をリラックスさせて。"
  },
  {
    "time": "00:06:31",
    "en": "I will be there.",
    "zh": "我會去的。",
    "ja": "私が行くよ。"
  },
  {
    "time": "00:06:32",
    "en": "Erica, are you actually okay?",
    "zh": "Erica，你真的沒事嗎？",
    "ja": "エリカ、本当に大丈夫？"
  },
  {
    "time": "00:06:35",
    "en": "I will be.",
    "zh": "我會沒事的。",
    "ja": "大丈夫になるよ。"
  },
  {
    "time": "00:06:36",
    "en": "See you soon.",
    "zh": "待會見。",
    "ja": "またすぐね。"
  },
  {
    "time": "00:06:41",
    "en": "Erica, Mr. Wang likes perfection.",
    "zh": "Erica，王先生喜歡完美。",
    "ja": "エリカ、ワンさんは完璧を好む。"
  },
  {
    "time": "00:06:44",
    "en": "Are you sure you can do this?",
    "zh": "你確定你能做到嗎？",
    "ja": "本当にできるの？"
  },
  {
    "time": "00:06:46",
    "en": "Yes, I'm sure.",
    "zh": "是的，我確定。",
    "ja": "はい、確信してる。"
  },
  {
    "time": "00:06:49",
    "en": "If you fail, don't tell me about your son.",
    "zh": "如果你失敗了，不要跟我提你的兒子。",
    "ja": "失敗したら、息子のことは言わないで。"
  },
  {
    "time": "00:06:54",
    "en": "Business is business.",
    "zh": "生意就是生意。",
    "ja": "ビジネスはビジネスだ。"
  },
  {
    "time": "00:06:59",
    "en": "I won't fail.",
    "zh": "我不會失敗的。",
    "ja": "失敗しないよ。"
  },
  {
    "time": "00:07:06",
    "en": "Come on, Leo, we're late.",
    "zh": "快點，Leo，我們遲到了。",
    "ja": "さあ、レオ、遅れてるよ。"
  },
  {
    "time": "00:07:09",
    "en": "Mom, keep walking, Leo.",
    "zh": "媽媽，繼續走，Leo。",
    "ja": "ママ、歩き続けて、レオ。"
  },
  {
    "time": "00:07:12",
    "en": "My lunchbox.",
    "zh": "我的便當盒。",
    "ja": "僕のランチボックス。"
  },
  {
    "time": "00:07:15",
    "en": "Where is it?",
    "zh": "在哪裡？",
    "ja": "どこ？"
  },
  {
    "time": "00:07:17",
    "en": "At home.",
    "zh": "在家裡。",
    "ja": "家にあるよ。"
  },
  {
    "time": "00:07:21",
    "en": "We'll sort it out.",
    "zh": "我們會解決的。",
    "ja": "なんとかするよ。"
  },
  {
    "time": "00:07:23",
    "en": "Come on.",
    "zh": "快點。",
    "ja": "さあ。"
  },
  {
    "time": "00:07:26",
    "en": "What is that?",
    "zh": "那是什麼？",
    "ja": "あれは何？"
  },
  {
    "time": "00:07:28",
    "en": "I don't know.",
    "zh": "我不知道。",
    "ja": "わからない。"
  },
  {
    "time": "00:07:29",
    "en": "Come on, we're late.",
    "zh": "快點，我們遲到了。",
    "ja": "急ごう、遅れてるよ。"
  },
  {
    "time": "00:07:35",
    "en": "Erica, are you okay?",
    "zh": "Erica，你還好嗎？",
    "ja": "エリカ、大丈夫？"
  },
  {
    "time": "00:07:37",
    "en": "What happened?",
    "zh": "發生什麼事了？",
    "ja": "何があったの？"
  },
  {
    "time": "00:07:38",
    "en": "Car trouble.",
    "zh": "車子出了問題。",
    "ja": "車のトラブル。"
  },
  {
    "time": "00:07:39",
    "en": "I'm fine.",
    "zh": "我沒事。",
    "ja": "私は大丈夫。"
  },
  {
    "time": "00:07:40",
    "en": "Miss Park, I'm very short on time.",
    "zh": "Park老師，我時間很緊。",
    "ja": "パーク先生、時間があまりありません。"
  },
  {
    "time": "00:07:42",
    "en": "Of course.",
    "zh": "當然。",
    "ja": "もちろん。"
  },
  {
    "time": "00:07:43",
    "en": "Oh, just one thing.",
    "zh": "喔，有件事。",
    "ja": "あ、ひとつだけ。"
  },
  {
    "time": "00:07:45",
    "en": "Leo's permission slip for Friday's field trip.",
    "zh": "Leo星期五校外教學的同意書。",
    "ja": "レオの金曜の遠足の許可証。"
  },
  {
    "time": "00:07:48",
    "en": "The deadline is this morning.",
    "zh": "截止日期是今天早上。",
    "ja": "締め切りは今朝です。"
  },
  {
    "time": "00:07:50",
    "en": "I'll send it.",
    "zh": "我會寄過去。",
    "ja": "送ります。"
  },
  {
    "time": "00:07:52",
    "en": "Today, if we don't have it today, he can't go.",
    "zh": "今天，如果今天沒交，他不能去。",
    "ja": "今日中にないと、彼は行けません。"
  },
  {
    "time": "00:07:56",
    "en": "I have it.",
    "zh": "我有。",
    "ja": "持ってるよ。"
  },
  {
    "time": "00:07:57",
    "en": "It's in the car.",
    "zh": "在車上。",
    "ja": "車の中にある。"
  },
  {
    "time": "00:07:58",
    "en": "Give me two minutes.",
    "zh": "給我兩分鐘。",
    "ja": "2分ちょうだい。"
  },
  {
    "time": "00:08:03",
    "en": "There you are.",
    "zh": "找到了。",
    "ja": "あった。"
  },
  {
    "time": "00:08:14",
    "en": "Oh, and Leo's reading log from last week.",
    "zh": "還有Leo上週的閱讀紀錄。",
    "ja": "それとレオの先週の読書記録。"
  },
  {
    "time": "00:08:18",
    "en": "We need that too.",
    "zh": "我們也需要那個。",
    "ja": "それも必要です。"
  },
  {
    "time": "00:08:20",
    "en": "Miss Park.",
    "zh": "Park老師。",
    "ja": "パーク先生。"
  },
  {
    "time": "00:08:21",
    "en": "I will send every outstanding document tonight.",
    "zh": "我今晚會寄出所有未交的文件。",
    "ja": "未提出の書類は今夜すべて送ります。"
  },
  {
    "time": "00:08:25",
    "en": "Every single one, I promise.",
    "zh": "每一份，我保證。",
    "ja": "全部だよ、約束する。"
  },
  {
    "time": "00:08:27",
    "en": "But right now, I really need to go.",
    "zh": "但現在我真的得走了。",
    "ja": "でも今は本当に行かないと。"
  },
  {
    "time": "00:08:30",
    "en": "Of course, go.",
    "zh": "當然，去吧。",
    "ja": "もちろん、行って。"
  },
  {
    "time": "00:08:35",
    "en": "Bye, Mom.",
    "zh": "拜拜，媽媽。",
    "ja": "バイバイ、ママ。"
  },
  {
    "time": "00:08:38",
    "en": "Have a good day.",
    "zh": "祝你有美好的一天。",
    "ja": "良い一日を。"
  },
  {
    "time": "00:08:42",
    "en": "I need to go right now.",
    "zh": "我現在得走了。",
    "ja": "今すぐ行かないと。"
  },
  {
    "time": "00:08:47",
    "en": "Good morning.",
    "zh": "早安。",
    "ja": "おはようございます。"
  },
  {
    "time": "00:08:48",
    "en": "Name, please.",
    "zh": "請問名字。",
    "ja": "お名前をお願いします。"
  },
  {
    "time": "00:08:49",
    "en": "Alex.",
    "zh": "Alex。",
    "ja": "アレックス。"
  },
  {
    "time": "00:08:51",
    "en": "Thank you.",
    "zh": "謝謝。",
    "ja": "ありがとう。"
  },
  {
    "time": "00:08:52",
    "en": "Next, Jamie.",
    "zh": "下一位，Jamie。",
    "ja": "次はジェイミー。"
  },
  {
    "time": "00:08:54",
    "en": "Next one.",
    "zh": "下一個。",
    "ja": "次の方。"
  },
  {
    "time": "00:08:55",
    "en": "Taylor.",
    "zh": "Taylor。",
    "ja": "テイラー。"
  },
  {
    "time": "00:08:56",
    "en": "Come on.",
    "zh": "快點。",
    "ja": "さあ。"
  },
  {
    "time": "00:08:57",
    "en": "Come on.",
    "zh": "快點。",
    "ja": "急いで。"
  },
  {
    "time": "00:08:58",
    "en": "Move.",
    "zh": "動作快點。",
    "ja": "動いて。"
  },
  {
    "time": "00:09:03",
    "en": "What happened out there?",
    "zh": "外面發生什麼事了？",
    "ja": "外で何があったの？"
  },
  {
    "time": "00:09:12",
    "en": "Mom, Mom, wait.",
    "zh": "媽媽，媽媽，等等。",
    "ja": "ママ、ママ、待って。"
  },
  {
    "time": "00:09:15",
    "en": "Leo, what are you doing?",
    "zh": "Leo，你在做什麼？",
    "ja": "レオ、何してるの？"
  },
  {
    "time": "00:09:17",
    "en": "Go back inside.",
    "zh": "回去裡面。",
    "ja": "中に戻って。"
  },
  {
    "time": "00:09:19",
    "en": "Take this.",
    "zh": "拿著這個。",
    "ja": "これを持って。"
  },
  {
    "time": "00:09:21",
    "en": "Leo, that's yours.",
    "zh": "Leo，那是你的。",
    "ja": "レオ、それは君のだよ。"
  },
  {
    "time": "00:09:24",
    "en": "It brings good luck.",
    "zh": "它帶來好運。",
    "ja": "幸運をもたらすんだ。"
  },
  {
    "time": "00:09:26",
    "en": "You need it more than me today.",
    "zh": "你今天比我更需要它。",
    "ja": "今日は君の方が僕より必要だよ。"
  },
  {
    "time": "00:09:35",
    "en": "Are you kidding me?",
    "zh": "你在開玩笑嗎？",
    "ja": "冗談でしょ？"
  },
  {
    "time": "00:09:45",
    "en": "Okay.",
    "zh": "好。",
    "ja": "わかった。"
  },
  {
    "time": "00:09:46",
    "en": "The highway is closed.",
    "zh": "高速公路封閉了。",
    "ja": "高速道路が閉鎖されている。"
  },
  {
    "time": "00:09:48",
    "en": "I need another way.",
    "zh": "我需要另一條路。",
    "ja": "別の道を探さないと。"
  },
  {
    "time": "00:09:51",
    "en": "Erica, Mr. Wang is here.",
    "zh": "Erica，王先生到了。",
    "ja": "エリカ、ワンさんが来たよ。"
  },
  {
    "time": "00:09:54",
    "en": "He arrived five minutes ago.",
    "zh": "他五分鐘前到的。",
    "ja": "5分前に到着した。"
  },
  {
    "time": "00:09:56",
    "en": "How is he?",
    "zh": "他怎麼樣？",
    "ja": "彼はどう？"
  },
  {
    "time": "00:09:57",
    "en": "Polite.",
    "zh": "有禮貌。",
    "ja": "礼儀正しい。"
  },
  {
    "time": "00:09:58",
    "en": "But he's already checked his watch twice.",
    "zh": "但他已經看了兩次手錶了。",
    "ja": "でももう2回も時計を見ている。"
  },
  {
    "time": "00:10:01",
    "en": "Give him coffee.",
    "zh": "給他咖啡。",
    "ja": "コーヒーを出して。"
  },
  {
    "time": "00:10:03",
    "en": "And offer to show him around the office.",
    "zh": "並且主動帶他參觀辦公室。",
    "ja": "オフィスを案内してあげて。"
  },
  {
    "time": "00:10:06",
    "en": "He needs to see the team, the space.",
    "zh": "他需要看看團隊和空間。",
    "ja": "チームとスペースを見せる必要がある。"
  },
  {
    "time": "00:10:09",
    "en": "He came here to check us out.",
    "zh": "他來這裡是要考察我們。",
    "ja": "彼は私たちをチェックしに来た。"
  },
  {
    "time": "00:10:11",
    "en": "So let him check us out.",
    "zh": "所以讓他看看吧。",
    "ja": "だから見せてあげよう。"
  },
  {
    "time": "00:10:14",
    "en": "And if he asks where you are, tell him I'm on my way.",
    "zh": "如果他問你在哪，告訴他我正在來的路上。",
    "ja": "もし彼が君の居場所を聞いたら、私が向かっていると言って。"
  },
  {
    "time": "00:10:19",
    "en": "Don't say anything else.",
    "zh": "不要多說其他。",
    "ja": "他には何も言わないで。"
  },
  {
    "time": "00:10:25",
    "en": "Mr. Wang, can I show you around the office while we wait?",
    "zh": "王先生，我們等的時候我可以帶您參觀辦公室嗎？",
    "ja": "ワンさん、待っている間にオフィスを案内してもいいですか？"
  },
  {
    "time": "00:10:29",
    "en": "The team would love to meet you.",
    "zh": "團隊很想見您。",
    "ja": "チームはあなたに会いたがっています。"
  },
  {
    "time": "00:10:31",
    "en": "Of course, Sarah.",
    "zh": "當然，Sarah。",
    "ja": "もちろん、サラ。"
  },
  {
    "time": "00:10:33",
    "en": "Lead the way.",
    "zh": "帶路吧。",
    "ja": "案内して。"
  },
  {
    "time": "00:10:35",
    "en": "Everyone, this is Mr. Wang.",
    "zh": "大家，這是王先生。",
    "ja": "みんな、こちらがワンさんです。"
  },
  {
    "time": "00:10:38",
    "en": "And this is our operations team.",
    "zh": "這是我們的營運團隊。",
    "ja": "こちらが私たちのオペレーションチームです。"
  },
  {
    "time": "00:10:42",
    "en": "Oops, sorry, wrong door.",
    "zh": "喔，不好意思，走錯門了。",
    "ja": "おっと、すみません、間違ったドアです。"
  },
  {
    "time": "00:10:45",
    "en": "And over here, the window, great view of the city.",
    "zh": "這邊是窗戶，可以看到很棒的城市景觀。",
    "ja": "こちらは窓で、素晴らしい街の景色が見えます。"
  },
  {
    "time": "00:10:50",
    "en": "Come on, come on, move.",
    "zh": "快點，快點，動起來。",
    "ja": "さあ、さあ、動いて。"
  },
  {
    "time": "00:10:53",
    "en": "This is the most important meeting of the year.",
    "zh": "這是今年最重要的會議。",
    "ja": "これは今年で最も重要な会議です。"
  },
  {
    "time": "00:10:56",
    "en": "Three weeks of work, and I am sitting here.",
    "zh": "三週的努力，我卻坐在這裡。",
    "ja": "3週間の努力の末、私はここに座っている。"
  },
  {
    "time": "00:11:02",
    "en": "Okay, Leo.",
    "zh": "好，Leo。",
    "ja": "よし、レオ。"
  },
  {
    "time": "00:11:04",
    "en": "I need that luck now.",
    "zh": "我現在需要那份幸運。",
    "ja": "今、幸運が必要だ。"
  },
  {
    "time": "00:11:09",
    "en": "Erica, he just asked how much longer he said he has a lunch meeting at noon.",
    "zh": "Erica，他剛問還要多久，他說中午有午餐會議。",
    "ja": "エリカ、彼はあとどれくらいか聞いてきた。正午にランチミーティングがあるそうだ。"
  },
  {
    "time": "00:11:14",
    "en": "Tell him 20 minutes.",
    "zh": "告訴他20分鐘。",
    "ja": "20分だと言って。"
  },
  {
    "time": "00:11:17",
    "en": "Erica, he has already waited 20 minutes.",
    "zh": "Erica，他已經等了20分鐘了。",
    "ja": "エリカ、彼はもう20分待っている。"
  },
  {
    "time": "00:11:21",
    "en": "Tell him 20 minutes.",
    "zh": "告訴他20分鐘。",
    "ja": "20分だと言って。"
  },
  {
    "time": "00:11:24",
    "en": "Erica, he's going to leave.",
    "zh": "Erica，他要走了。",
    "ja": "エリカ、彼は帰ろうとしている。"
  },
  {
    "time": "00:11:27",
    "en": "Not if you keep him there.",
    "zh": "只要你留住他，他不會走。",
    "ja": "君が引き止めれば、彼は帰らない。"
  },
  {
    "time": "00:11:29",
    "en": "I am not losing this contract, Sarah.",
    "zh": "我不會輸掉這份合約的，Sarah。",
    "ja": "この契約は絶対に逃さない、サラ。"
  },
  {
    "time": "00:11:39",
    "en": "My God, Erica, you look like a disaster.",
    "zh": "天啊，Erica，你看起來一團糟。",
    "ja": "なんてこった、エリカ、君はひどい状態だ。"
  },
  {
    "time": "00:11:55",
    "en": "Go home.",
    "zh": "回家去。",
    "ja": "家に帰れ。"
  },
  {
    "time": "00:11:56",
    "en": "I'll get Jason.",
    "zh": "我去叫Jason。",
    "ja": "ジェイソンを呼んでくる。"
  },
  {
    "time": "00:11:58",
    "en": "He doesn't have to pick up kids every morning.",
    "zh": "他不用每天早上接小孩。",
    "ja": "彼は毎朝子供を迎えに行かなくていい。"
  },
  {
    "time": "00:12:01",
    "en": "I am not going home, sir.",
    "zh": "長官，我不會回家。",
    "ja": "帰りません、 sir。"
  },
  {
    "time": "00:12:03",
    "en": "You're wasting your time.",
    "zh": "你在浪費時間。",
    "ja": "時間の無駄だ。"
  },
  {
    "time": "00:12:05",
    "en": "He's leaving.",
    "zh": "他要離開了。",
    "ja": "彼は去ってしまう。"
  },
  {
    "time": "00:12:10",
    "en": "He told his assistant to get the car.",
    "zh": "他叫助理去拿車。",
    "ja": "彼はアシスタントに車を用意させた。"
  },
  {
    "time": "00:12:14",
    "en": "They're waiting for the elevator.",
    "zh": "他們在等電梯。",
    "ja": "彼らはエレベーターを待っている。"
  },
  {
    "time": "00:12:16",
    "en": "Which elevator?",
    "zh": "哪個電梯？",
    "ja": "どのエレベーター？"
  },
  {
    "time": "00:12:18",
    "en": "Left bank, third floor.",
    "zh": "左側區域，三樓。",
    "ja": "左側のエレベーター、3階。"
  },
  {
    "time": "00:12:27",
    "en": "You must be Erica.",
    "zh": "你一定是Erica。",
    "ja": "あなたがエリカですね。"
  },
  {
    "time": "00:12:29",
    "en": "Mr. Wang, I'm sorry to keep you waiting.",
    "zh": "王先生，抱歉讓您久等了。",
    "ja": "ワンさん、お待たせしてすみません。"
  },
  {
    "time": "00:12:33",
    "en": "Mr. Erica, you use the car accident excuse twice today.",
    "zh": "Erica小姐，你今天用車禍當藉口兩次了。",
    "ja": "エリカさん、今日は車の事故を言い訳に2回使いましたね。"
  },
  {
    "time": "00:12:38",
    "en": "It's not an excuse, Mr. Wang.",
    "zh": "這不是藉口，王先生。",
    "ja": "言い訳ではありません、ワンさん。"
  },
  {
    "time": "00:12:40",
    "en": "It happened.",
    "zh": "事情真的發生了。",
    "ja": "本当に起こったことです。"
  },
  {
    "time": "00:12:42",
    "en": "I've been in business for 30 years.",
    "zh": "我做生意已經30年了。",
    "ja": "私は30年間ビジネスをしています。"
  },
  {
    "time": "00:12:45",
    "en": "I've heard every story there is.",
    "zh": "我聽過各種各樣的故事。",
    "ja": "あらゆる話を聞いてきました。"
  },
  {
    "time": "00:12:48",
    "en": "Miss Erica, I've been waiting for over an hour.",
    "zh": "Erica小姐，我已經等了一個多小時了。",
    "ja": "エリカさん、1時間以上待っています。"
  },
  {
    "time": "00:12:52",
    "en": "Mr. Wang, the other companies you met this week, they all showed up on time.",
    "zh": "王先生，這週你見過的其他公司都準時到達。",
    "ja": "ワンさん、今週会った他の会社は皆時間通りに来ました。"
  },
  {
    "time": "00:12:58",
    "en": "Mr. Wang, I look terrible today.",
    "zh": "王先生，我今天看起來很糟糕。",
    "ja": "ワンさん、今日はひどい格好です。"
  },
  {
    "time": "00:13:02",
    "en": "I left my coffee on the car roof this morning.",
    "zh": "我今天早上把咖啡放在車頂上了。",
    "ja": "今朝、コーヒーを車の屋根に置き忘れました。"
  },
  {
    "time": "00:13:05",
    "en": "I forgot it was there.",
    "zh": "我忘了它還在那裡。",
    "ja": "そこにあるのを忘れていました。"
  },
  {
    "time": "00:13:07",
    "en": "That was stupid.",
    "zh": "那很愚蠢。",
    "ja": "それは馬鹿なことでした。"
  },
  {
    "time": "00:13:10",
    "en": "I crashed my car because of it.",
    "zh": "我因此撞了車。",
    "ja": "それで車を壊しました。"
  },
  {
    "time": "00:13:12",
    "en": "My tire went flat.",
    "zh": "我的輪胎洩氣了。",
    "ja": "タイヤがパンクしました。"
  },
  {
    "time": "00:13:14",
    "en": "My laptop screen cracked.",
    "zh": "我的筆電螢幕裂了。",
    "ja": "ノートパソコンの画面が割れました。"
  },
  {
    "time": "00:13:16",
    "en": "I am not here to tell you it wasn't my fault.",
    "zh": "我不是來跟你說這不是我的錯。",
    "ja": "これは私のせいじゃないと言いに来たわけではありません。"
  },
  {
    "time": "00:13:20",
    "en": "Some of it was.",
    "zh": "有些是我的錯。",
    "ja": "一部は私の責任です。"
  },
  {
    "time": "00:13:22",
    "en": "But I am here.",
    "zh": "但我在這裡。",
    "ja": "でも私はここにいます。"
  },
  {
    "time": "00:13:28",
    "en": "Every company has a perfect plan.",
    "zh": "每家公司都有完美的計劃。",
    "ja": "どの会社も完璧な計画を持っています。"
  },
  {
    "time": "00:13:31",
    "en": "But plans break.",
    "zh": "但計劃會破裂。",
    "ja": "でも計画は崩れるものです。"
  },
  {
    "time": "00:13:37",
    "en": "Look at my laptop.",
    "zh": "看看我的筆電。",
    "ja": "私のノートパソコンを見て。"
  },
  {
    "time": "00:13:38",
    "en": "Look at my shirt.",
    "zh": "看看我的襯衫。",
    "ja": "私のシャツを見て。"
  },
  {
    "time": "00:13:40",
    "en": "Plans break.",
    "zh": "計劃會破裂。",
    "ja": "計画は崩れる。"
  },
  {
    "time": "00:13:41",
    "en": "If you want a perfect suit and a clean laptop,",
    "zh": "如果你想要完美的西裝和乾淨的筆電，",
    "ja": "完璧なスーツときれいなノートパソコンが欲しいなら、"
  },
  {
    "time": "00:13:44",
    "en": "there are three other companies.",
    "zh": "還有另外三家公司。",
    "ja": "他に3社あります。"
  },
  {
    "time": "00:13:47",
    "en": "Call them.",
    "zh": "打給他們吧。",
    "ja": "彼らに連絡してください。"
  },
  {
    "time": "00:13:49",
    "en": "But if you want someone who does not quit when everything breaks,",
    "zh": "但如果你想要一個在一切崩壞時不放棄的人，",
    "ja": "でも、すべてが崩れても諦めない人が欲しいなら、"
  },
  {
    "time": "00:13:55",
    "en": "you hire me.",
    "zh": "你就雇用我。",
    "ja": "私を雇ってください。"
  },
  {
    "time": "00:13:57",
    "en": "My son is seven years old.",
    "zh": "我兒子七歲。",
    "ja": "息子は7歳です。"
  },
  {
    "time": "00:14:00",
    "en": "He saw everything this morning.",
    "zh": "他今天早上看到了所有事情。",
    "ja": "彼は今朝すべてを見ました。"
  },
  {
    "time": "00:14:02",
    "en": "The crash, the flat tire, the waiting.",
    "zh": "車禍、輪胎洩氣、等待。",
    "ja": "事故、パンク、待ち時間。"
  },
  {
    "time": "00:14:05",
    "en": "This bracelet is from him.",
    "zh": "這手環是他給的。",
    "ja": "このブレスレットは彼からのものです。"
  },
  {
    "time": "00:14:08",
    "en": "He ran back from school just to give me this.",
    "zh": "他從學校跑回來只是為了給我這個。",
    "ja": "彼はこれを渡すために学校から走って戻ってきた。"
  },
  {
    "time": "00:14:11",
    "en": "He said you need it more than me today.",
    "zh": "他說你今天比我更需要它。",
    "ja": "彼は「今日は君の方が僕より必要だ」と言った。"
  },
  {
    "time": "00:14:16",
    "en": "This morning gave me five reasons to turn around and go home.",
    "zh": "今天早上給了我五個理由讓我轉身回家。",
    "ja": "今朝は帰ろうと思う理由を5つくれた。"
  },
  {
    "time": "00:14:21",
    "en": "I didn't.",
    "zh": "但我沒有。",
    "ja": "でも、しなかった。"
  },
  {
    "time": "00:14:23",
    "en": "Because I can't look at him tonight and say I gave up when things got hard.",
    "zh": "因為我今晚不能看著他說我在困難時放棄了。",
    "ja": "困難な時に諦めたと言えないからだ。"
  },
  {
    "time": "00:14:30",
    "en": "I don't quit, Mr. Wang.",
    "zh": "我不會放棄，王先生。",
    "ja": "私は諦めません、ワンさん。"
  },
  {
    "time": "00:14:32",
    "en": "Not on my son.",
    "zh": "不會在我兒子身上。",
    "ja": "息子のために。"
  },
  {
    "time": "00:14:34",
    "en": "And not on my clients.",
    "zh": "也不會在我的客戶身上。",
    "ja": "そしてクライアントのために。"
  },
  {
    "time": "00:14:36",
    "en": "Five minutes.",
    "zh": "五分鐘。",
    "ja": "5分ください。"
  },
  {
    "time": "00:14:39",
    "en": "Tell me about the first six months.",
    "zh": "告訴我前六個月的情況。",
    "ja": "最初の6ヶ月について教えて。"
  },
  {
    "time": "00:14:46",
    "en": "Your proposal is the strongest of the four companies I've seen.",
    "zh": "你的提案是我看過四家公司中最強的。",
    "ja": "あなたの提案は私が見た4社の中で最も強力です。"
  },
  {
    "time": "00:14:50",
    "en": "However, business runs on trust.",
    "zh": "然而，生意是建立在信任上的。",
    "ja": "しかし、ビジネスは信頼で成り立っています。"
  },
  {
    "time": "00:14:53",
    "en": "I need to consider that.",
    "zh": "我需要考慮這點。",
    "ja": "それを考慮しなければなりません。"
  },
  {
    "time": "00:14:55",
    "en": "I'll be in touch.",
    "zh": "我會聯絡你的。",
    "ja": "連絡します。"
  },
  {
    "time": "00:15:00",
    "en": "What did he say?",
    "zh": "他說什麼？",
    "ja": "彼は何と言った？"
  },
  {
    "time": "00:15:09",
    "en": "He said our proposal is the strongest.",
    "zh": "他說我們的提案是最強的。",
    "ja": "彼は私たちの提案が最強だと言った。"
  },
  {
    "time": "00:15:12",
    "en": "That's amazing.",
    "zh": "太棒了。",
    "ja": "素晴らしい。"
  },
  {
    "time": "00:15:14",
    "en": "Then he said he needs to think about it.",
    "zh": "然後他說他需要考慮一下。",
    "ja": "それから考える必要があると言った。"
  },
  {
    "time": "00:15:18",
    "en": "Okay.",
    "zh": "好。",
    "ja": "わかった。"
  },
  {
    "time": "00:15:33",
    "en": "Erica, are you okay?",
    "zh": "Erica，你還好嗎？",
    "ja": "エリカ、大丈夫？"
  },
  {
    "time": "00:15:35",
    "en": "Aren't you on Riverside Highway every morning?",
    "zh": "你不是每天早上都走Riverside高速公路嗎？",
    "ja": "毎朝リバーサイドハイウェイを通ってるんじゃないの？"
  },
  {
    "time": "00:15:38",
    "en": "Look at this link.",
    "zh": "看看這個連結。",
    "ja": "このリンクを見て。"
  },
  {
    "time": "00:15:39",
    "en": "What?",
    "zh": "什麼？",
    "ja": "何？"
  },
  {
    "time": "00:15:40",
    "en": "A pile-up?",
    "zh": "連環車禍？",
    "ja": "玉突き事故？"
  },
  {
    "time": "00:15:42",
    "en": "We have reports of a massive pile-up on Riverside Highway involving",
    "zh": "我們收到報告，Riverside高速公路發生大規模連環車禍，涉及",
    "ja": "リバーサイドハイウェイで大規模な玉突き事故があったと報告がある。"
  },
  {
    "time": "00:15:46",
    "en": "twenty-teen vehicles.",
    "zh": "二十多輛車。",
    "ja": "20台以上の車両が関係している。"
  },
  {
    "time": "00:15:48",
    "en": "Emergency crews are on the scene.",
    "zh": "緊急救援隊已在現場。",
    "ja": "緊急隊が現場にいる。"
  },
  {
    "time": "00:15:49",
    "en": "The highway is completely shut down.",
    "zh": "高速公路完全封閉。",
    "ja": "高速道路は完全に閉鎖されている。"
  },
  {
    "time": "00:15:52",
    "en": "Mom, what happened?",
    "zh": "媽媽，發生什麼事了？",
    "ja": "ママ、何があったの？"
  },
  {
    "time": "00:15:54",
    "en": "A lot of cars crashed.",
    "zh": "很多車子撞在一起了。",
    "ja": "たくさんの車が衝突した。"
  },
  {
    "time": "00:15:56",
    "en": "On the big road.",
    "zh": "在大路上。",
    "ja": "大きな道路で。"
  },
  {
    "time": "00:15:57",
    "en": "How many cars?",
    "zh": "多少輛車？",
    "ja": "何台の車？"
  },
  {
    "time": "00:16:00",
    "en": "Many.",
    "zh": "很多。",
    "ja": "たくさん。"
  },
  {
    "time": "00:16:01",
    "en": "More than twenty.",
    "zh": "超過二十輛。",
    "ja": "20台以上。"
  },
  {
    "time": "00:16:02",
    "en": "Did people get hurt?",
    "zh": "有人受傷嗎？",
    "ja": "怪我した人は？"
  },
  {
    "time": "00:16:04",
    "en": "Yes.",
    "zh": "有。",
    "ja": "はい。"
  },
  {
    "time": "00:16:06",
    "en": "Some people got hurt.",
    "zh": "有些人受傷了。",
    "ja": "何人か怪我をした。"
  },
  {
    "time": "00:16:07",
    "en": "Why?",
    "zh": "為什麼？",
    "ja": "なぜ？"
  },
  {
    "time": "00:16:09",
    "en": "Whoa.",
    "zh": "哇。",
    "ja": "うわ。"
  },
  {
    "time": "00:16:10",
    "en": "How did that happen?",
    "zh": "那是怎麼發生的？",
    "ja": "どうしてそうなったの？"
  },
  {
    "time": "00:16:12",
    "en": "Because one car stopped too fast.",
    "zh": "因為一輛車煞車太快。",
    "ja": "一台の車が急停止したから。"
  },
  {
    "time": "00:16:15",
    "en": "And all the other cars behind it, they couldn't stop in time.",
    "zh": "後面的車都來不及煞車。",
    "ja": "後ろの車が間に合わなかった。"
  },
  {
    "time": "00:16:18",
    "en": "Oh.",
    "zh": "喔。",
    "ja": "ああ。"
  },
  {
    "time": "00:16:19",
    "en": "That's scary.",
    "zh": "好可怕。",
    "ja": "怖いね。"
  },
  {
    "time": "00:16:22",
    "en": "That's my road.",
    "zh": "那是我常走的路。",
    "ja": "それは私の通る道だ。"
  },
  {
    "time": "00:16:25",
    "en": "If the coffee hadn't fallen, I would have been there.",
    "zh": "如果咖啡沒掉，我就會在那裡了。",
    "ja": "コーヒーが落ちなければ、私はそこにいた。"
  },
  {
    "time": "00:16:29",
    "en": "At 845, my coffee.",
    "zh": "八點四十五分，我的咖啡。",
    "ja": "8時45分、私のコーヒー。"
  },
  {
    "time": "00:16:34",
    "en": "The deadline is this morning.",
    "zh": "截止日期是今天早上。",
    "ja": "締め切りは今朝です。"
  },
  {
    "time": "00:16:36",
    "en": "Next.",
    "zh": "下一位。",
    "ja": "次の方。"
  },
  {
    "time": "00:16:39",
    "en": "You need it more than me today.",
    "zh": "你今天比我更需要它。",
    "ja": "今日は君の方が僕より必要だよ。"
  },
  {
    "time": "00:16:41",
    "en": "That cup of coffee?",
    "zh": "那杯咖啡？",
    "ja": "あのコーヒー？"
  },
  {
    "time": "00:16:43",
    "en": "It saved my life.",
    "zh": "它救了我的命。",
    "ja": "命を救ってくれた。"
  },
  {
    "time": "00:16:47",
    "en": "Mr. Wong, it is a good thing we left late today.",
    "zh": "Wong先生，我們今天晚點出發真是太好了。",
    "ja": "ウォンさん、今日は遅く出発してよかった。"
  },
  {
    "time": "00:16:51",
    "en": "Why?",
    "zh": "為什麼？",
    "ja": "なぜ？"
  },
  {
    "time": "00:16:53",
    "en": "Major pile-up on Riverside Highway, at least twenty vehicles,",
    "zh": "Riverside高速公路發生重大連環車禍，至少二十輛車，",
    "ja": "リバーサイドハイウェイで大規模な玉突き事故があり、少なくとも20台の車が関わっている。"
  },
  {
    "time": "00:16:57",
    "en": "police say it happened exactly at 845 a.m.",
    "zh": "警方說事故發生在上午八點四十五分整。",
    "ja": "警察によると、事故は午前8時45分ちょうどに起きた。"
  },
  {
    "time": "00:17:00",
    "en": "That's our usual route.",
    "zh": "那是我們平常的路線。",
    "ja": "それは私たちのいつものルートだ。"
  },
  {
    "time": "00:17:02",
    "en": "If we left the hotel at 830,",
    "zh": "如果我們八點半離開飯店，",
    "ja": "もし8時30分にホテルを出ていたら、"
  },
  {
    "time": "00:17:05",
    "en": "we'll be right back.",
    "zh": "我們就會回不來了。",
    "ja": "戻れなかっただろう。"
  },
  {
    "time": "00:17:07",
    "en": "Pull over right now.",
    "zh": "現在立刻靠邊停車。",
    "ja": "すぐに路肩に停めて。"
  },
  {
    "time": "00:17:09",
    "en": "845.",
    "zh": "八點四十五分。",
    "ja": "8時45分。"
  },
  {
    "time": "00:17:11",
    "en": "Mr. Wong,",
    "zh": "Wong先生，",
    "ja": "ウォンさん、"
  },
  {
    "time": "00:17:13",
    "en": "Erica, you saved my life today.",
    "zh": "Erica，你今天救了我的命。",
    "ja": "エリカ、君は今日私の命を救った。"
  },
  {
    "time": "00:17:17",
    "en": "I just saw the news.",
    "zh": "我剛看到新聞。",
    "ja": "ニュースを見たばかりだ。"
  },
  {
    "time": "00:17:19",
    "en": "845.",
    "zh": "八點四十五分。",
    "ja": "8時45分。"
  },
  {
    "time": "00:17:23",
    "en": "Mr. Wong,",
    "zh": "Wong先生，",
    "ja": "ウォンさん、"
  },
  {
    "time": "00:17:25",
    "en": "Erica, you saved my life today.",
    "zh": "Erica，你今天救了我的命。",
    "ja": "エリカ、君は今日私の命を救った。"
  },
  {
    "time": "00:17:29",
    "en": "I just saw the news.",
    "zh": "我剛看到新聞。",
    "ja": "ニュースを見たばかりだ。"
  },
  {
    "time": "00:17:31",
    "en": "845 a.m. Riverside Highway.",
    "zh": "上午八點四十五分，Riverside高速公路。",
    "ja": "午前8時45分、リバーサイドハイウェイ。"
  },
  {
    "time": "00:17:35",
    "en": "Without your call, I was there in that crash.",
    "zh": "如果不是你的電話，我就在那場車禍裡。",
    "ja": "君の電話がなければ、私はあの事故に巻き込まれていた。"
  },
  {
    "time": "00:17:39",
    "en": "But because of you, I am here.",
    "zh": "但因為你，我還在這裡。",
    "ja": "でも君のおかげでここにいる。"
  },
  {
    "time": "00:17:43",
    "en": "You saved my life, Erica.",
    "zh": "你救了我的命，Erica。",
    "ja": "命を救ってくれてありがとう、エリカ。"
  },
  {
    "time": "00:17:47",
    "en": "I didn't know.",
    "zh": "我不知道。",
    "ja": "知らなかった。"
  },
  {
    "time": "00:17:51",
    "en": "Send me the contract tonight.",
    "zh": "今晚把合約寄給我。",
    "ja": "今夜契約書を送って。"
  },
  {
    "time": "00:17:54",
    "en": "I will sign it tomorrow morning.",
    "zh": "我明天早上會簽署。",
    "ja": "明日の朝に署名します。"
  },
  {
    "time": "00:17:56",
    "en": "Mr. Wang, you really don't have to.",
    "zh": "王先生，您真的不用這樣。",
    "ja": "ワンさん、本当にそんなことはしなくていい。"
  },
  {
    "time": "00:17:59",
    "en": "I know I don't have to.",
    "zh": "我知道我不必這樣做。",
    "ja": "私もそう思います。"
  },
  {
    "time": "00:18:03",
    "en": "I want to.",
    "zh": "但我想這麼做。",
    "ja": "でもそうしたいんです。"
  },
  {
    "time": "00:18:05",
    "en": "Your proposal is the strongest.",
    "zh": "你的提案是最強的。",
    "ja": "あなたの提案は最強です。"
  },
  {
    "time": "00:18:07",
    "en": "And today you showed me exactly what kind of person you are.",
    "zh": "今天你讓我看到你是什麼樣的人。",
    "ja": "そして今日、あなたがどんな人かはっきり見せてくれた。"
  },
  {
    "time": "00:18:11",
    "en": "Thank you for that cup of coffee.",
    "zh": "謝謝你那杯咖啡。",
    "ja": "あのコーヒーに感謝します。"
  },
  {
    "time": "00:18:15",
    "en": "Erica, Mr. Wang's assistant just emailed.",
    "zh": "Erica，王先生的助理剛剛發了郵件。",
    "ja": "エリカ、ワンさんのアシスタントからメールが来た。"
  },
  {
    "time": "00:18:31",
    "en": "He wants the contract tonight.",
    "zh": "他要今晚拿到合約。",
    "ja": "彼は今夜契約書を欲しがっている。"
  },
  {
    "time": "00:18:33",
    "en": "He says he is signing tomorrow morning.",
    "zh": "他說他明天早上會簽署。",
    "ja": "彼は明日の朝に署名すると言っている。"
  },
  {
    "time": "00:18:35",
    "en": "Erica, you got it.",
    "zh": "Erica，你辦到了。",
    "ja": "エリカ、君はやったね。"
  },
  {
    "time": "00:18:39",
    "en": "What happened?",
    "zh": "發生什麼事了？",
    "ja": "何があった？"
  },
  {
    "time": "00:18:41",
    "en": "What did he say?",
    "zh": "他說什麼？",
    "ja": "彼は何と言った？"
  },
  {
    "time": "00:18:43",
    "en": "He said thank you for the cup of coffee.",
    "zh": "他說謝謝那杯咖啡。",
    "ja": "彼はコーヒーに感謝していると言った。"
  },
  {
    "time": "00:18:47",
    "en": "What?",
    "zh": "什麼？",
    "ja": "何？"
  },
  {
    "time": "00:18:49",
    "en": "I'll send you the contract draft tonight.",
    "zh": "我今晚會寄給你合約草稿。",
    "ja": "今夜契約書の草案を送ります。"
  },
  {
    "time": "00:18:52",
    "en": "Let's go in.",
    "zh": "我們進去吧。",
    "ja": "中に入りましょう。"
  },
  {
    "time": "00:18:53",
    "en": "Let's go.",
    "zh": "走吧。",
    "ja": "行こう。"
  },
  {
    "time": "00:18:57",
    "en": "I just spoke with Mr. Wang.",
    "zh": "我剛跟王先生談過了。",
    "ja": "ワンさんと話したばかりだ。"
  },
  {
    "time": "00:19:07",
    "en": "We have the contract five years.",
    "zh": "我們拿下五年合約。",
    "ja": "5年契約を獲得した。"
  },
  {
    "time": "00:19:11",
    "en": "That is great news.",
    "zh": "那是好消息。",
    "ja": "それは素晴らしいニュースだ。"
  },
  {
    "time": "00:19:13",
    "en": "Jason and I were just, Mr. Wang asked me something on the phone.",
    "zh": "Jason和我剛剛，王先生在電話中問我一件事。",
    "ja": "ジェイソンと私が話しているときに、ワンさんが電話で質問した。"
  },
  {
    "time": "00:19:17",
    "en": "He said, why does someone like Erica only have a sales title?",
    "zh": "他說，為什麼像Erica這樣的人只有銷售職稱？",
    "ja": "彼は言った、なぜエリカのような人が営業の肩書きだけなのか？"
  },
  {
    "time": "00:19:23",
    "en": "I did not have a good answer for him.",
    "zh": "我沒有好的答案給他。",
    "ja": "私は良い答えがなかった。"
  },
  {
    "time": "00:19:29",
    "en": "I can fix that, sir.",
    "zh": "我可以解決這個，長官。",
    "ja": "それは私が解決します、sir。"
  },
  {
    "time": "00:19:35",
    "en": "Congratulations, manager.",
    "zh": "恭喜，經理。",
    "ja": "おめでとう、マネージャー。"
  },
  {
    "time": "00:19:37",
    "en": "Erica, you earned this.",
    "zh": "Erica，這是你應得的。",
    "ja": "エリカ、これは君の努力の結果だ。"
  },
  {
    "time": "00:19:45",
    "en": "Go home.",
    "zh": "回家去。",
    "ja": "家に帰れ。"
  },
  {
    "time": "00:19:46",
    "en": "See your son.",
    "zh": "去見你的兒子。",
    "ja": "息子に会いに行け。"
  },
  {
    "time": "00:19:48",
    "en": "We signed the papers tomorrow.",
    "zh": "我們明天簽署文件。",
    "ja": "明日書類に署名します。"
  },
  {
    "time": "00:19:49",
    "en": "Thank you, sir.",
    "zh": "謝謝您，長官。",
    "ja": "ありがとうございます、sir。"
  },
  {
    "time": "00:19:57",
    "en": "The dented bumper.",
    "zh": "凹陷的保險桿。",
    "ja": "へこんだバンパー。"
  },
  {
    "time": "00:19:58",
    "en": "Still there.",
    "zh": "還在那裡。",
    "ja": "まだそこにある。"
  },
  {
    "time": "00:19:59",
    "en": "Nobody fixed it.",
    "zh": "沒有人修理它。",
    "ja": "誰も直していない。"
  },
  {
    "time": "00:20:06",
    "en": "Leo, I'm coming.",
    "zh": "Leo，我來了。",
    "ja": "レオ、今行くよ。"
  }
]