  "dialogue": [
    {
      "role": "teacher",
      "text": "Sophia arrives at the airport.",
      "zh": "索菲亞抵達機場。",
      "ja": "ソフィアは空港に到着します。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "She walks to passport control with her suitcase.",
      "zh": "她拖著行李箱走向護照檢查處。",
      "ja": "彼女はスーツケースを持ってパスポートコントロールへ歩きます。",
      "time": "00:00:02"
    },
    {
      "role": "teacher",
      "text": "She is excited but a little nervous.",
      "zh": "她很興奮，但有點緊張。",
      "ja": "彼女は興奮していますが、少し緊張しています。",
      "time": "00:00:05"
    },
    {
      "role": "teacher",
      "text": "The officer looks at her seriously.",
      "zh": "警官嚴肅地看著她。",
      "ja": "係官は真剣な表情で彼女を見ます。",
      "time": "00:00:08"
    },
    {
      "role": "teacher",
      "text": "He says,",
      "zh": "他說，",
      "ja": "彼は言います、",
      "time": "00:00:11"
    },
    {
      "role": "teacher",
      "text": "Good morning, your passport please.",
      "zh": "早安，請出示您的護照。",
      "ja": "おはようございます。パスポートをお願いします。",
      "time": "00:00:12"
    },
    {
      "role": "student",
      "text": "Sophia hands her passport politely.",
      "zh": "索菲亞禮貌地遞上護照。",
      "ja": "ソフィアは丁寧にパスポートを渡します。",
      "time": "00:00:15"
    },
    {
      "role": "student",
      "text": "Good morning, here you go.",
      "zh": "早安，給您。",
      "ja": "おはようございます、どうぞ。",
      "time": "00:00:19"
    },
    {
      "role": "teacher",
      "text": "The officer smiles and says,",
      "zh": "警官微笑著說，",
      "ja": "係官は微笑んで言います、",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "Welcome to New York, enjoy your stay.",
      "zh": "歡迎來到紐約，祝您旅途愉快。",
      "ja": "ニューヨークへようこそ。滞在をお楽しみください。",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "Sophia is in.",
      "zh": "索菲亞通過了。",
      "ja": "ソフィアは入国しました。",
      "time": "00:00:27"
    },
    {
      "role": "teacher",
      "text": "She is so happy.",
      "zh": "她非常開心。",
      "ja": "彼女はとても嬉しいです。",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "Her adventure in New York begins now.",
      "zh": "她在紐約的冒險現在開始了。",
      "ja": "彼女のニューヨークでの冒険が今始まります。",
      "time": "00:00:30"
    },
    {
      "role": "teacher",
      "text": "Sophia walks outside and raises her hand.",
      "zh": "索菲亞走到外面並舉手。",
      "ja": "ソフィアは外に出て手を挙げます。",
      "time": "00:00:33"
    },
    {
      "role": "teacher",
      "text": "She needs a taxi to get to her hotel.",
      "zh": "她需要搭計程車去飯店。",
      "ja": "彼女はホテルに行くためにタクシーが必要です。",
      "time": "00:00:35"
    },
    {
      "role": "teacher",
      "text": "A friendly driver stops.",
      "zh": "一位友善的司機停下來。",
      "ja": "親切な運転手が止まります。",
      "time": "00:00:38"
    },
    {
      "role": "teacher",
      "text": "He asks,",
      "zh": "他問，",
      "ja": "彼は尋ねます、",
      "time": "00:00:40"
    },
    {
      "role": "teacher",
      "text": "Where to?",
      "zh": "去哪裡？",
      "ja": "どちらまで？",
      "time": "00:00:41"
    },
    {
      "role": "student",
      "text": "Manhattan please, the grand hotel.",
      "zh": "請去曼哈頓，大飯店。",
      "ja": "マンハッタンへお願いします、グランドホテルです。",
      "time": "00:00:44"
    },
    {
      "role": "teacher",
      "text": "They talk in the taxi.",
      "zh": "他們在計程車裡聊天。",
      "ja": "彼らはタクシーの中で話します。",
      "time": "00:00:47"
    },
    {
      "role": "teacher",
      "text": "The driver asks,",
      "zh": "司機問，",
      "ja": "運転手は尋ねます、",
      "time": "00:00:49"
    },
    {
      "role": "teacher",
      "text": "First time in New York.",
      "zh": "第一次來紐約嗎？",
      "ja": "ニューヨークは初めてですか？",
      "time": "00:00:50"
    },
    {
      "role": "student",
      "text": "Yes, I'm so excited.",
      "zh": "是的，我很興奮。",
      "ja": "はい、とてもワクワクしています。",
      "time": "00:00:53"
    },
    {
      "role": "student",
      "text": "Look at New York City.",
      "zh": "看看紐約市。",
      "ja": "ニューヨーク市を見てください。",
      "time": "00:00:55"
    },
    {
      "role": "student",
      "text": "The streets are busy.",
      "zh": "街道很熱鬧。",
      "ja": "通りは賑やかです。",
      "time": "00:00:57"
    },
    {
      "role": "student",
      "text": "The buildings are huge.",
      "zh": "建築物很高大。",
      "ja": "建物は巨大です。",
      "time": "00:00:58"
    },
    {
      "role": "student",
      "text": "It is amazing.",
      "zh": "真令人驚嘆。",
      "ja": "素晴らしいです。",
      "time": "00:01:00"
    },
    {
      "role": "teacher",
      "text": "Sophia arrives at the hotel.",
      "zh": "索菲亞抵達飯店。",
      "ja": "ソフィアはホテルに到着します。",
      "time": "00:01:02"
    },
    {
      "role": "teacher",
      "text": "She opens the door and looks around.",
      "zh": "她打開門並環顧四周。",
      "ja": "彼女はドアを開けて周りを見渡します。",
      "time": "00:01:04"
    },
    {
      "role": "teacher",
      "text": "The lobby is beautiful.",
      "zh": "大廳很漂亮。",
      "ja": "ロビーは美しいです。",
      "time": "00:01:06"
    },
    {
      "role": "teacher",
      "text": "The receptionist smiles and says,",
      "zh": "接待員微笑著說，",
      "ja": "受付係は微笑んで言います、",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "Good afternoon.",
      "zh": "午安。",
      "ja": "こんにちは。",
      "time": "00:01:11"
    },
    {
      "role": "teacher",
      "text": "Welcome to the grand hotel.",
      "zh": "歡迎來到大飯店。",
      "ja": "グランドホテルへようこそ。",
      "time": "00:01:13"
    },
    {
      "role": "student",
      "text": "I have a reservation.",
      "zh": "我有預訂。",
      "ja": "予約があります。",
      "time": "00:01:15"
    },
    {
      "role": "student",
      "text": "My name is Sophia.",
      "zh": "我叫索菲亞。",
      "ja": "私の名前はソフィアです。",
      "time": "00:01:17"
    },
    {
      "role": "student",
      "text": "She gives her passport to the receptionist.",
      "zh": "她把護照交給接待員。",
      "ja": "彼女はパスポートを受付係に渡します。",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "The receptionist says,",
      "zh": "接待員說，",
      "ja": "受付係は言います、",
      "time": "00:01:23"
    },
    {
      "role": "teacher",
      "text": "Here is your key card,",
      "zh": "這是您的房卡，",
      "ja": "こちらがあなたのキーカードです、",
      "time": "00:01:25"
    },
    {
      "role": "teacher",
      "text": "room 304, third floor.",
      "zh": "304號房，三樓。",
      "ja": "304号室、3階です。",
      "time": "00:01:26"
    },
    {
      "role": "student",
      "text": "Sophia takes the key card and smiles.",
      "zh": "索菲亞拿著房卡並微笑。",
      "ja": "ソフィアはキーカードを受け取り、微笑みます。",
      "time": "00:01:29"
    },
    {
      "role": "student",
      "text": "What time is breakfast?",
      "zh": "早餐是幾點？",
      "ja": "朝食は何時ですか？",
      "time": "00:01:32"
    },
    {
      "role": "teacher",
      "text": "Always important.",
      "zh": "這總是很重要。",
      "ja": "いつも大事なことです。",
      "time": "00:01:34"
    },
    {
      "role": "teacher",
      "text": "Sophia finds a cozy cafe.",
      "zh": "索菲亞找到一家舒適的咖啡館。",
      "ja": "ソフィアは居心地の良いカフェを見つけます。",
      "time": "00:01:37"
    },
    {
      "role": "teacher",
      "text": "She walks in and looks around.",
      "zh": "她走進去並環顧四周。",
      "ja": "彼女は中に入り、周りを見渡します。",
      "time": "00:01:39"
    },
    {
      "role": "teacher",
      "text": "It smells like fresh coffee.",
      "zh": "聞起來有新鮮咖啡的香味。",
      "ja": "新鮮なコーヒーの香りがします。",
      "time": "00:01:41"
    },
    {
      "role": "teacher",
      "text": "The barista smiles and asks,",
      "zh": "咖啡師微笑著問，",
      "ja": "バリスタは微笑んで尋ねます、",
      "time": "00:01:44"
    },
    {
      "role": "teacher",
      "text": "Hi, what can I get you?",
      "zh": "您好，請問要點什麼？",
      "ja": "こんにちは、ご注文は何になさいますか？",
      "time": "00:01:46"
    },
    {
      "role": "student",
      "text": "Sophia thinks for a moment.",
      "zh": "索菲亞想了一會兒。",
      "ja": "ソフィアは少し考えます。",
      "time": "00:01:48"
    },
    {
      "role": "student",
      "text": "Sophia raises one finger and says,",
      "zh": "索菲亞舉起一根手指說，",
      "ja": "ソフィアは指を一本立てて言います、",
      "time": "00:01:50"
    },
    {
      "role": "student",
      "text": "Can I have a latte please?",
      "zh": "請給我一杯拿鐵，好嗎？",
      "ja": "ラテを一つお願いします。",
      "time": "00:01:53"
    },
    {
      "role": "student",
      "text": "Medium size and a croissant.",
      "zh": "中杯和一個可頌。",
      "ja": "ミディアムサイズとクロワッサンを。",
      "time": "00:01:55"
    },
    {
      "role": "teacher",
      "text": "Sophia sits by the window with her coffee.",
      "zh": "索菲亞拿著咖啡坐在窗邊。",
      "ja": "ソフィアはコーヒーを持って窓際に座ります。",
      "time": "00:01:57"
    },
    {
      "role": "student",
      "text": "She says,",
      "zh": "她說，",
      "ja": "彼女は言います、",
      "time": "00:02:00"
    },
    {
      "role": "student",
      "text": "For here or to go.",
      "zh": "內用還是外帶？",
      "ja": "こちらでお召し上がりですか、それともお持ち帰りですか？",
      "time": "00:02:01"
    },
    {
      "role": "teacher",
      "text": "For here of course.",
      "zh": "當然是內用。",
      "ja": "もちろん、こちらで。",
      "time": "00:02:03"
    },
    {
      "role": "teacher",
      "text": "Sophia is walking, but she is lost.",
      "zh": "索菲亞在走路，但迷路了。",
      "ja": "ソフィアは歩いていますが、迷子になっています。",
      "time": "00:02:05"
    },
    {
      "role": "teacher",
      "text": "She looks at her phone.",
      "zh": "她看著手機。",
      "ja": "彼女は携帯電話を見ます。",
      "time": "00:02:08"
    },
    {
      "role": "teacher",
      "text": "Where is Central Park?",
      "zh": "中央公園在哪裡？",
      "ja": "セントラルパークはどこですか？",
      "time": "00:02:10"
    },
    {
      "role": "student",
      "text": "She stops someone and says,",
      "zh": "她攔下一個人說，",
      "ja": "彼女は誰かを止めて言います、",
      "time": "00:02:11"
    },
    {
      "role": "student",
      "text": "Excuse me.",
      "zh": "不好意思。",
      "ja": "すみません。",
      "time": "00:02:13"
    },
    {
      "role": "student",
      "text": "Can you help me?",
      "zh": "你能幫我嗎？",
      "ja": "助けてくれますか？",
      "time": "00:02:14"
    },
    {
      "role": "student",
      "text": "How do I get to Central Park?",
      "zh": "我怎麼去中央公園？",
      "ja": "セントラルパークへはどう行けばいいですか？",
      "time": "00:02:16"
    },
    {
      "role": "teacher",
      "text": "The man points and says,",
      "zh": "那人指著方向說，",
      "ja": "男性は指をさして言います、",
      "time": "00:02:18"
    },
    {
      "role": "teacher",
      "text": "Go straight for two blocks.",
      "zh": "直走兩個街區。",
      "ja": "2ブロックまっすぐ行ってください。",
      "time": "00:02:20"
    },
    {
      "role": "teacher",
      "text": "Then turn left on fifth avenue.",
      "zh": "然後在第五大道左轉。",
      "ja": "それから5番街で左に曲がってください。",
      "time": "00:02:21"
    },
    {
      "role": "student",
      "text": "Sophia listens carefully and nods.",
      "zh": "索菲亞仔細聽著並點頭。",
      "ja": "ソフィアは注意深く聞いてうなずきます。",
      "time": "00:02:24"
    },
    {
      "role": "student",
      "text": "She repeats,",
      "zh": "她重複說，",
      "ja": "彼女は繰り返します、",
      "time": "00:02:27"
    },
    {
      "role": "student",
      "text": "Go straight, turn left,",
      "zh": "直走，左轉，",
      "ja": "まっすぐ行って、左に曲がって、",
      "time": "00:02:28"
    },
    {
      "role": "student",
      "text": "Got it.",
      "zh": "知道了。",
      "ja": "わかりました。",
      "time": "00:02:30"
    },
    {
      "role": "student",
      "text": "Thank you so much.",
      "zh": "非常感謝。",
      "ja": "どうもありがとうございます。",
      "time": "00:02:31"
    },
    {
      "role": "teacher",
      "text": "Sophia sees a beautiful shop.",
      "zh": "索菲亞看到一家漂亮的商店。",
      "ja": "ソフィアは美しいお店を見つけます。",
      "time": "00:02:33"
    },
    {
      "role": "teacher",
      "text": "She walks in and looks at everything.",
      "zh": "她走進去看著所有東西。",
      "ja": "彼女は中に入り、すべてを見ます。",
      "time": "00:02:35"
    },
    {
      "role": "teacher",
      "text": "She loves shopping.",
      "zh": "她喜歡購物。",
      "ja": "彼女は買い物が大好きです。",
      "time": "00:02:37"
    },
    {
      "role": "teacher",
      "text": "She finds a blue scarf.",
      "zh": "她找到一條藍色圍巾。",
      "ja": "彼女は青いスカーフを見つけます。",
      "time": "00:02:39"
    },
    {
      "role": "student",
      "text": "She holds it up and asks,",
      "zh": "她拿起來問，",
      "ja": "彼女はそれを持ち上げて尋ねます、",
      "time": "00:02:41"
    },
    {
      "role": "student",
      "text": "How much is this one?",
      "zh": "這個多少錢？",
      "ja": "これはいくらですか？",
      "time": "00:02:43"
    },
    {
      "role": "teacher",
      "text": "It is thirty five dollars.",
      "zh": "三十五美元。",
      "ja": "35ドルです。",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "Sophia pays by card.",
      "zh": "索菲亞用卡付款。",
      "ja": "ソフィアはカードで支払います。",
      "time": "00:02:46"
    },
    {
      "role": "student",
      "text": "I'll take it.",
      "zh": "我要買這個。",
      "ja": "これをください。",
      "time": "00:02:48"
    },
    {
      "role": "teacher",
      "text": "A very useful phrase when you go shopping.",
      "zh": "去購物時非常實用的句子。",
      "ja": "買い物をするときにとても役立つフレーズです。",
      "time": "00:02:49"
    },
    {
      "role": "teacher",
      "text": "What an amazing first day.",
      "zh": "多麼精彩的第一天啊。",
      "ja": "なんて素晴らしい初日でしょう。",
      "time": "00:02:53"
    },
    {
      "role": "teacher",
      "text": "Sophia saw the airport,",
      "zh": "索菲亞看到了機場，",
      "ja": "ソフィアは空港を見ました、",
      "time": "00:02:56"
    },
    {
      "role": "teacher",
      "text": "the hotel, a cafe,",
      "zh": "飯店，一家咖啡館，",
      "ja": "ホテル、カフェ、",
      "time": "00:02:57"
    },
    {
      "role": "teacher",
      "text": "the streets and a shop.",
      "zh": "街道和一家商店。",
      "ja": "通りとお店。",
      "time": "00:02:59"
    },
    {
      "role": "teacher",
      "text": "All in English.",
      "zh": "全部都是英文。",
      "ja": "すべて英語で。",
      "time": "00:03:01"
    },
    {
      "role": "teacher",
      "text": "Which scene was your favorite?",
      "zh": "你最喜歡哪個場景？",
      "ja": "どのシーンが一番好きでしたか？",
      "time": "00:03:03"
    },
    {
      "role": "teacher",
      "text": "Tell me in the comments.",
      "zh": "請在留言區告訴我。",
      "ja": "コメントで教えてください。",
      "time": "00:03:05"
    },
    {
      "role": "teacher",
      "text": "See you in the next video.",
      "zh": "下個影片見。",
      "ja": "次の動画でお会いしましょう。",
      "time": "00:03:06"
    },
    {
      "role": "teacher",
      "text": "Bye.",
      "zh": "再見。",
      "ja": "さようなら。",
      "time": "00:03:08"
    }
  ]
}