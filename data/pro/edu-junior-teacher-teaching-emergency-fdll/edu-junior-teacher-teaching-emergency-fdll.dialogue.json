  "dialogue": [
    {
      "role": "teacher",
      "text": "Hello. Hello Sally.",
      "zh": "你好。你好，莎莉。",
      "ja": "こんにちは。こんにちは、サリー。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "What's this? It's a book.",
      "zh": "這是什麼？這是一本書。",
      "ja": "これは何？本です。",
      "time": "00:00:19"
    },
    {
      "role": "teacher",
      "text": "What's that?",
      "zh": "那是什麼？",
      "ja": "あれは何？",
      "time": "00:00:29"
    },
    {
      "role": "teacher",
      "text": "It's a box.",
      "zh": "那是一個盒子。",
      "ja": "それは箱です。",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "Wow. What's that?",
      "zh": "哇。那是什麼？",
      "ja": "わあ。それは何？",
      "time": "00:00:45"
    },
    {
      "role": "teacher",
      "text": "It's a pencil.",
      "zh": "那是一支鉛筆。",
      "ja": "それは鉛筆です。",
      "time": "00:00:47"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとう。",
      "time": "00:00:51"
    },
    {
      "role": "teacher",
      "text": "You're welcome.",
      "zh": "不客氣。",
      "ja": "どういたしまして。",
      "time": "00:00:53"
    },
    {
      "role": "student",
      "text": "Wow. Pizza.",
      "zh": "哇。披薩。",
      "ja": "わあ。ピザ。",
      "time": "00:01:00"
    },
    {
      "role": "student",
      "text": "Oh no.",
      "zh": "喔不。",
      "ja": "あらら。",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "What color is it?",
      "zh": "它是什麼顏色？",
      "ja": "何色ですか？",
      "time": "00:01:22"
    },
    {
      "role": "student",
      "text": "It's red.",
      "zh": "它是紅色的。",
      "ja": "赤です。",
      "time": "00:01:25"
    },
    {
      "role": "teacher",
      "text": "Red.",
      "zh": "紅色。",
      "ja": "赤。",
      "time": "00:01:29"
    },
    {
      "role": "teacher",
      "text": "Stop. Green.",
      "zh": "停。綠色。",
      "ja": "止まれ。緑。",
      "time": "00:01:31"
    },
    {
      "role": "teacher",
      "text": "Go.",
      "zh": "走。",
      "ja": "進め。",
      "time": "00:01:33"
    },
    {
      "role": "student",
      "text": "Uh-huh.",
      "zh": "嗯嗯。",
      "ja": "うん。",
      "time": "00:01:35"
    },
    {
      "role": "teacher",
      "text": "Oh. It's green.",
      "zh": "喔。它是綠色的。",
      "ja": "ああ。緑です。",
      "time": "00:01:40"
    },
    {
      "role": "teacher",
      "text": "Okay. Let's go.",
      "zh": "好。走吧。",
      "ja": "はい。行きましょう。",
      "time": "00:01:44"
    },
    {
      "role": "student",
      "text": "I like green.",
      "zh": "我喜歡綠色。",
      "ja": "緑が好きです。",
      "time": "00:01:48"
    },
    {
      "role": "teacher",
      "text": "Red. Stop.",
      "zh": "紅色。停。",
      "ja": "赤。止まれ。",
      "time": "00:01:51"
    },
    {
      "role": "teacher",
      "text": "Green. Go. Red. Stop.",
      "zh": "綠色。走。紅色。停。",
      "ja": "緑。進め。赤。止まれ。",
      "time": "00:01:53"
    },
    {
      "role": "teacher",
      "text": "Green. Go.",
      "zh": "綠色。走。",
      "ja": "緑。進め。",
      "time": "00:01:57"
    },
    {
      "role": "student",
      "text": "It's raining. I don't have an umbrella.",
