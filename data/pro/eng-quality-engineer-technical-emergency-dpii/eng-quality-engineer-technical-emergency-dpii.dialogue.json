{
  "meta": {
    "slug": "eng-quality-engineer-technical-emergency-dpii",
    "category": "pro/engineering/quality_engineer",
    "source_url": "https://www.youtube.com/watch?v=DpIiX_cnmKo",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "Leo, I'm scared.",
      "zh": "Leo，我很害怕。",
      "ja": "レオ、怖いよ。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Why Anna?",
      "zh": "為什麼，Anna？",
      "ja": "どうして、アンナ？",
      "time": "00:00:07"
    },
    {
      "role": "student",
      "text": "Because I love you, and my dad hates it.",
      "zh": "因為我愛你，而我爸爸討厭這件事。",
      "ja": "だって、私はあなたを愛しているのに、父はそれを嫌っているの。",
      "time": "00:00:09"
    },
    {
      "role": "teacher",
      "text": "He hates me?",
      "zh": "他討厭我？",
      "ja": "彼は私を嫌っているの？",
      "time": "00:00:13"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:00:15"
    },
    {
      "role": "student",
      "text": "He says you are poor.",
      "zh": "他說你很窮。",
      "ja": "彼はあなたが貧しいと言っている。",
      "time": "00:00:17"
    },
    {
      "role": "student",
      "text": "He says you want my money.",
      "zh": "他說你想要我的錢。",
      "ja": "彼はあなたが私のお金を欲しがっていると言っている。",
      "time": "00:00:19"
    },
    {
      "role": "teacher",
      "text": "That's not true.",
      "zh": "那不是真的。",
      "ja": "それは違うよ。",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "I don't want your money, Anna.",
      "zh": "我不想要你的錢，Anna。",
      "ja": "私はあなたのお金は欲しくない、アンナ。",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "I want you.",
      "zh": "我想要的是你。",
      "ja": "私はあなたが欲しい。",
      "time": "00:00:26"
    },
    {
      "role": "student",
      "text": "I know that.",
      "zh": "我知道。",
      "ja": "それは知っている。",
      "time": "00:00:29"
    },
    {
      "role": "student",
      "text": "I believe you.",
      "zh": "我相信你。",
      "ja": "信じている。",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "But my dad only sees money.",
      "zh": "但我爸爸只看重錢。",
      "ja": "でも父はお金しか見ていない。",
      "time": "00:00:33"
    },
    {
      "role": "student",
      "text": "He thinks love is not real without it.",
      "zh": "他認為沒有錢愛情不是真實的。",
      "ja": "彼はお金なしの愛は本物じゃないと思っている。",
      "time": "00:00:36"
    },
    {
      "role": "student",
      "text": "Maybe he is right.",
      "zh": "也許他是對的。",
      "ja": "もしかしたら彼は正しいかも。",
      "time": "00:00:39"
    },
    {
      "role": "student",
      "text": "I have nothing.",
      "zh": "我一無所有。",
      "ja": "私は何も持っていない。",
      "time": "00:00:41"
    },
    {
      "role": "student",
      "text": "No job.",
      "zh": "沒有工作。",
      "ja": "仕事もない。",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "No house.",
      "zh": "沒有房子。",
      "ja": "家もない。",
      "time": "00:00:45"
    },
    {
      "role": "student",
      "text": "No car.",
      "zh": "沒有車。",
      "ja": "車もない。",
      "time": "00:00:46"
    },
    {
      "role": "student",
      "text": "Just dreams.",
      "zh": "只有夢想。",
      "ja": "夢だけだ。",
      "time": "00:00:48"
    },
    {
      "role": "teacher",
      "text": "You have a big heart.",
      "zh": "你有一顆大大的心。",
      "ja": "あなたは大きな心を持っている。",
      "time": "00:00:51"
    },
    {
      "role": "teacher",
      "text": "You are kind.",
      "zh": "你很善良。",
      "ja": "あなたは優しい。",
      "time": "00:00:53"
    },
    {
      "role": "teacher",
      "text": "You make me laugh.",
      "zh": "你讓我笑。",
      "ja": "あなたは私を笑わせる。",
      "time": "00:00:55"
    },
    {
      "role": "teacher",
      "text": "That is real to me.",
      "zh": "那對我來說是真實的。",
      "ja": "それは私にとって本物だ。",
      "time": "00:00:57"
    },
    {
      "role": "teacher",
      "text": "But is it enough?",
      "zh": "但這夠嗎？",
      "ja": "でもそれで十分？",
      "time": "00:00:59"
    },
    {
      "role": "teacher",
      "text": "If your dad says no, will you still choose me?",
      "zh": "如果你爸爸說不，你還會選擇我嗎？",
      "ja": "もし父が反対しても、私を選ぶ？",
      "time": "00:01:01"
    },
    {
      "role": "student",
      "text": "I want to.",
      "zh": "我想要。",
      "ja": "そうしたい。",
      "time": "00:01:05"
    },
    {
      "role": "student",
      "text": "I really do.",
      "zh": "我真的想。",
      "ja": "本当にそう思っている。",
      "time": "00:01:07"
    },
    {
      "role": "student",
      "text": "But Leo, he is my father.",
      "zh": "但是Leo，他是我爸爸。",
      "ja": "でもレオ、彼は私の父親だ。",
      "time": "00:01:09"
    },
    {
      "role": "student",
      "text": "How can I leave him?",
      "zh": "我怎麼能離開他？",
      "ja": "どうやって彼を離れられる？",
      "time": "00:01:12"
    },
    {
      "role": "student",
      "text": "He has raised me since I was a child.",
      "zh": "他從小養育我。",
      "ja": "彼は子供の頃から私を育ててくれた。",
      "time": "00:01:14"
    },
    {
      "role": "teacher",
      "text": "I understand, Anna.",
      "zh": "我明白，Anna。",
      "ja": "わかるよ、アンナ。",
      "time": "00:01:17"
    },
    {
      "role": "student",
      "text": "Anna, what are you doing?",
      "zh": "Anna，你在做什麼？",
      "ja": "アンナ、何してるの？",
      "time": "00:01:21"
    },
    {
      "role": "student",
      "text": "I'm talking to Leo, dad.",
      "zh": "我在跟Leo說話，爸爸。",
      "ja": "レオと話してるの、パパ。",
      "time": "00:01:30"
    },
    {
      "role": "teacher",
      "text": "I told you.",
      "zh": "我告訴過你。",
      "ja": "言っただろう。",
      "time": "00:01:33"
    },
    {
      "role": "teacher",
      "text": "Stay away from him.",
      "zh": "離他遠一點。",
      "ja": "彼から離れなさい。",
      "time": "00:01:34"
    },
    {
      "role": "student",
      "text": "Sir, I love Anna.",
      "zh": "先生，我愛Anna。",
      "ja": "先生、私はアンナを愛しています。",
      "time": "00:01:36"
    },
    {
      "role": "student",
      "text": "I want to be with her.",
      "zh": "我想和她在一起。",
      "ja": "彼女と一緒にいたい。",
      "time": "00:01:38"
    },
    {
      "role": "teacher",
      "text": "You.",
      "zh": "你。",
      "ja": "お前。",
      "time": "00:01:41"
    },
    {
      "role": "teacher",
      "text": "What do you have?",
      "zh": "你有什麼？",
      "ja": "お前に何がある？",
      "time": "00:01:42"
    },
    {
      "role": "teacher",
      "text": "You have nothing.",
      "zh": "你一無所有。",
      "ja": "お前は何も持っていない。",
      "time": "00:01:44"
    },
    {
      "role": "teacher",
      "text": "You are not her future.",
      "zh": "你不是她的未來。",
      "ja": "お前は彼女の未来じゃない。",
      "time": "00:01:46"
    },
    {
      "role": "teacher",
      "text": "Money can come and go.",
      "zh": "錢來錢去。",
      "ja": "お金は来たり去ったりする。",
      "time": "00:01:49"
    },
    {
      "role": "teacher",
      "text": "But love is real.",
      "zh": "但愛是真實的。",
      "ja": "でも愛は本物だ。",
      "time": "00:01:51"
    },
    {
      "role": "student",
      "text": "I love her.",
      "zh": "我愛她。",
      "ja": "私は彼女を愛している。",
      "time": "00:01:53"
    },
    {
      "role": "student",
      "text": "I will work hard.",
      "zh": "我會努力工作。",
      "ja": "一生懸命働く。",
      "time": "00:01:55"
    },
    {
      "role": "student",
      "text": "I will build a life.",
      "zh": "我會建立生活。",
      "ja": "人生を築く。",
      "time": "00:01:57"
    },
    {
      "role": "teacher",
      "text": "Words are easy.",
      "zh": "說說容易。",
      "ja": "言葉は簡単だ。",
      "time": "00:02:00"
    },
    {
      "role": "teacher",
      "text": "Life is hard.",
      "zh": "生活很難。",
      "ja": "人生は厳しい。",
      "time": "00:02:02"
    },
    {
      "role": "teacher",
      "text": "Life runs on money, not on love.",
      "zh": "生活靠錢，不靠愛。",
      "ja": "人生はお金で動く、愛ではない。",
      "time": "00:02:04"
    },
    {
      "role": "teacher",
      "text": "Go and try to buy some fruits with love.",
      "zh": "去試著用愛買些水果。",
      "ja": "愛で果物を買ってみろ。",
      "time": "00:02:08"
    },
    {
      "role": "teacher",
      "text": "You'll see, you cannot.",
      "zh": "你會看到，你做不到。",
      "ja": "見てみろ、できない。",
      "time": "00:02:10"
    },
    {
      "role": "teacher",
      "text": "Love cannot even buy a cup of coffee.",
      "zh": "愛甚至買不起一杯咖啡。",
      "ja": "愛はコーヒー一杯も買えない。",
      "time": "00:02:13"
    },
    {
      "role": "student",
      "text": "Dad, please.",
      "zh": "爸爸，拜託。",
      "ja": "パパ、お願い。",
      "time": "00:02:16"
    },
    {
      "role": "student",
      "text": "You don't know him.",
      "zh": "你不了解他。",
      "ja": "彼のことを知らない。",
      "time": "00:02:19"
    },
    {
      "role": "student",
      "text": "He may be poor, but he is honest.",
      "zh": "他或許窮，但他誠實。",
      "ja": "彼は貧しいかもしれないが、正直だ。",
      "time": "00:02:21"
    },
    {
      "role": "student",
      "text": "He loves me, not my money.",
      "zh": "他愛我，不是我的錢。",
      "ja": "彼は私を愛している、お金じゃない。",
      "time": "00:02:24"
    },
    {
      "role": "teacher",
      "text": "Anna, I am warning you.",
      "zh": "Anna，我警告你。",
      "ja": "アンナ、警告する。",
      "time": "00:02:27"
    },
    {
      "role": "teacher",
      "text": "Never trust the poor.",
      "zh": "永遠不要相信窮人。",
      "ja": "貧しい人を決して信じるな。",
      "time": "00:02:30"
    },
    {
      "role": "teacher",
      "text": "Let us go home.",
      "zh": "我們回家吧。",
      "ja": "家に帰ろう。",
      "time": "00:02:33"
    },
    {
      "role": "student",
      "text": "No.",
      "zh": "不。",
      "ja": "いや。",
      "time": "00:02:35"
    },
    {
      "role": "student",
      "text": "I want to stay.",
      "zh": "我想留下。",
      "ja": "ここにいたい。",
      "time": "00:02:37"
    },
    {
      "role": "student",
      "text": "I will not give up.",
      "zh": "我不會放棄。",
      "ja": "諦めない。",
      "time": "00:02:39"
    },
    {
      "role": "student",
      "text": "I will find a way.",
      "zh": "我會找到方法。",
      "ja": "方法を見つける。",
      "time": "00:02:49"
    },
    {
      "role": "student",
      "text": "I will get a job.",
      "zh": "我會找到工作。",
      "ja": "仕事を見つける。",
      "time": "00:02:51"
    },
    {
      "role": "student",
      "text": "I will make money.",
      "zh": "我會賺錢。",
      "ja": "お金を稼ぐ。",
      "time": "00:02:53"
    },
    {
      "role": "student",
      "text": "Then I will come back to you.",
      "zh": "然後我會回到你身邊。",
      "ja": "それから君のところに戻る。",
      "time": "00:02:55"
    },
    {
      "role": "student",
      "text": "I don't want money, Leo.",
      "zh": "我不想要錢，Leo。",
      "ja": "お金はいらない、レオ。",
      "time": "00:02:58"
    },
    {
      "role": "student",
      "text": "I want you.",
      "zh": "我想要你。",
      "ja": "君が欲しい。",
      "time": "00:03:01"
    },
    {
      "role": "student",
      "text": "Just promise me, don't change.",
      "zh": "只要答應我，不要改變。",
      "ja": "約束して、変わらないで。",
      "time": "00:03:03"
    },
    {
      "role": "teacher",
      "text": "I promise.",
      "zh": "我答應。",
      "ja": "約束する。",
      "time": "00:03:06"
    },
    {
      "role": "student",
      "text": "Leo, I like you.",
      "zh": "Leo，我喜歡你。",
      "ja": "レオ、好きよ。",
      "time": "00:03:21"
    },
    {
      "role": "student",
      "text": "You speak well.",
      "zh": "你說話很好。",
      "ja": "話し方が上手ね。",
      "time": "00:03:23"
    },
    {
      "role": "student",
      "text": "You are smart.",
      "zh": "你很聰明。",
      "ja": "賢いね。",
      "time": "00:03:25"
    },
    {
      "role": "student",
      "text": "You look like a hardworking person.",
      "zh": "你看起來像個努力工作的人。",
      "ja": "勤勉な人に見える。",
      "time": "00:03:27"
    },
    {
      "role": "teacher",
      "text": "You can start tomorrow.",
      "zh": "你明天可以開始。",
      "ja": "明日から始めていいよ。",
      "time": "00:03:30"
    },
    {
      "role": "student",
      "text": "Thank you, sir.",
      "zh": "謝謝您，先生。",
      "ja": "ありがとうございます、先生。",
      "time": "00:03:32"
    },
    {
      "role": "student",
      "text": "I will work hard.",
      "zh": "我會努力工作。",
      "ja": "一生懸命働きます。",
      "time": "00:03:35"
    },
    {
      "role": "student",
      "text": "I promise.",
      "zh": "我保證。",
      "ja": "約束します。",
      "time": "00:03:37"
    },
    {
      "role": "student",
      "text": "I will never be late.",
      "zh": "我絕不會遲到。",
      "ja": "遅刻しません。",
      "time": "00:03:39"
    },
    {
      "role": "teacher",
      "text": "Excellent.",
      "zh": "太好了。",
      "ja": "素晴らしい。",
      "time": "00:03:41"
    },
    {
      "role": "teacher",
      "text": "You are perfect for this job.",
      "zh": "你非常適合這份工作。",
      "ja": "この仕事にぴったりだ。",
      "time": "00:03:43"
    },
    {
      "role": "teacher",
      "text": "Sir, the mayor just called.",
      "zh": "先生，市長剛打電話來。",
      "ja": "先生、市長から電話がありました。",
      "time": "00:03:46"
    },
    {
      "role": "teacher",
      "text": "His nephew wants this job.",
      "zh": "他的侄子想要這份工作。",
      "ja": "彼の甥がこの仕事を欲しがっている。",
      "time": "00:03:49"
    },
    {
      "role": "teacher",
      "text": "He will come tomorrow.",
      "zh": "他明天會來。",
      "ja": "彼は明日来る。",
      "time": "00:03:51"
    },
    {
      "role": "student",
      "text": "What?",
      "zh": "什麼？",
      "ja": "え？",
      "time": "00:03:54"
    },
    {
      "role": "teacher",
      "text": "Are you sure?",
      "zh": "你確定嗎？",
      "ja": "本当か？",
      "time": "00:03:55"
    },
    {
      "role": "teacher",
      "text": "Yes, sir.",
      "zh": "是的，先生。",
      "ja": "はい、先生。",
      "time": "00:03:57"
    },
    {
      "role": "student",
      "text": "Leo, I'm sorry.",
      "zh": "Leo，對不起。",
      "ja": "レオ、ごめんね。",
      "time": "00:03:59"
    },
    {
      "role": "student",
      "text": "There is a problem.",
      "zh": "有問題。",
      "ja": "問題がある。",
      "time": "00:04:01"
    },
    {
      "role": "student",
      "text": "The job is not available now.",
      "zh": "這份工作現在沒了。",
      "ja": "その仕事はもうない。",
      "time": "00:04:03"
    },
    {
      "role": "teacher",
      "text": "But you just said I can come from tomorrow.",
      "zh": "但你剛說我明天可以來。",
      "ja": "でもさっき明日から来ていいと言った。",
      "time": "00:04:09"
    },
    {
      "role": "teacher",
      "text": "Yes, I did.",
      "zh": "是的，我說過。",
      "ja": "はい、言いました。",
      "time": "00:04:12"
    },
    {
      "role": "teacher",
      "text": "But things changed.",
      "zh": "但情況變了。",
      "ja": "でも状況が変わった。",
      "time": "00:04:15"
    },
    {
      "role": "teacher",
      "text": "I hope you understand.",
      "zh": "希望你能理解。",
      "ja": "わかってほしい。",
      "time": "00:04:17"
    },
    {
      "role": "student",
      "text": "No, sir.",
      "zh": "不，先生。",
      "ja": "いいえ、先生。",
      "time": "00:04:20"
    },
    {
      "role": "student",
      "text": "I don't.",
      "zh": "我不懂。",
      "ja": "わかりません。",
      "time": "00:04:22"
    },
    {
      "role": "student",
      "text": "This is not fair.",
      "zh": "這不公平。",
      "ja": "これは不公平だ。",
      "time": "00:04:24"
    },
    {
      "role": "teacher",
      "text": "Life is not fair, Leo.",
      "zh": "人生不公平，Leo。",
      "ja": "人生は不公平だ、レオ。",
      "time": "00:04:26"
    }
  ]
}