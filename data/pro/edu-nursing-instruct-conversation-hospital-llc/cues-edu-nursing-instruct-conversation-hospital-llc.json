[
  {
    "time": "00:00:00",
    "en": "What's wrong with you, John?",
    "zh": "你怎麼了，約翰？",
    "ja": "ジョン、どうしたの？",
    "source_url": "https://www.youtube.com/watch?v=LlC-Trk54Zg"
  },
  {
    "time": "00:00:19",
    "en": "You look sick.",
    "zh": "你看起來很不舒服。",
    "ja": "具合が悪そうだね。"
  },
  {
    "time": "00:00:20",
    "en": "I don't know what is wrong with me.",
    "zh": "我不知道我怎麼了。",
    "ja": "自分でも何が悪いのかわからない。"
  },
  {
    "time": "00:00:25",
    "en": "What?",
    "zh": "什麼？",
    "ja": "え？"
  },
  {
    "time": "00:00:27",
    "en": "Don't you have a cold?",
    "zh": "你是不是感冒了？",
    "ja": "風邪をひいてないの？"
  },
  {
    "time": "00:00:30",
    "en": "What is your symptom?",
    "zh": "你的症狀是什麼？",
    "ja": "症状は何？"
  },
  {
    "time": "00:00:34",
    "en": "Um...",
    "zh": "嗯……",
    "ja": "えっと…"
  },
  {
    "time": "00:00:36",
    "en": "I was shivering and it was cold last night.",
    "zh": "我昨晚發抖，覺得很冷。",
    "ja": "昨夜は震えて寒かった。"
  },
  {
    "time": "00:00:41",
    "en": "I think I have a headache too.",
    "zh": "我覺得我還頭痛。",
    "ja": "頭痛もあると思う。"
  },
  {
    "time": "00:00:44",
    "en": "I also snuffle and cough too.",
    "zh": "我還鼻塞和咳嗽。",
    "ja": "鼻づまりと咳もある。"
  },
  {
    "time": "00:00:49",
    "en": "And I'm so tired.",
    "zh": "而且我很累。",
    "ja": "それにとても疲れている。"
  },
  {
    "time": "00:00:52",
    "en": "Oh my goodness!",
    "zh": "天啊！",
    "ja": "なんてこった！"
  },
  {
    "time": "00:00:55",
    "en": "I'm pretty sure you have a cold.",
    "zh": "我很確定你感冒了。",
    "ja": "絶対に風邪をひいているよ。"
  },
  {
    "time": "00:00:58",
    "en": "What?",
    "zh": "什麼？",
    "ja": "え？"
  },
  {
    "time": "00:01:00",
    "en": "It's not even winter yet.",
    "zh": "現在還不是冬天呢。",
    "ja": "まだ冬じゃないよ。"
  },
  {
    "time": "00:01:02",
    "en": "And the weather is warm too.",
    "zh": "天氣也很暖和。",
    "ja": "天気も暖かいしね。"
  },
  {
    "time": "00:01:05",
    "en": "John, listen.",
    "zh": "約翰，聽我說。",
    "ja": "ジョン、聞いて。"
  },
  {
    "time": "00:01:07",
    "en": "It's warm afternoon.",
    "zh": "現在是溫暖的下午。",
    "ja": "暖かい午後だよ。"
  },
  {
    "time": "00:01:10",
    "en": "But what about in morning?",
    "zh": "但早上呢？",
    "ja": "でも朝はどう？"
  },
  {
    "time": "00:01:13",
    "en": "Isn't it cold?",
    "zh": "不是很冷嗎？",
    "ja": "寒くない？"
  },
  {
    "time": "00:01:15",
    "en": "It's easy to catch a cold during the change of seasons.",
    "zh": "換季時很容易感冒。",
    "ja": "季節の変わり目は風邪をひきやすいんだ。"
  },
  {
    "time": "00:01:20",
    "en": "I did not know that.",
    "zh": "我不知道這點。",
    "ja": "それは知らなかった。"
  },
  {
    "time": "00:01:22",
    "en": "I thought I only catch a cold during the winter.",
    "zh": "我以為我只會在冬天感冒。",
    "ja": "風邪は冬だけにひくと思ってた。"
  },
  {
    "time": "00:01:26",
    "en": "You should drink lots of warm water and eat foods for vitamins.",
    "zh": "你應該多喝溫水，多吃含維他命的食物。",
    "ja": "たくさん温かい水を飲んで、ビタミンのある食べ物を食べるべきだよ。"
  },
  {
    "time": "00:01:31",
    "en": "If you are not cured, you need to go to a hospital.",
    "zh": "如果沒好轉，你需要去醫院。",
    "ja": "治らなければ病院に行く必要があるよ。"
  },
  {
    "time": "00:01:36",
    "en": "Yeah, I should.",
    "zh": "是啊，我應該去。",
    "ja": "うん、そうするよ。"
  },
  {
    "time": "00:01:43",
    "en": "When is the science homework due?",
    "zh": "科學作業什麼時候交？",
    "ja": "理科の宿題はいつまで？"
  },
  {
    "time": "00:01:46",
    "en": "Ouch!",
    "zh": "哎呀！",
    "ja": "痛っ！"
  },
  {
    "time": "00:01:51",
    "en": "What's wrong?",
    "zh": "怎麼了？",
    "ja": "どうしたの？"
  },
  {
    "time": "00:01:54",
    "en": "It hurts so much.",
    "zh": "好痛。",
    "ja": "すごく痛い。"
  },
  {
    "time": "00:01:56",
    "en": "I'm scared that this could be a serious one.",
    "zh": "我怕這可能是嚴重的傷。",
    "ja": "これが重症かもしれなくて怖い。"
  },
  {
    "time": "00:02:00",
    "en": "Where?",
    "zh": "哪裡？",
    "ja": "どこ？"
  },
  {
    "time": "00:02:02",
    "en": "Did you get hurt?",
    "zh": "你受傷了嗎？",
    "ja": "怪我したの？"
  },
  {
    "time": "00:02:05",
    "en": "Look at this.",
    "zh": "看看這個。",
    "ja": "これを見て。"
  },
  {
    "time": "00:02:07",
    "en": "John, I have a bandage.",
    "zh": "約翰，我有繃帶。",
    "ja": "ジョン、包帯があるよ。"
  },
  {
    "time": "00:02:10",
    "en": "Don't be a crybaby.",
    "zh": "別愛哭。",
    "ja": "泣き虫にならないで。"
  },
  {
    "time": "00:02:15",
    "en": "At two.",
    "zh": "兩點。",
    "ja": "2時に。"
  },
  {
    "time": "00:02:19",
    "en": "Oops.",
    "zh": "哎呀。",
    "ja": "おっと。"
  },
  {
    "time": "00:02:20",
    "en": "What's wrong with you?",
    "zh": "你怎麼了？",
    "ja": "どうしたの？"
  },
  {
