    "ja": "ハニー。"
  },
  {
    "time": "00:04:45",
    "en": "Happy birthday.",
    "zh": "生日快樂。",
    "ja": "お誕生日おめでとう。"
  },
  {
    "time": "00:04:47",
    "en": "Honey, thank you so much.",
