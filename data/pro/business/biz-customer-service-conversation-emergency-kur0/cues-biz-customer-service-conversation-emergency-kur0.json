  },
  {
    "time": "00:06:10",
    "en": "Hello, Mr. Bread.",
    "zh": "你好，布拉德先生。",
    "ja": "こんにちは、ブレッドさん。"
  },
  {
    "time": "00:06:12",
    "en": "You're the mother of those four kids.",
    "zh": "你是那四個孩子的媽媽。",
    "ja": "あなたはあの四人の子供の母親ですね。"
  },
  {
    "time": "00:06:15",
    "en": "Don't tell me they don't need their hair done again.",
