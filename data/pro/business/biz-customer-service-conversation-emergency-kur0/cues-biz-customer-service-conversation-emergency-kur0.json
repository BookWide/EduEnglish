  },
  {
    "time": "00:05:05",
    "en": "Am I your maid?",
    "zh": "我是你的女傭嗎？",
    "ja": "私はあなたのメイド？"
  },
  {
    "time": "00:05:06",
    "en": "You can shape your gloves.",
    "zh": "你可以塑形你的手套。",
    "ja": "手袋を形作れるよ。"
  },
  {
    "time": "00:05:08",
