    "ja": "ああ、誕生日ですね、もちろん最高のものを用意しますよ。"
  },
  {
    "time": "00:06:28",
    "en": "Happy birthday to you.",
    "zh": "祝你生日快樂。",
    "ja": "お誕生日おめでとう。"
  },
  {
    "time": "00:06:31",
    "en": "Happy birthday to your customer.",
    "zh": "祝你的客戶生日快樂。",
    "ja": "お客様の誕生日おめでとう。"
  },
  {
    "time": "00:06:35",
    "en": "Happy birthday to you.",
    "zh": "祝你生日快樂。",
    "ja": "お誕生日おめでとう。"
  },
  {
    "time": "00:06:38",
    "en": "Thank you.",
    "zh": "謝謝。",
    "ja": "ありがとう。"
  },
  {
    "time": "00:06:41",
    "en": "Honey, where are you?",
    "zh": "親愛的，你在哪裡？",
    "ja": "ハニー、どこにいるの？"
  },
  {
    "time": "00:06:44",
    "en": "The kids are hungry and going crazy.",
    "zh": "孩子們又餓又瘋狂。",
    "ja": "子供たちはお腹が空いていて、暴れているよ。"
  },
  {
    "time": "00:06:46",
    "en": "Come back in club.",
    "zh": "回來幫忙。",
    "ja": "戻ってきて手伝って。"
  },
  {
    "time": "00:06:48",
    "en": "Do you have no hands or something?",
    "zh": "你沒有手嗎？",
    "ja": "手がないの？"
  },
  {
    "time": "00:06:51",
    "en": "Learn to cook our star.",
    "zh": "學著做飯吧，我們的明星。",
    "ja": "料理を覚えなさい、私たちのスター。"
  },
  {
    "time": "00:06:53",
    "en": "It's not my problem right now.",
    "zh": "這現在不是我的問題。",
    "ja": "今は私の問題じゃない。"
  },
  {
    "time": "00:06:55",
    "en": "Honey, huh?",
    "zh": "親愛的，嗯？",
