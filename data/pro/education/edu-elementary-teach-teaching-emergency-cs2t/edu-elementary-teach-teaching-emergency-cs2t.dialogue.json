    {
      "role": "teacher",
      "text": "Basic English conversation practice for kids.",
      "zh": "兒童基礎英語會話練習。",
      "ja": "子供向けの基本的な英会話練習です。",
      "time": "00:00:01"
    },
    {
      "role": "teacher",
      "text": "Hello.",
      "zh": "你好。",
      "ja": "こんにちは。",
      "time": "00:00:07"
    },
    {
      "role": "teacher",
      "text": "I'm your friend, Kolkaka.",
      "zh": "我是你的朋友，Kolkaka。",
      "ja": "私はあなたの友達、コルカカです。",
      "time": "00:00:08"
    },
    {
      "role": "teacher",
      "text": "I'll help you practice English conversation.",
      "zh": "我會幫助你練習英語會話。",
      "ja": "英会話の練習を手伝います。",
      "time": "00:00:11"
    },
    {
      "role": "teacher",
      "text": "Please follow my directions.",
      "zh": "請跟著我的指示做。",
      "ja": "私の指示に従ってください。",
      "time": "00:00:15"
    },
    {
      "role": "teacher",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとうございます。",
      "time": "00:00:18"
    },
    {
      "role": "teacher",
      "text": "It's lunch time.",
      "zh": "午餐時間到了。",
      "ja": "お昼の時間です。",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "Words.",
      "zh": "單字。",
      "ja": "単語。",
      "time": "00:00:25"
    },
    {
      "role": "teacher",
      "text": "After you listen to each word, say the word.",
      "zh": "聽完每個單字後，請說出該單字。",
      "ja": "各単語を聞いた後、その単語を言ってください。",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "Salad.",
      "zh": "沙拉。",
      "ja": "サラダ。",
      "time": "00:00:34"
    },
