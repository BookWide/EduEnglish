{
  "meta": {
    "slug": "hc-nurse-conversation-doctor-xraj",
    "category": "pro/healthcare/nurse",
    "source_url": "https://www.youtube.com/watch?v=XrajGeQmpYo",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "teacher",
      "text": "Look, look, up there is a",
      "zh": "看，那裡上面有一個",
      "ja": "見て、見て、あそこにあるのは",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Are you okay?",
      "zh": "你還好嗎？",
      "ja": "大丈夫ですか？",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "My name is Dr. Joelle.",
      "zh": "我叫喬艾爾醫生。",
      "ja": "私の名前はジョエル医師です。",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "You must be my new patient.",
      "zh": "你一定是我的新病人。",
      "ja": "あなたは私の新しい患者さんですね。",
      "time": "00:00:38"
    },
    {
      "role": "teacher",
      "text": "Leland?",
      "zh": "里蘭？",
      "ja": "リーランド？",
      "time": "00:00:40"
    },
    {
      "role": "teacher",
      "text": "I'm so excited to meet you.",
      "zh": "很高興見到你。",
      "ja": "お会いできてとても嬉しいです。",
      "time": "00:00:41"
    },
    {
      "role": "teacher",
      "text": "And I see you brought some friends.",
      "zh": "我看到你帶了一些朋友來。",
      "ja": "それに、友達も連れてきたんですね。",
      "time": "00:00:43"
    },
    {
      "role": "teacher",
      "text": "Please, come on in.",
      "zh": "請進來。",
      "ja": "どうぞ、中に入ってください。",
      "time": "00:00:45"
    },
    {
      "role": "teacher",
      "text": "You're not scary.",
      "zh": "你一點也不可怕。",
      "ja": "怖くないよ。",
      "time": "00:00:49"
    },
    {
      "role": "teacher",
      "text": "Are you okay?",
      "zh": "你還好嗎？",
      "ja": "大丈夫？",
      "time": "00:00:52"
    },
    {
      "role": "teacher",
      "text": "Sorry, Leland.",
      "zh": "抱歉，里蘭。",
      "ja": "ごめんね、リーランド。",
      "time": "00:00:55"
    },
    {
      "role": "teacher",
      "text": "Don't worry.",
      "zh": "別擔心。",
      "ja": "心配しないで。",
      "time": "00:00:57"
    },
    {
      "role": "teacher",
      "text": "That's Sammy.",
      "zh": "那是薩米。",
      "ja": "あれはサミーです。",
      "time": "00:00:58"
    },
    {
      "role": "teacher",
      "text": "She's my stethoscope.",
      "zh": "她是我的聽診器。",
      "ja": "彼女は私の聴診器です。",
      "time": "00:00:59"
    },
    {
      "role": "teacher",
      "text": "She won't hurt you.",
      "zh": "她不會傷害你。",
      "ja": "彼女はあなたを傷つけません。",
      "time": "00:01:00"
    },
    {
      "role": "teacher",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:01:01"
    },
    {
      "role": "teacher",
      "text": "A stethoscope helps me listen to your heart and your lungs so I know if you're healthy or not.",
      "zh": "聽診器幫助我聽你的心臟和肺部，這樣我就知道你是否健康。",
      "ja": "聴診器はあなたの心臓や肺の音を聞くのに役立ち、健康かどうかを知ることができます。",
      "time": "00:01:02"
    },
    {
      "role": "teacher",
      "text": "Is that a new friend?",
      "zh": "那是新朋友嗎？",
      "ja": "それは新しい友達ですか？",
      "time": "00:01:16"
    },
    {
      "role": "teacher",
      "text": "Hi.",
      "zh": "嗨。",
      "ja": "こんにちは。",
      "time": "00:01:18"
    },
    {
      "role": "teacher",
      "text": "I'm Sammy.",
      "zh": "我是薩米。",
      "ja": "私はサミーです。",
      "time": "00:01:19"
    },
    {
      "role": "teacher",
      "text": "Hi there.",
      "zh": "你好。",
      "ja": "やあ。",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "And this is Autumn.",
      "zh": "這是奧特姆。",
      "ja": "そしてこちらはオータムです。",
      "time": "00:01:23"
    },
    {
      "role": "teacher",
      "text": "He's my doctor's bag.",
      "zh": "他是我的醫生包。",
      "ja": "彼は私の医師バッグです。",
      "time": "00:01:24"
    },
    {
      "role": "teacher",
      "text": "He has all my textbooks and my medical tools.",
      "zh": "裡面有我所有的教科書和醫療工具。",
      "ja": "彼の中には私の教科書と医療器具が全部入っています。",
      "time": "00:01:25"
    },
    {
      "role": "teacher",
      "text": "Pretty cool, right?",
      "zh": "很酷吧？",
      "ja": "かっこいいでしょ？",
      "time": "00:01:28"
    },
    {
      "role": "student",
      "text": "Oh, oh, oh, oh.",
      "zh": "哦，哦，哦，哦。",
      "ja": "おお、おお、おお、おお。",
      "time": "00:01:30"
    },
    {
      "role": "student",
      "text": "I'm awake.",
      "zh": "我醒了。",
      "ja": "目が覚めたよ。",
      "time": "00:01:32"
    },
    {
      "role": "student",
      "text": "Hello there.",
      "zh": "你好。",
      "ja": "こんにちは。",
      "time": "00:01:33"
    },
    {
      "role": "student",
      "text": "Pleasure to meet you.",
      "zh": "很高興見到你。",
      "ja": "お会いできて光栄です。",
      "time": "00:01:34"
    },
    {
      "role": "student",
      "text": "I'm Otto.",
      "zh": "我是奧托。",
      "ja": "私はオットーです。",
      "time": "00:01:36"
    },
    {
      "role": "student",
      "text": "And this is Zeta.",
      "zh": "這是澤塔。",
      "ja": "そしてこちらはゼータです。",
      "time": "00:01:38"
    },
    {
      "role": "student",
      "text": "She's a packs machine that helps us see X-rays.",
      "zh": "她是一台幫助我們看X光的機器。",
      "ja": "彼女はX線を見るのを助ける機械です。",
      "time": "00:01:39"
    },
    {
      "role": "student",
      "text": "She's also a computer and she's a whole world of knowledge.",
      "zh": "她也是一台電腦，擁有豐富的知識。",
      "ja": "彼女はコンピューターでもあり、知識の宝庫です。",
      "time": "00:01:42"
    },
    {
      "role": "teacher",
      "text": "Howdy.",
      "zh": "你好。",
      "ja": "やあ。",
      "time": "00:01:47"
    },
    {
      "role": "teacher",
      "text": "Who's excited to examine things?",
      "zh": "誰想要檢查東西？",
      "ja": "誰が検査するのを楽しみにしていますか？",
      "time": "00:01:48"
    },
    {
      "role": "student",
      "text": "Can we be best friends?",
      "zh": "我們可以成為最好的朋友嗎？",
      "ja": "私たち、親友になれる？",
      "time": "00:01:52"
    },
    {
      "role": "teacher",
      "text": "You're also fun.",
      "zh": "你也很有趣。",
      "ja": "あなたも楽しいね。",
      "time": "00:01:55"
    },
    {
      "role": "student",
      "text": "Maybe you can help me with a question.",
      "zh": "也許你可以幫我解答一個問題。",
      "ja": "質問があるんだけど、手伝ってくれる？",
      "time": "00:01:58"
    },
    {
      "role": "student",
      "text": "I'm told going to the doctor's important.",
      "zh": "有人告訴我去看醫生很重要。",
      "ja": "お医者さんに行くことは大切だって言われたよ。",
      "time": "00:02:02"
    },
    {
      "role": "student",
      "text": "But what does the doctor even do?",
      "zh": "但是醫生到底做什麼呢？",
      "ja": "でも、お医者さんは何をするの？",
      "time": "00:02:05"
    },
    {
      "role": "teacher",
      "text": "That's a great question.",
      "zh": "這是個好問題。",
      "ja": "それはいい質問ですね。",
      "time": "00:02:09"
    },
    {
      "role": "teacher",
      "text": "Do you know what doctors do?",
      "zh": "你知道醫生做什麼嗎？",
      "ja": "医者が何をするか知っていますか？",
      "time": "00:02:11"
    },
    {
      "role": "teacher",
      "text": "Zeta, let's show our new friends what doctors do.",
      "zh": "澤塔，讓我們向新朋友展示醫生做什麼。",
      "ja": "ゼータ、新しい友達に医者の仕事を見せましょう。",
      "time": "00:02:13"
    },
    {
      "role": "student",
      "text": "It would be my pleasure.",
      "zh": "我很樂意。",
      "ja": "喜んで。",
      "time": "00:02:16"
    },
    {
      "role": "teacher",
      "text": "Doctors help people get better when they're not feeling well.",
      "zh": "醫生幫助生病的人恢復健康。",
      "ja": "医者は体調が悪い人を良くする手助けをします。",
      "time": "00:02:21"
    },
    {
      "role": "teacher",
      "text": "There are all different kinds of doctors.",
      "zh": "有各種不同類型的醫生。",
      "ja": "いろいろな種類の医者がいます。",
      "time": "00:02:26"
    },
    {
      "role": "student",
      "text": "Brain doctors?",
      "zh": "腦科醫生？",
      "ja": "脳の医者？",
      "time": "00:02:29"
    },
    {
      "role": "student",
      "text": "Throat doctors.",
      "zh": "喉科醫生。",
      "ja": "喉の医者。",
      "time": "00:02:32"
    },
    {
      "role": "student",
      "text": "Children's doctors.",
      "zh": "兒科醫生。",
      "ja": "小児科の医者。",
      "time": "00:02:36"
    },
    {
      "role": "teacher",
      "text": "Those are called P.B.A. Trishings.",
      "zh": "那些叫做P.B.A.特里辛斯。",
      "ja": "それらはP.B.A.トリシングスと呼ばれます。",
      "time": "00:02:39"
    },
    {
      "role": "student",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "P.D. Trishings?",
      "zh": "P.D.特里辛斯？",
      "ja": "P.D.トリシングス？",
      "time": "00:02:47"
    },
    {
      "role": "teacher",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:02:49"
    },
    {
      "role": "teacher",
      "text": "P.D. Our Trishings.",
      "zh": "P.D.我們的特里辛斯。",
      "ja": "P.D.アワートリシングス。",
      "time": "00:02:50"
    },
    {
      "role": "student",
      "text": "I never knew that.",
      "zh": "我從不知道。",
      "ja": "それは知りませんでした。",
      "time": "00:02:53"
    },
    {
      "role": "student",
      "text": "What about E. Doctors?",
      "zh": "那E.醫生呢？",
      "ja": "E.医者は？",
      "time": "00:02:56"
    },
    {
      "role": "student",
      "text": "And what about this doctor?",
      "zh": "那這位醫生呢？",
      "ja": "そしてこの医者は？",
      "time": "00:03:00"
    },
    {
      "role": "teacher",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:03:04"
    },
    {
      "role": "teacher",
      "text": "Those two.",
      "zh": "那兩個。",
      "ja": "あの二人です。",
      "time": "00:03:08"
    },
    {
      "role": "student",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:03:10"
    },
    {
      "role": "teacher",
      "text": "Did you know that anyone can be a doctor?",
      "zh": "你知道任何人都可以成為醫生嗎？",
      "ja": "誰でも医者になれるって知ってた？",
      "time": "00:03:12"
    },
    {
      "role": "teacher",
      "text": "Even you.",
      "zh": "甚至是你。",
      "ja": "あなたでも。",
      "time": "00:03:17"
    },
    {
      "role": "student",
      "text": "Even me?",
      "zh": "甚至是我？",
      "ja": "私でも？",
      "time": "00:03:20"
    },
    {
      "role": "teacher",
      "text": "That's right. Do you want to learn how?",
      "zh": "沒錯。你想學嗎？",
      "ja": "そうです。どうやってなるか学びたい？",
      "time": "00:03:23"
    },
    {
      "role": "teacher",
      "text": "This will be your doctor's journal.",
      "zh": "這將是你的醫生日誌。",
      "ja": "これはあなたの医者の日誌になります。",
      "time": "00:03:27"
    },
    {
      "role": "teacher",
      "text": "You've done a great job learning today.",
      "zh": "你今天學得很棒。",
      "ja": "今日はよく学びましたね。",
      "time": "00:03:29"
    },
    {
      "role": "teacher",
      "text": "Hello, earned the Curiosity sticker.",
      "zh": "你好，獲得了好奇心貼紙。",
      "ja": "こんにちは、好奇心のシールを獲得しました。",
      "time": "00:03:31"
    },
    {
      "role": "student",
      "text": "Cool.",
      "zh": "酷。",
      "ja": "かっこいい。",
      "time": "00:03:35"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:03:37"
    },
    {
      "role": "student",
      "text": "I get a sticker.",
      "zh": "我得到了一張貼紙。",
      "ja": "シールをもらった。",
      "time": "00:03:40"
    },
    {
      "role": "student",
      "text": "Yay!",
      "zh": "耶！",
      "ja": "やった！",
      "time": "00:03:43"
    },
    {
      "role": "student",
      "text": "I love stickers.",
      "zh": "我喜歡貼紙。",
      "ja": "シールが大好き。",
      "time": "00:03:47"
    },
    {
      "role": "teacher",
      "text": "The more you learn with us, the more stickers you'll get.",
      "zh": "你跟我們學得越多，就會得到越多貼紙。",
      "ja": "私たちと一緒に学べば学ぶほど、シールが増えますよ。",
      "time": "00:03:51"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:03:55"
    },
    {
      "role": "teacher",
      "text": "Absolutely.",
      "zh": "當然。",
      "ja": "もちろんです。",
      "time": "00:03:56"
    },
    {
      "role": "student",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:03:58"
    },
    {
      "role": "student",
      "text": "I can't wait to learn more about being a doctor, Dr. Joel.",
      "zh": "我迫不及待想學更多當醫生的事，喬艾爾醫生。",
      "ja": "もっと医者になることを学びたいです、ジョエル先生。",
      "time": "00:03:59"
    },
    {
      "role": "student",
      "text": "Are you going to help teach me?",
      "zh": "你會幫我教嗎？",
      "ja": "教えてくれますか？",
      "time": "00:04:03"
    },
    {
      "role": "teacher",
      "text": "I would love to.",
      "zh": "我很樂意。",
      "ja": "喜んでお手伝いします。",
      "time": "00:04:06"
    },
    {
      "role": "teacher",
      "text": "Sounds like we'd better get you a doctor's code.",
      "zh": "看來我們得給你一個醫生證件。",
      "ja": "医者の証明書を用意したほうがよさそうですね。",
      "time": "00:04:07"
    },
    {
      "role": "teacher",
      "text": "I think I might know someone who can help us.",
      "zh": "我想我認識可以幫助我們的人。",
      "ja": "助けてくれる人を知っているかもしれません。",
      "time": "00:04:09"
    },
    {
      "role": "teacher",
      "text": "Hmm.",
      "zh": "嗯。",
      "ja": "うーん。",
      "time": "00:04:12"
    },
    {
      "role": "teacher",
      "text": "I think I have one.",
      "zh": "我想我有一個。",
      "ja": "持っていると思います。",
      "time": "00:04:13"
    },
    {
      "role": "teacher",
      "text": "That's just the right size.",
      "zh": "大小剛剛好。",
      "ja": "ちょうどいいサイズです。",
      "time": "00:04:15"
    },
    {
      "role": "teacher",
      "text": "See, here.",
      "zh": "看這裡。",
      "ja": "ほら、ここに。",
      "time": "00:04:17"
    },
    {
      "role": "teacher",
      "text": "Hmm.",
      "zh": "嗯。",
      "ja": "うーん。",
      "time": "00:04:19"
    },
    {
      "role": "teacher",
      "text": "Hmm.",
      "zh": "嗯。",
      "ja": "うーん。",
      "time": "00:04:20"
    },
    {
      "role": "teacher",
      "text": "Hmm.",
      "zh": "嗯。",
      "ja": "うーん。",
      "time": "00:04:21"
    },
    {
      "role": "teacher",
      "text": "Uh-huh.",
      "zh": "嗯哼。",
      "ja": "うんうん。",
      "time": "00:04:22"
    },
    {
      "role": "teacher",
      "text": "There you go.",
      "zh": "給你。",
      "ja": "はい、どうぞ。",
      "time": "00:04:23"
    },
    {
      "role": "student",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:04:27"
    },
    {
      "role": "teacher",
      "text": "Would you look at that?",
      "zh": "你看看這個？",
      "ja": "見てください。",
      "time": "00:04:29"
    },
    {
      "role": "teacher",
      "text": "Suits you well, Leeland.",
      "zh": "很適合你，里蘭。",
      "ja": "リーランドによく似合いますよ。",
      "time": "00:04:32"
    },
    {
      "role": "student",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:04:34"
    },
    {
      "role": "teacher",
      "text": "Excellent.",
      "zh": "太棒了。",
      "ja": "素晴らしい。",
      "time": "00:04:35"
    },
    {
      "role": "teacher",
      "text": "Just right.",
      "zh": "剛剛好。",
      "ja": "ちょうどいい。",
      "time": "00:04:36"
    },
    {
      "role": "teacher",
      "text": "The perfect fit.",
      "zh": "完美合身。",
      "ja": "完璧なフィット感です。",
      "time": "00:04:38"
    },
    {
      "role": "student",
      "text": "I can't wait to learn more.",
      "zh": "我迫不及待想學更多。",
      "ja": "もっと学ぶのが待ちきれません。",
      "time": "00:04:40"
    },
    {
      "role": "teacher",
      "text": "Welcome to the doctor's office, Dr. Leeland.",
      "zh": "歡迎來到醫生辦公室，里蘭醫生。",
      "ja": "医者のオフィスへようこそ、リーランド先生。",
      "time": "00:04:43"
    },
    {
      "role": "teacher",
      "text": "And we can't wait to see you next time, little doctors.",
