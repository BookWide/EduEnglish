{
  "meta": {
    "slug": "svc-retail-staff-service-service-r2pe",
    "category": "pro/service/retail_staff",
    "source_url": "https://www.youtube.com/watch?v=r2pEEkaFq8U",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "How beautiful! I want those red shoes!",
      "zh": "多漂亮啊！我想要那雙紅色的鞋子！",
      "ja": "なんて美しいの！あの赤い靴が欲しい！",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Grandma, please!",
      "zh": "奶奶，拜託！",
      "ja": "おばあちゃん、お願いします！",
      "time": "00:00:08"
    },
    {
      "role": "student",
      "text": "Okay, how much?",
      "zh": "好，多少錢？",
      "ja": "はい、いくらですか？",
      "time": "00:00:11"
    },
    {
      "role": "student",
      "text": "$10!",
      "zh": "10美元！",
      "ja": "10ドル！",
      "time": "00:00:15"
    },
    {
      "role": "student",
      "text": "Thank you, Grandma!",
      "zh": "謝謝你，奶奶！",
      "ja": "ありがとう、おばあちゃん！",
      "time": "00:00:18"
    },
    {
      "role": "teacher",
      "text": "Karen, what are you doing?",
      "zh": "凱倫，你在做什麼？",
      "ja": "カレン、何をしているの？",
      "time": "00:00:23"
    },
    {
      "role": "student",
      "text": "I'm dancing, Grandma!",
      "zh": "我在跳舞，奶奶！",
      "ja": "踊っているよ、おばあちゃん！",
      "time": "00:00:35"
    },
    {
      "role": "teacher",
      "text": "She is dancing here! She is dancing there!",
      "zh": "她這裡跳舞！她那裡跳舞！",
      "ja": "彼女はここで踊っている！あそこでも踊っている！",
      "time": "00:00:39"
    },
    {
      "role": "teacher",
      "text": "She is a good dancer! That's right!",
      "zh": "她是個好舞者！沒錯！",
      "ja": "彼女は上手なダンサーだ！その通り！",
      "time": "00:00:58"
    },
    {
      "role": "teacher",
      "text": "Your Grandma isn't the hospital!",
      "zh": "你的奶奶不在醫院！",
      "ja": "あなたのおばあちゃんは病院にいません！",
      "time": "00:01:07"
    },
    {
      "role": "teacher",
      "text": "Karen, go home, please!",
      "zh": "凱倫，請回家！",
      "ja": "カレン、家に帰ってください！",
      "time": "00:01:10"
    },
    {
      "role": "student",
      "text": "Sorry, I can't!",
      "zh": "抱歉，我不能！",
      "ja": "ごめん、できない！",
      "time": "00:01:12"
    },
    {
      "role": "student",
      "text": "Oh, I'm sleepy!",
      "zh": "喔，我想睡了！",
      "ja": "ああ、眠い！",
      "time": "00:01:19"
    },
    {
      "role": "teacher",
      "text": "Oh, Karen, don't dance! Go to the hospital now!",
      "zh": "喔，凱倫，不要跳舞！現在去醫院！",
      "ja": "ああ、カレン、踊らないで！今すぐ病院に行きなさい！",
      "time": "00:01:27"
    },
    {
      "role": "student",
      "text": "Thank you very much!",
      "zh": "非常感謝！",
      "ja": "どうもありがとうございます！",
      "time": "00:01:35"
    },
    {
      "role": "student",
      "text": "I'm sorry, Grandma!",
      "zh": "對不起，奶奶！",
      "ja": "ごめんなさい、おばあちゃん！",
      "time": "00:01:41"
    },
    {
      "role": "student",
      "text": "Mom, where are you?",
      "zh": "媽媽，你在哪裡？",
      "ja": "ママ、どこにいるの？",
      "time": "00:01:54"
    },
    {
      "role": "teacher",
      "text": "I'm in the kitchen!",
      "zh": "我在廚房！",
      "ja": "私はキッチンにいます！",
      "time": "00:01:58"
    },
    {
      "role": "student",
      "text": "What are you doing?",
      "zh": "你在做什麼？",
      "ja": "何をしているの？",
      "time": "00:02:01"
    },
    {
      "role": "teacher",
      "text": "I'm making soup!",
      "zh": "我在煮湯！",
      "ja": "スープを作っています！",
      "time": "00:02:03"
    },
    {
      "role": "teacher",
      "text": "Can you help me?",
      "zh": "你能幫我嗎？",
      "ja": "手伝ってくれますか？",
      "time": "00:02:06"
    },
    {
      "role": "student",
      "text": "Yes, I can!",
      "zh": "可以，我可以！",
      "ja": "はい、できます！",
      "time": "00:02:08"
    },
    {
      "role": "teacher",
      "text": "Don't run! The soup is hot!",
      "zh": "不要跑！湯很燙！",
      "ja": "走らないで！スープは熱いよ！",
      "time": "00:02:10"
    },
    {
      "role": "student",
      "text": "Where are you?",
      "zh": "你在哪裡？",
      "ja": "どこにいるの？",
      "time": "00:02:15"
    },
    {
      "role": "student",
      "text": "I'm in the bedroom!",
      "zh": "我在臥室！",
      "ja": "私は寝室にいます！",
      "time": "00:02:19"
    },
    {
      "role": "student",
      "text": "This is for you!",
      "zh": "這是給你的！",
      "ja": "これはあなたのためです！",
      "time": "00:02:23"
    },
    {
      "role": "teacher",
      "text": "Thank you!",
      "zh": "謝謝！",
      "ja": "ありがとう！",
      "time": "00:02:26"
    },
    {
      "role": "student",
      "text": "It's too hot!",
      "zh": "太燙了！",
      "ja": "熱すぎる！",
      "time": "00:02:29"
    },
    {
      "role": "teacher",
      "text": "Are you okay?",
      "zh": "你還好嗎？",
      "ja": "大丈夫？",
      "time": "00:02:35"
    },
    {
      "role": "student",
      "text": "Yes, I'm okay.",
      "zh": "是的，我沒事。",
      "ja": "はい、大丈夫です。",
      "time": "00:02:37"
    },
    {
      "role": "teacher",
      "text": "Thank you!",
      "zh": "謝謝你！",
      "ja": "ありがとう！",
      "time": "00:02:39"
    },
    {
      "role": "teacher",
      "text": "Close your eyes, please!",
      "zh": "請閉上眼睛！",
      "ja": "目を閉じてください！",
      "time": "00:02:47"
    },
    {
      "role": "student",
      "text": "Okay!",
      "zh": "好的！",
      "ja": "はい！",
      "time": "00:02:50"
    },
    {
      "role": "teacher",
      "text": "Good morning!",
      "zh": "早安！",
      "ja": "おはようございます！",
      "time": "00:02:52"
    },
    {
      "role": "student",
      "text": "Good morning!",
      "zh": "早安！",
      "ja": "おはようございます！",
      "time": "00:02:54"
    },
    {
      "role": "teacher",
      "text": "Come in, please!",
      "zh": "請進！",
      "ja": "どうぞお入りください！",
      "time": "00:02:56"
    },
    {
      "role": "teacher",
      "text": "Open your eyes, please!",
      "zh": "請睜開眼睛！",
      "ja": "目を開けてください！",
      "time": "00:03:08"
    },
    {
      "role": "student",
      "text": "Oh, he has big ears!",
      "zh": "喔，他有大耳朵！",
      "ja": "ああ、彼は大きな耳をしている！",
      "time": "00:03:12"
    },
    {
      "role": "teacher",
      "text": "Can you help me?",
      "zh": "你能幫我嗎？",
      "ja": "手伝ってくれますか？",
      "time": "00:03:16"
    },
    {
      "role": "student",
      "text": "Sure, I can!",
      "zh": "當然，我可以！",
      "ja": "もちろん、できます！",
      "time": "00:03:20"
    },
    {
      "role": "teacher",
      "text": "How nice!",
      "zh": "真好！",
      "ja": "いいですね！",
      "time": "00:03:30"
    },
    {
      "role": "student",
      "text": "Thank you!",
      "zh": "謝謝！",
      "ja": "ありがとう！",
      "time": "00:03:32"
    },
    {
      "role": "teacher",
      "text": "You're welcome!",
      "zh": "不客氣！",
      "ja": "どういたしまして！",
      "time": "00:03:34"
    },
    {
      "role": "teacher",
      "text": "Put on your hat, please!",
      "zh": "請戴上你的帽子！",
      "ja": "帽子をかぶってください！",
      "time": "00:03:36"
    },
    {
      "role": "student",
      "text": "Great!",
      "zh": "太棒了！",
      "ja": "すごい！",
      "time": "00:03:41"
    },
    {
      "role": "teacher",
      "text": "How are you?",
      "zh": "你好嗎？",
      "ja": "お元気ですか？",
      "time": "00:03:43"
    },
    {
      "role": "student",
      "text": "What are you?",
      "zh": "你是什麼？",
      "ja": "あなたは何ですか？",
      "time": "00:03:51"
    },
    {
      "role": "teacher",
      "text": "Are you okay?",
      "zh": "你還好嗎？",
      "ja": "大丈夫ですか？",
      "time": "00:03:53"
    },
    {
      "role": "student",
      "text": "I'm okay!",
      "zh": "我沒事！",
      "ja": "大丈夫です！",
      "time": "00:03:55"
    },
    {
      "role": "teacher",
      "text": "The king has big ears!",
      "zh": "國王有大耳朵！",
      "ja": "王様は大きな耳をしている！",
      "time": "00:03:59"
    },
    {
      "role": "teacher",
      "text": "The king has big ears!",
      "zh": "國王有大耳朵！",
      "ja": "王様は大きな耳をしている！",
      "time": "00:04:07"
    },
    {
      "role": "teacher",
      "text": "The king has big ears!",
      "zh": "國王有大耳朵！",
      "ja": "王様は大きな耳をしている！",
      "time": "00:04:11"
    },
    {
      "role": "student",
      "text": "Jack, where are you?",
      "zh": "傑克，你在哪裡？",
      "ja": "ジャック、どこにいるの？",
      "time": "00:04:28"
    },
    {
      "role": "student",
      "text": "Look here, Mom.",
      "zh": "看這裡，媽媽。",
      "ja": "ここを見て、ママ。",
      "time": "00:04:30"
    },
    {
      "role": "teacher",
      "text": "Oh, no! Watch out!",
      "zh": "喔，不！小心！",
      "ja": "ああ、危ない！気をつけて！",
      "time": "00:04:32"
    },
    {
      "role": "student",
      "text": "Okay!",
      "zh": "好的！",
      "ja": "わかった！",
      "time": "00:04:34"
    },
    {
      "role": "student",
      "text": "Where's my box?",
      "zh": "我的盒子在哪裡？",
      "ja": "私の箱はどこ？",
      "time": "00:04:36"
    },
    {
      "role": "teacher",
      "text": "It's on the desk.",
      "zh": "它在桌子上。",
      "ja": "机の上にあります。",
      "time": "00:04:50"
    },
    {
      "role": "student",
      "text": "No, it's not on the desk.",
      "zh": "不，它不在桌子上。",
      "ja": "いいえ、机の上にはありません。",
      "time": "00:04:52"
    },
    {
      "role": "teacher",
      "text": "Look, who's that?",
      "zh": "看，那是誰？",
      "ja": "見て、あれは誰？",
      "time": "00:04:56"
    },
    {
      "role": "student",
      "text": "Oh, you have my box!",
      "zh": "喔，你拿著我的盒子！",
      "ja": "ああ、あなたが私の箱を持っている！",
      "time": "00:04:59"
    },
    {
      "role": "teacher",
      "text": "Give it to me!",
      "zh": "把它給我！",
      "ja": "それを私に渡して！",
      "time": "00:05:02"
    },
    {
      "role": "student",
      "text": "Oh, no!",
      "zh": "喔，不！",
      "ja": "ああ、いや！",
      "time": "00:05:04"
    },
    {
      "role": "student",
      "text": "Mom, I'm here!",
      "zh": "媽媽，我在這裡！",
      "ja": "ママ、ここにいるよ！",
      "time": "00:05:08"
    },
    {
      "role": "teacher",
      "text": "Watch out, Jack!",
      "zh": "小心，傑克！",
      "ja": "気をつけて、ジャック！",
      "time": "00:05:10"
    },
    {
      "role": "student",
      "text": "Thank you!",
      "zh": "謝謝！",
      "ja": "ありがとう！",
      "time": "00:05:12"
    }
  ]
}