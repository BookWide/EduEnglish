  "dialogue": [
    {
      "role": "teacher",
      "text": "Good morning, sir.",
      "zh": "早安，先生。",
      "ja": "おはようございます、先生。",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Good morning, everyone.",
      "zh": "大家早安。",
      "ja": "みなさん、おはようございます。",
      "time": "00:00:02"
    },
    {
      "role": "student",
      "text": "How are you sir?",
      "zh": "先生您好嗎？",
      "ja": "先生、お元気ですか？",
      "time": "00:00:04"
    },
    {
      "role": "teacher",
      "text": "Fine, thanks.",
      "zh": "很好，謝謝。",
      "ja": "元気です、ありがとう。",
      "time": "00:00:06"
    },
    {
      "role": "student",
      "text": "How are you?",
      "zh": "你怎麼樣？",
      "ja": "お元気ですか？",
      "time": "00:00:07"
    },
    {
      "role": "teacher",
      "text": "Great.",
      "zh": "很好。",
      "ja": "素晴らしいです。",
      "time": "00:00:08"
    },
    {
      "role": "student",
      "text": "Come and please.",
      "zh": "請過來。",
      "ja": "どうぞこちらへ。",
      "time": "00:00:09"
    },
    {
      "role": "student",
      "text": "Nice to meet you. My name is Kate.",
      "zh": "很高興認識你。我叫Kate。",
      "ja": "はじめまして。私の名前はケイトです。",
      "time": "00:00:11"
    },
    {
      "role": "teacher",
      "text": "Nice to meet you too.",
      "zh": "我也很高興認識你。",
      "ja": "こちらこそ、はじめまして。",
      "time": "00:00:14"
    },
    {
      "role": "teacher",
      "text": "Sit down, please.",
      "zh": "請坐。",
      "ja": "どうぞお座りください。",
      "time": "00:00:16"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとうございます。",
      "time": "00:00:18"
    }
  ]
