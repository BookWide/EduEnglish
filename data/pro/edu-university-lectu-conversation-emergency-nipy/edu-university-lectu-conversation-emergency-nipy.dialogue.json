    },
    {
      "role": "teacher",
      "text": "Where is Chester?",
      "zh": "Chester 在哪裡？",
      "ja": "チェスターはどこですか？",
      "time": "00:01:00"
    },
    {
      "role": "teacher",
      "text": "Chester is on top of the box.",
      "zh": "Chester 在盒子上面。",
      "ja": "チェスターは箱の上にいます。",
      "time": "00:01:02"
    },
    {
      "role": "teacher",
      "text": "He's on top of it.",
      "zh": "他在上面。",
      "ja": "彼はその上にいます。",
      "time": "00:01:04"
    },
    {
      "role": "teacher",
      "text": "The cat is on top of the box.",
      "zh": "貓在盒子上面。",
      "ja": "猫は箱の上にいます。",
      "time": "00:01:06"
    },
    {
      "role": "teacher",
      "text": "Where is Chester?",
      "zh": "Chester 在哪裡？",
      "ja": "チェスターはどこですか？",
      "time": "00:01:10"
    },
    {
      "role": "teacher",
      "text": "Chester is between the boxes.",
      "zh": "Chester 在盒子中間。",
      "ja": "チェスターは箱と箱の間にいます。",
      "time": "00:01:12"
    },
    {
      "role": "teacher",
      "text": "He's between them.",
      "zh": "他在它們中間。",
      "ja": "彼はそれらの間にいます。",
      "time": "00:01:14"
    },
    {
      "role": "teacher",
      "text": "The cat is between the boxes.",
      "zh": "貓在盒子中間。",
      "ja": "猫は箱と箱の間にいます。",
      "time": "00:01:15"
    },
    {
      "role": "teacher",
      "text": "In the box.",
      "zh": "在盒子裡。",
      "ja": "箱の中に。",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "In front of the box.",
      "zh": "在盒子前面。",
      "ja": "箱の前に。",
      "time": "00:01:24"
    },
    {
      "role": "teacher",
      "text": "Next to the box.",
      "zh": "在盒子旁邊。",
      "ja": "箱の隣に。",
      "time": "00:01:28"
    },
    {
      "role": "teacher",
      "text": "Under the box.",
      "zh": "在盒子下面。",
      "ja": "箱の下に。",
      "time": "00:01:32"
    },
    {
      "role": "teacher",
      "text": "On top of the box.",
      "zh": "在盒子上面。",
      "ja": "箱の上に。",
      "time": "00:01:36"
    },
    {
      "role": "teacher",
      "text": "Between the boxes.",
      "zh": "在盒子中間。",
      "ja": "箱と箱の間に。",
      "time": "00:01:39"
    },
    {
      "role": "teacher",
      "text": "Let's see how you'll be getting out of there Chester.",
      "zh": "讓我們看看 Chester 怎麼從那裡出來。",
      "ja": "チェスターがそこからどうやって出るか見てみましょう。",
      "time": "00:01:48"
    },
    {
      "role": "teacher",
      "text": "Go around.",
      "zh": "繞過去。",
      "ja": "回り道をして。",
      "time": "00:01:52"
    },
    {
      "role": "teacher",
      "text": "Do you want to keep on learning?",
      "zh": "你想繼續學習嗎？",
      "ja": "もっと学びたいですか？",
      "time": "00:01:57"
    },
    {
      "role": "teacher",
      "text": "Try for free our smile and learn platform for a month and enjoy all of our games, videos,",
      "zh": "免費試用我們的 Smile and Learn 平台一個月，享受所有遊戲、影片，",
      "ja": "私たちのSmile and Learnプラットフォームを1ヶ月無料で試して、すべてのゲームやビデオを楽しんでください。",
      "time": "00:01:59"
    },
    {
