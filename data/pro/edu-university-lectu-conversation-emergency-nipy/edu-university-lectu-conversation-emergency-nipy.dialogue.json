  "dialogue": [
    {
      "role": "teacher",
      "text": "Hello, friends.",
      "zh": "大家好，朋友們。",
      "ja": "こんにちは、みなさん。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Today we're going to learn words that tell us where things are.",
      "zh": "今天我們要學習表示物品位置的詞彙。",
      "ja": "今日は物の場所を表す言葉を学びます。",
      "time": "00:00:08"
    },
    {
      "role": "teacher",
      "text": "Our friend Chester will help us.",
      "zh": "我們的朋友 Chester 會幫助我們。",
      "ja": "友達のチェスターが手伝ってくれます。",
      "time": "00:00:13"
    },
    {
      "role": "teacher",
      "text": "Where is Chester?",
      "zh": "Chester 在哪裡？",
      "ja": "チェスターはどこですか？",
      "time": "00:00:19"
    },
    {
      "role": "teacher",
      "text": "Chester is in the box.",
      "zh": "Chester 在盒子裡。",
      "ja": "チェスターは箱の中にいます。",
      "time": "00:00:21"
    },
    {
      "role": "teacher",
      "text": "He's in it.",
      "zh": "他在裡面。",
      "ja": "彼はその中にいます。",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "The cat is in the box.",
      "zh": "貓在盒子裡。",
      "ja": "猫は箱の中にいます。",
      "time": "00:00:23"
    },
    {
      "role": "teacher",
      "text": "And now where is Chester?",
      "zh": "那麼現在 Chester 在哪裡？",
      "ja": "では今、チェスターはどこですか？",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "Chester is in front of the box.",
      "zh": "Chester 在盒子前面。",
      "ja": "チェスターは箱の前にいます。",
      "time": "00:00:31"
    },
    {
      "role": "teacher",
      "text": "He's in the front.",
      "zh": "他在前面。",
      "ja": "彼は前にいます。",
      "time": "00:00:33"
    },
    {
      "role": "teacher",
      "text": "The cat is in front of the box.",
      "zh": "貓在盒子前面。",
      "ja": "猫は箱の前にいます。",
      "time": "00:00:35"
    },
    {
      "role": "teacher",
      "text": "Where is Chester?",
