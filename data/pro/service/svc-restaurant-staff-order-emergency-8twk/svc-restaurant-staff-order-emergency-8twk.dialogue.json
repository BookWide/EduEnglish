  "dialogue": [
    {
      "role": "teacher",
      "text": "Good evening.",
      "zh": "晚上好。",
      "ja": "こんばんは。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Welcome to Teddy Restaurant.",
      "zh": "歡迎光臨泰迪餐廳。",
      "ja": "テディレストランへようこそ。",
      "time": "00:00:06"
    },
    {
      "role": "teacher",
      "text": "Here is your menu.",
      "zh": "這是您的菜單。",
      "ja": "こちらがメニューです。",
      "time": "00:00:09"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとうございます。",
      "time": "00:00:11"
    },
    {
      "role": "student",
      "text": "Everything looks delicious.",
      "zh": "看起來每樣都很好吃。",
      "ja": "どれも美味しそうですね。",
      "time": "00:00:12"
    },
    {
      "role": "student",
      "text": "What do you recommend?",
      "zh": "你推薦什麼？",
      "ja": "おすすめは何ですか？",
      "time": "00:00:14"
    },
    {
      "role": "teacher",
      "text": "Our grilled salmon is very popular.",
      "zh": "我們的烤鮭魚非常受歡迎。",
      "ja": "当店のグリルサーモンはとても人気です。",
      "time": "00:00:15"
    },
    {
      "role": "teacher",
      "text": "Would you like to try it?",
      "zh": "您想試試看嗎？",
      "ja": "お試しになりますか？",
      "time": "00:00:18"
    },
    {
      "role": "student",
      "text": "That sounds great.",
      "zh": "聽起來不錯。",
      "ja": "いいですね。",
      "time": "00:00:20"
    },
    {
      "role": "student",
      "text": "I'll have the grilled salmon.",
      "zh": "我要烤鮭魚。",
      "ja": "グリルサーモンをお願いします。",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "Perfect.",
      "zh": "太好了。",
      "ja": "かしこまりました。",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "Would you like a side of salad or mashed potatoes?",
      "zh": "您要搭配沙拉還是馬鈴薯泥？",
      "ja": "サイドにサラダかマッシュポテトはいかがですか？",
      "time": "00:00:25"
    },
    {
      "role": "student",
      "text": "I'll go with the salad, please.",
      "zh": "我要沙拉，謝謝。",
      "ja": "サラダでお願いします。",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "And what would you like to drink?",
      "zh": "您想喝什麼？",
      "ja": "お飲み物はいかがなさいますか？",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "A glass of lemonade, please.",
      "zh": "請給我一杯檸檬水。",
      "ja": "レモネードを一杯お願いします。",
      "time": "00:00:33"
    },
    {
      "role": "teacher",
      "text": "All right.",
      "zh": "好的。",
      "ja": "かしこまりました。",
      "time": "00:00:35"
    },
    {
      "role": "teacher",
      "text": "Your order will be ready shortly.",
      "zh": "您的餐點馬上就好。",
      "ja": "ご注文の品はまもなくご用意いたします。",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "Enjoy your meal.",
      "zh": "祝您用餐愉快。",
      "ja": "どうぞごゆっくりお召し上がりください。",
      "time": "00:00:39"
    },
    {
      "role": "student",
      "text": "Thank you so much.",
      "zh": "非常感謝。",
      "ja": "ありがとうございます。",
      "time": "00:00:41"
    }
  ]
}