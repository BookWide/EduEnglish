    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "teacher",
      "text": "Mommy cakes makeover.",
      "zh": "媽媽蛋糕改造。",
      "ja": "マミーケーキのメイクオーバー。",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Yeah.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:00:03"
    },
    {
      "role": "teacher",
      "text": "You're all sick.",
      "zh": "你們都生病了。",
      "ja": "みんな病気だね。",
      "time": "00:00:06"
    },
    {
      "role": "student",
      "text": "Wow. My sweetie looks great.",
      "zh": "哇，我的寶貝看起來很棒。",
      "ja": "わあ、私のスイーティーは素敵に見える。",
      "time": "00:00:08"
    },
    {
      "role": "teacher",
      "text": "I'm so grateful.",
      "zh": "我非常感激。",
      "ja": "とても感謝しています。",
      "time": "00:00:11"
    },
    {
      "role": "student",
      "text": "Thank you for all your hard work, Master Brad.",
      "zh": "謝謝你所有的辛勤工作，布拉德大師。",
      "ja": "ブラッドマスター、いつもお疲れ様です。",
      "time": "00:00:13"
    },
    {
      "role": "teacher",
      "text": "Ha-ha-ha-ha-ha!",
      "zh": "哈哈哈哈哈！",
      "ja": "ははははは！",
      "time": "00:00:16"
    },
    {
      "role": "student",
      "text": "Hey!",
      "zh": "嘿！",
      "ja": "ねえ！",
      "time": "00:00:18"
    },
    {
      "role": "teacher",
      "text": "I'm back here!",
      "zh": "我在這裡！",
      "ja": "ここに戻ったよ！",
      "time": "00:00:19"
    },
    {
      "role": "student",
      "text": "I'm back here!",
      "zh": "我回來了！",
      "ja": "戻ってきたよ！",
      "time": "00:00:21"
    },
    {
      "role": "teacher",
      "text": "I'm back!",
      "zh": "我回來了！",
      "ja": "戻ったよ！",
      "time": "00:00:23"
    },
    {
      "role": "student",
      "text": "Hey! You put that down right now!",
      "zh": "嘿！你現在就把那個放下！",
      "ja": "ねえ！今すぐそれを置いて！",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "Oops!",
      "zh": "哎呀！",
      "ja": "おっと！",
      "time": "00:00:27"
    },
    {
      "role": "student",
      "text": "Sorry!",
      "zh": "抱歉！",
      "ja": "ごめん！",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "Hey!",
      "zh": "嘿！",
      "ja": "ねえ！",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "You!",
      "zh": "你！",
      "ja": "あなた！",
      "time": "00:00:31"
    },
    {
      "role": "teacher",
      "text": "Master Brad, are you okay?",
      "zh": "布拉德大師，你還好嗎？",
      "ja": "ブラッドマスター、大丈夫？",
      "time": "00:00:32"
    },
    {
      "role": "student",
      "text": "Oh, I'm so sorry.",
      "zh": "哦，真的很抱歉。",
      "ja": "ああ、本当にごめんなさい。",
      "time": "00:00:34"
    },
    {
      "role": "teacher",
      "text": "Look, four kids.",
      "zh": "看，四個孩子。",
      "ja": "見て、子供が四人いる。",
      "time": "00:00:36"
    },
    {
      "role": "student",
      "text": "It's hard.",
      "zh": "這很難。",
      "ja": "大変だよ。",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "Oh, my kids.",
      "zh": "哦，我的孩子們。",
      "ja": "ああ、私の子供たち。",
      "time": "00:00:38"
    },
    {
      "role": "student",
      "text": "It's hard to go.",
      "zh": "很難離開。",
      "ja": "行くのは大変だ。",
      "time": "00:00:39"
    },
    {
      "role": "teacher",
      "text": "Hey!",
      "zh": "嘿！",
      "ja": "ねえ！",
      "time": "00:00:40"
    },
    {
      "role": "student",
      "text": "Hey!",
      "zh": "嘿！",
      "ja": "ねえ！",
      "time": "00:00:41"
    },
    {
      "role": "teacher",
      "text": "Hey!",
      "zh": "嘿！",
      "ja": "ねえ！",
      "time": "00:00:42"
    },
    {
      "role": "student",
      "text": "That's right.",
      "zh": "沒錯。",
      "ja": "その通り。",
      "time": "00:00:43"
    },
    {
      "role": "teacher",
      "text": "I need to pay for you.",
      "zh": "我需要付錢給你。",
      "ja": "あなたに支払わなければ。",
      "time": "00:00:44"
    },
    {
      "role": "student",
      "text": "Uh?",
      "zh": "嗯？",
      "ja": "え？",
      "time": "00:00:47"
    },
    {
      "role": "teacher",
      "text": "But, ma'am, let about your hair.",
      "zh": "但是，女士，關於你的頭髮。",
      "ja": "でも、奥様、あなたの髪について。",
      "time": "00:00:49"
    },
    {
      "role": "student",
      "text": "My hair?",
      "zh": "我的頭髮？",
      "ja": "私の髪？",
      "time": "00:00:53"
    },
    {
      "role": "teacher",
      "text": "Oh, no, thank you.",
      "zh": "哦，不用了，謝謝。",
      "ja": "ああ、いいえ、ありがとう。",
      "time": "00:00:54"
    },
    {
      "role": "student",
      "text": "Before children, I don't really have money to spare.",
      "zh": "生孩子之前，我真的沒有多餘的錢。",
      "ja": "子供ができる前は、余裕のお金はなかった。",
      "time": "00:00:56"
    },
    {
      "role": "teacher",
      "text": "Well, see you again soon.",
      "zh": "那麼，很快再見。",
      "ja": "では、またすぐに会いましょう。",
      "time": "00:00:58"
    },
    {
      "role": "student",
      "text": "Okay, it's time to go.",
      "zh": "好，該走了。",
      "ja": "はい、行く時間です。",
      "time": "00:01:00"
    },
    {
      "role": "teacher",
      "text": "No, ma'am.",
      "zh": "不，女士。",
      "ja": "いいえ、奥様。",
      "time": "00:01:02"
    },
    {
      "role": "student",
      "text": "You won't.",
      "zh": "你不會的。",
      "ja": "あなたはしないでしょう。",
      "time": "00:01:03"
    },
    {
      "role": "teacher",
      "text": "Stop it.",
      "zh": "停止。",
      "ja": "やめて。",
      "time": "00:01:04"
    },
    {
      "role": "student",
      "text": "You started it.",
      "zh": "是你先開始的。",
      "ja": "あなたが始めたんだ。",
      "time": "00:01:05"
    },
    {
      "role": "teacher",
      "text": "Honey, have you seen my cell phone?",
      "zh": "親愛的，你有看到我的手機嗎？",
      "ja": "ハニー、私の携帯電話見た？",
      "time": "00:01:07"
    },
    {
      "role": "student",
      "text": "Here.",
      "zh": "在這裡。",
      "ja": "ここにあるよ。",
      "time": "00:01:10"
    },
    {
      "role": "teacher",
      "text": "Oh, thank you.",
      "zh": "哦，謝謝你。",
      "ja": "ああ、ありがとう。",
      "time": "00:01:11"
    },
    {
      "role": "student",
      "text": "Mom, where's my hair clip?",
      "zh": "媽媽，我的髮夾在哪裡？",
      "ja": "ママ、私のヘアクリップはどこ？",
      "time": "00:01:12"
    },
    {
      "role": "teacher",
      "text": "It's on the table.",
      "zh": "它在桌子上。",
      "ja": "テーブルの上にあるよ。",
      "time": "00:01:15"
    },
    {
      "role": "student",
      "text": "Oh, fair it is.",
      "zh": "哦，公平。",
      "ja": "ああ、公平だね。",
      "time": "00:01:17"
    },
    {
      "role": "teacher",
      "text": "Bad apples are red.",
      "zh": "壞蘋果是紅色的。",
      "ja": "悪いリンゴは赤い。",
      "time": "00:01:18"
    },
    {
      "role": "student",
      "text": "Yeah, and strawberries are red too.",
      "zh": "是的，草莓也是紅色的。",
      "ja": "そうだね、イチゴも赤いよ。",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "Why it?",
      "zh": "為什麼呢？",
      "ja": "なぜ？",
      "time": "00:01:23"
    },
    {
      "role": "student",
      "text": "You'll never be a singer with a voice like that.",
      "zh": "你永遠不會成為那樣嗓音的歌手。",
      "ja": "そんな声じゃ歌手にはなれないよ。",
      "time": "00:01:24"
    },
    {
      "role": "teacher",
      "text": "It's as ugly as you say.",
      "zh": "它和你說的一樣難聽。",
      "ja": "言う通り醜いよ。",
      "time": "00:01:27"
    },
    {
      "role": "student",
      "text": "Mom, what did you say?",
      "zh": "媽媽，你說什麼？",
      "ja": "ママ、何て言ったの？",
      "time": "00:01:29"
    },
    {
      "role": "teacher",
      "text": "What's wrong with you two?",
      "zh": "你們兩個怎麼了？",
      "ja": "二人ともどうしたの？",
      "time": "00:01:31"
    },
    {
      "role": "student",
      "text": "Sorry.",
      "zh": "抱歉。",
      "ja": "ごめんなさい。",
      "time": "00:01:33"
    },
    {
      "role": "teacher",
      "text": "Sorry.",
      "zh": "抱歉。",
      "ja": "ごめんなさい。",
      "time": "00:01:34"
    },
    {
      "role": "student",
      "text": "Stop it!",
      "zh": "停止！",
      "ja": "やめて！",
      "time": "00:01:36"
    },
    {
      "role": "teacher",
      "text": "Ah, wait.",
      "zh": "啊，等等。",
      "ja": "ああ、待って。",
      "time": "00:01:39"
    },
    {
      "role": "student",
      "text": "Let's go, kids.",
      "zh": "走吧，孩子們。",
      "ja": "行こう、子供たち。",
      "time": "00:01:41"
    },
    {
      "role": "teacher",
      "text": "Mama!",
      "zh": "媽媽！",
      "ja": "ママ！",
      "time": "00:01:43"
    },
    {
      "role": "student",
      "text": "Mama!",
      "zh": "媽媽！",
      "ja": "ママ！",
      "time": "00:01:44"
    },
    {
      "role": "teacher",
      "text": "Mama!",
      "zh": "媽媽！",
      "ja": "ママ！",
      "time": "00:01:45"
    },
    {
      "role": "student",
      "text": "Ah.",
      "zh": "啊。",
      "ja": "ああ。",
      "time": "00:01:49"
    },
    {
      "role": "teacher",
      "text": "Ah.",
      "zh": "啊。",
      "ja": "ああ。",
      "time": "00:01:51"
    },
    {
      "role": "student",
      "text": "They always have time to make a mess, but never to clean.",
      "zh": "他們總有時間弄亂，但從不清理。",
      "ja": "彼らはいつも散らかす時間はあるけど、掃除する時間はない。",
      "time": "00:01:56"
    },
    {
      "role": "teacher",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:01:59"
    },
    {
      "role": "student",
      "text": "Oh, my.",
      "zh": "哦，我的天。",
      "ja": "ああ、私の。",
      "time": "00:02:21"
    },
    {
      "role": "teacher",
      "text": "It's my birthday tomorrow.",
      "zh": "明天是我的生日。",
      "ja": "明日は私の誕生日です。",
      "time": "00:02:23"
    },
    {
      "role": "student",
      "text": "Miss Blake.",
      "zh": "布雷克小姐。",
      "ja": "ブレイクさん。",
      "time": "00:02:28"
    },
    {
      "role": "teacher",
      "text": "A little quickly to the meeting room.",
      "zh": "快點去會議室。",
      "ja": "会議室に急いで。",
      "time": "00:02:29"
    },
    {
      "role": "student",
      "text": "What's wrong?",
      "zh": "怎麼了？",
      "ja": "どうしたの？",
      "time": "00:02:31"
    },
    {
      "role": "teacher",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:33"
    },
    {
      "role": "student",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:36"
    },
    {
      "role": "teacher",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:37"
    },
    {
      "role": "student",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:39"
    },
    {
      "role": "teacher",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:41"
    },
    {
      "role": "student",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:43"
    },
    {
      "role": "teacher",
      "text": "Happy birthday to you.",
      "zh": "祝你生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:02:45"
    },
    {
      "role": "student",
      "text": "Happy birthday!",
      "zh": "生日快樂！",
      "ja": "お誕生日おめでとう！",
      "time": "00:02:48"
    },
    {
      "role": "teacher",
      "text": "And to all the birthdays we'll celebrate together.",
      "zh": "以及我們將一起慶祝的所有生日。",
      "ja": "そして、私たちが一緒に祝うすべての誕生日に。",
      "time": "00:02:50"
    },
    {
      "role": "student",
      "text": "Oh, thank you, everyone.",
      "zh": "哦，謝謝大家。",
      "ja": "ああ、みんなありがとう。",
      "time": "00:02:54"
    },
    {
      "role": "teacher",
      "text": "I sure do miss the good old days.",
      "zh": "我真的很懷念過去的美好時光。",
      "ja": "昔の良き日々が恋しい。",
      "time": "00:02:56"
    },
    {
      "role": "student",
      "text": "Huh?",
      "zh": "嗯？",
      "ja": "え？",
      "time": "00:03:00"
    },
    {
      "role": "teacher",
      "text": "Hi, sweetie.",
      "zh": "嗨，親愛的。",
      "ja": "こんにちは、スイーティー。",
      "time": "00:03:01"
    },
    {
      "role": "student",
      "text": "Hi.",
      "zh": "嗨。",
      "ja": "はい。",
      "time": "00:03:03"
    },
    {
      "role": "teacher",
      "text": "Hey, what's that?",
      "zh": "嘿，那是什麼？",
      "ja": "ねえ、それは何？",
      "time": "00:03:04"
    },
    {
      "role": "student",
      "text": "It's not of your business.",
      "zh": "這不關你的事。",
      "ja": "あなたには関係ない。",
      "time": "00:03:06"
    },
    {
      "role": "teacher",
      "text": "Oh, wow.",
      "zh": "哦，哇。",
      "ja": "おお、わあ。",
      "time": "00:03:08"
    },
    {
      "role": "student",
      "text": "She got me a birthday present.",
      "zh": "她給了我一份生日禮物。",
      "ja": "彼女が誕生日プレゼントをくれた。",
      "time": "00:03:09"
    },
    {
      "role": "teacher",
      "text": "So sweet.",
      "zh": "真貼心。",
      "ja": "とても優しい。",
      "time": "00:03:11"
    },
    {
      "role": "student",
      "text": "You guys are home early.",
      "zh": "你們回家得早。",
      "ja": "みんな早く帰ってきたね。",
      "time": "00:03:12"
    },
    {
      "role": "teacher",
      "text": "What's that for?",
      "zh": "那是什麼？",
      "ja": "それは何のため？",
      "time": "00:03:16"
    },
    {
      "role": "student",
      "text": "Yeah, nothing.",
      "zh": "嗯，沒什麼。",
      "ja": "うん、何でもない。",
      "time": "00:03:19"
    },
    {
      "role": "teacher",
      "text": "What a gentleman.",
      "zh": "真是個紳士。",
      "ja": "なんて紳士なんだ。",
      "time": "00:03:21"
    },
    {
      "role": "student",
      "text": "He got me flowers.",
      "zh": "他送我花。",
      "ja": "彼は私に花をくれた。",
      "time": "00:03:23"
    },
    {
      "role": "teacher",
      "text": "Oh, honey.",
      "zh": "哦，親愛的。",
      "ja": "ああ、ハニー。",
      "time": "00:03:25"
    },
    {
      "role": "student",
      "text": "I'm home.",
      "zh": "我回來了。",
      "ja": "ただいま。",
      "time": "00:03:26"
    },
    {
      "role": "teacher",
      "text": "Is that all?",
      "zh": "就這樣嗎？",
      "ja": "それだけ？",
      "time": "00:03:27"
    },
    {
      "role": "student",
      "text": "Guess what this is.",
      "zh": "猜猜這是什麼。",
      "ja": "これが何か当ててみて。",
      "time": "00:03:28"
    },
    {
      "role": "teacher",
      "text": "A birthday gift?",
      "zh": "生日禮物？",
      "ja": "誕生日プレゼント？",
      "time": "00:03:30"
    },
    {
      "role": "student",
      "text": "Bingo!",
      "zh": "賓果！",
      "ja": "ビンゴ！",
      "time": "00:03:32"
    },
    {
      "role": "teacher",
      "text": "You can open it tomorrow.",
      "zh": "你明天可以打開它。",
      "ja": "明日開けていいよ。",
      "time": "00:03:33"
    },
    {
      "role": "student",
      "text": "I'm so glad he remembered.",
      "zh": "我很高興他記得。",
      "ja": "彼が覚えていてくれて嬉しい。",
      "time": "00:03:36"
    },
    {
      "role": "teacher",
      "text": "It must be from my oldest.",
      "zh": "一定是我大兒子送的。",
      "ja": "きっと長男からだね。",
      "time": "00:03:39"
    },
    {
      "role": "student",
      "text": "Let's open it, shall we?",
      "zh": "我們打開看看，好嗎？",
      "ja": "開けてみようか？",
      "time": "00:03:42"
    },
    {
      "role": "teacher",
      "text": "Mom?",
      "zh": "媽媽？",
      "ja": "ママ？",
      "time": "00:03:51"
    },
    {
      "role": "student",
      "text": "Why are you opening my boyfriend's present?",
      "zh": "你為什麼打開我男朋友的禮物？",
      "ja": "なんで彼氏のプレゼントを開けてるの？",
      "time": "00:03:52"
    },
    {
      "role": "teacher",
      "text": "It's for your boyfriend, huh?",
      "zh": "是給你男朋友的，對吧？",
      "ja": "彼氏のためのものだよね？",
      "time": "00:03:55"
    },
    {
      "role": "student",
      "text": "Sorry.",
      "zh": "抱歉。",
      "ja": "ごめん。",
      "time": "00:03:58"
    },
    {
      "role": "teacher",
      "text": "You messed up the ribbon.",
      "zh": "你弄亂了緞帶。",
      "ja": "リボンをぐちゃぐちゃにしたね。",
      "time": "00:03:59"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとう。",
      "time": "00:04:02"
    },
    {
      "role": "teacher",
      "text": "What a mom.",
      "zh": "真是個媽媽。",
      "ja": "なんてママだ。",
      "time": "00:04:05"
    },
    {
      "role": "student",
      "text": "Who are those flowers for?",
      "zh": "那些花是給誰的？",
      "ja": "あの花は誰のため？",
      "time": "00:04:06"
    },
    {
      "role": "teacher",
      "text": "Please, they're for my teacher.",
      "zh": "請，那是給我的老師的。",
      "ja": "お願い、それは私の先生のため。",
      "time": "00:04:08"
    },
    {
      "role": "student",
      "text": "Oh, for your teacher.",
      "zh": "哦，給你的老師。",
      "ja": "ああ、先生のためか。",
      "time": "00:04:10"
    },
    {
      "role": "teacher",
      "text": "Mom, look at this.",
      "zh": "媽媽，看這個。",
      "ja": "ママ、これ見て。",
      "time": "00:04:13"
    },
    {
      "role": "student",
      "text": "It's a giant made of you.",
      "zh": "這是一個你的巨人。",
      "ja": "あなたの巨大なものだ。",
      "time": "00:04:15"
    },
    {
      "role": "teacher",
      "text": "Oh, really?",
      "zh": "哦，真的嗎？",
      "ja": "ああ、本当？",
      "time": "00:04:18"
    },
    {
      "role": "student",
      "text": "Dad works really hard.",
      "zh": "爸爸工作很努力。",
      "ja": "パパは本当に一生懸命働いている。",
      "time": "00:04:21"
    },
    {
      "role": "teacher",
      "text": "Sissy's super pretty.",
      "zh": "姐姐超漂亮。",
      "ja": "お姉ちゃんはすごくきれい。",
      "time": "00:04:23"
    },
    {
      "role": "student",
      "text": "Rose the best at soccer.",
      "zh": "玫瑰是足球最棒的。",
      "ja": "ローズはサッカーが一番上手。",
      "time": "00:04:24"
    },
    {
      "role": "teacher",
      "text": "Other disgusting.",
      "zh": "其他的很噁心。",
      "ja": "他のはひどい。",
      "time": "00:04:26"
    },
    {
      "role": "student",
      "text": "And I'm a great artist.",
      "zh": "而我是個偉大的藝術家。",
      "ja": "そして私は素晴らしいアーティスト。",
      "time": "00:04:27"
    },
    {
      "role": "teacher",
      "text": "And mom does nothing at home.",
      "zh": "而媽媽在家什麼都不做。",
      "ja": "そしてママは家で何もしない。",
      "time": "00:04:29"
    },
    {
      "role": "student",
      "text": "Mom does nothing at home.",
      "zh": "媽媽在家什麼都不做。",
      "ja": "ママは家で何もしない。",
      "time": "00:04:35"
    },
    {
      "role": "teacher",
      "text": "Stop stealing my stuff.",
      "zh": "別偷我的東西。",
      "ja": "私のものを盗むのをやめて。",
      "time": "00:04:37"
    },
    {
      "role": "student",
      "text": "Come back here.",
      "zh": "回來這裡。",
      "ja": "ここに戻ってきて。",
      "time": "00:04:41"
    },
    {
      "role": "teacher",
      "text": "Honey.",
      "zh": "親愛的。",
      "ja": "ハニー。",
      "time": "00:04:43"
    },
    {
      "role": "student",
      "text": "Happy birthday.",
      "zh": "生日快樂。",
      "ja": "お誕生日おめでとう。",
      "time": "00:04:45"
    },
    {
      "role": "teacher",
      "text": "Honey, thank you so much.",
      "zh": "親愛的，非常感謝你。",
      "ja": "ハニー、本当にありがとう。",
      "time": "00:04:47"
    },
    {
      "role": "student",
      "text": "I know that you're going to love it.",
      "zh": "我知道你會喜歡的。",
      "ja": "きっと気に入るよ。",
      "time": "00:04:50"
    },
    {
      "role": "teacher",
      "text": "Open it up.",
      "zh": "打開它吧。",
      "ja": "開けてみて。",
      "time": "00:04:52"
    },
    {
      "role": "student",
      "text": "What got rubber gloves?",
      "zh": "什麼？橡膠手套？",
      "ja": "ゴム手袋？",
      "time": "00:04:55"
    },
    {
      "role": "teacher",
      "text": "Remember, I made that promise that I would make your life as easy as possible.",
      "zh": "記得，我答應過會讓你的生活盡可能輕鬆。",
      "ja": "覚えてる？君の生活をできるだけ楽にすると約束したよね。",
      "time": "00:04:58"
    },
    {
      "role": "student",
      "text": "Am I your maid?",
      "zh": "我是你的女傭嗎？",
      "ja": "私はあなたのメイド？",
      "time": "00:05:05"
    },
    {
      "role": "teacher",
      "text": "You can shape your gloves.",
      "zh": "你可以塑形你的手套。",
      "ja": "手袋を形作れるよ。",
      "time": "00:05:06"
    },
    {
      "role": "student",
      "text": "Honey, what's wrong?",
      "zh": "親愛的，怎麼了？",
      "ja": "ハニー、どうしたの？",
      "time": "00:05:08"
    },
    {
      "role": "teacher",
      "text": "Don't you like the color?",
      "zh": "你不喜歡這顏色嗎？",
      "ja": "色が気に入らないの？",
      "time": "00:05:10"
    },
    {
      "role": "student",
      "text": "This has nothing to do with the color.",
      "zh": "這和顏色無關。",
      "ja": "色とは関係ないよ。",
      "time": "00:05:12"
    },
    {
      "role": "teacher",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:05:17"
    },
    {
      "role": "student",
      "text": "I need such a selfish and considerate family.",
      "zh": "我需要這樣一個自私又體貼的家庭。",
      "ja": "こんなわがままで思いやりのある家族が必要だ。",
      "time": "00:05:19"
    },
    {
      "role": "teacher",
      "text": "Mm?",
      "zh": "嗯？",
      "ja": "ん？",
      "time": "00:05:27"
    },
    {
      "role": "student",
      "text": "Wasn't she in the barber shop the other day?",
      "zh": "她不是前幾天在理髮店嗎？",
      "ja": "彼女はこの前理髪店にいなかった？",
      "time": "00:05:28"
    },
    {
      "role": "teacher",
      "text": "Hi there.",
      "zh": "你好。",
      "ja": "こんにちは。",
      "time": "00:05:31"
    },
    {
      "role": "student",
      "text": "Hi Miss Choco.",
      "zh": "嗨，巧克力小姐。",
      "ja": "こんにちは、チョコさん。",
      "time": "00:05:34"
    },
    {
      "role": "teacher",
      "text": "You came to the barber shop the other day, right?",
      "zh": "你前幾天來過理髮店，對吧？",
      "ja": "この前理髪店に来たよね？",
      "time": "00:05:35"
    },
    {
      "role": "student",
      "text": "Is everything okay?",
      "zh": "一切都好嗎？",
      "ja": "大丈夫？",
      "time": "00:05:38"
    },
    {
      "role": "teacher",
      "text": "Oh, it's, uh, I wish I could help you.",
      "zh": "哦，是的，我希望我能幫你。",
      "ja": "ああ、それは、うん、助けられたらいいんだけど。",
      "time": "00:05:40"
    },
    {
      "role": "student",
      "text": "How I do a sacrifice for my family.",
      "zh": "我為家人做了犧牲。",
      "ja": "家族のために犠牲を払ったんだ。",
      "time": "00:05:47"
    },
    {
      "role": "teacher",
      "text": "Hi.",
      "zh": "嗨。",
      "ja": "こんにちは。",
      "time": "00:05:51"
    },
    {
      "role": "student",
      "text": "Is it that late already?",
      "zh": "已經那麼晚了嗎？",
      "ja": "もうそんなに遅いの？",
      "time": "00:05:52"
    },
    {
      "role": "teacher",
      "text": "I have to go cook dinner now.",
      "zh": "我現在得去做晚餐了。",
      "ja": "今から夕食を作らなきゃ。",
      "time": "00:05:54"
    },
    {
      "role": "student",
      "text": "Sorry, I bothered you.",
      "zh": "抱歉，打擾你了。",
      "ja": "ごめん、邪魔して。",
      "time": "00:05:56"
    },
    {
      "role": "teacher",
      "text": "Come with me.",
      "zh": "跟我來。",
      "ja": "私についてきて。",
      "time": "00:05:59"
    },
    {
      "role": "student",
      "text": "I've got something for you.",
      "zh": "我有東西給你。",
      "ja": "君に渡したいものがある。",
      "time": "00:06:00"
    }
  ]
}