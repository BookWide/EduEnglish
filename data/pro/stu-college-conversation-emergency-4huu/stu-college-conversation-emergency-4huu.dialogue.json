{
  "meta": {
    "slug": "stu-college-conversation-emergency-4huu",
    "category": "pro/student/college",
    "source_url": "https://www.youtube.com/watch?v=4HUuqXA_yz0",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "Hi, Mr. Danny.",
      "zh": "嗨，丹尼先生。",
      "ja": "こんにちは、ダニーさん。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Hi, Florence.",
      "zh": "嗨，佛羅倫斯。",
      "ja": "こんにちは、フローレンス。",
      "time": "00:00:13"
    },
    {
      "role": "teacher",
      "text": "Do you go to college?",
      "zh": "你上大學嗎？",
      "ja": "大学に通っていますか？",
      "time": "00:00:14"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:00:18"
    },
    {
      "role": "student",
      "text": "I do.",
      "zh": "我有。",
      "ja": "そうです。",
      "time": "00:00:19"
    },
    {
      "role": "teacher",
      "text": "What college do you go to?",
      "zh": "你上哪所大學？",
      "ja": "どの大学に通っていますか？",
      "time": "00:00:21"
    },
    {
      "role": "student",
      "text": "I go to Pasadena City College.",
      "zh": "我上帕薩迪納市立學院。",
      "ja": "パサデナシティカレッジに通っています。",
      "time": "00:00:25"
    },
    {
      "role": "teacher",
      "text": "Do you like it?",
      "zh": "你喜歡它嗎？",
      "ja": "気に入っていますか？",
      "time": "00:00:29"
    },
    {
      "role": "student",
      "text": "Oh, yes.",
      "zh": "哦，是的。",
      "ja": "ああ、はい。",
      "time": "00:00:32"
    },
    {
      "role": "student",
      "text": "I really like it.",
      "zh": "我真的很喜歡它。",
      "ja": "本当に気に入っています。",
      "time": "00:00:33"
    },
    {
      "role": "teacher",
      "text": "Why do you like it?",
      "zh": "你為什麼喜歡它？",
      "ja": "なぜそれが好きですか？",
      "time": "00:00:37"
    },
    {
      "role": "student",
      "text": "Because it has great teachers.",
      "zh": "因為那裡有很棒的老師。",
      "ja": "素晴らしい先生がいるからです。",
      "time": "00:00:40"
    },
    {
      "role": "teacher",
      "text": "What else?",
      "zh": "還有什麼？",
      "ja": "他には？",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "I like all my classmates, too.",
      "zh": "我也喜歡我的所有同學。",
      "ja": "クラスメートもみんな好きです。",
      "time": "00:00:46"
    },
    {
      "role": "teacher",
      "text": "Anything else?",
      "zh": "還有別的嗎？",
      "ja": "他に何かありますか？",
      "time": "00:00:51"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:00:54"
    },
    {
      "role": "student",
      "text": "It's not expensive.",
      "zh": "它不貴。",
      "ja": "高くないです。",
      "time": "00:00:55"
    },
    {
      "role": "teacher",
      "text": "Oh, OK.",
      "zh": "哦，好的。",
      "ja": "ああ、わかりました。",
      "time": "00:00:58"
    },
    {
      "role": "teacher",
      "text": "I wish you the best good luck for your study.",
      "zh": "祝你學業順利。",
      "ja": "勉強がうまくいくことを祈っています。",
      "time": "00:01:00"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとうございます。",
      "time": "00:01:04"
    },
    {
      "role": "student",
      "text": "Goodbye, Mr. Danny.",
      "zh": "再見，丹尼先生。",
      "ja": "さようなら、ダニーさん。",
      "time": "00:01:05"
    },
    {
      "role": "teacher",
      "text": "Goodbye.",
      "zh": "再見。",
      "ja": "さようなら。",
      "time": "00:01:07"
    },
    {
      "role": "teacher",
      "text": "Hi, Florence.",
      "zh": "嗨，佛羅倫斯。",
      "ja": "こんにちは、フローレンス。",
      "time": "00:01:08"
    },
    {
      "role": "student",
      "text": "Hi, Richard.",
      "zh": "嗨，理查德。",
      "ja": "こんにちは、リチャード。",
      "time": "00:01:24"
    },
    {
      "role": "student",
      "text": "Did you know the gravity is very important.",
      "zh": "你知道重力很重要嗎？",
      "ja": "重力がとても重要だって知ってた？",
      "time": "00:01:28"
    },
    {
      "role": "teacher",
      "text": "What is gravity?",
      "zh": "什麼是重力？",
      "ja": "重力とは何ですか？",
      "time": "00:01:35"
    },
    {
      "role": "student",
      "text": "It's the force that pulls everything down.",
      "zh": "它是把一切往下拉的力量。",
      "ja": "それはすべてを下に引っ張る力です。",
      "time": "00:01:38"
    },
    {
      "role": "teacher",
      "text": "I don't understand.",
      "zh": "我不懂。",
      "ja": "わかりません。",
      "time": "00:01:42"
    },
    {
      "role": "student",
      "text": "If you pour water into a glass, the water goes down into the glass.",
      "zh": "如果你把水倒進杯子，水會流進杯子裡。",
      "ja": "もし水をグラスに注ぐと、水はグラスの中に下がります。",
      "time": "00:01:45"
    },
    {
      "role": "teacher",
      "text": "Of course it does.",
      "zh": "當然會。",
      "ja": "もちろんそうです。",
      "time": "00:01:51"
    },
    {
      "role": "student",
      "text": "Without gravity, the water would go up.",
      "zh": "沒有重力，水會往上流。",
      "ja": "重力がなければ、水は上に行ってしまいます。",
      "time": "00:01:54"
    },
    {
      "role": "teacher",
      "text": "Ha, ha, ha.",
      "zh": "哈哈哈。",
      "ja": "ははは。",
      "time": "00:01:58"
    },
    {
      "role": "teacher",
      "text": "You're joking.",
      "zh": "你在開玩笑。",
      "ja": "冗談でしょう。",
      "time": "00:02:00"
    },
    {
      "role": "student",
      "text": "Without gravity, you would go up.",
      "zh": "沒有重力，你會往上飄。",
      "ja": "重力がなければ、あなたは上に浮かびます。",
      "time": "00:02:04"
    },
    {
      "role": "teacher",
      "text": "What do you mean?",
      "zh": "你是什麼意思？",
      "ja": "どういう意味ですか？",
      "time": "00:02:09"
    },
    {
      "role": "student",
      "text": "You would float into the sky like a balloon.",
      "zh": "你會像氣球一樣飄到天空。",
      "ja": "風船のように空に浮かびます。",
      "time": "00:02:11"
    },
    {
      "role": "teacher",
      "text": "That would be fun.",
      "zh": "那會很有趣。",
      "ja": "それは楽しいでしょうね。",
      "time": "00:02:16"
    },
    {
      "role": "student",
      "text": "Thank you for explaining me.",
      "zh": "謝謝你解釋給我聽。",
      "ja": "説明してくれてありがとう。",
      "time": "00:02:18"
    },
    {
      "role": "teacher",
      "text": "That's fine.",
      "zh": "沒關係。",
      "ja": "どういたしまして。",
      "time": "00:02:20"
    },
    {
      "role": "student",
      "text": "This is a huge library.",
      "zh": "這是一個很大的圖書館。",
      "ja": "これは大きな図書館です。",
      "time": "00:02:34"
    },
    {
      "role": "teacher",
      "text": "Yes, it has lots of rooms and lots of space.",
      "zh": "是的，它有很多房間和很多空間。",
      "ja": "はい、部屋もスペースもたくさんあります。",
      "time": "00:02:38"
    },
    {
      "role": "teacher",
      "text": "And lots of books.",
      "zh": "還有很多書。",
      "ja": "そしてたくさんの本もあります。",
      "time": "00:02:41"
    },
    {
      "role": "student",
      "text": "And lots of thieves.",
      "zh": "還有很多小偷。",
      "ja": "それにたくさんの泥棒もいます。",
      "time": "00:02:45"
    },
    {
      "role": "teacher",
      "text": "What do you mean?",
      "zh": "你是什麼意思？",
      "ja": "どういう意味ですか？",
      "time": "00:02:49"
    },
    {
      "role": "student",
      "text": "I mean, keep your belongings close to you.",
      "zh": "我的意思是，要把你的東西放在身邊。",
      "ja": "つまり、持ち物は身近に置いておきなさいということです。",
      "time": "00:02:52"
    },
    {
      "role": "teacher",
      "text": "The only thing in my backpack is used books.",
      "zh": "我背包裡唯一的東西是二手書。",
      "ja": "私のリュックの中には中古の本しか入っていません。",
      "time": "00:02:57"
    },
    {
      "role": "student",
      "text": "But thieves don't know that.",
      "zh": "但小偷不知道那點。",
      "ja": "でも泥棒はそれを知りません。",
      "time": "00:03:03"
    },
    {
      "role": "teacher",
      "text": "They might think that.",
      "zh": "他們可能會這麼想。",
      "ja": "そう思うかもしれません。",
      "time": "00:03:06"
    },
    {
      "role": "student",
      "text": "I've got an iPod or laptop in there.",
      "zh": "他們可能以為我背包裡有iPod或筆電。",
      "ja": "そこにiPodやノートパソコンが入っていると思うかもしれません。",
      "time": "00:03:07"
    },
    {
      "role": "teacher",
      "text": "Now you're thinking.",
      "zh": "現在你開始想了。",
      "ja": "今、考えていますね。",
      "time": "00:03:13"
    },
    {
      "role": "student",
      "text": "You'd think a library would be safe from thieves.",
      "zh": "你會以為圖書館是安全不會被偷的。",
      "ja": "図書館は泥棒から安全だと思うでしょう。",
      "time": "00:03:17"
    },
    {
      "role": "teacher",
      "text": "Not even a church is safe from thieves.",
      "zh": "連教堂也不安全，會被偷。",
      "ja": "教会でさえ泥棒から安全ではありません。",
      "time": "00:03:22"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとう。",
      "time": "00:03:25"
    },
    {
      "role": "teacher",
      "text": "Goodbye.",
      "zh": "再見。",
      "ja": "さようなら。",
      "time": "00:03:26"
    },
    {
      "role": "student",
      "text": "OK, good luck.",
      "zh": "好的，祝你好運。",
      "ja": "はい、頑張って。",
      "time": "00:03:27"
    },
    {
      "role": "student",
      "text": "Oh, I lost my pen.",
      "zh": "哦，我丟了筆。",
      "ja": "ああ、ペンをなくしました。",
      "time": "00:03:32"
    },
    {
      "role": "teacher",
      "text": "Where did you lose it?",
      "zh": "你在哪裡丟的？",
      "ja": "どこでなくしましたか？",
      "time": "00:03:49"
    },
    {
      "role": "student",
      "text": "I think I lost it today.",
      "zh": "我想我今天丟的。",
      "ja": "今日なくしたと思います。",
      "time": "00:03:53"
    },
    {
      "role": "student",
      "text": "I used it yesterday.",
      "zh": "我昨天還用過。",
      "ja": "昨日使いました。",
      "time": "00:03:55"
    },
    {
      "role": "teacher",
      "text": "Did you check all your desk?",
      "zh": "你檢查過你的桌子嗎？",
      "ja": "机の上を全部探しましたか？",
      "time": "00:03:58"
    },
    {
      "role": "student",
      "text": "Yes, it isn't there, either.",
      "zh": "是的，也不在那裡。",
      "ja": "はい、そこにもありません。",
      "time": "00:04:02"
    },
    {
      "role": "teacher",
      "text": "Did you check all your pockets?",
      "zh": "你檢查過所有口袋嗎？",
      "ja": "ポケットも全部探しましたか？",
      "time": "00:04:07"
    },
    {
      "role": "student",
      "text": "I checked all my pockets.",
      "zh": "我檢查過所有口袋。",
      "ja": "ポケットは全部調べました。",
      "time": "00:04:12"
    },
    {
      "role": "student",
      "text": "It's probably around somewhere.",
      "zh": "它可能在某個地方。",
      "ja": "どこかにあるはずです。",
      "time": "00:04:16"
    },
    {
      "role": "student",
      "text": "Oh, well, it only cost me a dollar.",
      "zh": "哦，好吧，它只花我一美元。",
      "ja": "まあ、1ドルしかかかりませんでした。",
      "time": "00:04:19"
    },
    {
      "role": "teacher",
      "text": "Only a dollar.",
      "zh": "只有一美元。",
      "ja": "たった1ドルですか。",
      "time": "00:04:23"
    },
    {
      "role": "teacher",
      "text": "Don't even look for it.",
      "zh": "甚至不用找了。",
      "ja": "探さなくてもいいですよ。",
      "time": "00:04:24"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとうございます。",
      "time": "00:04:27"
    },
    {
      "role": "teacher",
      "text": "Joyce, do you believe in God?",
      "zh": "喬伊斯，你相信上帝嗎？",
      "ja": "ジョイス、神を信じていますか？",
      "time": "00:04:47"
    },
    {
      "role": "student",
      "text": "Of course.",
      "zh": "當然。",
      "ja": "もちろんです。",
      "time": "00:04:51"
    },
    {
      "role": "teacher",
      "text": "Do you pray to God?",
      "zh": "你會向上帝祈禱嗎？",
      "ja": "神に祈りますか？",
      "time": "00:04:54"
    },
    {
      "role": "student",
      "text": "Occasionally.",
      "zh": "偶爾。",
      "ja": "時々します。",
      "time": "00:04:57"
    },
    {
      "role": "teacher",
      "text": "When's that?",
      "zh": "什麼時候？",
      "ja": "いつですか？",
      "time": "00:05:00"
    },
    {
      "role": "student",
      "text": "When I need something.",
      "zh": "當我需要什麼時候。",
      "ja": "何かが必要な時です。",
      "time": "00:05:03"
    },
    {
      "role": "teacher",
      "text": "Like what?",
      "zh": "像什麼？",
      "ja": "例えば何ですか？",
      "time": "00:05:06"
    },
    {
      "role": "student",
      "text": "Well, if I have a big tested school.",
      "zh": "嗯，如果我有一個重要的考試。",
      "ja": "大きなテストがある時です。",
      "time": "00:05:09"
    },
    {
      "role": "teacher",
      "text": "Does God answer your prayers?",
      "zh": "上帝會回答你的祈禱嗎？",
      "ja": "神はあなたの祈りに答えますか？",
      "time": "00:05:14"
    },
    {
      "role": "student",
      "text": "Yes, I've passed all my tests.",
      "zh": "是的，我通過了所有考試。",
      "ja": "はい、すべてのテストに合格しました。",
      "time": "00:05:16"
    },
    {
      "role": "teacher",
      "text": "Do you ever pray for money?",
      "zh": "你曾經為錢祈禱過嗎？",
      "ja": "お金のために祈ったことはありますか？",
      "time": "00:05:22"
    },
    {
      "role": "student",
      "text": "Not yet.",
      "zh": "還沒有。",
      "ja": "まだありません。",
      "time": "00:05:25"
    },
    {
      "role": "student",
      "text": "I won't need to do that until I graduate from high school.",
      "zh": "我不需要直到我高中畢業才會這麼做。",
      "ja": "高校を卒業するまでは必要ありません。",
      "time": "00:05:27"
    },
    {
      "role": "teacher",
      "text": "Well done.",
      "zh": "做得好。",
      "ja": "よくやった。",
      "time": "00:05:31"
    },
    {
      "role": "student",
      "text": "Goodbye, Richard.",
      "zh": "再見，理查德。",
      "ja": "さようなら、リチャード。",
      "time": "00:05:34"
    },
    {
      "role": "teacher",
      "text": "See you again later.",
      "zh": "待會兒見。",
      "ja": "また後で会いましょう。",
      "time": "00:05:35"
    },
    {
      "role": "student",
      "text": "Well, bye.",
      "zh": "那麼，再見。",
      "ja": "では、さようなら。",
      "time": "00:05:38"
    },
    {
      "role": "teacher",
      "text": "See you, too.",
      "zh": "我也會再見你的。",
      "ja": "私もまた会いましょう。",
      "time": "00:05:39"
    },
    {
      "role": "student",
      "text": "Hey, Sally.",
      "zh": "嗨，莎莉。",
      "ja": "ねえ、サリー。",
      "time": "00:05:56"
    },
    {
      "role": "student",
      "text": "Do you want to be my partner for class project?",
      "zh": "你想成為我課堂專案的夥伴嗎？",
      "ja": "クラスのプロジェクトのパートナーになりたい？",
      "time": "00:05:58"
    },
    {
      "role": "student",
      "text": "Sure, Lisa.",
      "zh": "當然，麗莎。",
      "ja": "もちろん、リサ。",
      "time": "00:06:02"
    },
    {
      "role": "student",
      "text": "I'm glad you asked me.",
      "zh": "我很高興你問我。",
      "ja": "聞いてくれてうれしいです。",
      "time": "00:06:04"
    },
    {
      "role": "student",
      "text": "I don't have a partner.",
      "zh": "我沒有夥伴。",
      "ja": "パートナーがいません。",
      "time": "00:06:06"
    },
    {
      "role": "student",
      "text": "So, can I sit here?",
      "zh": "那我可以坐這裡嗎？",
      "ja": "ここに座ってもいい？",
      "time": "00:06:09"
    },
    {
      "role": "student",
      "text": "Yes, sure.",
      "zh": "是的，當然。",
      "ja": "はい、もちろんです。",
      "time": "00:06:13"
    },
    {
      "role": "student",
      "text": "Do you want to meet after school and work on it together?",
      "zh": "你想放學後見面一起做嗎？",
      "ja": "放課後に会って一緒にやりたい？",
      "time": "00:06:18"
    },
    {
      "role": "student",
      "text": "I can today.",
      "zh": "我今天可以。",
      "ja": "今日は大丈夫です。",
      "time": "00:06:23"
    },
    {
      "role": "student",
      "text": "It's my grandmother's 80th birthday and we taking her out to dinner.",
      "zh": "今天是我奶奶80歲生日，我們要帶她出去吃飯。",
      "ja": "今日は祖母の80歳の誕生日で、外食に連れて行きます。",
      "time": "00:06:25"
    },
    {
      "role": "student",
      "text": "How about tomorrow?",
      "zh": "明天怎麼樣？",
      "ja": "明日はどう？",
      "time": "00:06:29"
    },
    {
      "role": "student",
      "text": "I can't tomorrow.",
      "zh": "我明天不行。",
      "ja": "明日は無理です。",
      "time": "00:06:32"
    },
    {
      "role": "student",
      "text": "I have soccer practice after school.",
      "zh": "我放學後有足球練習。",
      "ja": "放課後にサッカーの練習があります。",
      "time": "00:06:34"
    },
    {
      "role": "student",
      "text": "I can meet on Thursday.",
      "zh": "我星期四可以見面。",
      "ja": "木曜日なら会えます。",
      "time": "00:06:36"
    },
    {
      "role": "student",
      "text": "I can meet on Thursday, too.",
      "zh": "我星期四也可以見面。",
      "ja": "私も木曜日に会えます。",
      "time": "00:06:40"
    },
    {
      "role": "student",
      "text": "Do you want to come to my house?",
      "zh": "你想來我家嗎？",
      "ja": "私の家に来たい？",
      "time": "00:06:42"
    },
    {
      "role": "student",
      "text": "Sure, I'll ask my mom tonight.",
      "zh": "當然，我今晚會問我媽媽。",
      "ja": "いいですよ、今夜母に聞いてみます。",
      "time": "00:06:46"
    },
    {
      "role": "student",
      "text": "OK, we can walk together.",
      "zh": "好的，我們可以一起走路。",
      "ja": "わかりました、一緒に歩きましょう。",
      "time": "00:06:50"
    },
    {
      "role": "student",
      "text": "My house is very close to school.",
      "zh": "我家離學校很近。",
      "ja": "私の家は学校のすぐ近くです。",
      "time": "00:06:52"
    },
    {
      "role": "student",
      "text": "Should we start the project before Thursday?",
      "zh": "我們應該在星期四之前開始專案嗎？",
      "ja": "木曜日の前にプロジェクトを始めるべきですか？",
      "time": "00:06:56"
    },
    {
      "role": "student",
      "text": "That sounds like a good plan.",
      "zh": "聽起來是個好計畫。",
      "ja": "いい計画ですね。",
      "time": "00:07:01"
    },
    {
      "role": "student",
      "text": "I can work on the written portion.",
      "zh": "我可以負責寫作部分。",
      "ja": "私は文章の部分を担当します。",
      "time": "00:07:04"
    },
    {
      "role": "student",
      "text": "Do you want to do the pictures?",
      "zh": "你想負責畫圖嗎？",
      "ja": "絵を描くのはどう？",
      "time": "00:07:07"
    },
    {
      "role": "student",
      "text": "Yeah, I'm pretty good at drawing.",
      "zh": "是的，我畫畫還不錯。",
      "ja": "はい、絵を描くのは得意です。",
      "time": "00:07:10"
    },
    {
      "role": "student",
      "text": "I know.",
      "zh": "我知道。",
      "ja": "知っています。",
      "time": "00:07:15"
    },
    {
      "role": "student",
      "text": "I have seen you're drawing before.",
      "zh": "我以前看過你的畫。",
      "ja": "あなたの絵を見たことがあります。",
      "time": "00:07:16"
    },
    {
      "role": "student",
      "text": "You are very talented.",
      "zh": "你很有天賦。",
      "ja": "とても才能がありますね。",
      "time": "00:07:18"
    },
    {
      "role": "student",
      "text": "Thanks.",
      "zh": "謝謝。",
      "ja": "ありがとう。",
      "time": "00:07:22"
    },
    {
      "role": "student",
      "text": "My parents are artists.",
      "zh": "我父母是藝術家。",
      "ja": "私の両親はアーティストです。",
      "time": "00:07:23"
    },
    {
      "role": "student",
      "text": "They taught me how to draw it in an early age.",
      "zh": "他們從小教我怎麼畫畫。",
      "ja": "幼い頃から絵の描き方を教えてくれました。",
      "time": "00:07:25"
    },
    {
      "role": "student",
      "text": "That's nice.",
      "zh": "那很好。",
      "ja": "それはいいですね。",
      "time": "00:07:30"
    },
    {
      "role": "student",
      "text": "I wish I knew how to draw well.",
      "zh": "我希望我會畫畫。",
      "ja": "私も上手に絵が描けたらいいのに。",
      "time": "00:07:31"
    },
    {
      "role": "student",
      "text": "I can teach you.",
      "zh": "我可以教你。",
      "ja": "教えてあげますよ。",
      "time": "00:07:35"
    },
    {
      "role": "student",
      "text": "OK.",
      "zh": "好。",
      "ja": "はい。",
      "time": "00:07:36"
    },
    {
      "role": "student",
      "text": "But we better finish the project first.",
      "zh": "但我們最好先完成專案。",
      "ja": "でもまずはプロジェクトを終わらせたほうがいいですね。",
      "time": "00:07:37"
    },
    {
      "role": "student",
      "text": "You're right.",
      "zh": "你說得對。",
      "ja": "その通りです。",
      "time": "00:07:40"
    },
    {
      "role": "student",
      "text": "This is going to be fun.",
      "zh": "這會很有趣。",
      "ja": "楽しくなりそうです。",
      "time": "00:07:41"
    },
    {
      "role": "student",
      "text": "We make a good team.",
      "zh": "我們是好搭檔。",
      "ja": "私たちはいいチームです。",
      "time": "00:07:43"
    },
    {
      "role": "student",
      "text": "Dad, can you help me with my school project?",
      "zh": "爸爸，你能幫我做學校專案嗎？",
      "ja": "お父さん、学校のプロジェクトを手伝ってくれますか？",
      "time": "00:07:52"
    },
    {
      "role": "teacher",
      "text": "Sure, Kevin, what is your assignment?",
      "zh": "當然，凱文，你的作業是什麼？",
      "ja": "もちろん、ケビン、課題は何ですか？",
      "time": "00:08:07"
    },
    {
      "role": "student",
      "text": "We have to construct a building using any materials around the house.",
      "zh": "我們必須用家裡的材料建造一棟建築。",
      "ja": "家の周りの材料を使って建物を作らなければなりません。",
      "time": "00:08:12"
    },
    {
      "role": "teacher",
      "text": "What were you thinking about building?",
      "zh": "你想建造什麼？",
      "ja": "何を作ろうと思っていますか？",
      "time": "00:08:17"
    },
    {
      "role": "student",
      "text": "I want to build a skyscraper.",
      "zh": "我想建造一座摩天大樓。",
      "ja": "超高層ビルを作りたいです。",
      "time": "00:08:21"
    },
    {
      "role": "teacher",
      "text": "That should be fun.",
      "zh": "那應該很有趣。",
      "ja": "それは楽しいでしょう。",
      "time": "00:08:25"
    },
    {
      "role": "teacher",
      "text": "Any ideas about the materials?",
      "zh": "有什麼材料的想法嗎？",
      "ja": "材料について何か考えていますか？",
      "time": "00:08:26"
    },
    {
      "role": "student",
      "text": "I'm not sure.",
      "zh": "我不確定。",
      "ja": "よくわかりません。",
      "time": "00:08:31"
    },
    {
      "role": "student",
      "text": "I was thinking about using cardboard boxes.",
      "zh": "我在想用紙箱。",
      "ja": "段ボール箱を使おうと思っています。",
      "time": "00:08:32"
    },
    {
      "role": "teacher",
      "text": "That's a great idea.",
      "zh": "那是個好主意。",
      "ja": "それはいいアイデアです。",
      "time": "00:08:37"
    },
    {
      "role": "teacher",
      "text": "We have a lot of old boxes.",
      "zh": "我們有很多舊箱子。",
      "ja": "古い箱がたくさんあります。",
      "time": "00:08:38"
    },
    {
      "role": "teacher",
      "text": "I saved them after we moved here.",
      "zh": "搬來這裡後我都留著它們。",
      "ja": "ここに引っ越してきてから取ってあります。",
      "time": "00:08:40"
    },
    {
      "role": "student",
      "text": "Where are they?",
      "zh": "它們在哪裡？",
      "ja": "どこにありますか？",
      "time": "00:08:44"
    },
    {
      "role": "teacher",
      "text": "They're in the garage.",
      "zh": "它們在車庫裡。",
      "ja": "ガレージにあります。",
      "time": "00:08:48"
    },
    {
      "role": "teacher",
      "text": "Help me bring them into the house.",
      "zh": "幫我把它們搬進屋裡。",
      "ja": "家の中に運ぶのを手伝って。",
      "time": "00:08:50"
    },
    {
      "role": "student",
      "text": "OK.",
      "zh": "好的。",
      "ja": "わかりました。",
      "time": "00:08:54"
    },
    {
      "role": "teacher",
      "text": "What should we put them?",
      "zh": "我們應該把它們放在哪裡？",
      "ja": "どこに置きましょうか？",
      "time": "00:08:55"
    },
    {
      "role": "student",
      "text": "Let's put them in the living room.",
      "zh": "我們把它們放在客廳吧。",
      "ja": "リビングに置きましょう。",
      "time": "00:08:58"
    },
    {
      "role": "teacher",
      "text": "It's the biggest room in the house.",
      "zh": "那是家裡最大的房間。",
      "ja": "家で一番大きな部屋です。",
      "time": "00:09:01"
    },
    {
      "role": "teacher",
      "text": "There's plenty of space to make a mess.",
      "zh": "有足夠的空間可以弄亂。",
      "ja": "散らかしても十分なスペースがあります。",
      "time": "00:09:04"
    },
    {
      "role": "student",
      "text": "But mom isn't going to be happy with all the mess.",
      "zh": "但媽媽不會喜歡這麼亂。",
      "ja": "でもお母さんは散らかるのを喜ばないでしょう。",
      "time": "00:09:08"
    },
    {
      "role": "teacher",
      "text": "That's OK.",
      "zh": "沒關係。",
      "ja": "大丈夫です。",
      "time": "00:09:12"
    },
    {
      "role": "teacher",
      "text": "She can help us too.",
      "zh": "她也可以幫我們。",
      "ja": "彼女も手伝ってくれます。",
      "time": "00:09:13"
    },
    {
      "role": "student",
      "text": "That's a good plan.",
      "zh": "那是個好計畫。",
      "ja": "いい計画ですね。",
      "time": "00:09:16"
    },
    {
      "role": "student",
      "text": "Thank for your help, Dad.",
      "zh": "謝謝你的幫忙，爸爸。",
      "ja": "手伝ってくれてありがとう、お父さん。",
      "time": "00:09:19"
    },
    {
      "role": "teacher",
      "text": "It's my pleasure.",
      "zh": "不客氣。",
      "ja": "どういたしまして。",
      "time": "00:09:23"
    },
    {
      "role": "teacher",
      "text": "I'm an architect.",
      "zh": "我是一名建築師。",
      "ja": "私は建築家です。",
      "time": "00:09:25"
    },
    {
      "role": "teacher",
      "text": "Building is my specialty.",
      "zh": "建築是我的專長。",
      "ja": "建築が専門です。",
      "time": "00:09:26"
    },
    {
      "role": "student",
      "text": "I can't wait until I graduate.",
      "zh": "我迫不及待想畢業了。",
      "ja": "卒業が待ちきれません。",
      "time": "00:09:44"
    },
    {
      "role": "student",
      "text": "Me too.",
      "zh": "我也是。",
      "ja": "私もです。",
      "time": "00:09:49"
    },
    {
      "role": "student",
      "text": "No more homework for me.",
      "zh": "我再也不用做作業了。",
      "ja": "もう宿題はありません。",
      "time": "00:09:53"
    },
    {
      "role": "student",
      "text": "I hate my homework.",
      "zh": "我討厭作業。",
      "ja": "宿題が嫌いです。",
      "time": "00:09:56"
    },
    {
      "role": "teacher",
      "text": "Are you going to college?",
      "zh": "你打算上大學嗎？",
      "ja": "大学に行くつもりですか？",
      "time": "00:10:00"
    },
    {
      "role": "student",
      "text": "I can't afford it.",
      "zh": "我負擔不起。",
      "ja": "お金がありません。",
      "time": "00:10:04"
    },
    {
      "role": "student",
      "text": "Me neither.",
      "zh": "我也是。",
      "ja": "私もです。",
      "time": "00:10:07"
    },
    {
      "role": "teacher",
      "text": "So what are you doing to do?",
      "zh": "那你打算怎麼辦？",
      "ja": "それで、どうするつもりですか？",
      "time": "00:10:10"
    },
    {
      "role": "student",
      "text": "I'm joining the army.",
      "zh": "我要參軍。",
      "ja": "軍隊に入ります。",
      "time": "00:10:13"
    },
    {
      "role": "teacher",
      "text": "You're kidding.",
      "zh": "你在開玩笑吧。",
      "ja": "冗談でしょう。",
      "time": "00:10:14"
    },
    {
      "role": "student",
      "text": "You might get killed.",
      "zh": "你可能會死。",
      "ja": "死ぬかもしれませんよ。",
      "time": "00:10:20"
    },
    {
      "role": "student",
      "text": "I don't think so.",
      "zh": "我不這麼認為。",
      "ja": "そうは思いません。",
      "time": "00:10:23"
    },
    {
      "role": "student",
      "text": "After I finish, I'll have enough money to go to college.",
      "zh": "完成後，我會有足夠的錢去上大學。",
      "ja": "終わったら、大学に行くお金が十分にあります。",
      "time": "00:10:25"
    },
    {
      "role": "teacher",
      "text": "That's not a bad idea.",
      "zh": "那不是個壞主意。",
      "ja": "悪くない考えです。",
      "time": "00:10:30"
    },
    {
      "role": "student",
      "text": "Goodbye.",
      "zh": "再見。",
      "ja": "さようなら。",
      "time": "00:10:33"
    },
    {
      "role": "teacher",
      "text": "Goodbye.",
      "zh": "再見。",
      "ja": "さようなら。",
      "time": "00:10:34"
    },
    {
      "role": "student",
      "text": "How good is your math?",
      "zh": "你的數學有多好？",
      "ja": "数学はどのくらい得意ですか？",
      "time": "00:10:38"
    },
    {
      "role": "teacher",
      "text": "I can add two and two.",
      "zh": "我會算2加2。",
      "ja": "2たす2はできます。",
      "time": "00:11:00"
    },
    {
      "role": "student",
      "text": "So you're not very good at math.",
      "zh": "所以你數學不太好。",
      "ja": "ということは数学はあまり得意ではないですね。",
      "time": "00:11:04"
    },
    {
      "role": "teacher",
      "text": "I'm terrible at math.",
      "zh": "我數學很糟糕。",
      "ja": "数学は苦手です。",
      "time": "00:11:09"
    },
    {
      "role": "student",
      "text": "Well, I need some help.",
      "zh": "嗯，我需要幫助。",
      "ja": "ええ、助けが必要です。",
      "time": "00:11:12"
    },
    {
      "role": "teacher",
      "text": "With what?",
      "zh": "什麼方面？",
      "ja": "何のことで？",
      "time": "00:11:16"
    },
    {
      "role": "student",
      "text": "I'm talking a math course in school.",
      "zh": "我在學校上數學課。",
      "ja": "学校で数学の授業を受けています。",
      "time": "00:11:18"
    },
    {
      "role": "teacher",
      "text": "Well, you should ask your teacher any or classmates for help.",
      "zh": "那你應該請老師或同學幫忙。",
      "ja": "先生やクラスメートに助けを求めるべきです。",
      "time": "00:11:22"
    },
    {
      "role": "student",
      "text": "I can't do that.",
      "zh": "我做不到。",
      "ja": "それはできません。",
      "time": "00:11:29"
    },
    {
      "role": "teacher",
      "text": "Why not?",
      "zh": "為什麼不？",
      "ja": "なぜですか？",
      "time": "00:11:33"
    },
    {
      "role": "student",
      "text": "They might think I'm stupid.",
      "zh": "他們可能會覺得我很笨。",
      "ja": "馬鹿だと思われるかもしれません。",
      "time": "00:11:38"
    },
    {
      "role": "teacher",
      "text": "They're not going to think that.",
      "zh": "他們不會這麼想。",
      "ja": "そんなことは思いませんよ。",
      "time": "00:11:42"
    },
    {
      "role": "teacher",
      "text": "They'll be glad to help you honey.",
      "zh": "他們會很樂意幫助你的，親愛的。",
      "ja": "喜んで助けてくれますよ、ハニー。",
      "time": "00:11:44"
    },
    {
      "role": "student",
      "text": "Thank you for your encouragement.",
      "zh": "謝謝你的鼓勵。",
      "ja": "励ましてくれてありがとう。",
      "time": "00:11:48"
    }
  ]
}