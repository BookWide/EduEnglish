{
  "meta": {
    "slug": "life-business-trip-travel-hotel-a-tk",
    "category": "pro/lifestyle/business_trip",
    "source_url": "https://www.youtube.com/watch?v=a_tKTLyOS6Y",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "I'm going to go take this over a dozen times.",
      "zh": "我要去做這件事超過十次。",
      "ja": "これを十数回やるつもりです。",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "I can't fucking see thelympics history here.",
      "zh": "我根本看不到奧運歷史。",
      "ja": "ここでオリンピックの歴史が全然見えません。",
      "time": "00:00:03"
    },
    {
      "role": "student",
      "text": "Please have some great Ackman in the world.",
      "zh": "請讓世界上有些偉大的Ackman。",
      "ja": "世界に素晴らしいアックマンをお願いします。",
      "time": "00:00:27"
    },
    {
      "role": "student",
      "text": "OH!",
      "zh": "哦！",
      "ja": "おお！",
      "time": "00:00:28"
    },
    {
      "role": "student",
      "text": "Huh?",
      "zh": "嗯？",
      "ja": "え？",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "Hey, Mommy.",
      "zh": "嘿，媽媽。",
      "ja": "ねえ、お母さん。",
      "time": "00:00:49"
    },
    {
      "role": "student",
      "text": "Can I help?",
      "zh": "我可以幫忙嗎？",
      "ja": "手伝ってもいい？",
      "time": "00:00:50"
    },
    {
      "role": "student",
      "text": "Excuse me.",
      "zh": "不好意思。",
      "ja": "すみません。",
      "time": "00:01:08"
    },
    {
      "role": "student",
      "text": "You are still in this school.",
      "zh": "你還在這所學校。",
      "ja": "あなたはまだこの学校にいます。",
      "time": "00:01:10"
    },
    {
      "role": "student",
      "text": "Hotel dasso deu.",
      "zh": "飯店dasso deu。",
      "ja": "ホテルだっそでう。",
      "time": "00:01:22"
    },
    {
      "role": "student",
      "text": "Thank you very much.",
      "zh": "非常感謝。",
      "ja": "どうもありがとうございます。",
      "time": "00:01:27"
    },
    {
      "role": "student",
      "text": "Welcome.",
      "zh": "歡迎。",
      "ja": "ようこそ。",
      "time": "00:01:32"
    },
    {
      "role": "student",
      "text": "What's going on?",
      "zh": "發生什麼事？",
      "ja": "何が起こっているの？",
      "time": "00:01:37"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:01:49"
    },
    {
      "role": "student",
      "text": "Coming.",
      "zh": "來了。",
      "ja": "来ます。",
      "time": "00:01:52"
    },
    {
      "role": "student",
      "text": "Come here.",
      "zh": "過來。",
      "ja": "こっちに来て。",
      "time": "00:01:54"
    },
    {
      "role": "student",
      "text": "It's nice, isn't it?",
      "zh": "很不錯，對吧？",
      "ja": "いいでしょう？",
      "time": "00:02:06"
    },
    {
      "role": "student",
      "text": "Milk?",
      "zh": "牛奶？",
      "ja": "ミルク？",
      "time": "00:03:17"
    },
    {
      "role": "student",
      "text": "Milk!",
      "zh": "牛奶！",
      "ja": "ミルク！",
      "time": "00:03:18"
    },
    {
      "role": "student",
      "text": "Tea!",
      "zh": "茶！",
      "ja": "お茶！",
      "time": "00:03:34"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好的。",
      "ja": "わかりました。",
      "time": "00:03:41"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとう。",
      "time": "00:03:42"
    },
    {
      "role": "student",
      "text": "Oh, lovely weather, isn't it?",
      "zh": "天氣真好，不是嗎？",
      "ja": "いい天気ですね。",
      "time": "00:04:20"
    },
    {
      "role": "student",
      "text": "If you're ready, we can, yes, yes, please.",
      "zh": "如果你準備好了，我們可以，好的，請。",
      "ja": "準備ができたら、はい、どうぞ。",
      "time": "00:04:37"
    },
    {
      "role": "student",
      "text": "I brought you some more tea.",
      "zh": "我給你帶了更多茶。",
      "ja": "もっとお茶を持ってきました。",
      "time": "00:05:16"
    },
    {
      "role": "student",
      "text": "Perhaps you'd like to watch some television.",
      "zh": "也許你想看電視。",
      "ja": "テレビを見たいかもしれませんね。",
      "time": "00:05:38"
    },
    {
      "role": "student",
      "text": "Sorry.",
      "zh": "抱歉。",
      "ja": "ごめんなさい。",
      "time": "00:06:07"
    },
    {
      "role": "student",
      "text": "Oh, so good.",
      "zh": "哦，真好。",
      "ja": "ああ、とてもいい。",
      "time": "00:06:29"
    },
    {
      "role": "student",
      "text": "There's no food.",
      "zh": "沒有食物。",
      "ja": "食べ物がありません。",
      "time": "00:06:33"
    },
    {
      "role": "student",
      "text": "Right now.",
      "zh": "現在。",
      "ja": "今すぐ。",
      "time": "00:07:25"
    },
    {
      "role": "student",
      "text": "So my old man said hello my friend and don't deadly only on the way.",
      "zh": "所以我老爸說你好我的朋友，路上不要致命。",
      "ja": "だから私の父は友達にこんにちはと言って、道中は危険じゃないよと。",
      "time": "00:07:33"
    },
    {
      "role": "student",
      "text": "I went to man with me home packed in it and I walked behind with me I was all limited and I did it.",
      "zh": "我帶著家裡的東西去找那個人，我跟在後面，我都受限了，但我做到了。",
      "ja": "家に荷物を詰めて男の人のところに行き、後ろを歩いて、制限されていたけどやり遂げた。",
      "time": "00:07:46"
    },
    {
      "role": "student",
      "text": "I'll thank you, thank you god.",
      "zh": "我感謝你，感謝上帝。",
      "ja": "ありがとう、神様ありがとう。",
      "time": "00:08:11"
    },
    {
      "role": "student",
      "text": "Ta-da!",
      "zh": "噹噹！",
      "ja": "じゃーん！",
      "time": "00:08:44"
    },
    {
      "role": "student",
      "text": "Alright, yes.",
      "zh": "好，沒錯。",
      "ja": "よし、はい。",
      "time": "00:09:17"
    },
    {
      "role": "student",
      "text": "This is the good way.",
      "zh": "這是正確的路。",
      "ja": "これが良い道です。",
      "time": "00:09:19"
    },
    {
      "role": "student",
      "text": "Oh hello.",
      "zh": "哦，你好。",
      "ja": "ああ、こんにちは。",
      "time": "00:10:06"
    },
    {
      "role": "student",
      "text": "My old man said you're the man.",
      "zh": "我老爸說你是那個人。",
      "ja": "私の父は君が男だと言った。",
      "time": "00:10:20"
    },
    {
      "role": "student",
      "text": "Always the man with me.",
      "zh": "永遠是我的男人。",
      "ja": "いつも私のそばにいる男。",
      "time": "00:10:27"
    },
    {
      "role": "student",
      "text": "Don't worry, we'll get a new bun.",
      "zh": "別擔心，我們會買新的麵包。",
      "ja": "心配しないで、新しいパンを買うよ。",
      "time": "00:12:37"
    },
    {
      "role": "student",
      "text": "Toy shop, please.",
      "zh": "請去玩具店。",
      "ja": "おもちゃ屋さんへお願いします。",
      "time": "00:13:12"
    },
    {
      "role": "student",
      "text": "How much will it be?",
      "zh": "這要多少錢？",
      "ja": "いくらになりますか？",
      "time": "00:13:36"
    },
    {
      "role": "student",
      "text": "Excuse me.",
      "zh": "不好意思。",
      "ja": "すみません。",
      "time": "00:15:01"
    },
    {
      "role": "student",
      "text": "I'm happy.",
      "zh": "我很開心。",
      "ja": "私は幸せです。",
      "time": "00:15:12"
    },
    {
      "role": "student",
      "text": "Library, please.",
      "zh": "請去圖書館。",
      "ja": "図書館へお願いします。",
      "time": "00:16:07"
    },
    {
      "role": "student",
      "text": "Keep the change.",
      "zh": "不用找了。",
      "ja": "お釣りは取っておいてください。",
      "time": "00:17:14"
    },
    {
      "role": "student",
      "text": "Thanks, love.",
      "zh": "謝謝，親愛的。",
      "ja": "ありがとう、愛しい人。",
      "time": "00:17:44"
    },
    {
      "role": "student",
      "text": "You a cabbie?",
      "zh": "你是計程車司機嗎？",
      "ja": "あなたはタクシー運転手ですか？",
      "time": "00:17:49"
    },
    {
      "role": "student",
      "text": "I got two hours to see London town.",
      "zh": "我有兩個小時看倫敦市區。",
      "ja": "ロンドンの街を見るのに2時間あります。",
      "time": "00:17:55"
    },
    {
      "role": "student",
      "text": "Let's go.",
      "zh": "我們走吧。",
      "ja": "行きましょう。",
      "time": "00:18:09"
    },
    {
      "role": "student",
      "text": "Take a photo here.",
      "zh": "在這裡拍張照。",
      "ja": "ここで写真を撮って。",
      "time": "00:18:15"
    },
    {
      "role": "student",
      "text": "Where's the queen?",
      "zh": "女王在哪裡？",
      "ja": "女王はどこですか？",
      "time": "00:19:02"
    },
    {
      "role": "student",
      "text": "I'm going to miss my flight.",
      "zh": "我要錯過我的班機了。",
      "ja": "飛行機に乗り遅れそうです。",
      "time": "00:19:26"
    },
    {
      "role": "student",
      "text": "Eat the taste.",
      "zh": "品嚐味道。",
      "ja": "味わってください。",
      "time": "00:19:46"
    },
    {
      "role": "student",
      "text": "Nearly there.",
      "zh": "快到了。",
      "ja": "もうすぐです。",
      "time": "00:20:32"
    },
    {
      "role": "student",
      "text": "Keep the chain.",
      "zh": "保留零錢。",
      "ja": "お釣りは取っておいてください。",
      "time": "00:20:54"
    },
    {
      "role": "student",
      "text": "Woohoo.",
      "zh": "耶！",
      "ja": "やった！",
      "time": "00:21:23"
    },
    {
      "role": "student",
      "text": "I'm going away for two days.",
      "zh": "我要離開兩天。",
      "ja": "2日間出かけます。",
      "time": "00:22:41"
    },
    {
      "role": "student",
      "text": "You need to feed the fish.",
      "zh": "你需要餵魚。",
      "ja": "魚に餌をあげてね。",
      "time": "00:22:44"
    },
    {
      "role": "student",
      "text": "Oh, goodbye.",
      "zh": "哦，再見。",
      "ja": "ああ、さようなら。",
      "time": "00:23:08"
    },
    {
      "role": "student",
      "text": "Come on!",
      "zh": "加油！",
      "ja": "さあ！",
      "time": "00:23:27"
    },
    {
      "role": "student",
      "text": "Help!",
      "zh": "救命！",
      "ja": "助けて！",
      "time": "00:24:37"
    },
    {
      "role": "student",
      "text": "AHH!",
      "zh": "啊！",
      "ja": "ああ！",
      "time": "00:26:24"
    },
    {
      "role": "student",
      "text": "Sorry, I won't go on back.",
      "zh": "抱歉，我不會回去。",
      "ja": "ごめんなさい、戻りません。",
      "time": "00:27:00"
    },
    {
      "role": "student",
      "text": "How's it going?",
      "zh": "進展如何？",
      "ja": "調子はどう？",
      "time": "00:28:47"
    },
    {
      "role": "student",
      "text": "Fishy!",
      "zh": "魚！",
      "ja": "魚！",
      "time": "00:29:10"
    },
    {
      "role": "student",
      "text": "Is that love?",
      "zh": "那是愛嗎？",
      "ja": "それは愛ですか？",
      "time": "00:29:29"
    },
    {
      "role": "student",
      "text": "Well, Gals, there must be some way.",
      "zh": "好啦，大家，一定有辦法的。",
      "ja": "さて、みんな、何か方法があるはずだ。",
      "time": "00:30:34"
    },
    {
      "role": "student",
      "text": "Two?",
      "zh": "兩個？",
      "ja": "二つ？",
      "time": "00:31:21"
    },
    {
      "role": "student",
      "text": "Without you!",
      "zh": "沒有你！",
      "ja": "君なしで！",
      "time": "00:31:43"
    },
    {
      "role": "student",
      "text": "Baby!",
      "zh": "寶貝！",
      "ja": "ベイビー！",
      "time": "00:32:16"
    },
    {
      "role": "student",
      "text": "I see.",
      "zh": "我明白了。",
      "ja": "わかりました。",
      "time": "00:33:36"
    },
    {
      "role": "student",
      "text": "Time for Betty Vase.",
      "zh": "是時候給Betty Vase了。",
      "ja": "ベティ・ヴェイスの時間です。",
      "time": "00:34:18"
    },
    {
      "role": "student",
      "text": "Ahhh!",
      "zh": "啊啊！",
      "ja": "あああ！",
      "time": "00:35:39"
    },
    {
      "role": "student",
      "text": "Hello?",
      "zh": "哈囉？",
      "ja": "もしもし？",
      "time": "00:35:44"
    },
    {
      "role": "student",
      "text": "Come back here!",
      "zh": "回來這裡！",
      "ja": "こっちに戻って！",
      "time": "00:35:49"
    },
    {
      "role": "student",
      "text": "Breakfast!",
      "zh": "早餐！",
      "ja": "朝食！",
      "time": "00:36:14"
    },
    {
      "role": "student",
      "text": "Thanks!",
      "zh": "謝謝！",
      "ja": "ありがとう！",
      "time": "00:36:30"
    },
    {
      "role": "student",
      "text": "Is that the culprit, madam?",
      "zh": "那是罪犯嗎，女士？",
      "ja": "それが犯人ですか、奥様？",
      "time": "00:36:34"
    },
    {
      "role": "student",
      "text": "They're losing men tonight!",
      "zh": "今晚他們失去了人員！",
      "ja": "今夜彼らは人を失っています！",
      "time": "00:36:48"
    },
    {
      "role": "student",
      "text": "My wallet!",
      "zh": "我的錢包！",
      "ja": "私の財布！",
      "time": "00:36:56"
    },
    {
      "role": "student",
      "text": "I won!",
      "zh": "我贏了！",
      "ja": "勝った！",
      "time": "00:37:18"
    },
    {
      "role": "student",
      "text": "Ready for action!",
      "zh": "準備行動！",
      "ja": "行動準備完了！",
      "time": "00:37:46"
    },
    {
      "role": "student",
      "text": "I'm on your trail.",
      "zh": "我在追蹤你。",
      "ja": "君の後を追っている。",
      "time": "00:37:54"
    },
    {
      "role": "student",
      "text": "Come on!",
      "zh": "快點！",
      "ja": "さあ！",
      "time": "00:38:03"
    },
    {
      "role": "student",
      "text": "My turtles!",
      "zh": "我的烏龜！",
      "ja": "私のカメたち！",
      "time": "00:38:07"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとう。",
      "time": "00:39:16"
    },
    {
      "role": "student",
      "text": "Today's top story, a new superhero is helping people everywhere.",
      "zh": "今日頭條，一位新超級英雄正在幫助各地的人們。",
      "ja": "今日のトップニュース、新しいスーパーヒーローがどこでも人々を助けています。",
      "time": "00:39:31"
    },
    {
      "role": "student",
      "text": "Have you seen this thief?",
      "zh": "你有看到這個小偷嗎？",
      "ja": "この泥棒を見ましたか？",
      "time": "00:39:41"
    },
    {
      "role": "student",
      "text": "Gotcha!",
      "zh": "抓到了！",
      "ja": "捕まえた！",
      "time": "00:39:53"
    },
    {
      "role": "student",
      "text": "Don't!",
      "zh": "不要！",
      "ja": "やめて！",
      "time": "00:40:10"
    },
    {
      "role": "student",
      "text": "I'm out of here!",
      "zh": "我要走了！",
      "ja": "もう行くよ！",
      "time": "00:40:13"
    },
    {
      "role": "student",
      "text": "Now then. Where are you?",
      "zh": "那麼，你在哪裡？",
      "ja": "さて、君はどこだ？",
      "time": "00:41:09"
    },
    {
      "role": "student",
      "text": "I've got you.",
      "zh": "我抓到你了。",
      "ja": "捕まえたぞ。",
      "time": "00:41:13"
    },
    {
      "role": "student",
      "text": "Go!",
      "zh": "走！",
      "ja": "行け！",
      "time": "00:41:55"
    },
    {
      "role": "student",
      "text": "You're not going anywhere.",
      "zh": "你哪裡也去不了。",
      "ja": "どこにも行けませんよ。",
      "time": "00:42:24"
    },
    {
      "role": "student",
      "text": "My wallet!",
      "zh": "我的錢包！",
      "ja": "私の財布！",
      "time": "00:42:36"
    },
    {
      "role": "student",
      "text": "Oh, my things!",
      "zh": "哦，我的東西！",
      "ja": "ああ、私のもの！",
      "time": "00:43:02"
    },
    {
      "role": "student",
      "text": "Nice.",
      "zh": "不錯。",
      "ja": "いいね。",
      "time": "00:43:44"
    },
    {
      "role": "student",
      "text": "I'm terribly sorry.",
      "zh": "我非常抱歉。",
      "ja": "本当に申し訳ありません。",
      "time": "00:49:44"
    },
    {
      "role": "student",
      "text": "Stop.",
      "zh": "停下。",
      "ja": "止まれ。",
      "time": "00:50:34"
    },
    {
      "role": "student",
      "text": "Only today.",
      "zh": "只有今天。",
      "ja": "今日だけです。",
      "time": "00:50:40"
    },
    {
      "role": "student",
      "text": "And now back to the studio.",
      "zh": "現在回到演播室。",
      "ja": "そして今、スタジオに戻ります。",
      "time": "00:50:42"
    },
    {
      "role": "student",
      "text": "Breaking news we're getting more reports of the robot out of control.",
      "zh": "突發新聞，我們收到更多關於機器人失控的報告。",
      "ja": "速報、ロボットの暴走に関する報告が増えています。",
      "time": "00:50:44"
    },
    {
      "role": "student",
