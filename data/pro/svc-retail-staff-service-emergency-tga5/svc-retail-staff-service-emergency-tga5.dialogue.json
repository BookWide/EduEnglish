{
  "meta": {
    "slug": "svc-retail-staff-service-emergency-tga5",
    "category": "pro/service/retail_staff",
    "source_url": "https://www.youtube.com/watch?v=TGa5TaF23rQ",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "teacher",
      "text": "Welcome to ABC",
      "zh": "歡迎光臨ABC",
      "ja": "ABCへようこそ",
      "time": "00:00:11"
    },
    {
      "role": "teacher",
      "text": "How may I help you?",
      "zh": "我能為您服務什麼？",
      "ja": "いかがなさいましたか？",
      "time": "00:00:21"
    },
    {
      "role": "student",
      "text": "Can I take a look at the shoes behind the glass window?",
      "zh": "我可以看看玻璃櫥窗裡的鞋子嗎？",
      "ja": "ガラスの窓の後ろにある靴を見てもいいですか？",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "Yeah, yeah, yeah, yeah, yeah, yeah, of course, of course, follow me.",
      "zh": "當然，當然，跟我來。",
      "ja": "はい、はい、はい、もちろんです。ついてきてください。",
      "time": "00:00:29"
    },
    {
      "role": "teacher",
      "text": "You have good taste.",
      "zh": "你品味真好。",
      "ja": "いいセンスですね。",
      "time": "00:00:40"
    },
    {
      "role": "teacher",
      "text": "These shoes are the most popular at ABC.",
      "zh": "這雙鞋是ABC最受歡迎的。",
      "ja": "この靴はABCで一番人気です。",
      "time": "00:00:42"
    },
    {
      "role": "student",
      "text": "I really like the style.",
      "zh": "我真的很喜歡這款式。",
      "ja": "このスタイルが本当に好きです。",
      "time": "00:00:47"
    },
    {
      "role": "student",
      "text": "How much are they?",
      "zh": "多少錢？",
      "ja": "いくらですか？",
      "time": "00:00:50"
    },
    {
      "role": "teacher",
      "text": "They're brand new, like a piece of cake right out of the oven.",
      "zh": "它們是全新的，就像剛出爐的蛋糕一樣。",
      "ja": "新品で、まるで焼きたてのケーキのようです。",
      "time": "00:00:53"
    },
    {
      "role": "teacher",
      "text": "They're $68.",
      "zh": "價格是68美元。",
      "ja": "68ドルです。",
      "time": "00:00:58"
    },
    {
      "role": "student",
      "text": "Oh, no.",
      "zh": "喔，不。",
      "ja": "ああ、いやだ。",
      "time": "00:01:00"
    },
    {
      "role": "student",
      "text": "That's too expensive.",
      "zh": "太貴了。",
      "ja": "高すぎます。",
      "time": "00:01:02"
    },
    {
      "role": "student",
      "text": "I only have a few dollars in my pocket.",
      "zh": "我口袋裡只有幾塊錢。",
      "ja": "ポケットに数ドルしかありません。",
      "time": "00:01:05"
    },
    {
      "role": "student",
      "text": "Can I get a discount?",
      "zh": "可以打折嗎？",
      "ja": "割引してもらえますか？",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "Oh, no.",
      "zh": "喔，不。",
      "ja": "ああ、だめです。",
      "time": "00:01:12"
    },
    {
      "role": "teacher",
      "text": "I'm really sorry, sweetie.",
      "zh": "真的很抱歉，親愛的。",
      "ja": "本当にごめんなさい、かわいこちゃん。",
      "time": "00:01:14"
    },
    {
      "role": "teacher",
      "text": "This is the fixed price.",
      "zh": "這是固定價格。",
      "ja": "これは定価です。",
      "time": "00:01:17"
    },
    {
      "role": "teacher",
      "text": "Why don't you take a look at the products in the corner?",
      "zh": "你為什麼不看看角落裡的商品呢？",
      "ja": "隅にある商品を見てみませんか？",
      "time": "00:01:19"
    },
    {
      "role": "teacher",
      "text": "They're on sale.",
      "zh": "它們正在特價。",
      "ja": "セール中です。",
      "time": "00:01:23"
    },
    {
      "role": "student",
      "text": "Do you have size five for these?",
      "zh": "這雙有五號尺寸嗎？",
      "ja": "これのサイズ5はありますか？",
      "time": "00:01:27"
    },
    {
      "role": "teacher",
      "text": "Of course.",
      "zh": "當然有。",
      "ja": "もちろんです。",
      "time": "00:01:33"
    },
    {
      "role": "teacher",
      "text": "Try these.",
      "zh": "試穿這雙。",
      "ja": "これを試してみてください。",
      "time": "00:01:36"
    },
    {
      "role": "student",
      "text": "I think these are too small for me.",
      "zh": "我覺得這雙對我來說太小了。",
      "ja": "これは私には小さすぎると思います。",
      "time": "00:01:43"
    },
    {
      "role": "student",
      "text": "Can I have one size bigger?",
      "zh": "可以給我大一號的嗎？",
      "ja": "一つ大きいサイズをもらえますか？",
      "time": "00:01:47"
    },
    {
      "role": "teacher",
      "text": "Size six, let me get back to you in a sec.",
      "zh": "六號，請稍等我一下。",
      "ja": "サイズ6ですね、すぐにお持ちします。",
      "time": "00:01:51"
    },
    {
      "role": "teacher",
      "text": "Try these, sweetie.",
      "zh": "試穿這雙，親愛的。",
      "ja": "これを試してみてください、かわいこちゃん。",
      "time": "00:01:59"
    },
    {
      "role": "student",
      "text": "How do they fit?",
      "zh": "穿起來如何？",
      "ja": "履き心地はどうですか？",
      "time": "00:02:05"
    },
    {
      "role": "student",
      "text": "Perfect.",
      "zh": "很合適。",
      "ja": "完璧です。",
      "time": "00:02:07"
    },
    {
      "role": "student",
      "text": "I love them.",
      "zh": "我很喜歡它們。",
      "ja": "気に入りました。",
      "time": "00:02:08"
    },
    {
      "role": "student",
      "text": "I'll take them.",
      "zh": "我要買這雙。",
      "ja": "これを買います。",
      "time": "00:02:10"
    },
    {
      "role": "teacher",
      "text": "How would you like to pay?",
      "zh": "您想怎麼付款？",
      "ja": "お支払いはどうなさいますか？",
      "time": "00:02:13"
    },
    {
      "role": "teacher",
      "text": "Credit card or cash?",
      "zh": "信用卡還是現金？",
      "ja": "クレジットカードですか、それとも現金ですか？",
      "time": "00:02:16"
    },
    {
      "role": "student",
      "text": "Cash.",
      "zh": "現金。",
      "ja": "現金で。",
      "time": "00:02:20"
    },
    {
      "role": "student",
      "text": "Here you are.",
      "zh": "給你。",
      "ja": "どうぞ。",
      "time": "00:02:22"
    },
    {
      "role": "teacher",
      "text": "Here's your change of five dollars.",
      "zh": "這是找您的五美元。",
      "ja": "お釣りの5ドルです。",
      "time": "00:02:25"
    },
    {
      "role": "teacher",
      "text": "Thanks for coming.",
      "zh": "謝謝光臨。",
      "ja": "ご来店ありがとうございました。",
      "time": "00:02:28"
    },
    {
      "role": "teacher",
      "text": "Have a wonderful day.",
      "zh": "祝您有美好的一天。",
      "ja": "素敵な一日をお過ごしください。",
      "time": "00:02:31"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝。",
      "ja": "ありがとうございます。",
      "time": "00:02:33"
    },
    {
      "role": "student",
      "text": "I really love these shoes.",
      "zh": "我真的很喜歡這雙鞋。",
      "ja": "この靴が本当に大好きです。",
      "time": "00:02:34"
    }
  ]
}