[
  {
    "time": "00:00:00",
    "en": "It is important to keep our teeth clean and healthy.",
    "zh": "保持牙齒清潔和健康很重要。",
    "ja": "歯を清潔で健康に保つことは大切です。",
    "source_url": "https://www.youtube.com/watch?v=70loZVsvaqM"
  },
  {
    "time": "00:00:08",
    "en": "So today, I'm visiting the dentist.",
    "zh": "所以今天，我要去看牙醫。",
    "ja": "だから今日は歯医者に行きます。"
  },
  {
    "time": "00:00:15",
    "en": "Here we are. This is my dentist's office.",
    "zh": "我們到了。這是我的牙醫診所。",
    "ja": "着きました。ここが私の歯医者の診療所です。"
  },
  {
    "time": "00:00:22",
    "en": "I wore a special shirt.",
    "zh": "我穿了一件特別的襯衫。",
    "ja": "特別なシャツを着ました。"
  },
  {
    "time": "00:00:24",
    "en": "Let's go check in.",
    "zh": "我們去報到吧。",
    "ja": "受付に行きましょう。"
  },
  {
    "time": "00:00:25",
    "en": "Hi, I'm Katie.",
    "zh": "嗨，我是凱蒂。",
    "ja": "こんにちは、ケイティです。"
  },
  {
    "time": "00:00:27",
    "en": "I'm here to see my dentist's Kathy.",
    "zh": "我來看我的牙醫凱西。",
    "ja": "歯医者のキャシーに会いに来ました。"
  },
  {
    "time": "00:00:29",
    "en": "Nice to see you again, Katie.",
    "zh": "很高興再見到你，凱蒂。",
    "ja": "また会えて嬉しいよ、ケイティ。"
  },
  {
    "time": "00:00:31",
    "en": "Nice to see you.",
    "zh": "很高興見到你。",
    "ja": "お会いできて嬉しいです。"
  },
  {
    "time": "00:00:32",
    "en": "Kathy will be with you in a few moments.",
