      "time": "00:02:12"
    },
    {
      "role": "student",
      "text": "Don't push.",
      "zh": "不要推擠。",
      "ja": "押さないで。",
      "time": "00:02:18"
    },
    {
      "role": "student",
      "text": "Stay together.",
