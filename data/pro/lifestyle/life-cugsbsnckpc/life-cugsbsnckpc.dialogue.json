      "time": "00:01:26"
    },
    {
      "role": "student",
      "text": "No.",
      "zh": "不是。",
      "ja": "いいえ。",
      "time": "00:01:27"
    },
    {
      "role": "student",
      "text": "We're going to miss it.",
