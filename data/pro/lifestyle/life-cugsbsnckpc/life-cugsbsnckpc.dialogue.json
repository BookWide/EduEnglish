      "ja": "間に合わないでしょう。",
      "time": "00:01:28"
    },
    {
      "role": "student",
      "text": "Ah!",
      "zh": "啊！",
      "ja": "ああ！",
      "time": "00:01:33"
    },
    {
      "role": "student",
      "text": "Drive right carefully please.",
      "zh": "請小心右轉。",
      "ja": "右に注意して運転してください。",
