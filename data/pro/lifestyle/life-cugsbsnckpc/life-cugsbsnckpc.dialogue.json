    {
      "role": "student",
      "text": "Thank Dad.",
      "zh": "謝謝爸爸。",
      "ja": "ありがとうパパ。",
      "time": "00:06:31"
    },
    {
      "role": "student",
      "text": "Let's go.",
      "zh": "我們走吧。",
      "ja": "行きましょう。",
      "time": "00:06:36"
    },
    {
      "role": "student",
      "text": "We'll get on the boat and go shopping for souvenirs.",
