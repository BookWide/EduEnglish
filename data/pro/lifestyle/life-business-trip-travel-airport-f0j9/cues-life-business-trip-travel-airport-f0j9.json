  },
  {
    "time": "00:06:40",
    "en": "Oh.",
    "zh": "哦。",
    "ja": "ああ。"
  },
  {
    "time": "00:06:42",
    "en": "I miss you, Grandpa.",
    "zh": "我想你，爺爺。",
    "ja": "おじいちゃん、会いたいよ。"
  },
  {
    "time": "00:06:48",
    "en": "Grandpa.",
    "zh": "爺爺。",
    "ja": "おじいちゃん。"
  },
  {
    "time": "00:06:57",
    "en": "Oh.",
    "zh": "哦。",
    "ja": "ああ。"
  },
  {
    "time": "00:07:02",
    "en": "Grandpa.",
    "zh": "爺爺。",
    "ja": "おじいちゃん。"
  },
  {
    "time": "00:07:03",
    "en": "That's simple.",
    "zh": "那很簡單。",
    "ja": "それは簡単だよ。"
  },
