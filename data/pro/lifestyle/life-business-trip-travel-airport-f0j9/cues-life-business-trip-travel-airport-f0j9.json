    "zh": "嗯。",
    "ja": "え？"
  },
  {
    "time": "00:07:22",
    "en": "My name is Ben.",
    "zh": "我叫班。",
    "ja": "僕の名前はベン。"
  },
  {
    "time": "00:07:23",
    "en": "I'm your new partner.",
    "zh": "我是你的新夥伴。",
    "ja": "君の新しいパートナーだよ。"
  },
  {
    "time": "00:07:25",
    "en": "Ah.",
    "zh": "啊。",
    "ja": "ああ。"
  },
  {
    "time": "00:07:26",
    "en": "Hi.",
    "zh": "嗨。",
    "ja": "こんにちは。"
  },
  {
    "time": "00:07:27",
    "en": "I'm Winky.",
    "zh": "我是溫基。",
    "ja": "僕はウィンキー。"
  },
  {
    "time": "00:07:28",
    "en": "You are very late.",
    "zh": "你來得很晚。",
    "ja": "君はとても遅かったね。"
  },
  {
    "time": "00:07:30",
    "en": "Uh-oh.",
