  },
  {
    "time": "00:10:16",
    "en": "Look.",
    "zh": "看。",
    "ja": "見て。"
  },
  {
    "time": "00:10:17",
    "en": "It's a new bike.",
    "zh": "這是一輛新腳踏車。",
    "ja": "新しい自転車です。"
  },
  {
