  },
  {
    "time": "00:09:29",
    "en": "Mike.",
    "zh": "麥克。",
    "ja": "マイク。"
  },
  {
    "time": "00:09:30",
    "en": "Is she your mom?",
    "zh": "她是你媽媽嗎？",
    "ja": "彼女はあなたのお母さんですか？"
  },
  {
    "time": "00:09:32",
    "en": "Yes, she's my mom.",
