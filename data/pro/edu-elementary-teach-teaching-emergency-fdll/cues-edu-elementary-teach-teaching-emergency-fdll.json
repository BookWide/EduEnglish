  },
  {
    "time": "00:08:22",
    "en": "It's ten dollars.",
    "zh": "十美元。",
    "ja": "10ドルです。"
  },
  {
    "time": "00:08:27",
    "en": "Sally, you look very pretty.",
    "zh": "莎莉，你看起來很漂亮。",
