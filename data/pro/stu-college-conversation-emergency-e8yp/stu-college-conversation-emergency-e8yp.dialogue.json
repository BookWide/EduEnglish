{
  "meta": {
    "slug": "stu-college-conversation-emergency-e8yp",
    "category": "pro/student/college",
    "source_url": "https://www.youtube.com/watch?v=e8YPw24dhYc",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "Did you call me, sir?",
      "zh": "您叫我嗎，先生？",
      "ja": "お呼びですか、先生？",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Please sit down, Sarah.",
      "zh": "請坐下，莎拉。",
      "ja": "座ってください、サラ。",
      "time": "00:00:08"
    },
    {
      "role": "teacher",
      "text": "You are a good worker, Sarah.",
      "zh": "你是個好員工，莎拉。",
      "ja": "あなたは良い働き手です、サラ。",
      "time": "00:00:12"
    },
    {
      "role": "teacher",
      "text": "You always do your job well.",
      "zh": "你總是把工作做好。",
      "ja": "いつも仕事をきちんとこなしていますね。",
      "time": "00:00:15"
    },
    {
      "role": "student",
      "text": "Thank you, sir.",
      "zh": "謝謝您，先生。",
      "ja": "ありがとうございます、先生。",
      "time": "00:00:18"
    },
    {
      "role": "student",
      "text": "I try my best.",
      "zh": "我盡力而為。",
      "ja": "ベストを尽くしています。",
      "time": "00:00:20"
    },
    {
      "role": "teacher",
      "text": "I know your mother is sick.",
      "zh": "我知道你的母親生病了。",
      "ja": "お母さんが病気だと知っています。",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "I also know you have a younger sister.",
      "zh": "我也知道你有個妹妹。",
      "ja": "妹さんがいることも知っています。",
      "time": "00:00:25"
    },
    {
      "role": "student",
      "text": "Yes, sir.",
      "zh": "是的，先生。",
      "ja": "はい、先生。",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "That is true.",
      "zh": "沒錯。",
      "ja": "その通りです。",
      "time": "00:00:30"
    },
    {
      "role": "teacher",
      "text": "You need money.",
      "zh": "你需要錢。",
      "ja": "お金が必要ですね。",
      "time": "00:00:32"
    },
    {
      "role": "teacher",
      "text": "I understand.",
      "zh": "我理解。",
      "ja": "わかります。",
      "time": "00:00:34"
    },
    {
      "role": "teacher",
      "text": "Life is hard.",
      "zh": "生活很艱難。",
      "ja": "人生は厳しいです。",
      "time": "00:00:36"
    },
    {
      "role": "student",
      "text": "Yes, sometimes I don't sleep at night.",
      "zh": "是的，有時我晚上睡不著。",
      "ja": "はい、時々夜眠れません。",
      "time": "00:00:38"
    },
    {
      "role": "student",
      "text": "I worry a lot.",
      "zh": "我很擔心。",
      "ja": "とても心配しています。",
      "time": "00:00:43"
    },
    {
      "role": "teacher",
      "text": "I want to help you.",
      "zh": "我想幫助你。",
      "ja": "助けたいと思っています。",
      "time": "00:00:45"
    },
    {
      "role": "student",
      "text": "Help.",
      "zh": "幫助？",
      "ja": "助けるって？",
      "time": "00:00:48"
    },
    {
      "role": "teacher",
      "text": "How?",
      "zh": "怎麼幫？",
      "ja": "どうやって？",
      "time": "00:00:49"
    },
    {
      "role": "teacher",
      "text": "Yes, I will help you.",
      "zh": "是的，我會幫你。",
      "ja": "はい、助けます。",
      "time": "00:00:51"
    },
    {
      "role": "teacher",
      "text": "But I will ask something big from you.",
      "zh": "但我會向你提出一個很大的要求。",
      "ja": "でも大きなお願いがあります。",
      "time": "00:00:53"
    },
    {
      "role": "student",
      "text": "What is it?",
      "zh": "是什麼？",
      "ja": "何ですか？",
      "time": "00:00:56"
    },
    {
      "role": "teacher",
      "text": "I want you to marry my son.",
      "zh": "我想讓你嫁給我的兒子。",
      "ja": "私の息子と結婚してほしい。",
      "time": "00:00:58"
    },
    {
      "role": "student",
      "text": "What?",
      "zh": "什麼？",
      "ja": "えっ？",
      "time": "00:01:01"
    },
    {
      "role": "student",
      "text": "Marry, your son?",
      "zh": "嫁給你兒子？",
      "ja": "あなたの息子と結婚？",
      "time": "00:01:02"
    },
    {
      "role": "teacher",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:01:05"
    },
    {
      "role": "teacher",
      "text": "His name is Ronald.",
      "zh": "他叫羅納德。",
      "ja": "彼の名前はロナルドです。",
      "time": "00:01:06"
    },
    {
      "role": "teacher",
      "text": "He is a good, kind and honest man.",
      "zh": "他是個好人，善良且誠實。",
      "ja": "彼は良い人で、優しくて正直な男性です。",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "But he is shy.",
      "zh": "但他很害羞。",
      "ja": "でも彼は恥ずかしがり屋です。",
      "time": "00:01:12"
    },
    {
      "role": "teacher",
      "text": "Many girls say no to him.",
      "zh": "很多女孩拒絕他。",
      "ja": "多くの女の子が彼を断ります。",
      "time": "00:01:14"
    },
    {
      "role": "student",
      "text": "But, sir, I don't know him.",
      "zh": "但是，先生，我不認識他。",
      "ja": "でも、先生、彼のことは知りません。",
      "time": "00:01:17"
    },
    {
      "role": "teacher",
      "text": "That is okay.",
      "zh": "沒關係。",
      "ja": "それでいいんです。",
      "time": "00:01:21"
    },
    {
      "role": "teacher",
      "text": "You can meet him.",
      "zh": "你可以見見他。",
      "ja": "彼に会ってみてください。",
      "time": "00:01:23"
    },
    {
      "role": "teacher",
      "text": "Talk to him.",
      "zh": "跟他談談。",
      "ja": "話をしてみてください。",
      "time": "00:01:25"
    },
    {
      "role": "teacher",
      "text": "Take your time to know him.",
      "zh": "慢慢了解他。",
      "ja": "ゆっくり彼を知ってください。",
      "time": "00:01:26"
    },
    {
      "role": "student",
      "text": "This is very strange.",
      "zh": "這很奇怪。",
      "ja": "これはとても変です。",
      "time": "00:01:29"
    },
    {
      "role": "student",
      "text": "Why me?",
      "zh": "為什麼是我？",
      "ja": "なぜ私なの？",
      "time": "00:01:31"
    },
    {
      "role": "teacher",
      "text": "Because you are kind.",
      "zh": "因為你很善良。",
      "ja": "あなたは優しいからです。",
      "time": "00:01:33"
    },
    {
      "role": "teacher",
      "text": "You are simple.",
      "zh": "你很單純。",
      "ja": "あなたは素朴です。",
      "time": "00:01:36"
    },
    {
      "role": "teacher",
      "text": "You have a good heart.",
      "zh": "你有一顆善良的心。",
      "ja": "あなたは良い心を持っています。",
      "time": "00:01:38"
    },
    {
      "role": "teacher",
      "text": "I want someone like you for my son.",
      "zh": "我想要像你這樣的人給我的兒子。",
      "ja": "息子にはあなたのような人が欲しいのです。",
      "time": "00:01:40"
    },
    {
      "role": "student",
      "text": "I don't know what to say.",
      "zh": "我不知道該說什麼。",
      "ja": "何と言えばいいかわかりません。",
      "time": "00:01:43"
    },
    {
      "role": "teacher",
      "text": "I will give you a house.",
      "zh": "我會給你一棟房子。",
      "ja": "家をあげます。",
      "time": "00:01:45"
    },
    {
      "role": "teacher",
      "text": "I will pay for your mother's medicine.",
      "zh": "我會支付你母親的藥費。",
      "ja": "お母さんの薬代を払います。",
      "time": "00:01:48"
    },
    {
      "role": "teacher",
      "text": "I will help your sister go to college.",
      "zh": "我會幫助你妹妹上大學。",
      "ja": "妹さんの大学進学を助けます。",
      "time": "00:01:51"
    },
    {
      "role": "student",
      "text": "This is a lot.",
      "zh": "這太多了。",
      "ja": "それは多すぎます。",
      "time": "00:01:54"
    },
    {
      "role": "student",
      "text": "I am confused.",
      "zh": "我很困惑。",
      "ja": "混乱しています。",
      "time": "00:01:56"
    },
    {
      "role": "teacher",
      "text": "You don't have to answer now.",
      "zh": "你現在不必回答。",
      "ja": "今すぐ答える必要はありません。",
      "time": "00:01:58"
    },
    {
      "role": "teacher",
      "text": "Think about it.",
      "zh": "好好想想。",
      "ja": "考えてください。",
      "time": "00:02:01"
    },
    {
      "role": "teacher",
      "text": "Come back tomorrow.",
      "zh": "明天再來。",
      "ja": "明日戻ってきてください。",
      "time": "00:02:03"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好的。",
      "ja": "わかりました。",
      "time": "00:02:06"
    },
    {
      "role": "student",
      "text": "I will think.",
      "zh": "我會考慮。",
      "ja": "考えます。",
      "time": "00:02:08"
    },
    {
      "role": "student",
      "text": "I will tell you tomorrow.",
      "zh": "明天告訴你。",
      "ja": "明日お伝えします。",
      "time": "00:02:10"
    },
    {
      "role": "teacher",
      "text": "Sure.",
      "zh": "當然。",
      "ja": "もちろんです。",
      "time": "00:02:12"
    },
    {
      "role": "student",
      "text": "Daniel, thank you for coming.",
      "zh": "丹尼爾，謝謝你來。",
      "ja": "ダニエル、来てくれてありがとう。",
      "time": "00:02:14"
    },
    {
      "role": "student",
      "text": "You look tired.",
      "zh": "你看起來很累。",
      "ja": "疲れているようですね。",
      "time": "00:02:25"
    },
    {
      "role": "student",
      "text": "Is everything okay?",
      "zh": "一切都好嗎？",
      "ja": "大丈夫ですか？",
      "time": "00:02:27"
    },
    {
      "role": "student",
      "text": "My boss spoke to me today.",
      "zh": "我老闆今天跟我說話了。",
      "ja": "今日、上司が話しかけてきました。",
      "time": "00:02:30"
    },
    {
      "role": "student",
      "text": "He said something strange.",
      "zh": "他說了奇怪的話。",
      "ja": "変なことを言われました。",
      "time": "00:02:32"
    },
    {
      "role": "student",
      "text": "Strange.",
      "zh": "奇怪。",
      "ja": "変ですね。",
      "time": "00:02:35"
    },
    {
      "role": "student",
      "text": "What did he say?",
      "zh": "他說什麼？",
      "ja": "何と言いましたか？",
      "time": "00:02:36"
    },
    {
      "role": "student",
      "text": "Come and sit.",
      "zh": "來坐下。",
      "ja": "座ってください。",
      "time": "00:02:39"
    },
    {
      "role": "student",
      "text": "I will tell you.",
      "zh": "我會告訴你。",
      "ja": "話します。",
      "time": "00:02:40"
    },
    {
      "role": "student",
      "text": "He asked me to marry his son.",
      "zh": "他叫我嫁給他的兒子。",
      "ja": "彼の息子と結婚しろと言われました。",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "What?",
      "zh": "什麼？",
      "ja": "えっ？",
      "time": "00:02:47"
    },
    {
      "role": "student",
      "text": "He said that.",
      "zh": "他就是這麼說的。",
      "ja": "そう言われました。",
      "time": "00:02:48"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:02:50"
    },
    {
      "role": "student",
      "text": "He knows about my mother.",
      "zh": "他知道我母親的情況。",
      "ja": "私の母のことを知っています。",
      "time": "00:02:52"
    },
    {
      "role": "student",
      "text": "He knows she needs treatment.",
      "zh": "他知道她需要治療。",
      "ja": "彼女が治療を必要としていることも知っています。",
      "time": "00:02:54"
    },
    {
      "role": "student",
      "text": "He knows my sister wants to go to college.",
      "zh": "他知道我妹妹想上大學。",
      "ja": "妹が大学に行きたいことも知っています。",
      "time": "00:02:57"
    },
    {
      "role": "student",
      "text": "But I can't afford her fees.",
      "zh": "但我付不起學費。",
      "ja": "でも学費を払えません。",
      "time": "00:03:01"
    },
    {
      "role": "student",
      "text": "So he wants to buy your help with marriage.",
      "zh": "所以他想用婚姻換你的幫助。",
      "ja": "だから結婚の助けを買いたいのです。",
      "time": "00:03:04"
    },
    {
      "role": "student",
      "text": "He said his son Ronald is nice.",
      "zh": "他說他的兒子羅納德很好。",
      "ja": "彼の息子ロナルドは良い人だと言いました。",
      "time": "00:03:07"
    },
    {
      "role": "student",
      "text": "Many girls say no to him because he is shy.",
      "zh": "很多女孩因為他害羞而拒絕他。",
      "ja": "彼は恥ずかしがり屋なので、多くの女の子が断ります。",
      "time": "00:03:10"
    },
    {
      "role": "student",
      "text": "And what did you say?",
      "zh": "你怎麼說？",
      "ja": "あなたは何と言いましたか？",
      "time": "00:03:14"
    },
    {
      "role": "student",
      "text": "Nothing.",
      "zh": "沒說什麼。",
      "ja": "何も言いませんでした。",
      "time": "00:03:17"
    },
    {
      "role": "student",
      "text": "I was confused.",
      "zh": "我很困惑。",
      "ja": "混乱していました。",
      "time": "00:03:18"
    },
    {
      "role": "student",
      "text": "He said I can think and answer tomorrow.",
      "zh": "他說我可以考慮明天回答。",
      "ja": "考えて明日答えていいと言われました。",
      "time": "00:03:20"
    },
    {
      "role": "student",
      "text": "And what will you say?",
      "zh": "你會怎麼說？",
      "ja": "どう答えますか？",
      "time": "00:03:24"
    },
    {
      "role": "student",
      "text": "I don't know, Daniel.",
      "zh": "我不知道，丹尼爾。",
      "ja": "わかりません、ダニエル。",
      "time": "00:03:26"
    },
    {
      "role": "student",
      "text": "I love you.",
      "zh": "我愛你。",
      "ja": "愛しています。",
      "time": "00:03:28"
    },
    {
      "role": "student",
      "text": "But my family is in trouble.",
      "zh": "但我的家人有困難。",
      "ja": "でも家族が困っています。",
      "time": "00:03:30"
    },
    {
      "role": "student",
      "text": "Listen, Sarah.",
      "zh": "聽著，莎拉。",
      "ja": "聞いて、サラ。",
      "time": "00:03:37"
    },
    {
      "role": "student",
      "text": "This can help us.",
      "zh": "這可以幫助我們。",
      "ja": "これが私たちを助けるかもしれません。",
      "time": "00:03:39"
    },
    {
      "role": "student",
      "text": "Help us?",
      "zh": "幫助我們？",
      "ja": "助けるって？",
      "time": "00:03:42"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:03:44"
    },
    {
      "role": "student",
      "text": "If you marry him, we get money.",
      "zh": "如果你嫁給他，我們就有錢。",
      "ja": "彼と結婚すれば、お金が手に入ります。",
      "time": "00:03:45"
    },
    {
      "role": "student",
      "text": "A house, cars, servants, everything.",
      "zh": "房子、車子、僕人，什麼都有。",
      "ja": "家、車、使用人、すべてです。",
      "time": "00:03:48"
    },
    {
      "role": "student",
      "text": "We can use this chance.",
      "zh": "我們可以利用這個機會。",
      "ja": "このチャンスを使いましょう。",
      "time": "00:03:52"
    },
    {
      "role": "student",
      "text": "Use this?",
      "zh": "利用這個？",
      "ja": "使うって？",
      "time": "00:03:54"
    },
    {
      "role": "student",
      "text": "Daniel, this is marriage.",
      "zh": "丹尼爾，這是婚姻。",
      "ja": "ダニエル、これは結婚です。",
      "time": "00:03:56"
    },
    {
      "role": "student",
      "text": "This is not a joke.",
      "zh": "這不是玩笑。",
      "ja": "冗談ではありません。",
      "time": "00:03:59"
    },
    {
      "role": "student",
      "text": "Not a small thing.",
      "zh": "不是小事。",
      "ja": "小さなことではありません。",
      "time": "00:04:01"
    },
    {
      "role": "student",
      "text": "And I love you.",
      "zh": "而且我愛你。",
      "ja": "そして私はあなたを愛しています。",
      "time": "00:04:03"
    },
    {
      "role": "student",
      "text": "How can I marry him?",
      "zh": "我怎麼能嫁給他？",
      "ja": "どうやって彼と結婚できますか？",
      "time": "00:04:05"
    },
    {
      "role": "student",
      "text": "You don't love him.",
      "zh": "你不愛他。",
      "ja": "彼を愛していません。",
      "time": "00:04:08"
    },
    {
      "role": "student",
      "text": "Just act nice.",
      "zh": "只要裝得好。",
      "ja": "ただ優しく振る舞って。",
      "time": "00:04:10"
    },
    {
      "role": "student",
      "text": "Take the money.",
      "zh": "拿錢。",
      "ja": "お金を受け取って。",
      "time": "00:04:12"
    },
    {
      "role": "student",
      "text": "Later, we can escape together.",
      "zh": "以後我們可以一起逃走。",
      "ja": "後で一緒に逃げましょう。",
      "time": "00:04:14"
    },
    {
      "role": "student",
      "text": "You want me to lie?",
      "zh": "你要我說謊？",
      "ja": "嘘をつけと言うの？",
      "time": "00:04:18"
    },
    {
      "role": "student",
      "text": "No, I want you to live nicely.",
      "zh": "不，我希望你過得好。",
      "ja": "いいえ、あなたに良い生活をしてほしい。",
      "time": "00:04:20"
    },
    {
      "role": "student",
      "text": "I want us to have a good life.",
      "zh": "我希望我們有好生活。",
      "ja": "私たちが良い生活を送れるように。",
      "time": "00:04:23"
    },
    {
      "role": "student",
      "text": "Just think about this.",
      "zh": "好好想想這件事。",
      "ja": "これについて考えてください。",
      "time": "00:04:26"
    },
    {
      "role": "student",
      "text": "Your mother can get the best treatment.",
      "zh": "你母親可以得到最好的治療。",
      "ja": "お母さんは最高の治療を受けられます。",
      "time": "00:04:29"
    },
    {
      "role": "student",
      "text": "Your sister can go to a nice college.",
      "zh": "你妹妹可以上好大學。",
      "ja": "妹さんは良い大学に行けます。",
      "time": "00:04:32"
    },
    {
      "role": "student",
      "text": "Yes, my mother will be able to walk again.",
      "zh": "是的，我母親會再能走路。",
      "ja": "はい、母はまた歩けるようになります。",
      "time": "00:04:36"
    },
    {
      "role": "student",
      "text": "And my sister can finally become a doctor.",
      "zh": "我妹妹終於可以成為醫生。",
      "ja": "妹はついに医者になれます。",
      "time": "00:04:40"
    },
    {
      "role": "student",
      "text": "Then say yes.",
      "zh": "那就說好吧。",
      "ja": "それならイエスと言って。",
      "time": "00:04:44"
    },
    {
      "role": "student",
      "text": "Just meet him.",
      "zh": "只要見見他。",
      "ja": "ただ彼に会ってみて。",
      "time": "00:04:46"
    },
    {
      "role": "student",
      "text": "Try it.",
      "zh": "試試看。",
      "ja": "試してみて。",
      "time": "00:04:48"
    },
    {
      "role": "student",
      "text": "We will plan everything later.",
      "zh": "我們以後再計劃一切。",
      "ja": "後で全部計画しましょう。",
      "time": "00:04:50"
    },
    {
      "role": "student",
      "text": "This feels wrong.",
      "zh": "這感覺不對。",
      "ja": "これは間違っている気がします。",
      "time": "00:04:53"
    },
    {
      "role": "student",
      "text": "It feels smart.",
      "zh": "這感覺聰明。",
      "ja": "賢い感じがします。",
      "time": "00:04:55"
    },
    {
      "role": "student",
      "text": "Trust me.",
      "zh": "相信我。",
      "ja": "信じてください。",
      "time": "00:04:58"
    },
    {
      "role": "student",
      "text": "This is our chance.",
      "zh": "這是我們的機會。",
      "ja": "これは私たちのチャンスです。",
      "time": "00:04:59"
    },
    {
      "role": "student",
      "text": "OK.",
      "zh": "好。",
      "ja": "わかりました。",
      "time": "00:05:02"
    },
    {
      "role": "student",
      "text": "I will think about it tonight.",
      "zh": "我今晚會考慮。",
      "ja": "今夜考えます。",
      "time": "00:05:03"
    },
    {
      "role": "student",
      "text": "Good.",
      "zh": "好。",
      "ja": "いいですね。",
      "time": "00:05:06"
    },
    {
      "role": "student",
      "text": "I know you will do the right thing.",
      "zh": "我知道你會做對的事。",
      "ja": "あなたが正しいことをするのを知っています。",
      "time": "00:05:07"
    }
  ]
}