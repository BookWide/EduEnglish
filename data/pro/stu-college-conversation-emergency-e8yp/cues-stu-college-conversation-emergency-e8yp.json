[
  {
    "time": "00:00:00",
    "en": "Did you call me, sir?",
    "zh": "您叫我嗎，先生？",
    "ja": "私を呼びましたか、先生？",
    "source_url": "https://www.youtube.com/watch?v=e8YPw24dhYc"
  },
  {
    "time": "00:00:08",
    "en": "Please sit down, Sarah.",
    "zh": "請坐下，莎拉。",
    "ja": "どうぞお座りください、サラ。"
  },
  {
    "time": "00:00:12",
    "en": "You are a good worker, Sarah.",
    "zh": "你是個好員工，莎拉。",
    "ja": "あなたは良い働き手です、サラ。"
  },
  {
    "time": "00:00:15",
    "en": "You always do your job well.",
    "zh": "你總是把工作做得很好。",
    "ja": "いつも仕事をきちんとこなしていますね。"
  },
  {
    "time": "00:00:18",
    "en": "Thank you, sir.",
    "zh": "謝謝您，先生。",
    "ja": "ありがとうございます、先生。"
  },
  {
    "time": "00:00:20",
    "en": "I try my best.",
    "zh": "我盡力而為。",
    "ja": "私は最善を尽くしています。"
  },
  {
    "time": "00:00:22",
    "en": "I know your mother is sick.",
    "zh": "我知道你的母親生病了。",
    "ja": "あなたのお母さんが病気だと知っています。"
  },
  {
    "time": "00:00:25",
    "en": "I also know you have a younger sister.",
    "zh": "我也知道你有個妹妹。",
    "ja": "あなたに妹がいることも知っています。"
  },
  {
    "time": "00:00:28",
    "en": "Yes, sir.",
    "zh": "是的，先生。",
    "ja": "はい、先生。"
  },
  {
    "time": "00:00:30",
    "en": "That is true.",
    "zh": "沒錯。",
    "ja": "それは本当です。"
  },
  {
    "time": "00:00:32",
    "en": "You need money.",
    "zh": "你需要錢。",
    "ja": "あなたはお金が必要ですね。"
  },
  {
    "time": "00:00:34",
    "en": "I understand.",
    "zh": "我明白。",
    "ja": "わかりました。"
  },
  {
    "time": "00:00:36",
    "en": "Life is hard.",
    "zh": "生活很艱難。",
    "ja": "人生は厳しいものです。"
  },
  {
    "time": "00:00:38",
    "en": "Yes, sometimes I don't sleep at night.",
    "zh": "是的，有時我晚上睡不著。",
    "ja": "はい、時々夜眠れません。"
  },
  {
    "time": "00:00:43",
    "en": "I worry a lot.",
    "zh": "我很擔心。",
    "ja": "とても心配しています。"
  },
  {
    "time": "00:00:45",
    "en": "I want to help you.",
    "zh": "我想幫助你。",
    "ja": "あなたを助けたい。"
  },
  {
    "time": "00:00:48",
    "en": "Help.",
    "zh": "幫助。",
    "ja": "助ける。"
  },
  {
    "time": "00:00:49",
    "en": "How?",
    "zh": "怎麼幫？",
    "ja": "どうやって？"
  },
  {
    "time": "00:00:51",
    "en": "Yes, I will help you.",
    "zh": "是的，我會幫你。",
    "ja": "はい、助けます。"
  },
  {
    "time": "00:00:53",
    "en": "But I will ask something big from you.",
    "zh": "但我會向你提出一個很大的要求。",
    "ja": "でも大きなお願いがあります。"
  },
  {
    "time": "00:00:56",
    "en": "What is it?",
    "zh": "是什麼？",
    "ja": "それは何ですか？"
  },
  {
    "time": "00:00:58",
    "en": "I want you to marry my son.",
    "zh": "我想讓你嫁給我的兒子。",
    "ja": "私の息子と結婚してほしい。"
  },
  {
    "time": "00:01:01",
    "en": "What?",
    "zh": "什麼？",
    "ja": "えっ？"
  },
  {
    "time": "00:01:02",
    "en": "Mary, your son?",
    "zh": "瑪麗，你的兒子？",
    "ja": "メアリー、あなたの息子？"
  },
  {
    "time": "00:01:05",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:01:06",
    "en": "His name is Ronald.",
    "zh": "他叫羅納德。",
    "ja": "彼の名前はロナルドです。"
  },
  {
    "time": "00:01:09",
    "en": "He is a good, kind and honest man.",
    "zh": "他是個好心、善良且誠實的人。",
    "ja": "彼は良い人で、親切で正直な男性です。"
  },
  {
    "time": "00:01:12",
    "en": "But he is shy.",
    "zh": "但他很害羞。",
    "ja": "でも彼は恥ずかしがり屋です。"
  },
  {
    "time": "00:01:14",
    "en": "Many girls say no to him.",
    "zh": "很多女孩都拒絕他。",
    "ja": "多くの女の子が彼を断ります。"
  },
  {
    "time": "00:01:17",
    "en": "But, sir, I don't know him.",
    "zh": "但是，先生，我不認識他。",
    "ja": "でも、先生、私は彼を知りません。"
  },
  {
    "time": "00:01:21",
    "en": "That is okay.",
    "zh": "沒關係。",
    "ja": "それでいいんです。"
  },
  {
    "time": "00:01:23",
    "en": "You can meet him.",
    "zh": "你可以見見他。",
    "ja": "彼に会うことができます。"
  },
  {
    "time": "00:01:25",
    "en": "Talk to him.",
    "zh": "跟他談談。",
    "ja": "彼と話してください。"
  },
  {
    "time": "00:01:26",
    "en": "Take your time to know him.",
    "zh": "慢慢了解他。",
    "ja": "ゆっくり彼を知ってください。"
  },
  {
    "time": "00:01:29",
    "en": "This is very strange.",
    "zh": "這很奇怪。",
    "ja": "これはとても変です。"
  },
  {
    "time": "00:01:31",
    "en": "Why me?",
    "zh": "為什麼是我？",
    "ja": "なぜ私なの？"
  },
  {
    "time": "00:01:33",
    "en": "Because you are kind.",
    "zh": "因為你很善良。",
    "ja": "あなたが優しいからです。"
  },
  {
    "time": "00:01:36",
    "en": "You are simple.",
    "zh": "你很單純。",
    "ja": "あなたは素直です。"
  },
  {
    "time": "00:01:38",
    "en": "You have a good heart.",
    "zh": "你有一顆善良的心。",
    "ja": "あなたは良い心を持っています。"
  },
  {
    "time": "00:01:40",
    "en": "I want someone like you for my son.",
    "zh": "我想要像你這樣的人給我兒子。",
    "ja": "私は息子にあなたのような人が欲しい。"
  },
  {
    "time": "00:01:43",
    "en": "I don't know what to say.",
    "zh": "我不知道該說什麼。",
    "ja": "何と言っていいかわかりません。"
  },
  {
    "time": "00:01:45",
    "en": "I will give you a house.",
    "zh": "我會給你一棟房子。",
    "ja": "家をあげます。"
  },
  {
    "time": "00:01:48",
    "en": "I will pay for your mother's medicine.",
    "zh": "我會支付你母親的藥費。",
    "ja": "お母さんの薬代を払います。"
  },
  {
    "time": "00:01:51",
    "en": "I will help your sister go to college.",
    "zh": "我會幫助你妹妹上大學。",
    "ja": "妹さんの大学進学を助けます。"
  },
  {
    "time": "00:01:54",
    "en": "This is a lot.",
    "zh": "這很多。",
    "ja": "これは多いです。"
  },
  {
    "time": "00:01:56",
    "en": "I am confused.",
    "zh": "我很困惑。",
    "ja": "混乱しています。"
  },
  {
    "time": "00:01:58",
    "en": "You don't have to answer now.",
    "zh": "你現在不必回答。",
    "ja": "今すぐ答える必要はありません。"
  },
  {
    "time": "00:02:01",
    "en": "Think about it.",
    "zh": "好好想想。",
    "ja": "よく考えてください。"
  },
  {
    "time": "00:02:03",
    "en": "Come back tomorrow.",
    "zh": "明天再來。",
    "ja": "明日戻ってきてください。"
  },
  {
    "time": "00:02:06",
    "en": "Okay.",
    "zh": "好的。",
    "ja": "わかりました。"
  },
  {
    "time": "00:02:08",
    "en": "I will think.",
    "zh": "我會考慮。",
    "ja": "考えます。"
  },
  {
    "time": "00:02:10",
    "en": "I will tell you tomorrow.",
    "zh": "我明天告訴你。",
    "ja": "明日お伝えします。"
  },
  {
    "time": "00:02:12",
    "en": "Sure.",
    "zh": "當然。",
    "ja": "もちろんです。"
  }
]