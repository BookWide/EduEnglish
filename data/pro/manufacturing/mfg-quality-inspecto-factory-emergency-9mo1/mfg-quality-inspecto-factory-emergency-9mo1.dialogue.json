    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "Yeah",
      "zh": "是的",
      "ja": "はい",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "I",
      "zh": "我",
      "ja": "私",
      "time": "00:00:17"
    },
    {
      "role": "student",
      "text": "I'm lost!",
      "zh": "我迷路了！",
      "ja": "迷いました！",
      "time": "00:00:19"
    },
    {
      "role": "student",
      "text": "Where's the lollipop?",
      "zh": "棒棒糖在哪裡？",
      "ja": "ロリポップはどこ？",
      "time": "00:00:26"
    },
    {
      "role": "student",
      "text": "It's just really...",
      "zh": "真的只是...",
      "ja": "本当にただ...",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "Dude, what do I do?",
      "zh": "老兄，我該怎麼辦？",
      "ja": "ねえ、どうすればいい？",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "Hell, will we stuck here forever?",
      "zh": "該死，我們會永遠被困在這裡嗎？",
      "ja": "くそ、ここにずっと閉じ込められるの？",
      "time": "00:00:32"
    },
    {
      "role": "teacher",
      "text": "Do not panic, do not panic.",
      "zh": "不要慌張，不要慌張。",
      "ja": "慌てるな、慌てるな。",
      "time": "00:00:34"
    },
    {
      "role": "teacher",
      "text": "We are trained for professionals.",
      "zh": "我們是受過專業訓練的。",
      "ja": "私たちはプロの訓練を受けている。",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "Now stay calm, we are going around the leaf.",
      "zh": "現在保持冷靜，我們要繞過葉子。",
      "ja": "さあ、落ち着いて、葉っぱの周りを回る。",
      "time": "00:00:39"
    },
    {
      "role": "student",
      "text": "Around the leaf?",
      "zh": "繞過葉子？",
      "ja": "葉っぱの周り？",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "I don't think we can do that.",
      "zh": "我覺得我們做不到。",
      "ja": "それはできないと思う。",
      "time": "00:00:44"
    },
    {
      "role": "teacher",
      "text": "Not since this is nothing compared to the twig of 93.",
      "zh": "這跟93號的小枝比起來根本不算什麼。",
      "ja": "これは93番の小枝に比べれば何でもない。",
      "time": "00:00:46"
    },
    {
      "role": "teacher",
      "text": "That's it, that's it.",
      "zh": "就是這樣，就是這樣。",
      "ja": "そうだ、その調子。",
      "time": "00:00:50"
    },
    {
      "role": "teacher",
      "text": "Good! You're doing great!",
      "zh": "很好！你做得很棒！",
      "ja": "いいぞ！よくやってる！",
      "time": "00:00:52"
    },
    {
      "role": "teacher",
      "text": "There you go, hell you go!",
      "zh": "就這樣，繼續前進！",
      "ja": "さあ、行け！",
      "time": "00:00:54"
    },
    {
      "role": "teacher",
      "text": "Watch my eyes, don't look away.",
      "zh": "看著我的眼睛，不要移開視線。",
      "ja": "私の目を見て、そらさないで。",
      "time": "00:00:57"
    },
    {
      "role": "teacher",
      "text": "And here's the line again.",
      "zh": "線又來了。",
      "ja": "そしてまた線がある。",
      "time": "00:00:59"
    },
    {
      "role": "student",
      "text": "Thank you, Mr. Sorrell.",
      "zh": "謝謝你，索雷爾先生。",
      "ja": "ありがとう、ソレルさん。",
      "time": "00:01:01"
    },
    {
      "role": "teacher",
      "text": "Good job everybody!",
      "zh": "大家做得好！",
      "ja": "みんな、よくやった！",
      "time": "00:01:04"
    },
    {
      "role": "student",
      "text": "Oh my, there's quite a gap, Mr. Sorrell.",
      "zh": "天啊，有很大的間隙，索雷爾先生。",
      "ja": "あら、かなり隙間があるね、ソレルさん。",
      "time": "00:01:06"
    },
    {
      "role": "student",
      "text": "Shouldn't we tell the queen?",
      "zh": "我們不應該告訴女王嗎？",
      "ja": "女王に知らせるべきじゃない？",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "I don't think we need to involve the queen in this.",
      "zh": "我覺得我們不需要讓女王介入這件事。",
      "ja": "これに女王を巻き込む必要はないと思う。",
      "time": "00:01:10"
    },
    {
      "role": "teacher",
      "text": "She's got enough on her plate already.",
      "zh": "她已經有很多事情要處理了。",
      "ja": "彼女はもう十分忙しい。",
      "time": "00:01:12"
    },
    {
      "role": "teacher",
      "text": "Treating her daughter.",
      "zh": "還要照顧她的女兒。",
      "ja": "娘の治療もしている。",
      "time": "00:01:14"
    },
    {
      "role": "student",
      "text": "Oh yes, Princess Adam.",
      "zh": "哦，是的，亞當公主。",
      "ja": "ああ、そうだ、アダム姫。",
      "time": "00:01:16"
    },
    {
      "role": "student",
      "text": "The poor dear.",
      "zh": "可憐的孩子。",
      "ja": "かわいそうな子。",
      "time": "00:01:18"
    }
  ]
}