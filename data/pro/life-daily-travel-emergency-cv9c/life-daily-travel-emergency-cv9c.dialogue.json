  "dialogue": [
    {
      "role": "teacher",
      "text": "English Singsing",
      "zh": "English Singsing",
      "ja": "English Singsing",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "John's daily life",
      "zh": "約翰的日常生活",
      "ja": "ジョンの日常生活",
      "time": "00:00:07"
    },
    {
      "role": "student",
      "text": "I'm going to study hard starting from today",
      "zh": "我從今天開始要努力學習",
      "ja": "今日から一生懸命勉強します",
      "time": "00:00:16"
    },
    {
      "role": "student",
      "text": "Do not disturb me",
      "zh": "不要打擾我",
      "ja": "邪魔しないでください",
      "time": "00:00:20"
    },
    {
      "role": "teacher",
      "text": "Yeah, yeah",
      "zh": "好，好",
      "ja": "うん、うん",
      "time": "00:00:23"
    },
    {
      "role": "teacher",
      "text": "Please do so",
      "zh": "請這麼做",
      "ja": "そうしてください",
      "time": "00:00:25"
    },
    {
      "role": "student",
      "text": "So, I will wake up at 6",
      "zh": "所以，我會六點起床",
      "ja": "だから、6時に起きます",
      "time": "00:00:27"
    },
    {
      "role": "student",
      "text": "And jog for an hour",
      "zh": "然後慢跑一小時",
      "ja": "そして1時間ジョギングします",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "At 6 am",
      "zh": "早上六點",
      "ja": "午前6時に",
      "time": "00:00:33"
    },
    {
      "role": "teacher",
      "text": "Aren't you usually a sleepy head in the morning?",
      "zh": "你平常早上不是很愛睏嗎？",
      "ja": "普段は朝は眠たがりじゃない？",
      "time": "00:00:36"
    },
    {
      "role": "student",
      "text": "If I plan it, I do it",
      "zh": "如果我計劃了，我就會做到",
      "ja": "計画すればやります",
      "time": "00:00:41"
    },
    {
      "role": "teacher",
      "text": "Alright, continue",
      "zh": "好，繼續說",
      "ja": "よし、続けて",
      "time": "00:00:45"
    },
    {
      "role": "student",
      "text": "Yes, how breakfast to seven",
      "zh": "是的，早餐吃到七點",
      "ja": "はい、朝食は7時まで",
      "time": "00:00:48"
    },
    {
      "role": "student",
      "text": "And go to school at eight",
      "zh": "八點去學校",
      "ja": "8時に学校へ行きます",
      "time": "00:00:51"
    },
    {
      "role": "teacher",
      "text": "Great",
      "zh": "很好",
      "ja": "素晴らしい",
      "time": "00:00:53"
    },
    {
      "role": "teacher",
      "text": "Alright, and you have classes from nine to four, right?",
      "zh": "好，你從九點上課到四點，對吧？",
      "ja": "よし、9時から4時まで授業があるんだね？",
      "time": "00:00:57"
    },
    {
      "role": "teacher",
      "text": "What's after school?",
      "zh": "放學後呢？",
      "ja": "放課後は？",
      "time": "00:01:02"
    },
    {
      "role": "student",
      "text": "Do school homework for two hours from 4 pm?",
      "zh": "下午四點開始做兩小時的功課",
      "ja": "午後4時から2時間宿題をします",
      "time": "00:01:04"
    },
    {
      "role": "student",
      "text": "Read a book from 6 to 8",
      "zh": "六點到八點讀書",
      "ja": "6時から8時まで本を読みます",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "What?",
      "zh": "什麼？",
      "ja": "え？",
      "time": "00:01:15"
    },
    {
      "role": "teacher",
      "text": "John, when are you having dinner?",
      "zh": "約翰，你什麼時候吃晚餐？",
      "ja": "ジョン、夕食はいつ食べるの？",
      "time": "00:01:17"
    },
    {
      "role": "student",
      "text": "Oh, that's right",
      "zh": "喔，對了",
      "ja": "ああ、そうだ",
      "time": "00:01:20"
    },
    {
      "role": "student",
      "text": "Dinner time at 6",
      "zh": "六點吃晚餐",
      "ja": "6時に夕食を食べます",
      "time": "00:01:22"
    },
    {
      "role": "student",
      "text": "And from 7 to 9, I will read a science magazine",
      "zh": "然後七點到九點讀科學雜誌",
      "ja": "7時から9時まで科学雑誌を読みます",
      "time": "00:01:25"
    },
    {
      "role": "teacher",
      "text": "That's a good plan, John",
      "zh": "這是個好計劃，約翰",
      "ja": "いい計画だね、ジョン",
      "time": "00:01:30"
    },
    {
      "role": "student",
      "text": "From 9, hmm",
      "zh": "九點開始，嗯",
      "ja": "9時から、うーん",
      "time": "00:01:33"
    },
    {
      "role": "student",
      "text": "Computer games, I will just play for one hour",
      "zh": "玩電腦遊戲，我只玩一小時",
      "ja": "コンピューターゲームは1時間だけします",
      "time": "00:01:36"
    },
    {
      "role": "student",
      "text": "And I will go to bed at 10",
      "zh": "然後十點睡覺",
      "ja": "そして10時に寝ます",
      "time": "00:01:40"
    },
    {
      "role": "student",
      "text": "Ta-da!",
      "zh": "噹噹！",
      "ja": "じゃーん！",
      "time": "00:01:44"
    },
    {
      "role": "student",
      "text": "What do you think of my new schedule?",
      "zh": "你覺得我的新計劃怎麼樣？",
      "ja": "私の新しいスケジュールはどう思う？",
      "time": "00:01:45"
    },
    {
      "role": "teacher",
      "text": "If you follow through with it, it will be splendid",
      "zh": "如果你能堅持下去，那會很棒",
      "ja": "続けられれば素晴らしいよ",
      "time": "00:01:49"
    },
    {
      "role": "student",
      "text": "Of course, I'll start immediately",
      "zh": "當然，我會立刻開始",
      "ja": "もちろん、すぐに始めます",
      "time": "00:01:54"
    },
    {
