  {
    "time": "00:10:23",
    "en": "I don't think so.",
    "zh": "我不這麼認為。",
    "ja": "そうは思いません。"
  },
  {
    "time": "00:10:25",
    "en": "After I finish, I'll have enough money to go to college.",
    "zh": "完成後，我會有足夠的錢上大學。",
    "ja": "終わったら、大学に行くためのお金が十分にあります。"
  },
  {
    "time": "00:10:30",
    "en": "That's not a bad idea.",
    "zh": "那不是個壞主意。",
    "ja": "悪い考えではありません。"
  },
  {
    "time": "00:10:33",
    "en": "Goodbye.",
    "zh": "再見。",
    "ja": "さようなら。"
  },
  {
    "time": "00:10:34",
    "en": "Goodbye.",
    "zh": "再見。",
    "ja": "さようなら。"
  },
  {
    "time": "00:10:38",
    "en": "How good is your math?",
    "zh": "你的數學有多好？",
    "ja": "数学はどのくらい得意ですか？"
