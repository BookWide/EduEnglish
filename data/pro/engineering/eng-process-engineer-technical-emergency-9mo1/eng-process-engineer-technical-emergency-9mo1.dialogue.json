    },
    {
      "role": "student",
      "text": "It's just really...",
      "zh": "真的很...",
      "ja": "本当に...",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "Do what do I do?",
      "zh": "我該怎麼辦？",
      "ja": "どうすればいい？",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "Hell will we stuck here forever?",
