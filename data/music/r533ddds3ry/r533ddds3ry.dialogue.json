  "dialogue": [
    {
      "role": "teacher",
      "text": "If you ever find yourself stuck in the middle of",
      "zh": "如果你發現自己被困在中間",
      "ja": "もしあなたが真ん中で立ち往生したら",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "the sea",
      "zh": "大海中間",
      "ja": "海の真ん中で",
      "time": "00:00:08"
    },
    {
      "role": "teacher",
      "text": "I'll sell the world to find you.",
      "zh": "我會賣掉全世界去找你。",
      "ja": "君を見つけるために世界を売るよ。",
      "time": "00:00:10"
    },
    {
      "role": "teacher",
      "text": "If you ever find yourself lost in the dark",
      "zh": "如果你發現自己迷失在黑暗中",
      "ja": "もし暗闇で迷ったら",
      "time": "00:00:16"
    },
    {
      "role": "teacher",
      "text": "and you can't see",
      "zh": "而且你看不見",
      "ja": "そして見えなくても",
      "time": "00:00:20"
    },
    {
      "role": "teacher",
      "text": "I'll be the light to guide",
      "zh": "我會成為指引你的光。",
      "ja": "君を導く光になるよ。",
      "time": "00:00:21"
    },
    {
      "role": "teacher",
      "text": "you.",
      "zh": "你。",
      "ja": "君を。",
      "time": "00:00:24"
    },
    {
      "role": "teacher",
      "text": "And that's what we're made of",
      "zh": "這就是我們的本質",
      "ja": "それが私たちの本質だ",
      "time": "00:00:28"
    },
    {
      "role": "teacher",
      "text": "when we are called to help our friends in need.",
      "zh": "當我們被召喚去幫助需要幫助的朋友時。",
      "ja": "困っている友達を助けるために呼ばれたとき。",
      "time": "00:00:31"
    },
    {
      "role": "teacher",
      "text": "You can't count on me like one, two, three, I'll be there.",
      "zh": "你可以像數一二三一樣依靠我，我會在那裡。",
      "ja": "1、2、3のように私を頼って、私はそこにいるよ。",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "And I know",
      "zh": "我知道",
      "ja": "そして私は知っている",
      "time": "00:00:46"
    },
    {
      "role": "teacher",
      "text": "when I need it",
      "zh": "當我需要時",
      "ja": "必要なときに",
      "time": "00:00:47"
    },
    {
      "role": "teacher",
      "text": "I can count on you like four",
      "zh": "我可以像數四",
      "ja": "4のように君を頼れる",
      "time": "00:00:49"
    },
    {
      "role": "teacher",
      "text": "three",
      "zh": "三",
      "ja": "3",
      "time": "00:00:52"
    },
    {
      "role": "teacher",
      "text": "two",
