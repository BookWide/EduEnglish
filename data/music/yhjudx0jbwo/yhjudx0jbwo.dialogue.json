  },
  "dialogue": [
    {
      "role": "teacher",
      "text": "Please listen to 'Sayonara'.",
      "zh": "請聽「さよなら」。",
      "ja": "さよなら聴いてください。",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "さよなら聴いてください。",
      "local_pron": "Sayonara kiite kudasai.",
      "ja_pron": "Sayonara kiite kudasai.",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "365 days of divine airplane",
      "zh": "365天的神飛機",
      "ja": "365日の神飛行機",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "365日の神飛行機",
      "local_pron": "Sanbyaku rokujuu go nichi no kami hikouki",
      "ja_pron": "Sanbyaku rokujuu go nichi no kami hikouki",
      "time": "00:00:03"
    },
    {
      "role": "teacher",
      "text": "Looking up at the morning sky",
      "zh": "仰望早晨的天空",
      "ja": "朝の空を見上げて",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "朝の空を見上げて",
      "local_pron": "Asa no sora o miagete",
      "ja_pron": "Asa no sora o miagete",
      "time": "00:00:23"
    },
    {
      "role": "teacher",
      "text": "So that today, this one day",
      "zh": "讓今天這一天",
      "ja": "今日という一日が",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "今日という一日が",
      "local_pron": "Kyou to iu ichinichi ga",
      "ja_pron": "Kyou to iu ichinichi ga",
      "time": "00:00:27"
    },
    {
      "role": "teacher",
      "text": "Can be spent with a smile",
      "zh": "能夠帶著笑容",
      "ja": "笑顔でいられるように",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "笑顔でいられるように",
      "local_pron": "Egao de irareru you ni",
      "ja_pron": "Egao de irareru you ni",
      "time": "00:00:31"
    },
    {
      "role": "teacher",
      "text": "I quietly made a wish",
      "zh": "我輕輕地許下願望",
      "ja": "そっとお願いした",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "そっとお願いした",
      "local_pron": "Sotto onegai shita",
      "ja_pron": "Sotto onegai shita",
      "time": "00:00:36"
    },
    {
      "role": "teacher",
      "text": "Sometimes I close my eyes",
      "zh": "有時候我也會閉上眼睛",
      "ja": "時には目もふって",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "時には目もふって",
      "local_pron": "Toki ni wa me mo futte",
      "ja_pron": "Toki ni wa me mo futte",
      "time": "00:00:41"
    },
    {
      "role": "teacher",
      "text": "And tears overflow",
      "zh": "淚水也會溢出",
      "ja": "涙も溢れるけど",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "涙も溢れるけど",
      "local_pron": "Namida mo afureru kedo",
      "ja_pron": "Namida mo afureru kedo",
      "time": "00:00:46"
    },
    {
      "role": "teacher",
      "text": "On days when things don't go as planned",
      "zh": "在事情不如預期的日子裡",
      "ja": "思い通りにならない日は",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "思い通りにならない日は",
      "local_pron": "Omoidouri ni naranai hi wa",
      "ja_pron": "Omoidouri ni naranai hi wa",
      "time": "00:00:50"
    },
    {
      "role": "teacher",
      "text": "Let's do our best tomorrow",
      "zh": "明天再加油吧",
      "ja": "明日頑張ろう",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "明日頑張ろう",
      "local_pron": "Ashita ganbarou",
      "ja_pron": "Ashita ganbarou",
      "time": "00:00:55"
    },
    {
      "role": "teacher",
      "text": "The dream I keep watching",
      "zh": "我一直在追尋的夢想",
      "ja": "ずっと見てる夢は",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "ずっと見てる夢は",
      "local_pron": "Zutto miteru yume wa",
      "ja_pron": "Zutto miteru yume wa",
      "time": "00:01:00"
    },
    {
      "role": "teacher",
      "text": "Is that I can be alone",
      "zh": "是我能夠獨自一人",
      "ja": "私がもう一人で",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "私がもう一人で",
      "local_pron": "Watashi ga mou hitori de",
      "ja_pron": "Watashi ga mou hitori de",
      "time": "00:01:04"
    },
    {
      "role": "teacher",
      "text": "Do what I want to do as I like",
      "zh": "隨心所欲地做想做的事",
      "ja": "焼いたいこと好きなように",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "焼いたいこと好きなように",
      "local_pron": "Yakitai koto suki na you ni",
      "ja_pron": "Yakitai koto suki na you ni",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "A dream to be free",
      "zh": "自由自在的夢想",
      "ja": "自由にできる夢",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "自由にできる夢",
      "local_pron": "Jiyuu ni dekiru yume",
      "ja_pron": "Jiyuu ni dekiru yume",
      "time": "00:01:13"
    },
    {
      "role": "teacher",
      "text": "Life is a divine airplane",
      "zh": "人生是神飛機",
      "ja": "人生は神飛行機",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "人生は神飛行機",
      "local_pron": "Jinsei wa kami hikouki",
      "ja_pron": "Jinsei wa kami hikouki",
      "time": "00:01:17"
    },
    {
      "role": "teacher",
      "text": "Flying with wishes on board",
      "zh": "承載著願望飛翔",
      "ja": "願いのせて飛んでいくよ",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "願いのせて飛んでいくよ",
      "local_pron": "Negai nosete tonde iku yo",
      "ja_pron": "Negai nosete tonde iku yo",
      "time": "00:01:22"
    },
    {
      "role": "teacher",
      "text": "With all my strength in the wind",
      "zh": "在風中用盡全力",
      "ja": "風の中を力の限り",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "風の中を力の限り",
      "local_pron": "Kaze no naka o chikara no kagiri",
      "ja_pron": "Kaze no naka o chikara no kagiri",
      "time": "00:01:27"
    },
    {
      "role": "teacher",
      "text": "Just keep moving forward",
      "zh": "只是一直前進",
      "ja": "ただ進むだけ",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "ただ進むだけ",
      "local_pron": "Tada susumu dake",
      "ja_pron": "Tada susumu dake",
      "time": "00:01:32"
    },
    {
      "role": "teacher",
      "text": "Competing for the distance",
      "zh": "像是在競爭距離",
      "ja": "その距離を競うように",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "その距離を競うように",
      "local_pron": "Sono kyori o kisou you ni",
      "ja_pron": "Sono kyori o kisou you ni",
      "time": "00:01:36"
    },
    {
      "role": "teacher",
      "text": "Where did I fly? Where did I fly?",
      "zh": "飛到哪裡了？飛到哪裡了？",
      "ja": "飛んだかどこ飛んだのか",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "飛んだかどこ飛んだのか",
      "local_pron": "Tonda ka doko tonda no ka",
      "ja_pron": "Tonda ka doko tonda no ka",
      "time": "00:01:40"
    },
    {
      "role": "teacher",
      "text": "That is the most important thing",
      "zh": "那才是最重要的",
      "ja": "それが一番大切なんだ",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "それが一番大切なんだ",
      "local_pron": "Sore ga ichiban taisetsu nanda",
      "ja_pron": "Sore ga ichiban taisetsu nanda",
      "time": "00:01:46"
    },
    {
      "role": "teacher",
      "text": "Now, follow your heart",
      "zh": "現在，隨著心走吧",
      "ja": "さあ心のままに",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "さあ心のままに",
      "local_pron": "Saa kokoro no mama ni",
      "ja_pron": "Saa kokoro no mama ni",
      "time": "00:01:51"
    },
