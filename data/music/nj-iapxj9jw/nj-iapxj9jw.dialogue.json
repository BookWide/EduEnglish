      "ko_pron": "Saenggakman haedo nunmuri na",
      "time": "00:00:23"
    },
    {
      "role": "student",
      "text": "The one who protected me through time",
      "zh": "守護我的人",
      "ja": "시간 날 지켜준 사람",
      "local_lang": "ko",
      "local_label": "韓文",
      "local": "시간 날 지켜준 사람",
