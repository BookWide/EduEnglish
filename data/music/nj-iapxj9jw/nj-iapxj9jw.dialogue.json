      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "This is",
      "zh": "這是",
      "ja": "이건",
      "local_lang": "ko",
      "local_label": "韓文",
      "local": "이건",
      "local_pron": "Igeon",
      "ko": "이건",
      "ko_pron": "Igeon",
      "time": "00:00:10"
    },
    {
      "role": "student",
      "text": "Can I smile without you?",
      "zh": "沒有你我能笑嗎？",
      "ja": "니가 없이 웃을 수 있을까",
      "local_lang": "ko",
      "local_label": "韓文",
      "local": "니가 없이 웃을 수 있을까",
