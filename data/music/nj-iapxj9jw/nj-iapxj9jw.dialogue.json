      "ko_pron": "Sigan nal jikyeojun saram",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "Now I will protect you",
      "zh": "現在我會守護你",
      "ja": "이제는 내가 그대 지킬 테니",
