      "ko_pron": "Neoui pumeun hangsang ttatteuthaesseo",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "In my weary day",
      "zh": "在我疲憊的一天裡",
      "ja": "고단했던 나의 하루에",
      "local_lang": "ko",
      "local_label": "韓文",
      "local": "고단했던 나의 하루에",
