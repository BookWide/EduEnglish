  "dialogue": [
    {
      "role": "student",
      "text": "Hail of ice",
      "zh": "冰雹",
      "ja": "氷の雹",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "hail of ice Every morning you greet me",
      "zh": "冰雹 每天早晨你迎接我",
      "ja": "氷の雹 毎朝あなたは私を迎える",
      "time": "00:00:07"
    },
    {
      "role": "student",
      "text": "Small",
      "zh": "小小的",
      "ja": "小さい",
      "time": "00:00:26"
    },
    {
      "role": "student",
      "text": "and white",
      "zh": "又白",
      "ja": "そして白い",
      "time": "00:00:27"
    },
    {
      "role": "student",
      "text": "clean",
      "zh": "乾淨",
      "ja": "きれいな",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "and bright You look happy to meet me",
      "zh": "又明亮 你看起來很高興見到我",
      "ja": "そして明るい あなたは私に会えて嬉しそう",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "Blossom of snow",
      "zh": "雪之花",
      "ja": "雪の花",
      "time": "00:00:41"
    },
    {
      "role": "student",
      "text": "may you bloom",
      "zh": "願你綻放",
      "ja": "咲きますように",
      "time": "00:00:44"
    },
    {
      "role": "student",
      "text": "and grow Bloom",
      "zh": "並成長 綻放",
      "ja": "そして育つ 咲いて",
      "time": "00:00:48"
    },
    {
      "role": "student",
      "text": "and grow forever",
      "zh": "並永遠成長",
      "ja": "そして永遠に育つ",
      "time": "00:00:52"
    },
    {
      "role": "student",
      "text": "Hail of ice, hail of ice Bless my homeland forever",
      "zh": "冰雹，冰雹 永遠保佑我的家鄉",
      "ja": "氷の雹、氷の雹 私の故郷を永遠に祝福して",
      "time": "00:00:55"
    },
