  "dialogue": [
    {
      "role": "teacher",
      "text": "in the sense of evening",
      "zh": "在傍晚的感覺中",
      "ja": "夕方の感覚の中で",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "The sense of the evening",
      "zh": "傍晚的感覺",
      "ja": "夕方の感覚",
      "time": "00:00:25"
    },
    {
      "role": "teacher",
      "text": "When the world is fast asleep",
      "zh": "當世界沉睡時",
      "ja": "世界がぐっすり眠っているとき",
      "time": "00:00:31"
    },
    {
      "role": "teacher",
      "text": "I still hear your gentle whisper",
      "zh": "我仍聽見你輕柔的耳語",
      "ja": "あなたの優しいささやきがまだ聞こえる",
      "time": "00:00:37"
    },
    {
      "role": "teacher",
      "text": "Come softly from my dreams",
      "zh": "輕輕地從我的夢中來",
      "ja": "私の夢からそっとやってくる",
      "time": "00:00:43"
    },
    {
      "role": "teacher",
      "text": "Every moment that we shared",
      "zh": "我們共享的每一刻",
      "ja": "私たちが共有したすべての瞬間",
      "time": "00:00:50"
    },
    {
      "role": "teacher",
      "text": "Still lives inside my heart",
      "zh": "仍然活在我心中",
      "ja": "まだ私の心の中に生きている",
      "time": "00:00:57"
    },
    {
      "role": "teacher",
      "text": "Even though we're far away",
      "zh": "即使我們相隔遙遠",
      "ja": "たとえ私たちが遠く離れていても",
      "time": "00:01:03"
    },
    {
      "role": "teacher",
      "text": "I love whom there's a part",
      "zh": "我愛著你的一部分",
      "ja": "私はあなたの一部を愛している",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "Time may change the roads we take",
      "zh": "時間可能改變我們走的路",
      "ja": "時間は私たちが進む道を変えるかもしれない",
      "time": "00:01:16"
    },
    {
      "role": "teacher",
      "text": "And where I'll let you go",
      "zh": "以及我讓你去的地方",
      "ja": "そして私があなたを行かせる場所",
      "time": "00:01:19"
    },
    {
      "role": "teacher",
      "text": "But there's one thing in my heart",
      "zh": "但我心中有一件事",
      "ja": "でも私の心には一つのことがある",
      "time": "00:01:22"
    },
    {
      "role": "teacher",
      "text": "I hope you always know",
      "zh": "我希望你永遠知道",
      "ja": "あなたがいつも知っていることを願う",
      "time": "00:01:25"
    },
    {
      "role": "teacher",
      "text": "I will always love you",
      "zh": "我將永遠愛你",
      "ja": "私はいつもあなたを愛しています",
      "time": "00:01:30"
    },
    {
      "role": "teacher",
      "text": "No matter where you are",
      "zh": "無論你身在何處",
      "ja": "あなたがどこにいても",
      "time": "00:01:33"
    },
    {
      "role": "teacher",
      "text": "Through the endless distance",
      "zh": "穿越無盡的距離",
      "ja": "果てしない距離を越えて",
      "time": "00:01:37"
    },
    {
      "role": "teacher",
      "text": "Under every star",
      "zh": "在每一顆星星下",
      "ja": "すべての星の下で",
      "time": "00:01:41"
    },
    {
      "role": "teacher",
      "text": "Even if tomorrow",
      "zh": "即使明天",
      "ja": "たとえ明日",
      "time": "00:01:43"
    },
    {
      "role": "teacher",
      "text": "Takes you far away",
      "zh": "帶你遠走高飛",
      "ja": "あなたを遠くへ連れて行っても",
      "time": "00:01:47"
    },
    {
      "role": "teacher",
      "text": "My heart will still be yours",
      "zh": "我的心仍屬於你",
      "ja": "私の心はまだあなたのものです",
      "time": "00:01:50"
    },
    {
      "role": "teacher",
      "text": "Forever and a day",
      "zh": "永遠不變",
      "ja": "永遠に、そしてもう一日",
      "time": "00:01:55"
    },
    {
      "role": "teacher",
      "text": "I remember all you left to",
      "zh": "我記得你留下的一切",
      "ja": "あなたが残したすべてを覚えている",
      "time": "00:02:10"
    },
    {
      "role": "teacher",
      "text": "Like a melody so sweet",
      "zh": "像一首如此甜美的旋律",
      "ja": "とても甘いメロディのように",
      "time": "00:02:25"
    },
    {
      "role": "teacher",
      "text": "Every tear and every promise",
      "zh": "每一滴淚水和每一個承諾",
      "ja": "すべての涙とすべての約束",
      "time": "00:02:33"
    },
    {
      "role": "teacher",
      "text": "Every heartbeat that we need",
      "zh": "我們需要的每一次心跳",
      "ja": "私たちが必要とするすべての鼓動",
      "time": "00:02:40"
    },
    {
      "role": "teacher",
      "text": "Though the seasons keep on turning",
      "zh": "雖然季節不停轉換",
      "ja": "季節が回り続けても",
      "time": "00:02:47"
    },
    {
      "role": "teacher",
      "text": "Hellies keep passing by",
      "zh": "日子不停流逝",
      "ja": "日々が過ぎ去っていく",
      "time": "00:02:53"
    },
    {
      "role": "teacher",
      "text": "You're the dream I keep believing",
      "zh": "你是我一直相信的夢想",
      "ja": "あなたは私が信じ続ける夢です",
      "time": "00:03:00"
    },
    {
      "role": "teacher",
      "text": "You're the reason that I try",
      "zh": "你是我努力的理由",
      "ja": "あなたは私が頑張る理由です",
      "time": "00:03:06"
    },
    {
      "role": "teacher",
      "text": "Like mainly the stiffer in ways",
      "zh": "像主要的堅持方式",
      "ja": "主に堅くなるような方法で",
      "time": "00:03:12"
    },
    {
      "role": "teacher",
      "text": "Across the open sky",
      "zh": "穿越開闊的天空",
      "ja": "広い空を越えて",
      "time": "00:03:15"
    },
    {
      "role": "teacher",
      "text": "But my love will stay the same",
      "zh": "但我的愛將保持不變",
      "ja": "でも私の愛は変わらない",
      "time": "00:03:18"
    },
    {
      "role": "teacher",
      "text": "No matter how I always love you",
      "zh": "無論如何我永遠愛你",
      "ja": "どんなにしても私はいつもあなたを愛しています",
      "time": "00:03:21"
    },
    {
      "role": "teacher",
      "text": "No matter where you are",
      "zh": "無論你身在何處",
      "ja": "あなたがどこにいても",
      "time": "00:03:29"
    },
    {
      "role": "teacher",
      "text": "Through the endless distance",
      "zh": "穿越無盡的距離",
      "ja": "果てしない距離を越えて",
      "time": "00:03:33"
    },
    {
      "role": "teacher",
      "text": "Under every star",
      "zh": "在每一顆星星下",
      "ja": "すべての星の下で",
      "time": "00:03:37"
    },
    {
      "role": "teacher",
      "text": "Even if tomorrow",
      "zh": "即使明天",
      "ja": "たとえ明日",
      "time": "00:03:40"
    },
    {
      "role": "teacher",
      "text": "Takes you far away",
      "zh": "帶你遠走高飛",
      "ja": "あなたを遠くへ連れて行っても",
      "time": "00:03:43"
    },
    {
      "role": "teacher",
      "text": "My heart will still be yours",
      "zh": "我的心仍屬於你",
      "ja": "私の心はまだあなたのものです",
      "time": "00:03:46"
    },
    {
      "role": "teacher",
      "text": "Forever and a day",
      "zh": "永遠不變",
      "ja": "永遠に、そしてもう一日",
      "time": "00:03:51"
    },
    {
      "role": "teacher",
      "text": "If some day you feel alone",
      "zh": "如果有一天你感到孤單",
      "ja": "もしある日あなたが孤独を感じたら",
      "time": "00:03:58"
    },
    {
      "role": "teacher",
      "text": "And the life feels cold and blue",
      "zh": "生活感覺寒冷且憂鬱",
      "ja": "そして人生が冷たく青く感じるとき",
      "time": "00:04:11"
    },
    {
      "role": "teacher",
      "text": "Just forever and a day",
      "zh": "就永遠和多一天",
      "ja": "ただ永遠に、そしてもう一日",
      "time": "00:04:14"
    },
    {
      "role": "teacher",
      "text": "My heart beats just for you",
      "zh": "我的心只為你跳動",
      "ja": "私の心はただあなたのために鼓動している",
      "time": "00:04:19"
    },
    {
      "role": "teacher",
      "text": "I will always love you",
      "zh": "我將永遠愛你",
      "ja": "私はいつもあなたを愛しています",
      "time": "00:04:27"
    },
    {
      "role": "teacher",
      "text": "More than words to show",
      "zh": "超過言語所能表達",
      "ja": "言葉以上に示す",
      "time": "00:04:32"
    },
    {
      "role": "teacher",
      "text": "You're the light inside my soul",
      "zh": "你是我靈魂中的光",
      "ja": "あなたは私の魂の中の光です",
      "time": "00:04:35"
    },
    {
      "role": "teacher",
      "text": "Be your only love at night",
      "zh": "成為你夜晚唯一的愛",
      "ja": "夜にあなたの唯一の愛であること",
      "time": "00:04:38"
    },
    {
      "role": "teacher",
      "text": "The world's face",
      "zh": "世界的面貌",
      "ja": "世界の顔",
      "time": "00:04:42"
    },
    {
      "role": "teacher",
      "text": "And the skies turn gray",
      "zh": "天空變得灰暗",
      "ja": "空が灰色に変わる",
      "time": "00:04:45"
    },
    {
      "role": "teacher",
      "text": "My love will stay with you",
      "zh": "我的愛將與你同在",
      "ja": "私の愛はあなたと共にあります",
      "time": "00:04:48"
    },
    {
      "role": "teacher",
      "text": "Forever and a day",
      "zh": "永遠不變",
      "ja": "永遠に、そしてもう一日",
      "time": "00:04:53"
    }
  ]
