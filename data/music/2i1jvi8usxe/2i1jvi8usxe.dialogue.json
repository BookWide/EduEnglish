  "dialogue": [
    {
      "role": "teacher",
      "text": "Are you still there?",
      "zh": "你還在嗎？",
      "ja": "まだそこにいる？",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "I never left.",
      "zh": "我從未離開。",
      "ja": "私はずっとここにいるよ。",
      "time": "00:00:07"
    },
    {
      "role": "teacher",
      "text": "Then why does every night feel so far away?",
      "zh": "那為什麼每個夜晚感覺如此遙遠？",
      "ja": "じゃあ、なぜ毎晩がこんなに遠く感じるの？",
      "time": "00:00:09"
    },
    {
      "role": "student",
      "text": "Because I'm holding you in a place time can't reach.",
      "zh": "因為我把你抱在時間無法觸及的地方。",
      "ja": "それは、時間が届かない場所であなたを抱きしめているから。",
      "time": "00:00:14"
    },
    {
      "role": "teacher",
      "text": "Hmmm...",
      "zh": "嗯……",
      "ja": "うーん…",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "Hmmm...",
      "zh": "嗯……",
      "ja": "うーん…",
      "time": "00:00:29"
    },
    {
      "role": "student",
      "text": "Rain traces your name.",
      "zh": "雨水描繪你的名字。",
      "ja": "雨があなたの名前をなぞる。",
      "time": "00:00:32"
    },
    {
      "role": "student",
      "text": "Sky remembers love's flame.",
      "zh": "天空記得愛的火焰。",
      "ja": "空は愛の炎を覚えている。",
      "time": "00:00:35"
    },
    {
      "role": "student",
      "text": "I sit where laughter died.",
      "zh": "我坐在笑聲消逝的地方。",
      "ja": "笑いが消えた場所に座っている。",
      "time": "00:00:39"
    },
    {
      "role": "student",
      "text": "Walls whisper shadows hide.",
      "zh": "牆壁低語著影子藏匿。",
      "ja": "壁が囁く、影が隠れていると。",
      "time": "00:00:42"
    },
    {
      "role": "student",
      "text": "Your voice and silence cause.",
      "zh": "你的聲音與沉默引起。",
      "ja": "あなたの声と沈黙が引き起こす。",
      "time": "00:00:46"
    },
    {
      "role": "student",
      "text": "They threw the night for.",
      "zh": "他們為夜晚而投擲。",
      "ja": "彼らは夜を投げた。",
      "time": "00:00:50"
    },
    {
      "role": "student",
      "text": "In light warms my skin.",
      "zh": "光線溫暖我的肌膚。",
      "ja": "光が私の肌を温める。",
      "time": "00:00:55"
    },
    {
      "role": "student",
      "text": "Old words quiet when I keep you in sleep.",
      "zh": "當我讓你沉睡時，舊語句變得安靜。",
      "ja": "あなたを眠らせると古い言葉は静かになる。",
      "time": "00:00:59"
    },
    {
      "role": "student",
      "text": "Memories promises I keep.",
      "zh": "我守護著記憶與承諾。",
      "ja": "私は記憶と約束を守る。",
      "time": "00:01:04"
    },
    {
      "role": "student",
      "text": "Even silence speaks your name.",
      "zh": "即使沉默也呼喚你的名字。",
      "ja": "沈黙さえもあなたの名前を語る。",
      "time": "00:01:08"
    },
    {
      "role": "student",
      "text": "You're my only thing, you're my only one.",
      "zh": "你是我唯一的存在，你是我唯一的人。",
      "ja": "あなたは私の唯一のもの、私のただ一人。",
      "time": "00:01:12"
    },
    {
      "role": "student",
      "text": "The stars lose their glow.",
      "zh": "星星失去了光芒。",
      "ja": "星は輝きを失う。",
      "time": "00:01:18"
    },
    {
      "role": "student",
      "text": "You're my only one.",
      "zh": "你是我唯一的人。",
      "ja": "あなたは私のただ一人。",
      "time": "00:01:21"
    },
    {
      "role": "student",
      "text": "You call that phone call.",
      "zh": "你打那通電話。",
      "ja": "あなたはその電話をかける。",
      "time": "00:01:24"
    },
    {
      "role": "student",
      "text": "It loves the road we run.",
      "zh": "它愛著我們奔跑的道路。",
      "ja": "それは私たちが走る道を愛している。",
      "time": "00:01:29"
    },
    {
      "role": "student",
      "text": "How I walk in your mind.",
      "zh": "我如何走進你的心中。",
      "ja": "私はあなたの心の中を歩く。",
      "time": "00:01:32"
    },
    {
      "role": "student",
      "text": "You're my only one.",
      "zh": "你是我唯一的人。",
      "ja": "あなたは私のただ一人。",
      "time": "00:01:38"
    },
    {
      "role": "student",
      "text": "Passway hand touched my in street lights.",
      "zh": "路過的手觸碰我，在街燈下。",
      "ja": "通り過ぎる手が街灯の中で私に触れた。",
      "time": "00:01:47"
    },
    {
      "role": "student",
      "text": "Fade like stolen time.",
      "zh": "像被偷走的時間般消逝。",
      "ja": "盗まれた時間のように消えていく。",
      "time": "00:01:52"
    },
    {
      "role": "student",
      "text": "It was still yet you stayed.",
      "zh": "它依然存在，而你依舊停留。",
      "ja": "それはまだあった、でもあなたは残った。",
      "time": "00:01:54"
    },
    {
      "role": "student",
      "text": "Your love won't ever fade.",
      "zh": "你的愛永不消逝。",
      "ja": "あなたの愛は決して消えない。",
      "time": "00:01:56"
    },
    {
      "role": "student",
      "text": "Your the calm I came.",
      "zh": "你是我來到的寧靜。",
      "ja": "あなたは私が来た静けさ。",
      "time": "00:01:58"
    },
    {
      "role": "student",
      "text": "Hear this love I say.",
      "zh": "聽我說這份愛。",
      "ja": "この愛を聞いてほしい。",
      "time": "00:02:02"
    },
    {
      "role": "student",
      "text": "I try moving on.",
      "zh": "我試著繼續前行。",
      "ja": "私は前に進もうとする。",
      "time": "00:02:07"
    },
    {
      "role": "student",
      "text": "Don't feel cold, love gone.",
      "zh": "不要感覺寒冷，愛並未消失。",
      "ja": "冷たさを感じない、愛は消えていない。",
      "time": "00:02:10"
    },
    {
      "role": "student",
      "text": "But in every new sky shadow never died.",
      "zh": "但在每個新天空中，影子從未消逝。",
      "ja": "しかし新しい空の中で影は決して死なない。",
      "time": "00:02:13"
    },
    {
      "role": "student",
      "text": "You're my only one.",
      "zh": "你是我唯一的人。",
      "ja": "あなたは私のただ一人。",
      "time": "00:02:17"
    },
    {
      "role": "student",
      "text": "Time can't undo what's begun.",
      "zh": "時間無法抹去已開始的事。",
      "ja": "時間は始まったことを取り消せない。",
      "time": "00:02:20"
    },
    {
      "role": "student",
      "text": "You're my only one.",
      "zh": "你是我唯一的人。",
      "ja": "あなたは私のただ一人。",
      "time": "00:02:25"
