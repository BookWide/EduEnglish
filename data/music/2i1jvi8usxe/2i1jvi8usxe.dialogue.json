    },
    {
      "role": "student",
      "text": "You're my only one.",
      "zh": "你是我唯一的人。",
      "ja": "あなたは私のただ一人。",
      "time": "00:04:39"
    },
    {
      "role": "student",
      "text": "Will you remember me?",
      "zh": "你會記得我嗎？",
      "ja": "私のことを覚えていてくれる？",
      "time": "00:04:44"
    },
    {
      "role": "student",
      "text": "I remember you always.",
      "zh": "我永遠記得你。",
      "ja": "私はいつもあなたを覚えている。",
      "time": "00:04:47"
    },
    {
      "role": "student",
      "text": "And if we never meet again.",
      "zh": "如果我們再也不相見。",
      "ja": "もしまた会えなくても。",
      "time": "00:04:51"
    },
    {
      "role": "student",
      "text": "I love you from far.",
      "zh": "我從遠方愛著你。",
      "ja": "遠くからあなたを愛している。",
      "time": "00:04:54"
    }
