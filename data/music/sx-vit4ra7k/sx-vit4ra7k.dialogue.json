  "dialogue": [
    {
      "role": "student",
      "text": "Yumena-nara-ba, dore-ho-do, yoka-pare, shou,",
      "zh": "如果是夢的話，該有多好啊，",
      "ja": "夢ならば、どれほどよかったでしょう、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "夢ならば、どれほどよかったでしょう、",
      "local_pron": "Yumena naraba, dore hodo yokatta deshou,",
      "ja_pron": "Yumena naraba, dore hodo yokatta deshou,",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Ima-dan, niyana-tan, no koto-wo, yume-ni-minu,",
      "zh": "現在的你，沒有在夢中見過，",
      "ja": "今だにあなたのことを夢に見ぬ、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "今だにあなたのことを夢に見ぬ、",
      "local_pron": "Imadani anata no koto o yume ni minu,",
      "ja_pron": "Imadani anata no koto o yume ni minu,",
      "time": "00:00:08"
    },
    {
      "role": "student",
      "text": "Vasreta-mono-to-ri-ni-kai-ru-yomi,",
      "zh": "拾起遺失的東西，重複讀著，",
      "ja": "忘れた物取りに帰る夜み、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "忘れた物取りに帰る夜み、",
      "local_pron": "Wasureta mono tori ni kaeru yomi,",
      "ja_pron": "Wasureta mono tori ni kaeru yomi,",
      "time": "00:00:13"
    },
    {
      "role": "student",
      "text": "Hrudita-mo-hi-deno-ko-ri-wo-hala.",
      "zh": "心也被冰冷的寒氣包圍著。",
      "ja": "心田も氷出の凍りを張ら。",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "心田も氷出の凍りを張ら。",
      "local_pron": "Shinden mo koori no kori o hara.",
      "ja_pron": "Shinden mo koori no kori o hara.",
      "time": "00:00:19"
    },
    {
      "role": "student",
      "text": "Mobo-an-an-ishi-abase-ga-ru-komoto,",
      "zh": "模糊的記憶在心中搖晃，",
      "ja": "朧な記憶揺らぐ事、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "朧な記憶揺らぐ事、",
      "local_pron": "Oboro na kioku yuragu koto,",
      "ja_pron": "Oboro na kioku yuragu koto,",
      "time": "00:00:27"
    },
    {
      "role": "student",
      "text": "Saibon-ni-an-tan, dao-shien, te-kure-ta,",
      "zh": "細胞裡你曾經幫助我，",
      "ja": "細胞にあなた助けてくれた、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "細胞にあなた助けてくれた、",
      "local_pron": "Saibou ni anata tasukete kureta,",
      "ja_pron": "Saibou ni anata tasukete kureta,",
      "time": "00:00:33"
    },
    {
      "role": "student",
      "text": "Yetsu-ni-kaku-shi-peta, kurai-ka-komo,",
      "zh": "隱藏著的痛苦，像黑暗籠罩，",
      "ja": "血に隠しぺた、暗いかこも、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "血に隠しぺた、暗いかこも、",
      "local_pron": "Chi ni kakushi peta, kurai kakomo,",
      "ja_pron": "Chi ni kakushi peta, kurai kakomo,",
      "time": "00:00:38"
    },
    {
      "role": "student",
      "text": "Anakanda-imakai, yume-ni-kurai-mama,",
      "zh": "在夢中仍然沉浸於黑暗，",
      "ja": "穴かんだ今界、夢に暗いまま、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "穴かんだ今界、夢に暗いまま、",
      "local_pron": "Anakanda imakai, yume ni kurai mama,",
      "ja_pron": "Anakanda imakai, yume ni kurai mama,",
      "time": "00:00:44"
    },
    {
      "role": "student",
      "text": "Hitomo-kora-hi-zō-ki-zutututoto-nato,",
      "zh": "人們的心像火焰般燃燒，",
      "ja": "人も心火像きずつつととなと、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "人も心火像きずつつととなと、",
      "local_pron": "Hito mo kokoro hi zouki tsuttsuto nato,",
      "ja_pron": "Hito mo kokoro hi zouki tsuttsuto nato,",
      "time": "00:00:50"
    },
    {
      "role": "student",
      "text": "Auri-wa-shina-ito-waka-te-ru,",
      "zh": "愛理已經年輕逝去，",
      "ja": "愛理は死な糸若てる、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "愛理は死な糸若てる、",
      "local_pron": "Airi wa shina ito wakateru,",
      "ja_pron": "Airi wa shina ito wakateru,",
      "time": "00:00:55"
    },
    {
      "role": "student",
      "text": "Aoriho-kara-shimi-sae, Aoriho-fudu-shimi-sae,",
      "zh": "從青葉到不動，滲透著悲傷，",
      "ja": "青葉から染みさえ、青葉不動染みさえ、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "青葉から染みさえ、青葉不動染みさえ、",
      "local_pron": "Aoba kara shimi sae, aoba fudou shimi sae,",
      "ja_pron": "Aoba kara shimi sae, aoba fudou shimi sae,",
      "time": "00:01:00"
    },
    {
      "role": "student",
      "text": "Somosubet-te-bo, Aishita-nada-koko-moni,",
      "zh": "即使失去一切，我仍愛著這片海，",
      "ja": "全てでも、愛したなだここに、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "全てでも、愛したなだここに、",
      "local_pron": "Subete demo, aishita nada koko ni,",
      "ja_pron": "Subete demo, aishita nada koko ni,",
      "time": "00:01:05"
    },
    {
      "role": "student",
      "text": "Guna-nido-kuri-hana-wenai,",
      "zh": "不會再重複那悲傷的花，",
      "ja": "二度繰り返さない、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "二度繰り返さない、",
      "local_pron": "Nido kurikaesanai,",
      "ja_pron": "Nido kurikaesanai,",
      "time": "00:01:11"
    },
    {
      "role": "student",
      "text": "Inigayama-om no hi-boi,",
      "zh": "稻荷山的火焰，",
      "ja": "稲荷山の火焔、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "稲荷山の火焔、",
      "local_pron": "Inariyama no hoen,",
      "ja_pron": "Inariyama no hoen,",
      "time": "00:01:14"
    },
    {
      "role": "student",
      "text": "Aumeka-huri-anumare-washta-ere-na-i,",
      "zh": "不會忘記那曾經的誓言，",
      "ja": "誓い振り生まれ忘れ得ない、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "誓い振り生まれ忘れ得ない、",
      "local_pron": "Chikai furi umare wasure enai,",
      "ja_pron": "Chikai furi umare wasure enai,",
      "time": "00:01:17"
    },
    {
      "role": "student",
      "text": "Inigayama-om no hi-boi,",
      "zh": "稻荷山的火焰，",
      "ja": "稲荷山の火焔、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "稲荷山の火焔、",
      "local_pron": "Inariyama no hoen,",
      "ja_pron": "Inariyama no hoen,",
      "time": "00:01:22"
    },
    {
      "role": "student",
      "text": "Inigayama-om no hi-boi,",
      "zh": "稻荷山的火焰，",
      "ja": "稲荷山の火焔、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "稲荷山の火焔、",
      "local_pron": "Inariyama no hoen,",
      "ja_pron": "Inariyama no hoen,",
      "time": "00:01:26"
    },
    {
      "role": "student",
      "text": "Kurai-ami-de-anakanu, Saibon-asou-ota,",
      "zh": "在黑暗中無法相見，細胞也在哭泣，",
      "ja": "暗い闇で会えず、細胞嘆く歌、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "暗い闇で会えず、細胞嘆く歌、",
      "local_pron": "Kurai yami de a ezu, saibou nageku uta,",
      "ja_pron": "Kurai yami de a ezu, saibou nageku uta,",
      "time": "00:01:39"
    },
    {
      "role": "student",
      "text": "Sonori-nikaku-se-meni-obou-e-te-ru,",
      "zh": "那樣的記憶深深烙印在心中，",
      "ja": "その記憶背に負うえてる、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "その記憶背に負うえてる、",
      "local_pron": "Sono kioku se ni oueteru,",
      "ja_pron": "Sono kioku se ni oueteru,",
      "time": "00:01:44"
    },
    {
      "role": "student",
      "text": "Uketou-me-ki-wenai-mono-be-anutabi,",
      "zh": "接受著無法忘記的東西，",
      "ja": "受け止めきれないものべ歩旅、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "受け止めきれないものべ歩旅、",
      "local_pron": "Uketome kirenai mono be anutabi,",
      "ja_pron": "Uketome kirenai mono be anutabi,",
      "time": "00:01:50"
    },
    {
      "role": "student",
      "text": "Aurete-yamanai-no-anami-tanaka,",
      "zh": "不停止的淚水在田中流淌，",
      "ja": "あふれてやまないの涙田中、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "あふれてやまないの涙田中、",
      "local_pron": "Afurete yamanai no namida Tanaka,",
      "ja_pron": "Afurete yamanai no namida Tanaka,",
      "time": "00:01:55"
    },
    {
      "role": "student",
      "text": "Na-ri-moshite-tano, Na-ri-omite-tano,",
      "zh": "成為了你，成為了我，",
      "ja": "なりもしてたの、なりおみてたの、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "なりもしてたの、なりおみてたの、",
      "local_pron": "Nari mo shiteta no, nari omiteta no,",
      "ja_pron": "Nari mo shiteta no, nari omiteta no,",
      "time": "00:02:01"
    },
    {
      "role": "student",
      "text": "Sato-shina-shiranai-okou-gahou-re,",
      "zh": "不知故鄉的我，",
      "ja": "里知らない故郷がほれ、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "里知らない故郷がほれ、",
      "local_pron": "Sato shiranai kokyou gahore,",
      "ja_pron": "Sato shiranai kokyou gahore,",
      "time": "00:02:07"
    },
    {
      "role": "student",
      "text": "Nokokare-ana-tagahima,",
      "zh": "剩下的你我，",
      "ja": "残されたあなたひま、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "残されたあなたひま、",
      "local_pron": "Nokosareta anata hima,",
      "ja_pron": "Nokosareta anata hima,",
      "time": "00:02:12"
    },
    {
      "role": "student",
      "text": "Uketou-moshite-tano-anakanu,",
      "zh": "接受著你我無法相見，",
      "ja": "受け止めしてたの会えかぬ、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "受け止めしてたの会えかぬ、",
      "local_pron": "Uketome shiteta no aekanu,",
      "ja_pron": "Uketome shiteta no aekanu,",
      "time": "00:02:15"
    },
    {
      "role": "student",
      "text": "Aumeka-nikaku-se-meni-obou-e-te-ru,",
      "zh": "誓言深深烙印在心中，",
      "ja": "誓い記憶背に負うえてる、",
      "local_lang": "ja",
