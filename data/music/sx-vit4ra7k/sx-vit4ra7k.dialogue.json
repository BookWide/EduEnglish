    {
      "role": "student",
      "text": "Ibi-",
      "zh": "伊比-",
      "ja": "イビ-",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "イビ-",
      "local_pron": "Ibi-",
      "ja_pron": "Ibi-",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "I must fail, when I'm in the way that I am",
      "zh": "當我保持原本的樣子時，我必須失敗，",
      "ja": "私は今のままでいると失敗しなければならない、",
      "local_lang": "ja",
      "local_label": "日文",
      "local": "私は今のままでいると失敗しなければならない、",
      "local_pron": "Watashi wa ima no mama de iru to shippai shinakereba naranai,",
      "ja_pron": "Watashi wa ima no mama de iru to shippai shinakereba naranai,",
      "time": "00:03:16"
    },
    {
      "role": "student",
      "text": "I'm a hero, I'm a hero, I'm a hero, I'm a hero, I'm a hero, I'm a hero, I'm a hero,",
      "zh": "我是英雄，我是英雄，我是英雄，我是英雄，我是英雄，我是英雄，我是英雄，",
      "ja": "私はヒーロー、私はヒーロー、私はヒーロー、私はヒーロー、私はヒーロー、私はヒーロー、私はヒーロー、",
