      "local_lang": "ko",
      "local_label": "韓文",
      "time": "00:00:50"
    },
    {
      "role": "student",
      "text": "I love you",
      "zh": "我愛你",
      "ja": "그대를 사랑해요",
      "local": "그대를 사랑해요",
      "local_pron": "geudaereul saranghaeyo",
