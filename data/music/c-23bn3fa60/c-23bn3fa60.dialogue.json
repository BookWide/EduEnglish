      "local_lang": "ko",
      "local_label": "韓文",
      "time": "00:00:36"
    },
    {
      "role": "student",
      "text": "The more I love you, the more courage I need",
      "zh": "越愛你越需要勇氣",
      "ja": "그댈 사랑할수록 용기가 필요해요",
      "local": "그댈 사랑할수록 용기가 필요해요",
