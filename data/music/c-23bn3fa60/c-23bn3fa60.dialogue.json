      "local_lang": "ko",
      "local_label": "韓文",
      "time": "00:00:42"
    },
    {
      "role": "student",
      "text": "I will look into your eyes and speak",
      "zh": "我會對你對視並說話",
      "ja": "눈을 맞추고 말할게요",
      "local": "눈을 맞추고 말할게요",
