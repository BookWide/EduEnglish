      "local_label": "韓文",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "Only if I'm with you",
      "zh": "只要和你在一起",
      "ja": "오직 그대와 함께라면",
      "local": "오직 그대와 함께라면",
