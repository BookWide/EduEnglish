  "dialogue": [
    {
      "role": "student",
      "text": "I...I didn't mean to do it.",
      "zh": "我...我不是故意的。",
      "ja": "わたしは…わざとじゃなかった。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Why didn't you listen?",
      "zh": "你為什麼不聽話？",
      "ja": "なぜ聞かなかったの？",
      "time": "00:00:19"
    },
    {
      "role": "student",
      "text": "I just wanted to help.",
      "zh": "我只是想幫忙。",
      "ja": "ただ手伝いたかっただけ。",
      "time": "00:00:22"
    },
    {
      "role": "teacher",
      "text": "Good morning, Mom.",
      "zh": "早安，媽媽。",
      "ja": "おはよう、お母さん。",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "Good morning.",
      "zh": "早安。",
      "ja": "おはよう。",
      "time": "00:00:32"
    },
    {
      "role": "teacher",
      "text": "Mom does so much.",
      "zh": "媽媽做了很多事。",
      "ja": "お母さんはたくさんやってくれる。",
      "time": "00:00:39"
    },
    {
      "role": "student",
      "text": "Mom, can I help you?",
      "zh": "媽媽，我可以幫忙嗎？",
      "ja": "お母さん、手伝ってもいい？",
      "time": "00:00:42"
    },
    {
      "role": "teacher",
      "text": "Yes, you can help.",
      "zh": "可以，你可以幫忙。",
      "ja": "うん、手伝っていいよ。",
      "time": "00:00:45"
    },
    {
      "role": "teacher",
      "text": "Don't carry the cups.",
      "zh": "不要拿杯子。",
      "ja": "コップは持たないでね。",
      "time": "00:00:51"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好。",
      "ja": "わかった。",
      "time": "00:00:53"
    },
    {
      "role": "student",
      "text": "I am sorry.",
      "zh": "對不起。",
      "ja": "ごめんなさい。",
      "time": "00:01:09"
    },
    {
      "role": "teacher",
      "text": "What happened?",
      "zh": "發生什麼事了？",
      "ja": "どうしたの？",
      "time": "00:01:16"
    },
    {
      "role": "teacher",
      "text": "Why were you carrying the cups?",
      "zh": "你為什麼拿杯子？",
      "ja": "なぜコップを持っていたの？",
      "time": "00:01:17"
    },
    {
      "role": "student",
      "text": "I wanted to help Mom.",
      "zh": "我想幫媽媽。",
      "ja": "お母さんを手伝いたかった。",
      "time": "00:01:20"
    },
    {
      "role": "teacher",
      "text": "That's a good reason.",
      "zh": "那是個好理由。",
      "ja": "それはいい理由だね。",
      "time": "00:01:22"
    },
    {
      "role": "teacher",
      "text": "Oh no.",
      "zh": "喔不。",
      "ja": "あらら。",
      "time": "00:01:26"
    },
    {
      "role": "teacher",
      "text": "Careful.",
      "zh": "小心。",
      "ja": "気をつけて。",
      "time": "00:01:28"
    },
    {
      "role": "student",
      "text": "I will try again.",
      "zh": "我會再試一次。",
      "ja": "もう一度やってみる。",
      "time": "00:01:29"
    },
    {
      "role": "student",
      "text": "Mom, why do we wash dishes?",
      "zh": "媽媽，我們為什麼要洗碗？",
      "ja": "お母さん、なぜお皿を洗うの？",
      "time": "00:01:32"
    },
    {
      "role": "teacher",
      "text": "Because clean things are safe.",
      "zh": "因為乾淨的東西才安全。",
      "ja": "きれいなものは安全だからよ。",
      "time": "00:01:36"
    },
    {
      "role": "student",
      "text": "I'm sorry I broke your cup.",
      "zh": "對不起，我弄破了你的杯子。",
      "ja": "ごめんね、コップを割ってしまった。",
      "time": "00:01:38"
    },
    {
      "role": "teacher",
      "text": "You clean this?",
      "zh": "你要洗這個嗎？",
      "ja": "これを洗うの？",
      "time": "00:01:41"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "うん。",
      "time": "00:01:43"
    },
    {
      "role": "student",
      "text": "Step by step.",
      "zh": "一步一步來。",
      "ja": "一歩ずつね。",
      "time": "00:01:44"
    },
    {
      "role": "student",
      "text": "Because you always help me.",
      "zh": "因為你總是幫助我。",
      "ja": "だっていつも助けてくれるから。",
      "time": "00:01:45"
    },
    {
      "role": "teacher",
      "text": "I'm not sad about the cup.",
      "zh": "我不為杯子難過。",
      "ja": "コップのことで悲しくないよ。",
      "time": "00:01:47"
    },
    {
      "role": "teacher",
      "text": "I was just tired.",
      "zh": "我只是累了。",
      "ja": "ただ疲れていただけ。",
      "time": "00:01:48"
    },
    {
      "role": "teacher",
      "text": "We are a team.",
      "zh": "我們是一隊的。",
      "ja": "私たちはチームだよ。",
      "time": "00:01:49"
    },
    {
      "role": "student",
      "text": "Yes, we are a team.",
      "zh": "是的，我們是一隊。",
      "ja": "うん、私たちはチームだね。",
      "time": "00:01:51"
    },
    {
      "role": "teacher",
      "text": "Careful.",
      "zh": "小心。",
      "ja": "気をつけて。",
      "time": "00:01:53"
    },
    {
      "role": "student",
      "text": "I am careful.",
      "zh": "我很小心。",
      "ja": "気をつけてるよ。",
      "time": "00:01:55"
    },
    {
      "role": "teacher",
      "text": "Wow.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:01:59"
    },
    {
      "role": "teacher",
      "text": "Teamwork.",
      "zh": "團隊合作。",
      "ja": "チームワーク。",
      "time": "00:02:01"
    },
    {
      "role": "student",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "うん。",
      "time": "00:02:02"
    },
    {
      "role": "student",
      "text": "We are a team.",
      "zh": "我們是一隊。",
      "ja": "私たちはチームだ。",
      "time": "00:02:03"
    },
    {
      "role": "teacher",
      "text": "This is our new cup.",
      "zh": "這是我們的新杯子。",
      "ja": "これは私たちの新しいコップ。",
      "time": "00:02:06"
    },
    {
      "role": "student",
      "text": "I will take care of it.",
      "zh": "我會好好照顧它。",
      "ja": "大事にするよ。",
      "time": "00:02:08"
    },
    {
      "role": "teacher",
      "text": "I know you will.",
      "zh": "我知道你會的。",
      "ja": "そうしてくれるとわかってる。",
      "time": "00:02:10"
    },
    {
      "role": "teacher",
      "text": "Small help can show big love.",
      "zh": "小小的幫助能展現大大的愛。",
      "ja": "小さな助けが大きな愛を示す。",
      "time": "00:02:13"
    },
    {
      "role": "teacher",
      "text": "Mistakes happen.",
      "zh": "錯誤會發生。",
      "ja": "失敗は起こるもの。",
      "time": "00:02:16"
    },
    {
      "role": "teacher",
      "text": "But love and teamwork make it.",
      "zh": "但愛與團隊合作能克服。",
      "ja": "でも愛とチームワークがそれを乗り越える。",
      "time": "00:02:18"
    }
  ]
}