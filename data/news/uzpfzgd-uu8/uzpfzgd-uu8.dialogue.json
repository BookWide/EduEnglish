  },
  "dialogue": [
    {
      "role": "teacher",
      "text": "Welcome to English for Newbie.",
      "zh": "歡迎來到 English for Newbie。",
      "ja": "English for Newbieへようこそ。",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "Let's begin together.",
      "zh": "讓我們一起開始吧。",
      "ja": "一緒に始めましょう。",
      "time": "00:00:03"
    },
    {
      "role": "student",
      "text": "Yes, I know. I am working on it.",
      "zh": "是的，我知道。我正在努力。",
      "ja": "はい、わかっています。取り組んでいます。",
      "time": "00:00:10"
    },
    {
      "role": "student",
      "text": "So much work to do.",
      "zh": "有好多工作要做。",
      "ja": "やることがたくさんあります。",
      "time": "00:00:13"
    },
    {
      "role": "student",
      "text": "Oh no. It is 6 p.m.",
      "zh": "喔不，已經下午六點了。",
      "ja": "あら、大変。もう午後6時です。",
      "time": "00:00:15"
    },
    {
      "role": "student",
      "text": "I am late.",
      "zh": "我遲到了。",
      "ja": "遅刻しています。",
      "time": "00:00:19"
    },
    {
      "role": "student",
      "text": "Leo is waiting.",
      "zh": "Leo 在等我。",
      "ja": "レオが待っています。",
      "time": "00:00:21"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "喔。",
      "ja": "ああ。",
      "time": "00:00:24"
    },
    {
      "role": "student",
      "text": "Hello little aunt.",
      "zh": "哈囉，小阿姨。",
      "ja": "こんにちは、小さなおばさん。",
      "time": "00:00:31"
    },
    {
      "role": "student",
      "text": "Where are you going?",
      "zh": "你要去哪裡？",
      "ja": "どこに行くの？",
      "time": "00:00:33"
    },
    {
      "role": "student",
      "text": "Leo. Leo.",
      "zh": "Leo，Leo。",
      "ja": "レオ、レオ。",
      "time": "00:00:35"
    },
    {
      "role": "student",
      "text": "You are here.",
      "zh": "你在這裡。",
      "ja": "ここにいるね。",
      "time": "00:00:38"
    },
    {
      "role": "student",
      "text": "I am so sorry Leo.",
      "zh": "對不起，Leo。",
      "ja": "ごめんね、レオ。",
      "time": "00:00:39"
    },
    {
      "role": "student",
      "text": "Mommy is late again.",
      "zh": "媽媽又遲到了。",
      "ja": "ママはまた遅刻しました。",
      "time": "00:00:41"
    },
    {
      "role": "student",
      "text": "It's okay mom.",
      "zh": "沒關係，媽媽。",
      "ja": "大丈夫だよ、ママ。",
      "time": "00:00:43"
    },
    {
      "role": "student",
      "text": "Let's go home baby.",
      "zh": "寶貝，我們回家吧。",
      "ja": "さあ、家に帰ろうね。",
      "time": "00:00:45"
    },
    {
      "role": "student",
      "text": "Oh no.",
      "zh": "喔不。",
      "ja": "ああ、いやだ。",
      "time": "00:00:53"
    },
    {
      "role": "student",
      "text": "The house is still messy.",
      "zh": "家裡還是亂的。",
      "ja": "家はまだ散らかっています。",
      "time": "00:01:00"
    },
    {
      "role": "student",
      "text": "And I have to cook dinner.",
      "zh": "而且我還得做晚餐。",
      "ja": "それに夕食を作らなきゃ。",
      "time": "00:01:05"
    },
    {
      "role": "student",
      "text": "Come on Grace. Hurry up.",
      "zh": "加油，Grace，快點。",
      "ja": "さあ、グレース、急いで。",
      "time": "00:01:07"
    },
    {
      "role": "student",
      "text": "Oh no.",
      "zh": "喔不。",
      "ja": "ああ、いやだ。",
      "time": "00:01:14"
    },
    {
      "role": "student",
      "text": "My favorite bowl.",
      "zh": "我最喜歡的碗。",
      "ja": "お気に入りのボウルが。",
      "time": "00:01:16"
    },
    {
      "role": "student",
      "text": "I can't do this.",
      "zh": "我做不到。",
      "ja": "できないよ。",
      "time": "00:01:20"
    },
    {
      "role": "student",
      "text": "I am so tired.",
      "zh": "我好累。",
      "ja": "とても疲れた。",
      "time": "00:01:22"
    },
    {
      "role": "student",
      "text": "I have no energy.",
      "zh": "我沒有力氣了。",
      "ja": "元気がない。",
      "time": "00:01:24"
    },
    {
      "role": "student",
      "text": "Hello mom.",
      "zh": "哈囉，媽媽。",
      "ja": "こんにちは、ママ。",
      "time": "00:01:31"
    },
    {
      "role": "student",
      "text": "We are home.",
      "zh": "我們回家了。",
      "ja": "ただいま。",
      "time": "00:01:32"
    },
    {
      "role": "student",
      "text": "We are home.",
      "zh": "我們回家了。",
      "ja": "ただいま。",
      "time": "00:01:33"
    },
    {
      "role": "student",
      "text": "Sorry we are late.",
      "zh": "抱歉我們遲到了。",
      "ja": "遅れてごめんね。",
      "time": "00:01:34"
    },
    {
      "role": "student",
      "text": "Traffic was terrible.",
      "zh": "交通很糟糕。",
      "ja": "交通がひどかった。",
      "time": "00:01:35"
    },
    {
      "role": "teacher",
      "text": "But Grace, what happened?",
      "zh": "可是 Grace，發生什麼事了？",
      "ja": "でもグレース、どうしたの？",
      "time": "00:01:39"
    },
    {
      "role": "student",
      "text": "I am just very tired.",
      "zh": "我只是很累。",
      "ja": "ただとても疲れているだけ。",
      "time": "00:01:44"
    },
    {
      "role": "teacher",
      "text": "Hey, don't worry.",
      "zh": "嘿，別擔心。",
      "ja": "ねえ、心配しないで。",
      "time": "00:01:47"
    },
    {
      "role": "teacher",
      "text": "Sit down and relax.",
      "zh": "坐下來放鬆一下。",
      "ja": "座ってリラックスして。",
      "time": "00:01:49"
    },
    {
      "role": "teacher",
      "text": "Mom needs a break.",
      "zh": "媽媽需要休息。",
      "ja": "ママは休憩が必要です。",
      "time": "00:01:51"
    },
    {
      "role": "teacher",
      "text": "Team.",
      "zh": "團隊。",
      "ja": "チーム。",
      "time": "00:01:53"
    },
    {
      "role": "teacher",
      "text": "Let's help mom.",
      "zh": "讓我們幫忙媽媽。",
      "ja": "ママを手伝おう。",
      "time": "00:01:55"
    },
    {
      "role": "teacher",
      "text": "Operation cleanup.",
      "zh": "清理行動開始。",
      "ja": "掃除作戦開始。",
      "time": "00:01:57"
    },
    {
      "role": "teacher",
      "text": "I'll wash the vegetables.",
      "zh": "我來洗菜。",
      "ja": "野菜を洗うよ。",
      "time": "00:01:59"
    },
    {
      "role": "teacher",
      "text": "I'll wipe the table.",
      "zh": "我來擦桌子。",
      "ja": "テーブルを拭くよ。",
      "time": "00:02:01"
    },
    {
      "role": "teacher",
      "text": "I'll pick up the toys.",
      "zh": "我來撿玩具。",
      "ja": "おもちゃを片付けるよ。",
      "time": "00:02:03"
    },
    {
      "role": "teacher",
      "text": "One, two, three.",
      "zh": "一、二、三。",
      "ja": "いち、に、さん。",
      "time": "00:02:07"
    },
    {
      "role": "teacher",
      "text": "I love you guys.",
      "zh": "我愛你們。",
      "ja": "みんな大好き。",
      "time": "00:02:11"
    },
    {
      "role": "teacher",
      "text": "Cheers delicious dinner.",
      "zh": "為美味的晚餐乾杯。",
      "ja": "おいしい夕食に乾杯。",
      "time": "00:02:15"
    },
    {
      "role": "teacher",
      "text": "Thank you everyone.",
      "zh": "謝謝大家。",
      "ja": "みんなありがとう。",
      "time": "00:02:21"
    },
    {
      "role": "student",
      "text": "This food is yummy.",
      "zh": "這食物真好吃。",
      "ja": "この食べ物はおいしい。",
      "time": "00:02:23"
    },
    {
      "role": "student",
      "text": "Mom, fruit for you.",
      "zh": "媽媽，水果給你。",
      "ja": "ママ、果物だよ。",
      "time": "00:02:25"
    },
    {
      "role": "student",
      "text": "Sweet apple.",
      "zh": "甜甜的蘋果。",
      "ja": "甘いリンゴ。",
      "time": "00:02:28"
    },
    {
      "role": "student",
      "text": "And look mom.",
      "zh": "還有看，媽媽。",
      "ja": "それから見て、ママ。",
      "time": "00:02:31"
    },
    {
      "role": "student",
      "text": "I got an A on my drawing.",
      "zh": "我的畫得了 A。",
      "ja": "絵でAをもらったよ。",
      "time": "00:02:33"
    },
    {
      "role": "student",
      "text": "You see?",
      "zh": "你看見了嗎？",
      "ja": "見た？",
      "time": "00:02:37"
    },
    {
      "role": "teacher",
      "text": "In a family we share the work.",
      "zh": "在家庭裡我們分擔工作。",
      "ja": "家族では仕事を分担します。",
      "time": "00:02:39"
    },
    {
      "role": "teacher",
      "text": "Sharing each other makes us happy.",
      "zh": "互相分擔讓我們快樂。",
      "ja": "助け合うことは幸せをもたらします。",
      "time": "00:02:42"
    },
    {
      "role": "teacher",
      "text": "That's right.",
      "zh": "沒錯。",
      "ja": "その通り。",
      "time": "00:02:45"
    },
    {
      "role": "teacher",
      "text": "Sharing housework is sharing love.",
      "zh": "分擔家務就是分享愛。",
      "ja": "家事を分担することは愛を分かち合うことです。",
      "time": "00:02:46"
    },
    {
      "role": "teacher",
      "text": "Do you help your family with housework?",
      "zh": "你會幫家人做家務嗎？",
      "ja": "家族の家事を手伝いますか？",
      "time": "00:02:50"
    },
    {
      "role": "teacher",
      "text": "Let's do it together to have a happy family.",
      "zh": "讓我們一起做，擁有幸福的家庭。",
      "ja": "一緒にやって幸せな家族になろう。",
      "time": "00:02:53"
    },
    {
      "role": "student",
      "text": "Mom, this Sunday is boring.",
      "zh": "媽媽，這個星期天好無聊。",
      "ja": "ママ、今日日曜日は退屈だよ。",
      "time": "00:02:59"
    },
    {
      "role": "student",
      "text": "My cars are boring too.",
      "zh": "我的車子也很無聊。",
      "ja": "僕の車もつまらない。",
      "time": "00:03:02"
    },
    {
      "role": "student",
      "text": "Me too.",
      "zh": "我也是。",
      "ja": "僕も。",
      "time": "00:03:05"
    },
    {
      "role": "student",
      "text": "No school.",
      "zh": "沒上學。",
      "ja": "学校がない。",
      "time": "00:03:06"
    },
    {
      "role": "student",
      "text": "No friends.",
      "zh": "沒朋友。",
      "ja": "友達もいない。",
      "time": "00:03:08"
    },
    {
      "role": "student",
      "text": "Just nothing.",
      "zh": "什麼都沒有。",
      "ja": "何もない。",
      "time": "00:03:10"
    },
    {
      "role": "student",
      "text": "Nothing to do?",
      "zh": "沒事做嗎？",
      "ja": "やることがないの？",
      "time": "00:03:12"
    },
    {
      "role": "teacher",
      "text": "Look.",
      "zh": "看。",
      "ja": "見て。",
      "time": "00:03:15"
    },
    {
      "role": "teacher",
      "text": "I have a mission.",
      "zh": "我有個任務。",
      "ja": "ミッションがある。",
      "time": "00:03:17"
    },
    {
      "role": "student",
      "text": "A mission?",
      "zh": "任務？",
      "ja": "ミッション？",
      "time": "00:03:19"
    },
    {
      "role": "teacher",
      "text": "Yes.",
      "zh": "是的。",
      "ja": "はい。",
      "time": "00:03:20"
    },
    {
      "role": "teacher",
      "text": "This baby tree needs a home.",
      "zh": "這棵小樹需要一個家。",
      "ja": "この小さな木には家が必要です。",
      "time": "00:03:21"
    },
    {
      "role": "teacher",
      "text": "It needs soil and sun.",
      "zh": "它需要土壤和陽光。",
      "ja": "土と太陽が必要です。",
      "time": "00:03:23"
    },
    {
      "role": "teacher",
      "text": "Will you help me?",
      "zh": "你願意幫我嗎？",
      "ja": "手伝ってくれる？",
      "time": "00:03:25"
    },
    {
      "role": "student",
      "text": "Did someone say help?",
      "zh": "有人說幫忙嗎？",
      "ja": "誰か助けって言った？",
      "time": "00:03:26"
    },
    {
      "role": "student",
      "text": "Super gardener is here.",
      "zh": "超級園丁來了。",
      "ja": "スーパ―ガーデナーが来たよ。",
      "time": "00:03:29"
    },
    {
      "role": "student",
      "text": "Let's go to the park.",
      "zh": "我們去公園吧。",
      "ja": "公園に行こう。",
      "time": "00:03:31"
    },
    {
      "role": "student",
      "text": "Mom, why do we plant trees?",
      "zh": "媽媽，我們為什麼要種樹？",
      "ja": "ママ、なぜ木を植えるの？",
      "time": "00:03:34"
    },
    {
      "role": "student",
      "text": "Why are they important?",
      "zh": "它們為什麼重要？",
      "ja": "なぜ大切なの？",
      "time": "00:03:41"
    },
    {
      "role": "teacher",
      "text": "Good question.",
      "zh": "好問題。",
      "ja": "いい質問ですね。",
      "time": "00:03:44"
    },
    {
      "role": "teacher",
      "text": "Trees are superheroes.",
      "zh": "樹是超級英雄。",
      "ja": "木はスーパーヒーローです。",
      "time": "00:03:46"
    },
    {
      "role": "teacher",
      "text": "Breathe in.",
      "zh": "吸氣。",
      "ja": "息を吸って。",
      "time": "00:03:48"
    },
    {
      "role": "teacher",
      "text": "And breathe out.",
      "zh": "吐氣。",
      "ja": "息を吐いて。",
      "time": "00:03:49"
    },
    {
      "role": "teacher",
      "text": "Hmmm.",
      "zh": "嗯。",
      "ja": "ふう。",
      "time": "00:03:52"
    },
    {
      "role": "teacher",
      "text": "Fresh air.",
      "zh": "新鮮空氣。",
      "ja": "新鮮な空気。",
      "time": "00:03:54"
    },
    {
      "role": "student",
      "text": "Thank you Mr. Tree.",
      "zh": "謝謝你，樹先生。",
      "ja": "ありがとう、木さん。",
      "time": "00:03:56"
    },
    {
      "role": "teacher",
      "text": "Trees make fresh air.",
      "zh": "樹木製造新鮮空氣。",
      "ja": "木は新鮮な空気を作ります。",
      "time": "00:03:58"
    },
    {
      "role": "teacher",
      "text": "It is called oxygen.",
      "zh": "這叫做氧氣。",
      "ja": "それは酸素と呼ばれます。",
      "time": "00:04:00"
    },
    {
      "role": "teacher",
      "text": "And look.",
      "zh": "還有看。",
      "ja": "そして見て。",
      "time": "00:04:02"
    },
    {
      "role": "teacher",
      "text": "They make shade too.",
      "zh": "它們也提供陰涼。",
      "ja": "木は日陰も作ります。",
      "time": "00:04:04"
    },
    {
      "role": "teacher",
      "text": "And birds live in trees too.",
      "zh": "鳥兒也住在樹上。",
      "ja": "鳥も木に住んでいます。",
      "time": "00:04:06"
    },
    {
      "role": "teacher",
      "text": "It is a home for animals.",
      "zh": "它是動物的家。",
      "ja": "動物たちの家です。",
      "time": "00:04:09"
    },
    {
      "role": "teacher",
      "text": "Exactly Maya.",
      "zh": "沒錯，Maya。",
      "ja": "その通り、マヤ。",
      "time": "00:04:13"
    },
    {
      "role": "teacher",
      "text": "Oxygen, shade and home.",
      "zh": "氧氣、陰涼和家。",
      "ja": "酸素、日陰、そして家。",
      "time": "00:04:15"
    },
    {
      "role": "teacher",
      "text": "Trees are amazing.",
      "zh": "樹木真了不起。",
      "ja": "木は素晴らしいです。",
      "time": "00:04:18"
    },
    {
      "role": "teacher",
      "text": "Let's plant it here.",
      "zh": "我們就在這裡種吧。",
      "ja": "ここに植えましょう。",
      "time": "00:04:21"
    },
    {
      "role": "teacher",
      "text": "This is the perfect spot.",
      "zh": "這是完美的位置。",
      "ja": "ここが完璧な場所です。",
      "time": "00:04:23"
    },
    {
      "role": "teacher",
      "text": "Hmmm.",
      "zh": "嗯。",
      "ja": "うーん。",
      "time": "00:04:26"
    },
    {
      "role": "teacher",
      "text": "The soil is hard.",
      "zh": "土壤很硬。",
      "ja": "土が硬い。",
      "time": "00:04:27"
    },
    {
      "role": "teacher",
      "text": "But.",
      "zh": "但是。",
      "ja": "でも。",
      "time": "00:04:29"
    },
    {
      "role": "teacher",
      "text": "Don't worry kids.",
      "zh": "別擔心，孩子們。",
      "ja": "心配しないで、子供たち。",
      "time": "00:04:31"
    },
    {
      "role": "teacher",
      "text": "Watch your dad.",
      "zh": "看你爸爸。",
      "ja": "お父さんを見て。",
      "time": "00:04:33"
    },
    {
      "role": "student",
      "text": "Uh oh.",
      "zh": "哎呀。",
      "ja": "あらら。",
      "time": "00:04:36"
    },
    {
      "role": "student",
      "text": "Hmmm.",
      "zh": "嗯。",
      "ja": "うーん。",
      "time": "00:04:39"
    },
    {
      "role": "student",
      "text": "Dad, you have dirt on your nose.",
      "zh": "爸爸，你鼻子上有泥巴。",
      "ja": "パパ、鼻に土がついてるよ。",
      "time": "00:04:42"
    },
    {
      "role": "student",
      "text": "Dad, you are funny.",
      "zh": "爸爸，你真好笑。",
      "ja": "パパ、おかしいよ。",
      "time": "00:04:46"
    },
    {
      "role": "student",
      "text": "Let me help.",
      "zh": "讓我來幫忙。",
      "ja": "手伝わせて。",
      "time": "00:04:49"
    },
    {
      "role": "student",
      "text": "Whoa.",
      "zh": "哇。",
      "ja": "わあ。",
      "time": "00:04:51"
    },
    {
      "role": "student",
      "text": "Something is moving in the hole.",
      "zh": "洞裡有東西在動。",
      "ja": "穴の中で何かが動いている。",
      "time": "00:04:54"
    },
    {
      "role": "student",
      "text": "Is it a snake?",
      "zh": "是蛇嗎？",
      "ja": "ヘビかな？",
      "time": "00:04:57"
    },
    {
      "role": "teacher",
      "text": "Don't be scared.",
      "zh": "別害怕。",
      "ja": "怖がらないで。",
      "time": "00:05:00"
    },
    {
      "role": "teacher",
      "text": "Look closely.",
      "zh": "仔細看。",
      "ja": "よく見て。",
      "time": "00:05:01"
    },
    {
      "role": "teacher",
      "text": "It is an earthworm.",
      "zh": "那是一條蚯蚓。",
      "ja": "それはミミズです。",
      "time": "00:05:03"
    },
    {
      "role": "student",
      "text": "Ew.",
      "zh": "噁。",
      "ja": "うわっ。",
      "time": "00:05:06"
    },
    {
      "role": "student",
      "text": "Ugh.",
      "zh": "噁。",
      "ja": "うっ。",
      "time": "00:05:07"
    },
    {
      "role": "student",
      "text": "It looks slimy.",
      "zh": "看起來黏黏的。",
      "ja": "ぬるぬるしている。",
      "time": "00:05:08"
    },
    {
      "role": "teacher",
      "text": "No, no.",
      "zh": "不，不是。",
      "ja": "違うよ。",
      "time": "00:05:10"
    },
    {
      "role": "teacher",
      "text": "He is a friend.",
      "zh": "牠是朋友。",
      "ja": "彼は友達です。",
      "time": "00:05:11"
    },
    {
      "role": "teacher",
      "text": "The worm is a tiny gardener.",
      "zh": "蚯蚓是小小的園丁。",
      "ja": "ミミズは小さな庭師です。",
      "time": "00:05:12"
    },
    {
      "role": "teacher",
      "text": "He makes tunnels in the soil.",
      "zh": "牠在土裡挖洞。",
      "ja": "土の中にトンネルを作ります。",
      "time": "00:05:14"
    },
    {
      "role": "teacher",
      "text": "This helps water reach the tree's roots.",
      "zh": "這幫助水分到達樹根。",
      "ja": "これが水を木の根に届けるのを助けます。",
      "time": "00:05:16"
    },
    {
      "role": "student",
      "text": "Hello Mr. Worm.",
      "zh": "你好，蚯蚓先生。",
      "ja": "こんにちは、ミミズさん。",
      "time": "00:05:20"
    },
    {
      "role": "student",
      "text": "Please help our tree grow.",
      "zh": "請幫助我們的樹成長。",
      "ja": "私たちの木が育つのを助けてください。",
      "time": "00:05:22"
    },
    {
      "role": "teacher",
      "text": "Now.",
      "zh": "現在。",
      "ja": "さあ。",
      "time": "00:05:27"
    },
    {
      "role": "teacher",
      "text": "Be gentle.",
      "zh": "要輕柔。",
      "ja": "優しくね。",
      "time": "00:05:29"
    },
    {
      "role": "teacher",
      "text": "Roots are like feet.",
      "zh": "根就像腳。",
      "ja": "根は足のようなものです。",
      "time": "00:05:31"
    },
    {
      "role": "teacher",
      "text": "They drink water from the soil.",
      "zh": "它們從土壤吸水。",
      "ja": "土から水を吸います。",
      "time": "00:05:33"
    },
    {
      "role": "teacher",
      "text": "Drink some water, baby tree.",
      "zh": "喝點水吧，小樹。",
      "ja": "水を飲んでね、小さな木。",
      "time": "00:05:36"
    },
    {
      "role": "student",
      "text": "Mom, look.",
      "zh": "媽媽，看。",
      "ja": "ママ、見て。",
      "time": "00:05:39"
    },
    {
      "role": "student",
      "text": "It is so small.",
      "zh": "它好小。",
      "ja": "とても小さい。",
      "time": "00:05:41"
    },
    {
      "role": "student",
      "text": "It is shorter than me.",
      "zh": "比我還矮。",
      "ja": "僕よりも小さい。",
      "time": "00:05:43"
    },
    {
      "role": "student",
      "text": "When will it be big?",
      "zh": "什麼時候會長大？",
      "ja": "いつ大きくなるの？",
      "time": "00:05:45"
    },
    {
      "role": "teacher",
      "text": "Patience, Leo.",
      "zh": "耐心點，Leo。",
      "ja": "我慢して、レオ。",
      "time": "00:05:47"
    },
    {
      "role": "teacher",
      "text": "Trees grow slowly, but they become strong.",
      "zh": "樹長得慢，但會變強壯。",
      "ja": "木はゆっくり育ちますが、強くなります。",
      "time": "00:05:49"
    },
    {
      "role": "teacher",
      "text": "Just like you and Maya, every day a little bit.",
      "zh": "就像你和Maya，每天一點點。",
      "ja": "君たちとマヤのように、毎日少しずつ。",
      "time": "00:05:52"
    },
    {
      "role": "student",
      "text": "But Mom, the park is big.",
      "zh": "可是媽媽，公園很大。",
      "ja": "でもママ、公園は広いよ。",
      "time": "00:05:56"
    },
    {
      "role": "student",
      "text": "Will we forget our tree?",
      "zh": "我們會忘記我們的樹嗎？",
      "ja": "私たちの木を忘れちゃう？",
      "time": "00:06:00"
    },
    {
      "role": "teacher",
      "text": "Don't worry.",
      "zh": "別擔心。",
      "ja": "心配しないで。",
      "time": "00:06:03"
    },
    {
      "role": "teacher",
      "text": "I have a surprise.",
      "zh": "我有驚喜。",
      "ja": "サプライズがあるよ。",
      "time": "00:06:04"
    },
    {
      "role": "teacher",
      "text": "Let's give it a name.",
      "zh": "我們給它取個名字吧。",
      "ja": "名前をつけましょう。",
      "time": "00:06:06"
    },
    {
      "role": "teacher",
      "text": "The happy tree.",
      "zh": "快樂樹。",
      "ja": "ハッピーツリー。",
      "time": "00:06:12"
    },
    {
      "role": "student",
      "text": "Perfect.",
      "zh": "完美。",
      "ja": "完璧。",
      "time": "00:06:15"
    },
    {
      "role": "teacher",
      "text": "Because we are happy today.",
      "zh": "因為我們今天很快樂。",
      "ja": "今日はみんな幸せだから。",
      "time": "00:06:17"
    },
    {
      "role": "student",
      "text": "Growth fast.",
      "zh": "快快長大。",
      "ja": "早く育ってね。",
      "time": "00:06:22"
    },
    {
      "role": "student",
      "text": "Growth fast.",
      "zh": "快快長大。",
      "ja": "早く育ってね。",
      "time": "00:06:23"
    },
    {
      "role": "student",
      "text": "Happy tree.",
      "zh": "快樂樹。",
      "ja": "ハッピーツリー。",
      "time": "00:06:24"
    },
    {
      "role": "teacher",
      "text": "Good job team.",
      "zh": "幹得好，團隊。",
      "ja": "よくやった、チーム。",
      "time": "00:06:26"
    },
    {
      "role": "teacher",
      "text": "We did it.",
      "zh": "我們成功了。",
      "ja": "やったね。",
      "time": "00:06:28"
    },
    {
      "role": "teacher",
      "text": "High five.",
      "zh": "擊掌。",
      "ja": "ハイタッチ。",
      "time": "00:06:30"
    },
    {
      "role": "student",
      "text": "Yeah.",
      "zh": "耶。",
      "ja": "イエーイ。",
      "time": "00:06:31"
    },
    {
      "role": "teacher",
      "text": "We had a great day.",
      "zh": "我們度過美好的一天。",
      "ja": "素敵な一日でした。",
      "time": "00:06:34"
    },
    {
      "role": "teacher",
      "text": "What about you?",
      "zh": "你呢？",
      "ja": "あなたはどう？",
      "time": "00:06:37"
    },
    {
      "role": "teacher",
      "text": "Do you like planting trees?",
      "zh": "你喜歡種樹嗎？",
      "ja": "木を植えるのは好きですか？",
      "time": "00:06:38"
    },
    {
      "role": "teacher",
      "text": "What tree did you plant?",
      "zh": "你種了什麼樹？",
      "ja": "どんな木を植えましたか？",
      "time": "00:06:40"
    },
    {
      "role": "teacher",
      "text": "Tell us in the comments.",
      "zh": "在留言告訴我們。",
      "ja": "コメントで教えてね。",
      "time": "00:06:42"
    },
    {
      "role": "teacher",
      "text": "Please like and share.",
      "zh": "請按讚並分享。",
      "ja": "いいねとシェアをお願いします。",
      "time": "00:06:44"
    },
    {
      "role": "teacher",
      "text": "If this video is useful.",
      "zh": "如果這個影片有幫助。",
      "ja": "この動画が役に立ったら。",
      "time": "00:06:47"
    },
    {
      "role": "teacher",
      "text": "And don't forget to subscribe to watch more fun stories with us.",
      "zh": "別忘了訂閱，觀看更多有趣故事。",
      "ja": "チャンネル登録も忘れずに、もっと楽しい話を見ましょう。",
      "time": "00:06:50"
    },
    {
      "role": "teacher",
      "text": "Goodbye.",
      "zh": "再見。",
      "ja": "さようなら。",
      "time": "00:06:56"
    },
    {
      "role": "teacher",
      "text": "See you next time.",
      "zh": "下次見。",
      "ja": "また次回。",
      "time": "00:06:57"
    }
  ]
}