      "ja": "それが大事なことだよ。",
      "time": "00:05:31"
    },
    {
      "role": "student",
      "text": "The power is back.",
      "zh": "電力回來了。",
      "ja": "電気が戻った。",
      "time": "00:05:33"
    },
    {
      "role": "student",
      "text": "The lights are on.",
      "zh": "燈亮了。",
      "ja": "ライトがついた。",
      "time": "00:05:35"
    },
    {
      "role": "student",
      "text": "The power is back.",
      "zh": "電力回來了。",
      "ja": "電気が戻った。",
      "time": "00:05:37"
    },
    {
      "role": "student",
      "text": "Everything's working again.",
