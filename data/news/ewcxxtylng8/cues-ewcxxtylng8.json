[
  {
    "time": "00:00:00",
    "en": "It is very dark tonight.",
    "zh": "今晚非常黑暗。",
    "ja": "今夜はとても暗いです。",
    "source_url": "https://www.youtube.com/watch?v=EWCxxtYLng8"
  },
  {
    "time": "00:00:06",
    "en": "Let's go inside.",
    "zh": "我們進去吧。",
    "ja": "中に入りましょう。"
  },
  {
    "time": "00:00:08",
    "en": "Dad, look at the front door.",
    "zh": "爸爸，看前門。",
    "ja": "パパ、玄関のドアを見て。"
  },
  {
    "time": "00:00:11",
    "en": "It is wide open.",
    "zh": "門大開著。",
    "ja": "大きく開いています。"
  },
  {
    "time": "00:00:13",
    "en": "It is not closed.",
    "zh": "沒有關上。",
    "ja": "閉まっていません。"
  },
  {
    "time": "00:00:15",
    "en": "Stop everyone.",
    "zh": "大家停下。",
    "ja": "みんな止まって。"
  },
  {
    "time": "00:00:17",
    "en": "Red alert.",
    "zh": "紅色警報。",
    "ja": "赤色警報。"
  },
  {
    "time": "00:00:18",
    "en": "Danger.",
    "zh": "危險。",
    "ja": "危険です。"
  },
  {
    "time": "00:00:19",
    "en": "Ethan, what is wrong?",
    "zh": "伊森，怎麼了？",
    "ja": "イーサン、どうしたの？"
  },
  {
    "time": "00:00:22",
    "en": "The door is open.",
    "zh": "門是開著的。",
    "ja": "ドアが開いています。"
  },
  {
    "time": "00:00:23",
    "en": "But I closed it today.",
    "zh": "但我今天有關。",
    "ja": "でも今日閉めたはずです。"
  },
  {
    "time": "00:00:25",
    "en": "I think.",
    "zh": "我想是這樣。",
    "ja": "そう思います。"
  },
  {
    "time": "00:00:27",
    "en": "Oh no!",
    "zh": "喔不！",
    "ja": "ああ、いや！"
  },
  {
    "time": "00:00:28",
    "en": "Did a bad monster open the door?",
    "zh": "是壞怪獸開了門嗎？",
    "ja": "悪いモンスターがドアを開けたの？"
  },
  {
    "time": "00:00:31",
    "en": "No, Leo.",
    "zh": "不是，Leo。",
    "ja": "違うよ、レオ。"
  },
  {
    "time": "00:00:33",
    "en": "Not a monster.",
    "zh": "不是怪獸。",
    "ja": "モンスターじゃない。"
  },
  {
    "time": "00:00:34",
    "en": "A thief.",
    "zh": "是小偷。",
    "ja": "泥棒だよ。"
  },
  {
    "time": "00:00:36",
    "en": "Someone took our things.",
    "zh": "有人拿走了我們的東西。",
    "ja": "誰かが私たちの物を持っていった。"
  },
  {
    "time": "00:00:38",
    "en": "A thief?",
    "zh": "小偷？",
    "ja": "泥棒？"
  },
  {
    "time": "00:00:40",
    "en": "That is very bad.",
    "zh": "那很糟糕。",
    "ja": "それはとても悪いことです。"
  },
  {
    "time": "00:00:42",
    "en": "Yes, we must be careful.",
    "zh": "是的，我們必須小心。",
    "ja": "はい、気をつけなければなりません。"
  },
  {
    "time": "00:00:45",
    "en": "He can be inside.",
    "zh": "他可能在裡面。",
    "ja": "彼は中にいるかもしれません。"
  },
  {
    "time": "00:00:47",
    "en": "Inside?",
    "zh": "裡面？",
    "ja": "中に？"
  },
  {
    "time": "00:00:49",
    "en": "Right now, I am scared, Mommy.",
    "zh": "現在我很害怕，媽媽。",
    "ja": "今、怖いよ、ママ。"
  },
  {
    "time": "00:00:53",
    "en": "Stay close to me, Maya.",
    "zh": "靠近我，Maya。",
    "ja": "私のそばにいて、マヤ。"
  },
  {
    "time": "00:00:55",
    "en": "Hold my hand.",
    "zh": "牽著我的手。",
    "ja": "手を握って。"
  },
  {
    "time": "00:00:57",
    "en": "Do not worry.",
    "zh": "別擔心。",
    "ja": "心配しないで。"
  },
  {
    "time": "00:00:58",
    "en": "I will go inside first.",
    "zh": "我先進去。",
    "ja": "私が先に入るよ。"
  },
  {
    "time": "00:01:01",
    "en": "Stay here in the yard.",
    "zh": "待在院子裡。",
    "ja": "庭にいてね。"
  },
  {
    "time": "00:01:02",
    "en": "I will check the rooms.",
    "zh": "我會檢查房間。",
    "ja": "部屋を調べるよ。"
  },
  {
    "time": "00:01:07",
    "en": "Hello?",
    "zh": "有人嗎？",
    "ja": "もしもし？"
  },
  {
    "time": "00:01:08",
    "en": "Is anybody here?",
    "zh": "有人在嗎？",
    "ja": "誰かいますか？"
  },
  {
    "time": "00:01:10",
    "en": "Show yourself.",
    "zh": "現身吧。",
    "ja": "姿を見せて。"
  },
  {
    "time": "00:01:11",
    "en": "I am coming in.",
    "zh": "我要進去了。",
    "ja": "入りますよ。"
  },
  {
    "time": "00:01:13",
    "en": "Please be careful, Ethan.",
    "zh": "請小心，伊森。",
    "ja": "気をつけてね、イーサン。"
  },
  {
    "time": "00:01:15",
    "en": "It is safe.",
    "zh": "安全的。",
    "ja": "安全です。"
  },
  {
    "time": "00:01:16",
    "en": "The room is empty.",
    "zh": "房間是空的。",
    "ja": "部屋は空っぽです。"
  },
  {
    "time": "00:01:18",
    "en": "I will turn on the light.",
    "zh": "我會開燈。",
    "ja": "電気をつけます。"
  },
  {
    "time": "00:01:20",
    "en": "Is the thief gone, Dad?",
    "zh": "小偷走了嗎，爸爸？",
    "ja": "泥棒はもういませんか、パパ？"
  },
  {
    "time": "00:01:22",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:01:23",
    "en": "Nobody is here.",
    "zh": "沒有人在這裡。",
    "ja": "誰もいません。"
  },
  {
    "time": "00:01:25",
    "en": "You can come in now.",
    "zh": "你們現在可以進來了。",
    "ja": "今入っていいよ。"
  },
  {
    "time": "00:01:26",
    "en": "Oh my goodness.",
    "zh": "天啊。",
    "ja": "なんてことだ。"
  },
  {
    "time": "00:01:29",
    "en": "What a big mess.",
    "zh": "好亂啊。",
    "ja": "すごく散らかっている。"
  },
  {
    "time": "00:01:32",
    "en": "My toys.",
    "zh": "我的玩具。",
    "ja": "私のおもちゃ。"
  },
  {
    "time": "00:01:34",
    "en": "My dolls and blocks are on the floor.",
    "zh": "我的娃娃和積木都掉在地上。",
    "ja": "私の人形とブロックが床に散らばっている。"
  },
  {
    "time": "00:01:37",
    "en": "And look at the bookshelf.",
    "zh": "還有看書架。",
    "ja": "それに本棚を見て。"
  },
  {
    "time": "00:01:39",
    "en": "All the books are on the carpet.",
    "zh": "所有書都掉在地毯上。",
    "ja": "本が全部カーペットの上にあります。"
  },
  {
    "time": "00:01:42",
    "en": "The living room is destroyed.",
    "zh": "客廳被弄得亂七八糟。",
    "ja": "リビングルームがめちゃくちゃです。"
  },
  {
    "time": "00:01:44",
    "en": "It is very dirty.",
    "zh": "非常髒亂。",
    "ja": "とても汚れています。"
  },
  {
    "time": "00:01:46",
    "en": "He opened all the drawers.",
    "zh": "他打開了所有抽屜。",
    "ja": "彼はすべての引き出しを開けました。"
  },
  {
    "time": "00:01:48",
    "en": "He was looking for money.",
    "zh": "他在找錢。",
    "ja": "お金を探していたんだ。"
  },
  {
    "time": "00:01:50",
    "en": "Dad, look at the table.",
    "zh": "爸爸，看桌子。",
    "ja": "パパ、テーブルを見て。"
  },
  {
    "time": "00:01:52",
    "en": "The TV is gone.",
    "zh": "電視不見了。",
    "ja": "テレビがなくなっている。"
  },
  {
    "time": "00:01:54",
    "en": "Yes, Leo.",
    "zh": "是的，Leo。",
    "ja": "そうだよ、レオ。"
  },
  {
    "time": "00:01:55",
    "en": "Our house was robbed.",
    "zh": "我們家被搶劫了。",
    "ja": "私たちの家が強盗にあった。"
  },
  {
    "time": "00:01:58",
    "en": "The thief took our big television.",
    "zh": "小偷拿走了我們的大電視。",
    "ja": "泥棒が大きなテレビを持っていった。"
  },
  {
    "time": "00:02:03",
    "en": "Let's check the kitchen.",
    "zh": "我們去看看廚房。",
    "ja": "キッチンを見てみよう。"
  },
  {
    "time": "00:02:05",
    "en": "The room where we cook.",
    "zh": "我們做飯的房間。",
    "ja": "料理をする部屋です。"
  },
  {
    "time": "00:02:07",
    "en": "Look, Mom.",
    "zh": "看，媽媽。",
    "ja": "見て、ママ。"
  },
  {
    "time": "00:02:09",
    "en": "The refrigerator is open.",
    "zh": "冰箱開著。",
    "ja": "冷蔵庫が開いている。"
  },
  {
    "time": "00:02:12",
    "en": "And there is milk and juice on the floor.",
    "zh": "牛奶和果汁倒在地上。",
    "ja": "ミルクとジュースが床にこぼれている。"
  },
  {
    "time": "00:02:15",
    "en": "Oh no.",
    "zh": "喔不。",
    "ja": "ああ、いやだ。"
  },
  {
    "time": "00:02:16",
    "en": "My yellow plates are broken on the floor.",
    "zh": "我的黃色盤子摔破了。",
    "ja": "私の黄色いお皿が床で割れている。"
  },
  {
    "time": "00:02:19",
    "en": "He made a big mess in the kitchen too.",
    "zh": "他也把廚房弄得很亂。",
    "ja": "キッチンもひどく散らかしている。"
  },
  {
    "time": "00:02:22",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "そうだね。"
  },
  {
    "time": "00:02:23",
    "en": "And he even ate our chocolate cookies.",
    "zh": "他甚至吃了我們的巧克力餅乾。",
    "ja": "それにチョコレートクッキーまで食べた。"
  },
  {
    "time": "00:02:26",
    "en": "That is very mean.",
    "zh": "那真壞。",
    "ja": "それはとても意地悪だ。"
  },
  {
    "time": "00:02:28",
    "en": "I love those cookies.",
    "zh": "我很喜歡那些餅乾。",
    "ja": "あのクッキーが大好き。"
  },
  {
    "time": "00:02:31",
    "en": "He was very hungry and very bad.",
    "zh": "他又餓又壞。",
    "ja": "彼はとてもお腹が空いていて、悪かった。"
  },
  {
    "time": "00:02:34",
    "en": "Come on team.",
    "zh": "來吧，團隊。",
    "ja": "さあ、チーム。"
  },
  {
    "time": "00:02:36",
    "en": "Let's check upstairs.",
    "zh": "我們去樓上看看。",
    "ja": "上の階を調べよう。"
  },
  {
    "time": "00:02:40",
    "en": "Let's check the bedroom.",
    "zh": "我們去看臥室。",
    "ja": "寝室を見てみよう。"
  },
  {
    "time": "00:02:42",
    "en": "Oh no.",
    "zh": "喔不。",
    "ja": "ああ、いやだ。"
  },
  {
    "time": "00:02:43",
    "en": "All my clothes are on the bed.",
    "zh": "我所有的衣服都在床上。",
    "ja": "私の服が全部ベッドの上にある。"
  },
  {
    "time": "00:02:46",
    "en": "And my clothes are on the floor.",
    "zh": "我的衣服也在地上。",
    "ja": "服も床に散らばっている。"
  },
  {
    "time": "00:02:49",
    "en": "Look.",
    "zh": "看。",
    "ja": "見て。"
  },
  {
    "time": "00:02:50",
    "en": "My jewelry box is open.",
    "zh": "我的珠寶盒打開了。",
    "ja": "私の宝石箱が開いている。"
  },
  {
    "time": "00:02:53",
    "en": "Did he take everything, Mommy?",
    "zh": "他把所有東西都拿走了嗎，媽媽？",
    "ja": "全部持っていったの？ママ。"
  },
  {
    "time": "00:02:56",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:02:57",
    "en": "My rings and necklaces are missing.",
    "zh": "我的戒指和項鍊不見了。",
    "ja": "私の指輪とネックレスがなくなっている。"
  },
  {
    "time": "00:03:00",
    "en": "Mommy is crying.",
    "zh": "媽媽在哭。",
    "ja": "ママが泣いている。"
  },
  {
    "time": "00:03:02",
    "en": "She is very sad.",
    "zh": "她很難過。",
    "ja": "とても悲しんでいる。"
  },
  {
    "time": "00:03:05",
    "en": "Do not cry, Grace.",
    "zh": "不要哭，Grace。",
    "ja": "泣かないで、グレース。"
  },
  {
    "time": "00:03:07",
    "en": "Please do not be sad.",
    "zh": "請不要難過。",
    "ja": "悲しまないでください。"
  },
  {
    "time": "00:03:09",
    "en": "Look at us.",
    "zh": "看看我們。",
    "ja": "私たちを見て。"
  },
  {
    "time": "00:03:10",
    "en": "We are safe.",
    "zh": "我們很安全。",
    "ja": "私たちは安全です。"
  },
  {
    "time": "00:03:12",
    "en": "Nobody is hurt.",
    "zh": "沒有人受傷。",
    "ja": "誰も怪我をしていません。"
  },
  {
    "time": "00:03:13",
    "en": "But Dad, the television and the rings are gone.",
    "zh": "但是爸爸，電視和戒指都不見了。",
    "ja": "でもパパ、テレビと指輪がなくなっている。"
  },
  {
    "time": "00:03:17",
    "en": "It is okay, Leo.",
    "zh": "沒關係，Leo。",
    "ja": "大丈夫だよ、レオ。"
  },
  {
    "time": "00:03:19",
    "en": "We can buy new things.",
    "zh": "我們可以買新的東西。",
    "ja": "新しいものを買えばいい。"
  },
  {
    "time": "00:03:21",
    "en": "Our family is safe.",
    "zh": "我們的家人是安全的。",
    "ja": "家族は安全です。"
  },
  {
    "time": "00:03:23",
    "en": "That is the most precious thing.",
    "zh": "那是最珍貴的。",
    "ja": "それが一番大切なことです。"
  },
  {
    "time": "00:03:25",
    "en": "You are right, Ethan.",
    "zh": "你說得對，伊森。",
    "ja": "その通りだよ、イーサン。"
  },
  {
    "time": "00:03:27",
    "en": "My family is here.",
    "zh": "我的家人在這裡。",
    "ja": "家族がここにいる。"
  },
  {
    "time": "00:03:29",
    "en": "Now, I will call the police to help us.",
    "zh": "現在，我會打電話給警察幫忙。",
    "ja": "今から警察に助けを求めるよ。"
  },
  {
    "time": "00:03:33",
    "en": "Hello 911.",
    "zh": "你好，911。",
    "ja": "もしもし、911です。"
  },
  {
    "time": "00:03:35",
    "en": "Our house was robbed.",
    "zh": "我們家被搶劫了。",
    "ja": "私たちの家が強盗にあいました。"
  },
  {
    "time": "00:03:37",
    "en": "Please send help.",
    "zh": "請派人來幫忙。",
    "ja": "助けを送ってください。"
  },
  {
    "time": "00:03:40",
    "en": "Look outside.",
    "zh": "看外面。",
    "ja": "外を見て。"
  },
  {
    "time": "00:03:42",
    "en": "Flashing blue and red lights.",
    "zh": "閃爍的藍紅燈光。",
    "ja": "青と赤の点滅ライト。"
  },
  {
    "time": "00:03:44",
    "en": "Good evening family.",
    "zh": "晚上好，家人們。",
    "ja": "こんばんは、みなさん。"
  },
  {
    "time": "00:03:46",
    "en": "I am Officer Bob.",
    "zh": "我是警官Bob。",
    "ja": "私はボブ警官です。"
  },
  {
    "time": "00:03:48",
    "en": "I am a policeman.",
    "zh": "我是一名警察。",
    "ja": "私は警察官です。"
  },
  {
    "time": "00:03:50",
    "en": "I catch bad guys.",
    "zh": "我抓壞人。",
    "ja": "悪者を捕まえます。"
  },
  {
    "time": "00:03:52",
    "en": "Hello Officer.",
    "zh": "你好，警官。",
    "ja": "こんにちは、警官さん。"
  },
  {
    "time": "00:03:54",
    "en": "A thief stole our TV.",
    "zh": "小偷偷了我們的電視。",
    "ja": "泥棒がテレビを盗みました。"
  },
  {
    "time": "00:03:56",
    "en": "I am sorry to hear that.",
    "zh": "聽到這個我很難過。",
    "ja": "それはお気の毒に。"
  },
  {
    "time": "00:03:58",
    "en": "Let me check the front door.",
    "zh": "讓我檢查前門。",
    "ja": "玄関のドアを調べさせてください。"
  },
  {
    "time": "00:04:00",
    "en": "Did the thief break the door, Officer?",
    "zh": "小偷有破壞門嗎，警官？",
    "ja": "泥棒はドアを壊しましたか、警官？"
  },
  {
    "time": "00:04:04",
    "en": "No.",
    "zh": "沒有。",
    "ja": "いいえ。"
  },
  {
    "time": "00:04:05",
    "en": "The window is not broken.",
    "zh": "窗戶沒有破。",
    "ja": "窓は壊れていません。"
  },
  {
    "time": "00:04:07",
    "en": "The door is fine.",
    "zh": "門沒事。",
    "ja": "ドアは大丈夫です。"
  },
  {
    "time": "00:04:08",
    "en": "Did you lock the door with a key?",
    "zh": "你有用鑰匙鎖門嗎？",
    "ja": "鍵でドアをロックしましたか？"
  },
  {
    "time": "00:04:11",
    "en": "Oh no.",
    "zh": "喔不。",
    "ja": "ああ、いやだ。"
  },
  {
    "time": "00:04:13",
    "en": "I remember now.",
    "zh": "我現在想起來了。",
    "ja": "今思い出しました。"
  },
  {
    "time": "00:04:15",
    "en": "I was in a big hurry today.",
    "zh": "我今天很匆忙。",
    "ja": "今日はとても急いでいました。"
  },
  {
    "time": "00:04:17",
    "en": "I was not thinking.",
    "zh": "我沒多想。",
    "ja": "考えていませんでした。"
  },
  {
    "time": "00:04:19",
    "en": "Ethan, you forgot to lock the front door?",
    "zh": "伊森，你忘了鎖前門？",
    "ja": "イーサン、玄関のドアをロックし忘れたの？"
  },
  {
    "time": "00:04:23",
    "en": "I am so sorry Grace.",
    "zh": "對不起，Grace。",
    "ja": "ごめんね、グレース。"
  },
  {
    "time": "00:04:25",
    "en": "It was my mistake.",
    "zh": "是我的錯。",
    "ja": "私のミスでした。"
  },
  {
    "time": "00:04:30",
    "en": "I feel so bad about my mistake.",
    "zh": "我對我的錯誤感到很難過。",
    "ja": "自分のミスがとても悪く感じます。"
  },
  {
    "time": "00:04:32",
    "en": "It is my fault.",
    "zh": "是我的錯。",
    "ja": "私の責任です。"
  },
  {
    "time": "00:04:34",
    "en": "I put our family in danger.",
    "zh": "我讓家人陷入危險。",
    "ja": "家族を危険にさらしました。"
  },
  {
    "time": "00:04:36",
    "en": "Please forgive me.",
    "zh": "請原諒我。",
    "ja": "許してください。"
  },
  {
    "time": "00:04:38",
    "en": "It is okay, Ethan.",
    "zh": "沒關係，伊森。",
    "ja": "大丈夫だよ、イーサン。"
  },
  {
    "time": "00:04:40",
    "en": "We all make mistakes.",
    "zh": "我們都會犯錯。",
    "ja": "誰でも間違いを犯します。"
  },
  {
    "time": "00:04:42",
    "en": "Do not be sad, Dad.",
    "zh": "不要難過，爸爸。",
    "ja": "悲しまないで、パパ。"
  },
  {
    "time": "00:04:44",
    "en": "We love you.",
    "zh": "我們愛你。",
    "ja": "私たちはあなたを愛しています。"
  },
  {
    "time": "00:04:46",
    "en": "Your family is right Dad.",
    "zh": "你的家人說得對，爸爸。",
    "ja": "家族の言う通りだよ、パパ。"
  },
  {
    "time": "00:04:48",
    "en": "Do not be sad.",
    "zh": "不要難過。",
    "ja": "悲しまないで。"
  },
  {
    "time": "00:04:50",
    "en": "But I will give you some safety tips for next time.",
    "zh": "但我會給你一些下次的安全建議。",
    "ja": "でも次のために安全のコツを教えます。"
  },
  {
    "time": "00:04:53",
    "en": "First, always check the locks two times before you leave.",
    "zh": "首先，離開前一定要檢查兩次鎖。",
    "ja": "まず、出かける前に鍵を二度確認しましょう。"
  },
  {
    "time": "00:04:57",
    "en": "Check the doors and check the windows.",
    "zh": "檢查門和窗戶。",
    "ja": "ドアと窓をチェックしてください。"
  },
  {
    "time": "00:05:00",
    "en": "Second, you must have good communication with your neighbors.",
    "zh": "第二，你必須和鄰居保持良好溝通。",
    "ja": "次に、隣人と良いコミュニケーションを持つこと。"
  },
  {
    "time": "00:05:04",
    "en": "You must talk to them when something bad happens.",
    "zh": "當有壞事發生時，要和他們說。",
    "ja": "悪いことが起きたら話し合いましょう。"
  },
  {
    "time": "00:05:08",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:05:09",
    "en": "We will talk to them tomorrow morning.",
    "zh": "我們明天早上會和他們談談。",
    "ja": "明日の朝、話します。"
  },
  {
    "time": "00:05:14",
    "en": "Now let's find clues to solve the mystery.",
    "zh": "現在讓我們找線索解開謎團。",
    "ja": "さあ、謎を解く手がかりを探しましょう。"
  },
  {
    "time": "00:05:17",
    "en": "Look at the floor, Officer Bob.",
    "zh": "看地板，Bob警官。",
    "ja": "床を見て、ボブ警官。"
  },
  {
    "time": "00:05:20",
    "en": "Let me use my bright flashlight.",
    "zh": "讓我用我的強光手電筒。",
    "ja": "明るい懐中電灯を使わせて。"
  },
  {
    "time": "00:05:23",
    "en": "What is it, Officer?",
    "zh": "是什麼，警官？",
    "ja": "何ですか、警官？"
  },
  {
    "time": "00:05:26",
    "en": "What do you see?",
    "zh": "你看到了什麼？",
    "ja": "何が見えますか？"
  },
  {
    "time": "00:05:28",
    "en": "Muddy footprints from dirty shoes.",
    "zh": "髒鞋留下的泥腳印。",
    "ja": "汚れた靴の泥だらけの足跡。"
  },
  {
    "time": "00:05:31",
    "en": "He made our clean carpet very dirty.",
    "zh": "他把我們乾淨的地毯弄得很髒。",
    "ja": "きれいなカーペットをとても汚しました。"
  },
  {
    "time": "00:05:34",
    "en": "Follow me.",
    "zh": "跟我來。",
    "ja": "ついてきて。"
  },
  {
    "time": "00:05:35",
    "en": "The footprints go out the back door.",
    "zh": "腳印通往後門。",
    "ja": "足跡は裏口へ続いています。"
  },
  {
    "time": "00:05:38",
    "en": "Let's go to the backyard.",
    "zh": "我們去後院。",
    "ja": "裏庭に行きましょう。"
  },
  {
    "time": "00:05:40",
    "en": "Hurry.",
    "zh": "快點。",
    "ja": "急いで。"
  },
  {
    "time": "00:05:42",
    "en": "It is very dark in the backyard.",
    "zh": "後院很黑暗。",
    "ja": "裏庭はとても暗いです。"
  },
  {
    "time": "00:05:45",
    "en": "Stay close to us kids.",
    "zh": "孩子們靠近我們。",
    "ja": "子供たち、私たちの近くにいて。"
  },
  {
    "time": "00:05:47",
    "en": "My flashlight shows the footprints.",
    "zh": "我的手電筒照出腳印。",
    "ja": "懐中電灯が足跡を照らしています。"
  },
  {
    "time": "00:05:50",
    "en": "They go to the tall wooden fence.",
    "zh": "腳印通往高木柵欄。",
    "ja": "足跡は高い木のフェンスへ続いています。"
  },
  {
    "time": "00:05:53",
    "en": "Look at the grass.",
    "zh": "看草地。",
    "ja": "草を見て。"
  },
  {
    "time": "00:05:55",
    "en": "There is no TV here.",
    "zh": "這裡沒有電視。",
    "ja": "ここにテレビはありません。"
  },
  {
    "time": "00:05:57",
    "en": "A no jewelry box.",
    "zh": "也沒有珠寶盒。",
    "ja": "宝石箱もありません。"
  },
  {
    "time": "00:05:59",
    "en": "Did the thief take out things?",
    "zh": "小偷拿出東西了嗎？",
    "ja": "泥棒は物を持ち出しましたか？"
  },
  {
    "time": "00:06:02",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:06:03",
    "en": "The thief took them.",
    "zh": "小偷拿走了。",
    "ja": "泥棒が持ち去りました。"
  },
  {
    "time": "00:06:05",
    "en": "He ran away.",
    "zh": "他逃跑了。",
    "ja": "彼は逃げました。"
  },
  {
    "time": "00:06:07",
    "en": "Listen family, we have many similar robberies here.",
    "zh": "聽著家人們，這裡有很多類似的搶劫案。",
    "ja": "聞いてください、家族のみなさん。ここでは似たような強盗が多発しています。"
  },
  {
    "time": "00:06:11",
    "en": "Many houses near here were robbed this week.",
    "zh": "這週附近很多房子被搶。",
    "ja": "今週、この近くの多くの家が強盗にあいました。"
  },
  {
    "time": "00:06:14",
    "en": "Wow.",
    "zh": "哇。",
    "ja": "わあ。"
  },
  {
    "time": "00:06:16",
    "en": "So we cannot be careless.",
    "zh": "所以我們不能大意。",
    "ja": "だから油断できません。"
  },
  {
    "time": "00:06:18",
    "en": "We must be alert.",
    "zh": "我們必須保持警覺。",
    "ja": "警戒を怠ってはいけません。"
  },
  {
    "time": "00:06:20",
    "en": "Can you catch him, Officer Bob?",
    "zh": "你能抓到他嗎，Bob警官？",
    "ja": "彼を捕まえられますか、ボブ警官？"
  },
  {
    "time": "00:06:22",
    "en": "We have a suspect.",
    "zh": "我們有嫌疑人。",
    "ja": "容疑者がいます。"
  },
  {
    "time": "00:06:24",
    "en": "We know who he is.",
    "zh": "我們知道他是誰。",
    "ja": "彼が誰か分かっています。"
  },
  {
    "time": "00:06:26",
    "en": "Where is he?",
    "zh": "他在哪裡？",
    "ja": "彼はどこにいますか？"
  },
  {
    "time": "00:06:28",
    "en": "He is very fast.",
    "zh": "他很快。",
    "ja": "彼はとても速いです。"
  },
  {
    "time": "00:06:30",
    "en": "But I will investigate and find him.",
    "zh": "但我會調查並找到他。",
    "ja": "でも調査して彼を見つけます。"
  },
  {
    "time": "00:06:34",
    "en": "Good morning, Mr. Clark.",
    "zh": "早安，Clark先生。",
    "ja": "おはようございます、クラークさん。"
  },
  {
    "time": "00:06:37",
    "en": "Good morning, Grace.",
    "zh": "早安，Grace。",
    "ja": "おはよう、グレース。"
  },
  {
    "time": "00:06:39",
    "en": "Is everything okay?",
    "zh": "一切都好嗎？",
    "ja": "大丈夫ですか？"
  },
  {
    "time": "00:06:41",
    "en": "Our house was robbed last night.",
    "zh": "我們家昨晚被搶了。",
    "ja": "昨夜、私たちの家が強盗にあいました。"
  },
  {
    "time": "00:06:43",
    "en": "Oh no.",
    "zh": "喔不。",
    "ja": "ああ、いやだ。"
  },
  {
    "time": "00:06:45",
    "en": "That is terrible.",
    "zh": "那真糟糕。",
    "ja": "それはひどいですね。"
  },
  {
    "time": "00:06:47",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:06:49",
    "en": "The thief took our TV and some rings.",
    "zh": "小偷拿走了我們的電視和一些戒指。",
    "ja": "泥棒がテレビといくつかの指輪を持っていきました。"
  },
  {
    "time": "00:06:52",
    "en": "I have security cameras on my house.",
    "zh": "我家有監視攝影機。",
    "ja": "私の家には防犯カメラがあります。"
  },
  {
    "time": "00:06:56",
    "en": "I will check the videos for you.",
    "zh": "我會幫你查看錄影。",
    "ja": "ビデオを確認してあげます。"
  },
  {
    "time": "00:06:59",
    "en": "Thank you, Mr. Clark.",
    "zh": "謝謝你，Clark先生。",
    "ja": "ありがとうございます、クラークさん。"
  },
  {
    "time": "00:07:02",
    "en": "We must look out for each other.",
    "zh": "我們必須互相照應。",
    "ja": "お互いに気をつけなければなりません。"
  },
  {
    "time": "00:07:05",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:07:06",
    "en": "Good neighbors help each other.",
    "zh": "好鄰居會互相幫助。",
    "ja": "良い隣人は助け合います。"
  },
  {
    "time": "00:07:08",
    "en": "It is a new beautiful day.",
    "zh": "這是美好的一天。",
    "ja": "新しい美しい日です。"
  },
  {
    "time": "00:07:12",
    "en": "Let's clean our house, family.",
    "zh": "家人們，我們來打掃房子。",
    "ja": "家族のみんな、家を掃除しましょう。"
  },
  {
    "time": "00:07:15",
    "en": "Yes.",
    "zh": "好的。",
    "ja": "はい。"
  },
  {
    "time": "00:07:16",
    "en": "The living room is very dirty.",
    "zh": "客廳很髒。",
    "ja": "リビングルームはとても汚れています。"
  },
  {
    "time": "00:07:18",
    "en": "I will pick up my toys.",
    "zh": "我要撿起我的玩具。",
    "ja": "おもちゃを片付けます。"
  },
  {
    "time": "00:07:21",
    "en": "I will clean the dirty carpet.",
    "zh": "我要清理髒地毯。",
    "ja": "汚れたカーペットを掃除します。"
  },
  {
    "time": "00:07:24",
    "en": "I will put the books on the bookshelf.",
    "zh": "我要把書放回書架。",
    "ja": "本を本棚に戻します。"
  },
  {
    "time": "00:07:27",
    "en": "Look.",
    "zh": "看。",
    "ja": "見て。"
  },
  {
    "time": "00:07:28",
    "en": "The cookie jar is empty on the table.",
    "zh": "桌上的餅乾罐是空的。",
    "ja": "テーブルのクッキージャーは空です。"
  },
  {
    "time": "00:07:31",
    "en": "That is okay.",
    "zh": "沒關係。",
    "ja": "大丈夫です。"
  },
  {
    "time": "00:07:33",
    "en": "We can bake new cookies today.",
    "zh": "我們今天可以烤新的餅乾。",
    "ja": "今日新しいクッキーを焼きましょう。"
  },
  {
    "time": "00:07:36",
    "en": "Yay.",
    "zh": "耶。",
    "ja": "やったー。"
  },
  {
    "time": "00:07:37",
    "en": "I love sweet chocolate cookies.",
    "zh": "我喜歡甜甜的巧克力餅乾。",
    "ja": "甘いチョコレートクッキーが大好き。"
  },
  {
    "time": "00:07:40",
    "en": "And I will sweep the kitchen floor.",
    "zh": "我會掃廚房地板。",
    "ja": "キッチンの床を掃きます。"
  },
  {
    "time": "00:07:43",
    "en": "Thank you, team.",
    "zh": "謝謝你們，團隊。",
    "ja": "ありがとう、チーム。"
  },
  {
    "time": "00:07:44",
    "en": "You are great helpers.",
    "zh": "你們是很棒的幫手。",
    "ja": "みんなは素晴らしい助っ人です。"
  },
  {
    "time": "00:07:46",
    "en": "Our house is clean and beautiful again.",
    "zh": "我們的家又乾淨又漂亮了。",
    "ja": "家がまたきれいで美しくなりました。"
  },
  {
    "time": "00:07:51",
    "en": "Look.",
    "zh": "看。",
    "ja": "見て。"
  },
  {
    "time": "00:07:52",
    "en": "Dad is back from the store.",
    "zh": "爸爸從商店回來了。",
    "ja": "パパが店から戻ってきた。"
  },
  {
    "time": "00:07:56",
    "en": "What is in the big brown bag, Dad?",
    "zh": "爸爸，大棕袋裡是什麼？",
    "ja": "パパ、大きな茶色の袋の中は何？"
  },
  {
    "time": "00:07:59",
    "en": "I bought new heavy locks for the doors.",
    "zh": "我買了新的重型門鎖。",
    "ja": "ドア用の新しい頑丈な鍵を買いました。"
  },
  {
    "time": "00:08:02",
    "en": "That is excellent, Ethan.",
    "zh": "太好了，伊森。",
    "ja": "それは素晴らしい、イーサン。"
  },
  {
    "time": "00:08:05",
    "en": "And I bought a very loud alarm.",
    "zh": "我還買了一個很響的警報器。",
    "ja": "それにとても大きなアラームも買いました。"
  },
  {
    "time": "00:08:08",
    "en": "You have a hammer and a screwdriver, Dad?",
    "zh": "爸爸，你有錘子和螺絲起子嗎？",
    "ja": "パパ、ハンマーとドライバーはありますか？"
  },
  {
    "time": "00:08:11",
    "en": "Yes, Leo.",
    "zh": "有的，Leo。",
    "ja": "あるよ、レオ。"
  },
  {
    "time": "00:08:12",
    "en": "Let's put the new locks on the door right now.",
    "zh": "我們現在就裝新鎖。",
    "ja": "今すぐ新しい鍵をドアに取り付けよう。"
  },
  {
    "time": "00:08:16",
    "en": "Yes.",
    "zh": "好的。",
    "ja": "はい。"
  },
  {
    "time": "00:08:17",
    "en": "Let's install the new alarm too.",
    "zh": "我們也裝新警報器。",
    "ja": "新しいアラームも取り付けましょう。"
  },
  {
    "time": "00:08:20",
    "en": "Now the bad thief cannot come inside.",
    "zh": "現在壞小偷進不來了。",
    "ja": "これで悪い泥棒は入れません。"
  },
  {
    "time": "00:08:24",
    "en": "Remember my mistake, kids?",
    "zh": "孩子們，記得我的錯誤嗎？",
    "ja": "みんな、私のミスを覚えてる？"
  },
  {
    "time": "00:08:27",
    "en": "Always lock the doors.",
    "zh": "一定要鎖門。",
    "ja": "必ずドアをロックしましょう。"
  },
  {
    "time": "00:08:29",
    "en": "But the bad thief is still out there, Dad.",
    "zh": "但壞小偷還在外面，爸爸。",
    "ja": "でも悪い泥棒はまだ外にいるよ、パパ。"
  },
  {
    "time": "00:08:32",
    "en": "Yes, but we have a new alarm.",
    "zh": "是的，但我們有新警報器。",
    "ja": "そうだけど、新しいアラームがあるから。"
  },
  {
    "time": "00:08:35",
    "en": "We are safe.",
    "zh": "我們很安全。",
    "ja": "私たちは安全です。"
  },
  {
    "time": "00:08:37",
    "en": "Did you like our video today?",
    "zh": "你喜歡我們今天的影片嗎？",
    "ja": "今日のビデオは気に入りましたか？"
  },
  {
    "time": "00:08:40",
    "en": "Your like is very important to show us.",
    "zh": "你的讚對我們很重要。",
    "ja": "いいねは私たちにとってとても大切です。"
  },
  {
    "time": "00:08:43",
    "en": "Please like and subscribe.",
    "zh": "請按讚並訂閱。",
    "ja": "いいねとチャンネル登録をお願いします。"
  },
  {
    "time": "00:08:45",
    "en": "Bye bye.",
    "zh": "再見。",
    "ja": "バイバイ。"
  },
  {
    "time": "00:08:47",
    "en": "Bye bye.",
    "zh": "再見。",
    "ja": "バイバイ。"
  }
]