  "dialogue": [
    {
      "role": "student",
      "text": "Oh, no! The dress!",
      "zh": "喔，不！裙子！",
      "ja": "ああ、ダメだ！ドレスが！",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "David, you burned my dress. I am leaving now, David.",
      "zh": "大衛，你燒壞了我的裙子。我現在要走了，大衛。",
      "ja": "デイビッド、私のドレスを燃やしたのね。今すぐ出て行くわ、デイビッド。",
      "time": "00:00:17"
    },
    {
      "role": "student",
      "text": "Let's play together! This is fun!",
      "zh": "我們一起玩吧！這很有趣！",
      "ja": "一緒に遊ぼう！楽しいね！",
      "time": "00:00:30"
    },
    {
      "role": "student",
      "text": "I feel very tired today.",
      "zh": "我今天感覺很累。",
      "ja": "今日はとても疲れた。",
      "time": "00:00:40"
    },
    {
      "role": "student",
      "text": "Dad, why are you sad?",
      "zh": "爸爸，你為什麼難過？",
      "ja": "パパ、どうして悲しいの？",
      "time": "00:00:47"
    },
    {
      "role": "student",
      "text": "I made mom angry.",
      "zh": "我讓媽媽生氣了。",
      "ja": "ママを怒らせてしまったんだ。",
      "time": "00:00:57"
    },
    {
      "role": "student",
      "text": "What did you do, Dad?",
      "zh": "爸爸，你做了什麼？",
      "ja": "パパ、何をしたの？",
      "time": "00:01:08"
    },
    {
      "role": "student",
      "text": "I burned mom's favorite dress. I watched TV and forgot it.",
      "zh": "我燒壞了媽媽最喜歡的裙子。我看電視忘了它。",
      "ja": "ママのお気に入りのドレスを燃やしてしまった。テレビを見ていて忘れてたんだ。",
      "time": "00:01:12"
    },
    {
      "role": "student",
      "text": "The dress was on fire?",
      "zh": "裙子著火了？",
      "ja": "ドレスが燃えたの？",
      "time": "00:01:21"
    },
    {
      "role": "student",
      "text": "Yes, mom was very angry.",
      "zh": "是的，媽媽非常生氣。",
      "ja": "うん、ママはとても怒ってたよ。",
      "time": "00:01:26"
    },
    {
      "role": "student",
      "text": "Mom must be very sad.",
      "zh": "媽媽一定很難過。",
      "ja": "ママはきっととても悲しいよ。",
      "time": "00:01:33"
    },
    {
      "role": "student",
      "text": "She went to grandma's house.",
      "zh": "她去奶奶家了。",
      "ja": "彼女はおばあちゃんの家に行った。",
      "time": "00:01:40"
    },
    {
      "role": "student",
      "text": "Let's play again.",
      "zh": "我們再玩一次吧。",
      "ja": "もう一度遊ぼう。",
      "time": "00:01:53"
    },
    {
      "role": "student",
      "text": "Okay, but I miss mom.",
      "zh": "好，但我想念媽媽。",
      "ja": "うん、でもママが恋しい。",
      "time": "00:01:56"
    },
    {
      "role": "student",
      "text": "I will sleep for a moment.",
      "zh": "我會睡一會兒。",
      "ja": "ちょっと寝るね。",
      "time": "00:02:01"
    },
    {
      "role": "student",
      "text": "Just a short rest.",
      "zh": "只是短暫休息。",
      "ja": "ちょっとだけ休憩。",
      "time": "00:02:05"
    },
    {
      "role": "student",
      "text": "I feel hungry.",
      "zh": "我餓了。",
      "ja": "お腹がすいた。",
      "time": "00:02:12"
    },
    {
      "role": "student",
      "text": "Me too. I want food.",
      "zh": "我也是。我想吃東西。",
      "ja": "僕も。食べたい。",
      "time": "00:02:19"
    },
    {
      "role": "student",
      "text": "Dad, please wake up.",
      "zh": "爸爸，請醒醒。",
      "ja": "パパ、起きて。",
      "time": "00:02:23"
    },
    {
      "role": "student",
      "text": "Okay, I will cook.",
      "zh": "好，我來煮飯。",
      "ja": "わかった、料理するよ。",
      "time": "00:02:27"
    },
    {
      "role": "student",
      "text": "Oh, I see a chicken.",
      "zh": "喔，我看到一隻雞。",
      "ja": "ああ、チキンがある。",
      "time": "00:02:38"
    },
    {
      "role": "student",
      "text": "It is very hard and cold.",
      "zh": "它很硬又冷。",
      "ja": "とても硬くて冷たい。",
      "time": "00:02:41"
    },
    {
      "role": "student",
      "text": "I will break the ice.",
      "zh": "我要敲碎冰塊。",
      "ja": "氷を割るよ。",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "Oh, it's still intact.",
      "zh": "喔，它還是完整的。",
      "ja": "ああ、まだ壊れてない。",
      "time": "00:02:48"
    },
    {
      "role": "student",
      "text": "Dad, please be careful.",
      "zh": "爸爸，請小心。",
      "ja": "パパ、気をつけて。",
      "time": "00:02:53"
    },
    {
      "role": "student",
      "text": "Fire will melt it.",
      "zh": "火會把它融化。",
      "ja": "火で溶けちゃうよ。",
      "time": "00:03:01"
    },
    {
      "role": "student",
      "text": "This cartoon is funny.",
      "zh": "這部卡通很有趣。",
      "ja": "このアニメは面白い。",
      "time": "00:03:12"
    },
    {
      "role": "student",
      "text": "I smell something bad.",
      "zh": "我聞到怪味道。",
      "ja": "変な匂いがする。",
      "time": "00:03:19"
    },
    {
      "role": "student",
      "text": "Dad, what is that smell?",
      "zh": "爸爸，那是什麼味道？",
      "ja": "パパ、その匂いは何？",
      "time": "00:03:26"
    },
    {
      "role": "student",
      "text": "Oh no, I burned the chicken.",
      "zh": "喔不，我把雞燒焦了。",
      "ja": "ああ、チキンを焦がしちゃった。",
      "time": "00:03:34"
    },
    {
      "role": "student",
      "text": "The chicken is black.",
      "zh": "雞變黑了。",
      "ja": "チキンが真っ黒だ。",
      "time": "00:03:41"
    },
    {
      "role": "student",
      "text": "We have no food.",
      "zh": "我們沒有食物了。",
      "ja": "食べ物がない。",
      "time": "00:03:51"
    },
    {
      "role": "student",
      "text": "Don't worry. I will order pizza.",
      "zh": "別擔心。我會訂披薩。",
      "ja": "心配しないで。ピザを注文するよ。",
      "time": "00:03:59"
    },
    {
      "role": "student",
      "text": "Hello. One big pizza, please.",
      "zh": "你好。請給我一個大披薩。",
      "ja": "もしもし。大きなピザを一つお願いします。",
      "time": "00:04:07"
    },
    {
      "role": "student",
      "text": "I am very hungry.",
      "zh": "我很餓。",
      "ja": "とてもお腹がすいた。",
      "time": "00:04:14"
    },
    {
      "role": "student",
      "text": "Pizza is here.",
      "zh": "披薩到了。",
      "ja": "ピザが来たよ。",
      "time": "00:04:21"
    },
    {
      "role": "student",
      "text": "Thank you very much.",
      "zh": "非常感謝。",
      "ja": "どうもありがとう。",
      "time": "00:04:31"
    },
    {
      "role": "student",
      "text": "This pizza is very good.",
      "zh": "這披薩很好吃。",
      "ja": "このピザはとても美味しい。",
      "time": "00:04:40"
    },
    {
      "role": "student",
      "text": "Yes, I feel happy now.",
      "zh": "是的，我現在很開心。",
      "ja": "うん、今は幸せだよ。",
      "time": "00:04:49"
    },
    {
      "role": "student",
      "text": "The house is very messy.",
      "zh": "房子很亂。",
      "ja": "家がとても散らかってる。",
      "time": "00:04:55"
    },
    {
      "role": "student",
      "text": "I will clean the floor.",
      "zh": "我會擦地板。",
      "ja": "床を掃除するよ。",
      "time": "00:04:59"
    },
    {
      "role": "student",
      "text": "Dad, my toys are there.",
      "zh": "爸爸，我的玩具在那裡。",
      "ja": "パパ、僕のおもちゃがあそこにある。",
      "time": "00:05:05"
    },
    {
      "role": "student",
      "text": "Oh, what is inside?",
      "zh": "喔，裡面是什麼？",
      "ja": "ああ、中には何があるの？",
      "time": "00:05:21"
    },
    {
      "role": "student",
      "text": "Where are my toys?",
      "zh": "我的玩具在哪裡？",
      "ja": "僕のおもちゃはどこ？",
      "time": "00:05:28"
    },
    {
      "role": "student",
      "text": "I wish mom was here.",
      "zh": "我希望媽媽在這裡。",
      "ja": "ママがここにいてほしい。",
      "time": "00:05:39"
    },
    {
      "role": "student",
      "text": "I have an idea.",
      "zh": "我有個主意。",
      "ja": "いい考えがあるよ。",
      "time": "00:05:45"
    },
    {
      "role": "student",
      "text": "Dad, let's go pick up mom.",
      "zh": "爸爸，我們去接媽媽吧。",
      "ja": "パパ、ママを迎えに行こう。",
      "time": "00:05:49"
    },
    {
      "role": "student",
      "text": "Yes, I will say sorry.",
      "zh": "好，我會說對不起。",
      "ja": "うん、ごめんねと言うよ。",
      "time": "00:05:57"
    },
    {
      "role": "student",
      "text": "These flowers are for mom.",
      "zh": "這些花是給媽媽的。",
      "ja": "この花はママのため。",
      "time": "00:06:08"
    },
    {
      "role": "student",
      "text": "I feel nervous.",
      "zh": "我感到緊張。",
      "ja": "緊張してる。",
      "time": "00:06:15"
    },
    {
      "role": "student",
      "text": "Why are you here?",
      "zh": "你們為什麼在這裡？",
      "ja": "どうしてここにいるの？",
      "time": "00:06:26"
    },
    {
      "role": "student",
      "text": "I am very sorry, Emma.",
      "zh": "我非常抱歉，艾瑪。",
      "ja": "本当にごめんね、エマ。",
      "time": "00:06:32"
    },
    {
      "role": "student",
      "text": "We miss you, mom.",
      "zh": "我們想你，媽媽。",
      "ja": "ママが恋しいよ。",
      "time": "00:06:41"
    },
    {
      "role": "student",
      "text": "Please come home.",
      "zh": "請回家吧。",
      "ja": "家に帰ってきて。",
      "time": "00:06:43"
    },
    {
      "role": "student",
      "text": "I will help at home.",
      "zh": "我會幫忙做家事。",
      "ja": "家の手伝いをするよ。",
      "time": "00:06:51"
    },
    {
      "role": "student",
      "text": "I clean the floor.",
      "zh": "我擦地板。",
      "ja": "床を掃除する。",
      "time": "00:07:02"
    },
    {
      "role": "student",
      "text": "I wipe the table.",
      "zh": "我擦桌子。",
      "ja": "テーブルを拭く。",
      "time": "00:07:06"
    },
    {
      "role": "student",
      "text": "I wash the dishes.",
      "zh": "我洗碗。",
      "ja": "皿を洗う。",
      "time": "00:07:11"
    },
    {
      "role": "student",
      "text": "Thank you for helping David.",
      "zh": "謝謝你幫忙，大衛。",
      "ja": "手伝ってくれてありがとう、デイビッド。",
      "time": "00:07:18"
    },
    {
      "role": "student",
      "text": "Dad works very hard.",
      "zh": "爸爸很努力工作。",
      "ja": "パパはとても頑張ってる。",
      "time": "00:07:25"
    },
    {
      "role": "student",
      "text": "Our house looks clean.",
      "zh": "我們的家看起來很乾淨。",
      "ja": "家がきれいになったね。",
      "time": "00:07:30"
    },
    {
      "role": "student",
      "text": "Dinner is ready.",
      "zh": "晚餐準備好了。",
      "ja": "夕食ができたよ。",
      "time": "00:07:37"
    },
    {
      "role": "student",
      "text": "Wow, this food is great.",
      "zh": "哇，這食物真棒。",
      "ja": "わあ、この料理はすごい。",
      "time": "00:07:43"
    },
    {
      "role": "student",
      "text": "I am very happy.",
      "zh": "我很開心。",
      "ja": "とても幸せだよ。",
      "time": "00:07:46"
    },
    {
      "role": "student",
      "text": "Yes, Tom, me too.",
      "zh": "是的，湯姆，我也是。",
      "ja": "うん、トム、僕もだよ。",
      "time": "00:07:52"
    },
    {
      "role": "student",
      "text": "Yes, babies.",
      "zh": "是的，寶貝們。",
      "ja": "そうだね、赤ちゃんたち。",
      "time": "00:07:57"
    },
    {
      "role": "student",
      "text": "Family is important.",
      "zh": "家庭很重要。",
      "ja": "家族は大切だよ。",
      "time": "00:07:59"
    },
    {
      "role": "student",
      "text": "I love our family.",
      "zh": "我愛我們的家人。",
      "ja": "僕は家族が大好き。",
      "time": "00:08:02"
    },
    {
      "role": "student",
      "text": "We love you too.",
      "zh": "我們也愛你。",
      "ja": "私たちもあなたを愛してる。",
      "time": "00:08:08"
    },
    {
      "role": "student",
      "text": "I will do better.",
      "zh": "我會做得更好。",
      "ja": "もっと頑張るよ。",
      "time": "00:08:15"
    },
    {
      "role": "student",
      "text": "This is a happy home.",
      "zh": "這是個幸福的家。",
      "ja": "ここは幸せな家だ。",
      "time": "00:08:22"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとう。",
      "time": "00:08:29"
    },
    {
      "role": "student",
      "text": "Thank you for forgiving me.",
      "zh": "謝謝你原諒我。",
      "ja": "許してくれてありがとう。",
      "time": "00:08:32"
    },
    {
      "role": "student",
      "text": "Let's help each other.",
      "zh": "讓我們互相幫助。",
      "ja": "お互いに助け合おう。",
      "time": "00:08:40"
    },
    {
      "role": "student",
      "text": "I like this day.",
      "zh": "我喜歡這一天。",
      "ja": "この日が好きだ。",
      "time": "00:08:50"
    },
    {
      "role": "student",
      "text": "I love you too.",
      "zh": "我也愛你。",
      "ja": "僕も愛してるよ。",
      "time": "00:09:01"
    }
  ]
