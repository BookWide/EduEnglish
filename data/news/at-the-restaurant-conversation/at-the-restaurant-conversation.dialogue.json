  "dialogue": [
    {
      "role": "teacher",
      "text": "Hello, how can I help you?",
      "zh": "你好，我能幫你什麼？",
      "ja": "こんにちは、いかがなさいましたか？",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Hello, I would like a table for four please.",
