      "time": "00:02:16"
    },
    {
      "role": "teacher",
      "text": "I'll have the chocolate cake.",
      "zh": "我要巧克力蛋糕。",
      "ja": "チョコレートケーキをください。",
      "time": "00:02:19"
    },
    {
      "role": "student",
      "text": "I'll have ice cream.",
      "zh": "我要冰淇淋。",
      "ja": "アイスクリームをお願いします。",
