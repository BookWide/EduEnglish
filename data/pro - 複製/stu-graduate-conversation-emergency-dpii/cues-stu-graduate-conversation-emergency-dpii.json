[
  {
    "time": "00:00:00",
    "en": "Leo, I'm scared.",
    "zh": "Leo，我很害怕。",
    "ja": "レオ、怖いよ。",
    "source_url": "https://www.youtube.com/watch?v=DpIiX_cnmKo"
  },
  {
    "time": "00:00:07",
    "en": "Why Anna?",
    "zh": "為什麼，Anna？",
    "ja": "なぜ、アンナ？"
  },
  {
    "time": "00:00:09",
    "en": "Because I love you, and my dad hates it.",
    "zh": "因為我愛你，而我爸爸討厭這件事。",
    "ja": "あなたを愛しているから、でもお父さんはそれを嫌っているの。"
  },
  {
    "time": "00:00:13",
    "en": "He hates me?",
    "zh": "他討厭我？",
    "ja": "彼は私を嫌っているの？"
  },
  {
    "time": "00:00:15",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:00:17",
    "en": "He says you are poor.",
    "zh": "他說你很窮。",
    "ja": "彼はあなたが貧しいと言っている。"
  },
  {
    "time": "00:00:19",
    "en": "He says you want my money.",
    "zh": "他說你想要我的錢。",
    "ja": "彼はあなたが私のお金を欲しがっていると言っている。"
  },
  {
    "time": "00:00:22",
    "en": "That's not true.",
    "zh": "那不是真的。",
    "ja": "それは違うよ。"
  },
  {
    "time": "00:00:24",
    "en": "I don't want your money, Anna.",
    "zh": "我不想要你的錢，Anna。",
    "ja": "アンナ、君のお金は欲しくない。"
  },
  {
    "time": "00:00:26",
    "en": "I want you.",
    "zh": "我想要的是你。",
    "ja": "君が欲しいんだ。"
  },
  {
    "time": "00:00:29",
    "en": "I know that.",
    "zh": "我知道。",
    "ja": "それはわかってる。"
  },
  {
    "time": "00:00:31",
    "en": "I believe you.",
    "zh": "我相信你。",
    "ja": "信じているよ。"
  },
  {
    "time": "00:00:33",
    "en": "But my dad only sees money.",
    "zh": "但我爸爸只看到錢。",
    "ja": "でもお父さんはお金しか見ていない。"
  },
  {
    "time": "00:00:36",
    "en": "He thinks love is not real without it.",
    "zh": "他認為沒有錢愛情不是真實的。",
    "ja": "お金がなければ愛は本物じゃないと思っている。"
  },
  {
    "time": "00:00:39",
    "en": "Maybe he is right.",
    "zh": "也許他是對的。",
    "ja": "もしかしたら彼は正しいのかも。"
  },
  {
    "time": "00:00:41",
    "en": "I have nothing.",
    "zh": "我一無所有。",
    "ja": "僕は何も持っていない。"
  },
  {
    "time": "00:00:43",
    "en": "No job.",
    "zh": "沒有工作。",
    "ja": "仕事もない。"
  },
  {
    "time": "00:00:45",
    "en": "No house.",
    "zh": "沒有房子。",
    "ja": "家もない。"
  },
  {
    "time": "00:00:46",
    "en": "No car.",
    "zh": "沒有車。",
    "ja": "車もない。"
  },
  {
    "time": "00:00:48",
    "en": "Just dreams.",
    "zh": "只有夢想。",
    "ja": "夢だけだ。"
  },
  {
    "time": "00:00:51",
    "en": "You have a big heart.",
    "zh": "你有一顆大大的心。",
    "ja": "君は大きな心を持っている。"
  },
  {
    "time": "00:00:53",
    "en": "You are kind.",
    "zh": "你很善良。",
    "ja": "優しい人だ。"
  },
  {
    "time": "00:00:55",
    "en": "You make me laugh.",
    "zh": "你讓我笑。",
    "ja": "僕を笑わせてくれる。"
  },
  {
    "time": "00:00:57",
    "en": "That is real to me.",
    "zh": "那對我來說是真實的。",
    "ja": "それは僕にとって本物だ。"
  },
  {
    "time": "00:00:59",
    "en": "But is it enough?",
    "zh": "但這夠了嗎？",
    "ja": "でもそれで十分かな？"
  },
  {
    "time": "00:01:01",
    "en": "If your dad says no, will you still choose me?",
    "zh": "如果你爸爸說不，你還會選擇我嗎？",
    "ja": "お父さんが反対しても、僕を選んでくれる？"
  },
  {
    "time": "00:01:05",
    "en": "I want to.",
    "zh": "我想要。",
    "ja": "そうしたい。"
  },
  {
    "time": "00:01:07",
    "en": "I really do.",
    "zh": "我真的想。",
    "ja": "本当にそう思ってる。"
  },
  {
    "time": "00:01:09",
    "en": "But Leo, he is my father.",
    "zh": "但Leo，他是我爸爸。",
    "ja": "でもレオ、彼は私の父親よ。"
  },
  {
    "time": "00:01:12",
    "en": "How can I leave him?",
    "zh": "我怎麼能離開他？",
    "ja": "どうやって彼を離れられるの？"
  },
  {
    "time": "00:01:14",
    "en": "He has raised me since I was a child.",
    "zh": "他從我小時候就養育我。",
    "ja": "彼は子供の頃から私を育ててくれた。"
  },
  {
    "time": "00:01:17",
    "en": "I understand, Anna.",
    "zh": "我理解你，Anna。",
    "ja": "わかるよ、アンナ。"
  },
  {
    "time": "00:01:21",
    "en": "Anna, what are you doing?",
    "zh": "Anna，你在做什麼？",
    "ja": "アンナ、何をしているの？"
  },
  {
    "time": "00:01:30",
    "en": "I'm talking to Leo, dad.",
    "zh": "我在跟Leo說話，爸爸。",
    "ja": "レオと話しているのよ、お父さん。"
  },
  {
    "time": "00:01:33",
    "en": "I told you.",
    "zh": "我告訴過你了。",
    "ja": "言っただろう。"
  },
  {
    "time": "00:01:34",
    "en": "Stay away from him.",
    "zh": "離他遠一點。",
    "ja": "彼から離れなさい。"
  },
  {
    "time": "00:01:36",
    "en": "Sir, I love Anna.",
    "zh": "先生，我愛Anna。",
    "ja": "先生、僕はアンナを愛しています。"
  },
  {
    "time": "00:01:38",
    "en": "I want to be with her.",
    "zh": "我想和她在一起。",
    "ja": "彼女と一緒にいたい。"
  },
  {
    "time": "00:01:41",
    "en": "You.",
    "zh": "你。",
    "ja": "お前。"
  },
  {
    "time": "00:01:42",
    "en": "What do you have?",
    "zh": "你有什麼？",
    "ja": "何があるんだ？"
  },
  {
    "time": "00:01:44",
    "en": "You have nothing.",
    "zh": "你一無所有。",
    "ja": "何も持っていない。"
  },
  {
    "time": "00:01:46",
    "en": "You are not her future.",
    "zh": "你不是她的未來。",
    "ja": "彼女の未来じゃない。"
  },
  {
    "time": "00:01:49",
    "en": "Money can come and go.",
    "zh": "錢來來去去。",
    "ja": "お金は入っては出ていくものだ。"
  },
  {
    "time": "00:01:51",
    "en": "But love is real.",
    "zh": "但愛是真實的。",
    "ja": "でも愛は本物だ。"
  },
  {
    "time": "00:01:53",
    "en": "I love her.",
    "zh": "我愛她。",
    "ja": "彼女を愛している。"
  },
  {
    "time": "00:01:55",
    "en": "I will work hard.",
    "zh": "我會努力工作。",
    "ja": "一生懸命働く。"
  },
  {
    "time": "00:01:57",
    "en": "I will build a life.",
    "zh": "我會建立生活。",
    "ja": "生活を築く。"
  },
  {
    "time": "00:02:00",
    "en": "Words are easy.",
    "zh": "說話容易。",
    "ja": "言葉は簡単だ。"
  },
  {
    "time": "00:02:02",
    "en": "Life is hard.",
    "zh": "生活很難。",
    "ja": "人生は厳しい。"
  },
  {
    "time": "00:02:04",
    "en": "Life runs on money, not on love.",
    "zh": "生活靠錢，不靠愛。",
    "ja": "人生はお金で動く、愛ではない。"
  },
  {
    "time": "00:02:08",
    "en": "Go and try to buy some fruits with love.",
    "zh": "去試著用愛買些水果看看。",
    "ja": "愛で果物を買ってみろ。"
  },
  {
    "time": "00:02:10",
    "en": "You'll see, you cannot.",
    "zh": "你會發現，買不到。",
    "ja": "無理だとわかるだろう。"
  },
  {
    "time": "00:02:13",
    "en": "Love cannot even buy a cup of coffee.",
    "zh": "愛甚至買不起一杯咖啡。",
    "ja": "愛はコーヒー一杯すら買えない。"
  },
  {
    "time": "00:02:16",
    "en": "Dad, please.",
    "zh": "爸爸，拜託。",
    "ja": "お父さん、お願い。"
  },
  {
    "time": "00:02:19",
    "en": "You don't know him.",
    "zh": "你不了解他。",
    "ja": "彼のことを知らない。"
  },
  {
    "time": "00:02:21",
    "en": "He may be poor, but he is honest.",
    "zh": "他或許窮，但他誠實。",
    "ja": "彼は貧しいかもしれないが正直だ。"
  },
  {
    "time": "00:02:24",
    "en": "He loves me, not my money.",
    "zh": "他愛的是我，不是我的錢。",
    "ja": "彼は僕の金じゃなくて僕を愛している。"
  },
  {
    "time": "00:02:27",
    "en": "Anna, I am warning you.",
    "zh": "Anna，我警告你。",
    "ja": "アンナ、警告するよ。"
  },
  {
    "time": "00:02:30",
    "en": "Never trust the poor.",
    "zh": "永遠不要相信窮人。",
    "ja": "貧乏人を信用するな。"
  },
  {
    "time": "00:02:33",
    "en": "Let us go home.",
    "zh": "我們回家吧。",
    "ja": "家に帰ろう。"
  },
  {
    "time": "00:02:35",
    "en": "No.",
    "zh": "不。",
    "ja": "いやだ。"
  },
  {
    "time": "00:02:37",
    "en": "I want to stay.",
    "zh": "我想留下來。",
    "ja": "ここにいたい。"
  },
  {
    "time": "00:02:39",
    "en": "I will not give up.",
    "zh": "我不會放棄。",
    "ja": "諦めない。"
  },
  {
    "time": "00:02:49",
    "en": "I will find a way.",
    "zh": "我會找到方法。",
    "ja": "方法を見つける。"
  },
  {
    "time": "00:02:51",
    "en": "I will get a job.",
    "zh": "我會找到工作。",
    "ja": "仕事を見つける。"
  },
  {
    "time": "00:02:53",
    "en": "I will make money.",
    "zh": "我會賺錢。",
    "ja": "お金を稼ぐ。"
  },
  {
    "time": "00:02:55",
    "en": "Then I will come back to you.",
    "zh": "然後我會回到你身邊。",
    "ja": "それから君の元に戻る。"
  },
  {
    "time": "00:02:58",
    "en": "I don't want money, Leo.",
    "zh": "我不想要錢，Leo。",
    "ja": "お金はいらない、レオ。"
  },
  {
    "time": "00:03:01",
    "en": "I want you.",
    "zh": "我想要你。",
    "ja": "君が欲しい。"
  },
  {
    "time": "00:03:03",
    "en": "Just promise me, don't change.",
    "zh": "只要答應我，不要改變。",
    "ja": "約束して、変わらないで。"
  },
  {
    "time": "00:03:06",
    "en": "I promise.",
    "zh": "我答應你。",
    "ja": "約束する。"
  }
]