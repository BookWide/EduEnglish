{
  "version": "2026.01",
  "rules": {
    "modes": {
      "A": {
        "label": "照原路線",
        "description": "天氣穩定，照原計畫出發。",
        "action": "照常公告"
      },
      "B": {
        "label": "照走但縮短",
        "description": "天氣稍不穩，建議縮短路線、提早下山。",
        "action": "公告短版路線"
      },
      "C": {
        "label": "改同區低風險路線",
        "description": "原路線雨天風險偏高，改附近 A/B 級路線。",
        "action": "改線公告"
      },
      "D": {
        "label": "山下備案",
        "description": "天氣差但未達取消，改短步道、午餐、咖啡或森林園區。",
        "action": "山下備案公告"
      },
      "E": {
        "label": "延期或取消",
        "description": "颱風、豪雨、雷雨、封路或溪谷危險，不建議出行。",
        "action": "取消公告"
      }
    },
    "cancel_conditions": [
      "typhoon_warning",
      "heavy_rain_warning",
      "road_closed",
      "thunderstorm_high",
      "stream_route_with_rain",
      "permit_route_not_adjustable"
    ],
    "score_rules": {
      "rain_probability": {
        "0-30": 0,
        "31-50": 1,
        "51-70": 2,
        "71-100": 3
      },
      "rain_amount": {
        "none": 0,
        "light": 1,
        "medium": 2,
        "heavy": 4
      },
      "route_sensitivity": {
        "低": 0,
        "中": 1,
        "高": 3
      },
      "people_count": {
        "1-10": 0,
        "11-20": 1,
        "21-30": 2
      }
    },
    "score_result": [
      {
        "min": 0,
        "max": 2,
        "mode": "A"
      },
      {
        "min": 3,
        "max": 5,
        "mode": "B"
      },
      {
        "min": 6,
        "max": 8,
        "mode": "C"
      },
      {
        "min": 9,
        "max": 11,
        "mode": "D"
      },
      {
        "min": 12,
        "max": 99,
        "mode": "E"
      }
    ]
  }
}