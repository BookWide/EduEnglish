  "dialogue": [
    {
      "role": "student",
      "text": "I carry, sorry I'm late. How are you?",
      "zh": "我來了，抱歉我遲到了。你好嗎？",
      "ja": "来ました、遅れてすみません。お元気ですか？",
      "time": "00:00:00"
    },
    {
      "role": "teacher",
      "text": "I'm fine, and you?",
      "zh": "我很好，你呢？",
