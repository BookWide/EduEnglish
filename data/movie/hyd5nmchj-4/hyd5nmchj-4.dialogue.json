    },
    {
      "role": "student",
      "text": "Her name is Audrey.",
      "zh": "她叫奧黛麗。",
      "ja": "彼女の名前はオードリーです。",
      "time": "00:01:17"
    },
    {
      "role": "teacher",
      "text": "How old is she?",
