    },
    {
      "role": "student",
      "text": "My father is 51 years old.",
      "zh": "我爸爸51歲。",
      "ja": "私の父は51歳です。",
      "time": "00:01:49"
    },
    {
      "role": "teacher",
      "text": "And how old is your mother?",
