      "text": "I have one brother.",
      "zh": "我有一個兄弟。",
      "ja": "私は兄弟が一人います。",
      "time": "00:02:01"
    },
    {
      "role": "teacher",
      "text": "How old is he?",
      "zh": "他幾歲？",
