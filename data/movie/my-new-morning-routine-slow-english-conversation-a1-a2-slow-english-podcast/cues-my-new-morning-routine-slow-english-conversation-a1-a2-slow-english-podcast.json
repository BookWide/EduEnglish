    "zh": "手機、鑰匙、錢包。",
    "ja": "携帯、鍵、財布。"
  },
  {
    "time": "00:05:31",
    "en": "Yes, yes, yes.",
    "zh": "有，有，有。",
    "ja": "はい、はい、はい。"
  },
  {
    "time": "00:05:34",
    "en": "I open the door, unit 402.",
    "zh": "我打開門，402號單元。",
    "ja": "ドアを開けて、402号室。"
  },
  {
    "time": "00:05:37",
    "en": "I'll see you later.",
    "zh": "待會見。",
    "ja": "また後でね。"
  },
  {
    "time": "00:05:39",
    "en": "Here we go, Ashley.",
    "zh": "出發吧，Ashley。",
    "ja": "さあ行こう、アシュリー。"
  },
  {
    "time": "00:05:41",
    "en": "Let's have a great day.",
    "zh": "祝我們有美好的一天。",
    "ja": "素敵な一日にしよう。"
  }
]