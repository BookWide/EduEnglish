    },
    {
      "role": "student",
      "text": "This is hard.",
      "zh": "這很難選。",
      "ja": "難しいな。",
      "time": "00:03:26"
    },
    {
      "role": "teacher",
      "text": "Okay, I pick my favorite hoodie.",
