  },
  {
    "time": "00:04:10",
    "en": "Pull this out, Sven.",
    "zh": "把這拔出來，斯文。",
    "ja": "これを抜いてくれ、スヴェン。"
  },
  {
    "time": "00:04:14",
    "en": "Oh, come on.",
    "zh": "喔，拜託。",
    "ja": "おい、頼むよ。"
  },
  {
    "time": "00:04:16",
    "en": "I'm coming.",
    "zh": "我來了。",
    "ja": "行くよ。"
  },
  {
    "time": "00:04:18",
    "en": "Let's go kiss Hans.",
    "zh": "我們去吻漢斯吧。",
    "ja": "ハンスにキスしに行こう。"
  },
  {
    "time": "00:04:20",
    "en": "Who is this Hans?",
    "zh": "這個漢斯是誰？",
    "ja": "このハンスって誰？"
  },
  {
    "time": "00:04:33",
    "en": "Just hang in there.",
    "zh": "撐住。",
    "ja": "頑張って。"
  },
  {
    "time": "00:04:34",
    "en": "Come on, buddy.",
    "zh": "加油，夥伴。",
    "ja": "さあ、友よ。"
  },
  {
    "time": "00:04:35",
    "en": "Faster.",
    "zh": "快點。",
    "ja": "もっと速く。"
  },
  {
    "time": "00:04:42",
    "en": "Oh, boy.",
    "zh": "喔，天啊。",
    "ja": "おお、やばい。"
  },
  {
    "time": "00:04:43",
    "en": "Help me, you guys have the castle.",
    "zh": "幫幫我，你們有城堡。",
    "ja": "助けてくれ、君たちは城を持っている。"
  },
  {
    "time": "00:04:45",
    "en": "Stand off site, Olaf.",
    "zh": "站遠點，奧拉夫。",
    "ja": "離れてて、オラフ。"
  },
  {
    "time": "00:04:47",
    "en": "I will.",
    "zh": "我會的。",
    "ja": "わかった。"
  },
  {
    "time": "00:05:01",
    "en": "It's Princess Ana.",
    "zh": "是安娜公主。",
    "ja": "アナ姫だ。"
  },
  {
    "time": "00:05:03",
    "en": "Are you going to be okay?",
    "zh": "你會沒事吧？",
    "ja": "大丈夫か？"
  },
  {
    "time": "00:05:06",
    "en": "Don't worry about me.",
    "zh": "別擔心我。",
    "ja": "俺のことは心配しないで。"
  },
  {
    "time": "00:05:08",
    "en": "Ana, you had us with you.",
    "zh": "安娜，你有我們陪著你。",
    "ja": "アナ、君には俺たちがいる。"
  },
  {
    "time": "00:05:10",
    "en": "My lady.",
    "zh": "小姐。",
    "ja": "お嬢様。"
  },
  {
    "time": "00:05:11",
    "en": "Get her warm and find Prince Hans immediately.",
    "zh": "讓她暖和起來，立刻去找漢斯王子。",
    "ja": "彼女を温めて、すぐにハンス王子を探して。"
  },
  {
    "time": "00:05:14",
    "en": "We will.",
    "zh": "我們會的。",
    "ja": "わかりました。"
  },
  {
    "time": "00:05:15",
    "en": "Thank you.",
    "zh": "謝謝你。",
    "ja": "ありがとう。"
  },
  {
    "time": "00:05:16",
    "en": "Make sure she's safe.",
    "zh": "確保她安全。",
    "ja": "彼女の安全を確保して。"
  },
  {
    "time": "00:05:17",
    "en": "What are you doing?",
    "zh": "你在做什麼？",
    "ja": "何をしている？"
  },
  {
    "time": "00:05:19",
    "en": "What are you doing?",
    "zh": "你在做什麼？",
    "ja": "何をしている？"
  },
  {
    "time": "00:05:20",
    "en": "I'm going to get you inside.",
    "zh": "我要帶你進去。",
    "ja": "中に連れて行くよ。"
  },
  {
    "time": "00:05:22",
    "en": "Don't worry about me.",
    "zh": "別擔心我。",
    "ja": "俺のことは心配しないで。"
  },
  {
    "time": "00:05:24",
    "en": "Ana, you had us with you.",
    "zh": "安娜，你有我們陪著你。",
    "ja": "アナ、君には俺たちがいる。"
  },
  {
    "time": "00:05:26",
    "en": "My lady.",
    "zh": "小姐。",
    "ja": "お嬢様。"
  },
  {
    "time": "00:05:27",
    "en": "Get her warm and find Prince Hans immediately.",
    "zh": "讓她暖和起來，立刻去找漢斯王子。",
    "ja": "彼女を温めて、すぐにハンス王子を探して。"
  },
  {
    "time": "00:05:29",
    "en": "We will.",
    "zh": "我們會的。",
    "ja": "わかりました。"
  },
  {
    "time": "00:05:30",
    "en": "Thank you.",
    "zh": "謝謝你。",
    "ja": "ありがとう。"
  },
  {
    "time": "00:05:32",
    "en": "Oh.",
    "zh": "喔。",
    "ja": "ああ。"
  },
  {
    "time": "00:05:46",
    "en": "So where's Hans?",
    "zh": "那漢斯在哪裡？",
    "ja": "じゃあハンスはどこ？"
  },
  {
    "time": "00:05:48",
    "en": "What happened to your kiss?",
    "zh": "你的吻怎麼了？",
    "ja": "キスはどうした？"
  },
  {
    "time": "00:05:50",
    "en": "I was wrong about him.",
    "zh": "我對他錯了。",
    "ja": "彼について間違っていた。"
  },
  {
    "time": "00:05:52",
    "en": "It wasn't true love.",
    "zh": "那不是真愛。",
    "ja": "それは真実の愛じゃなかった。"
  },
  {
    "time": "00:05:54",
    "en": "But we ran all the way here.",
    "zh": "但我們一路跑到這裡。",
    "ja": "でもここまで走ってきた。"
  },
  {
    "time": "00:05:56",
    "en": "Please, Olaf, you can't stay here.",
    "zh": "拜託，奧拉夫，你不能留在這裡。",
    "ja": "お願い、オラフ、ここにいちゃだめだ。"
  },
  {
    "time": "00:05:58",
    "en": "You'll melt.",
    "zh": "你會融化的。",
    "ja": "溶けちゃうよ。"
  },
  {
    "time": "00:05:59",
    "en": "I am not leaving you until we find some other act of true love to save you.",
    "zh": "我不會離開你，直到我們找到其他真愛的行為來救你。",
    "ja": "君を救う別の真実の愛の行為を見つけるまで離れない。"
  },
  {
    "time": "00:06:03",
    "en": "Do you have any ideas?",
    "zh": "你有什麼想法嗎？",
    "ja": "何かアイデアはある？"
  },
  {
    "time": "00:06:05",
    "en": "I don't even know what love is.",
    "zh": "我甚至不知道什麼是愛。",
    "ja": "愛が何かわからない。"
  },
  {
    "time": "00:06:07",
    "en": "That's okay.",
    "zh": "沒關係。",
    "ja": "それでいいんだ。"
  },
  {
    "time": "00:06:08",
    "en": "I do.",
    "zh": "我知道。",
    "ja": "わかるよ。"
  },
  {
    "time": "00:06:09",
    "en": "Love is putting someone else's needs before yours.",
    "zh": "愛是把別人的需要放在自己之前。",
    "ja": "愛とは自分より他人のニーズを優先することだ。"
  },
  {
    "time": "00:06:14",
    "en": "Like, you know, how Christoph brought you back here to Hans and left you forever.",
    "zh": "就像克里斯托夫帶你回漢斯身邊，永遠陪著你。",
    "ja": "例えば、クリストフが君をハンスのところに連れてきて、ずっとそばにいることだ。"
  },
  {
    "time": "00:06:22",
    "en": "Christoph.",
    "zh": "克里斯托夫。",
    "ja": "クリストフ。"
  },
  {
    "time": "00:06:23",
    "en": "Love's me?",
    "zh": "愛我？",
    "ja": "愛してる？"
  },
  {
    "time": "00:06:25",
    "en": "Wow, you really don't know anything about love.",
    "zh": "哇，你真的一點都不懂愛。",
    "ja": "わあ、本当に愛について何も知らないね。"
  },
  {
    "time": "00:06:28",
    "en": "Anything about love deals.",
    "zh": "關於愛的任何事。",
    "ja": "愛について何も。"
  },
  {
    "time": "00:06:30",
    "en": "Olaf, you're melting.",
    "zh": "奧拉夫，你在融化。",
    "ja": "オラフ、溶けてるよ。"
  },
  {
    "time": "00:06:32",
    "en": "Some people are worth melting for.",
    "zh": "有些人值得你融化。",
    "ja": "溶けてもいい人がいるんだ。"
  },
  {
    "time": "00:06:39",
    "en": "You're just maybe not right this second.",
    "zh": "也許你現在還不是時候。",
    "ja": "今はまだその時じゃないだけかも。"
  },
  {
    "time": "00:06:41",
    "en": "Oh!",
    "zh": "喔！",
    "ja": "おお！"
  },
  {
    "time": "00:06:43",
    "en": "Don't worry, I've got it.",
    "zh": "別擔心，我懂了。",
    "ja": "心配しないで、わかったよ。"
  },
  {
    "time": "00:06:47",
    "en": "We're going to get through it.",
    "zh": "我們會度過難關的。",
    "ja": "乗り越えられるよ。"
  },
  {
    "time": "00:06:49",
    "en": "Oh, wait.",
    "zh": "喔，等等。",
    "ja": "ああ、待って。"
  },
  {
    "time": "00:06:50",
    "en": "Hang on.",
    "zh": "等一下。",
    "ja": "ちょっと待って。"
  },
  {
    "time": "00:06:51",
    "en": "Are you getting something?",
    "zh": "你有發現什麼嗎？",
    "ja": "何か見えた？"
  },
  {
    "time": "00:06:53",
    "en": "It's Christoph and Sven!",
    "zh": "是克里斯托夫和斯文！",
    "ja": "クリストフとスヴェンだ！"
  },
  {
    "time": "00:06:55",
    "en": "They're coming back this way!",
    "zh": "他們正朝這邊回來！",
    "ja": "こっちに戻ってきてる！"
  },
  {
    "time": "00:06:57",
    "en": "They are?",
    "zh": "他們是嗎？",
    "ja": "本当？"
  },
  {
    "time": "00:06:59",
    "en": "Wow, he's really moving fast.",
    "zh": "哇，他真的跑得很快。",
    "ja": "わあ、彼は本当に速い。"
  },
  {
    "time": "00:07:01",
    "en": "I guess it was wrong.",
    "zh": "我想我錯了。",
    "ja": "間違ってたみたいだ。"
  },
  {
    "time": "00:07:03",
    "en": "I guess Christoph doesn't love you enough to leave you behind.",
    "zh": "我想克里斯托夫不會愛你到拋下你。",
    "ja": "クリストフは君を置いていくほど愛してないんだ。"
  },
  {
    "time": "00:07:06",
    "en": "Come on, come on, come on.",
    "zh": "快點，快點，快點。",
    "ja": "さあ、さあ、さあ。"
  },
  {
    "time": "00:07:08",
    "en": "Okay, okay, welcome.",
    "zh": "好，好，歡迎。",
    "ja": "よし、よし、ようこそ。"
  },
  {
    "time": "00:07:10",
    "en": "No, hold.",
    "zh": "不，等等。",
    "ja": "いや、待って。"
  },
  {
    "time": "00:07:11",
    "en": "Sorry.",
    "zh": "抱歉。",
    "ja": "ごめん。"
  },
  {
    "time": "00:07:12",
    "en": "Okay, okay.",
    "zh": "好，好。",
    "ja": "よし、よし。"
  },
  {
    "time": "00:07:13",
    "en": "Here we are.",
    "zh": "我們到了。",
    "ja": "着いたよ。"
  },
  {
    "time": "00:07:17",
    "en": "I owe you a sled.",
    "zh": "我欠你一輛雪橇。",
    "ja": "そりを借りてる。"
  },
  {
    "time": "00:07:22",
    "en": "Are you serious?",
    "zh": "你認真的嗎？",
    "ja": "本気か？"
  },
  {
    "time": "00:07:24",
    "en": "Yes.",
    "zh": "是的。",
    "ja": "はい。"
  },
  {
    "time": "00:07:25",
    "en": "And it's the latest model.",
    "zh": "而且是最新款。",
    "ja": "しかも最新モデルだ。"
  },
  {
    "time": "00:07:26",
    "en": "No.",
    "zh": "不。",
    "ja": "いや。"
  },
  {
    "time": "00:07:27",
    "en": "I can't accept this.",
    "zh": "我不能接受這個。",
    "ja": "これは受け取れない。"
  },
  {
    "time": "00:07:28",
    "en": "You have to.",
    "zh": "你必須接受。",
    "ja": "受け取らなきゃ。"
  },
  {
    "time": "00:07:29",
    "en": "No returns.",
    "zh": "不退貨。",
    "ja": "返品不可。"
  },
  {
    "time": "00:07:30",
    "en": "No exchanges.",
    "zh": "不換貨。",
    "ja": "交換不可。"
  },
  {
    "time": "00:07:31",
    "en": "Queen's orders.",
    "zh": "女王的命令。",
    "ja": "女王の命令だ。"
  },
  {
    "time": "00:07:32",
    "en": "She's named you the official Airendel Icemaster and Deliverer.",
    "zh": "她任命你為官方阿倫戴爾冰雪大師和送貨員。",
    "ja": "彼女は君をアレンデールの公式アイスマスター兼配達人に任命した。"
  },
  {
    "time": "00:07:35",
    "en": "What?",
    "zh": "什麼？",
    "ja": "何？"
  },
  {
    "time": "00:07:36",
    "en": "That's not a thing.",
    "zh": "那不是一回事。",
    "ja": "そんなものはない。"
  },
  {
    "time": "00:07:37",
    "en": "Don't sure it is.",
    "zh": "不確定是不是。",
    "ja": "そうかもしれない。"
  },
  {
    "time": "00:07:38",
    "en": "And it even has a cup holder.",
    "zh": "而且還有杯架。",
    "ja": "しかもカップホルダー付きだ。"
  },
  {
    "time": "00:07:40",
    "en": "Do you like it?",
    "zh": "你喜歡嗎？",
    "ja": "気に入った？"
  },
  {
    "time": "00:07:41",
    "en": "I like it.",
    "zh": "我喜歡。",
    "ja": "好きだよ。"
  },
  {
    "time": "00:07:42",
    "en": "I love it!",
    "zh": "我愛它！",
    "ja": "大好き！"
  },
  {
    "time": "00:07:43",
    "en": "I could kiss you.",
    "zh": "我可以吻你。",
    "ja": "キスしてもいい？"
  },
  {
    "time": "00:07:46",
    "en": "I could.",
    "zh": "我可以。",
    "ja": "できるよ。"
  },
  {
    "time": "00:07:47",
    "en": "I mean, I'd like to.",
    "zh": "我是說，我想要。",
    "ja": "つまり、したいんだ。"
  },
  {
    "time": "00:07:48",
    "en": "May I?",
    "zh": "我可以嗎？",
    "ja": "してもいい？"
  },
  {
    "time": "00:07:49",
    "en": "We meet?",
    "zh": "我們見面？",
    "ja": "会う？"
  },
  {
    "time": "00:07:50",
    "en": "I mean, may we wait?",
    "zh": "我是說，我們可以等嗎？",
    "ja": "つまり、待ってもいい？"
  },
  {
    "time": "00:07:51",
    "en": "What?",
    "zh": "什麼？",
    "ja": "何？"
  },
  {
    "time": "00:07:52",
    "en": "We may.",
    "zh": "我們可以。",
    "ja": "いいよ。"
  },
  {
    "time": "00:07:57",
    "en": "I'm tired, too.",
    "zh": "我也累了。",
    "ja": "僕も疲れた。"
  },
  {
    "time": "00:07:58",
    "en": "And Sven promised to read me a bedtime story.",
    "zh": "斯文答應要給我讀睡前故事。",
    "ja": "スヴェンが寝る前の話を読んでくれるって約束した。"
  },
  {
    "time": "00:08:01",
    "en": "Didn't you, Sven?",
    "zh": "不是嗎，斯文？",
    "ja": "そうだろ、スヴェン？"
  },
  {
    "time": "00:08:02",
    "en": "Did I?",
    "zh": "是嗎？",
    "ja": "そうだったかな？"
  },
  {
    "time": "00:08:03",
    "en": "Oh, you do the best voices.",
    "zh": "喔，你的配音最好聽。",
    "ja": "ああ、君の声真に迫ってるよ。"
  },
  {
    "time": "00:08:06",
    "en": "Like, when you pretend to be Christophe and you're like,",
    "zh": "就像你假裝是克里斯托夫時，你會說，",
    "ja": "例えば、クリストフのふりをするとき、君はこう言う、"
  },
  {
    "time": "00:08:08",
    "en": "\"Oh, I just need to go talk to some rocks about my childhood.\"",
    "zh": "「哦，我只是需要去跟一些石頭談談我的童年。」",
    "ja": "「ああ、子供時代のことで岩に話しかけに行かないと。」"
  },
  {
    "time": "00:08:11",
    "en": "Um, how about you guys start without me?",
    "zh": "嗯，你們先開始吧，我晚點來。",
    "ja": "えっと、君たち先に始めてていいよ。"
  },
  {
    "time": "00:08:21",
    "en": "Did Elsa seem weird to you?",
    "zh": "你覺得艾莎怪怪的嗎？",
    "ja": "エルサは変に見えた？"
  },
  {
    "time": "00:08:23",
    "en": "She seemed like Elsa?",
    "zh": "她看起來像艾莎嗎？",
    "ja": "彼女はエルサらしかった？"
  },
  {
    "time": "00:08:26",
    "en": "That last word really seemed to throw her.",
    "zh": "那最後一個字真的讓她慌了。",
    "ja": "最後の言葉で彼女は本当に動揺した。"
  },
  {
    "time": "00:08:29",
    "en": "What was it?",
    "zh": "是什麼？",
    "ja": "何だった？"
  },
  {
    "time": "00:08:30",
    "en": "I don't know.",
    "zh": "我不知道。",
    "ja": "わからない。"
  },
  {
    "time": "00:08:31",
    "en": "I don't know.",
    "zh": "我不知道。",
    "ja": "わからない。"
  },
  {
    "time": "00:08:32",
    "en": "I don't know.",
    "zh": "我不知道。",
    "ja": "わからない。"
  },
  {
    "time": "00:08:33",
    "en": "But...",
    "zh": "但是...",
    "ja": "でも..."
  },
  {
    "time": "00:08:34",
    "en": "Ice?",
    "zh": "冰？",
    "ja": "氷？"
  },
  {
    "time": "00:08:35",
    "en": "Oh, come on!",
    "zh": "喔，拜託！",
    "ja": "おいおい！"
  },
  {
    "time": "00:08:36",
    "en": "She couldn't act up.",
    "zh": "她不可能裝出來的。",
    "ja": "彼女が演技するはずがない。"
  },
  {
    "time": "00:08:38",
    "en": "Ice?",
    "zh": "冰？",
    "ja": "氷？"
  },
  {
    "time": "00:08:39",
    "en": "I better go check on her.",
    "zh": "我最好去看看她。",
    "ja": "彼女を確認しに行ったほうがいい。"
  },
  {
    "time": "00:08:40",
    "en": "Thanks, honey.",
    "zh": "謝謝，親愛的。",
    "ja": "ありがとう、ハニー。"
  },
  {
    "time": "00:08:41",
    "en": "Love you.",
    "zh": "愛你。",
    "ja": "愛してる。"
  },
  {
    "time": "00:08:44",
    "en": "Love you, too.",
    "zh": "我也愛你。",
    "ja": "僕も愛してる。"
  },
  {
    "time": "00:08:47",
    "en": "It's fine.",
    "zh": "沒事的。",
    "ja": "大丈夫だよ。"
  },
  {
    "time": "00:08:49",
    "en": "They're both asleep.",
    "zh": "他們都睡著了。",
    "ja": "二人とも眠っている。"
  },
