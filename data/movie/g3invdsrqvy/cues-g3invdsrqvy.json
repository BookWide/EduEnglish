  },
  {
    "time": "00:01:32",
    "en": "Oh, wow.",
    "zh": "哦，哇。",
    "ja": "おお、わあ。"
  },
  {
    "time": "00:01:34",
    "en": "Look at this.",
    "zh": "看看這個。",
    "ja": "これを見て。"
  },
  {
