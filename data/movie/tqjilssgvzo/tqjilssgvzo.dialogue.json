      "time": "00:03:04"
    },
    {
      "role": "teacher",
      "text": "Ow.",
      "zh": "哎呀。",
      "ja": "痛い。",
      "time": "00:03:05"
    },
    {
      "role": "teacher",
      "text": "Ow.",
      "zh": "哎呀。",
      "ja": "痛い。",
      "time": "00:03:06"
    },
    {
      "role": "teacher",
      "text": "Ow.",
      "zh": "哎呀。",
      "ja": "痛い。",
      "time": "00:03:07"
    },
    {
      "role": "teacher",
      "text": "Ow.",
      "zh": "哎呀。",
      "ja": "痛い。",
      "time": "00:03:12"
    },
    {
      "role": "teacher",
      "text": "Oh",
      "zh": "哦",
      "ja": "ああ",
      "time": "00:03:20"
    },
    {
