  },
  "dialogue": [
    {
      "role": "student",
      "text": "Live.",
      "zh": "活著。",
      "ja": "生きている。",
      "time": "00:01:00"
    },
    {
      "role": "student",
      "text": "kindness, love for you.",
      "zh": "善良，對你的愛。",
      "ja": "優しさ、あなたへの愛。",
      "time": "00:01:13"
    },
    {
      "role": "student",
      "text": "Yes, I've been under you, Ted.",
      "zh": "是的，我一直在你下面，Ted。",
      "ja": "はい、私はあなたの下にいました、テッド。",
      "time": "00:01:24"
    },
    {
      "role": "student",
      "text": "Take yourself in a little thing.",
      "zh": "把自己放在一點小事上。",
      "ja": "小さなことに自分を置いて。",
      "time": "00:01:31"
    },
    {
      "role": "student",
      "text": "Take you over me.",
      "zh": "讓你勝過我。",
      "ja": "私よりあなたを優先する。",
      "time": "00:01:39"
    },
    {
      "role": "student",
      "text": "So.",
      "zh": "所以。",
      "ja": "だから。",
      "time": "00:01:45"
    },
    {
      "role": "student",
      "text": "Livy.",
      "zh": "利維。",
      "ja": "リヴィ。",
      "time": "00:01:51"
    },
    {
      "role": "student",
      "text": "Livy, hold on.",
      "zh": "利維，等等。",
      "ja": "リヴィ、待って。",
      "time": "00:01:53"
    },
    {
      "role": "student",
      "text": "Sir.",
      "zh": "先生。",
      "ja": "先生。",
      "time": "00:01:56"
    },
    {
      "role": "student",
      "text": "Livy, wait.",
      "zh": "利維，等等。",
      "ja": "リヴィ、待って。",
      "time": "00:01:57"
    },
    {
      "role": "student",
      "text": "Of course, there is.",
      "zh": "當然，有的。",
      "ja": "もちろん、あります。",
      "time": "00:02:07"
    },
    {
      "role": "student",
      "text": "Let's go.",
      "zh": "我們走吧。",
      "ja": "行こう。",
      "time": "00:02:09"
    },
    {
      "role": "student",
      "text": "I see your bus.",
      "zh": "我看到你的巴士了。",
      "ja": "バスが見えるよ。",
      "time": "00:02:10"
    },
    {
      "role": "student",
      "text": "Hold on.",
      "zh": "等等。",
      "ja": "待って。",
      "time": "00:02:11"
    },
    {
      "role": "student",
      "text": "Sam, can you walk the back of me, please?",
      "zh": "Sam，你能走在我後面嗎？",
      "ja": "サム、私の後ろを歩いてくれる？",
      "time": "00:02:12"
    },
    {
      "role": "student",
      "text": "Livy, slow down.",
      "zh": "利維，慢點。",
      "ja": "リヴィ、ゆっくりして。",
      "time": "00:02:16"
    },
    {
      "role": "student",
      "text": "We're getting on the bus together.",
      "zh": "我們一起上巴士。",
      "ja": "一緒にバスに乗るよ。",
      "time": "00:02:18"
    },
    {
      "role": "student",
      "text": "Did you get the back?",
      "zh": "你拿到背面了嗎？",
      "ja": "裏面を取った？",
      "time": "00:02:41"
    },
    {
      "role": "student",
      "text": "What?",
      "zh": "什麼？",
      "ja": "何？",
      "time": "00:02:43"
    },
    {
      "role": "student",
      "text": "The back.",
      "zh": "背面。",
      "ja": "裏。",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "Did you not read it?",
      "zh": "你沒讀過嗎？",
      "ja": "読まなかったの？",
      "time": "00:02:47"
    },
    {
      "role": "student",
      "text": "Hey, Dad.",
      "zh": "嘿，爸爸。",
      "ja": "ねえ、お父さん。",
      "time": "00:02:59"
    },
    {
      "role": "student",
      "text": "We're still at the station.",
      "zh": "我們還在車站。",
      "ja": "まだ駅にいるよ。",
      "time": "00:03:00"
    },
    {
      "role": "student",
      "text": "Oh, she's not here yet.",
      "zh": "哦，她還沒來。",
      "ja": "ああ、彼女はまだ来ていない。",
      "time": "00:03:02"
    },
    {
      "role": "student",
      "text": "It's been like an hour.",
      "zh": "已經一個小時了。",
      "ja": "もう1時間くらい経ってる。",
      "time": "00:03:03"
    },
    {
      "role": "student",
      "text": "I can.",
      "zh": "我可以。",
      "ja": "できるよ。",
      "time": "00:03:05"
    },
    {
      "role": "student",
      "text": "I know.",
      "zh": "我知道。",
      "ja": "知ってる。",
      "time": "00:03:06"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好。",
      "ja": "わかった。",
      "time": "00:03:07"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好。",
      "ja": "わかった。",
      "time": "00:03:08"
    },
    {
      "role": "student",
      "text": "Bye.",
      "zh": "再見。",
      "ja": "バイバイ。",
      "time": "00:03:09"
    },
    {
      "role": "student",
      "text": "Best moving day ever.",
      "zh": "有史以來最棒的搬家日。",
      "ja": "最高の引っ越し日だ。",
      "time": "00:03:11"
    },
    {
      "role": "student",
      "text": "We're here.",
      "zh": "我們到了。",
      "ja": "着いたよ。",
      "time": "00:03:15"
    },
    {
      "role": "student",
      "text": "We're together.",
      "zh": "我們在一起。",
      "ja": "一緒だ。",
      "time": "00:03:16"
    },
    {
      "role": "student",
      "text": "Just give it a chance, okay?",
      "zh": "給它一個機會，好嗎？",
      "ja": "チャンスをあげて、いい？",
      "time": "00:03:17"
    },
    {
      "role": "student",
      "text": "You're back to California, you hippies.",
      "zh": "你們回加州去吧，你們這些嬉皮士。",
      "ja": "カリフォルニアに戻れ、ヒッピーたち。",
      "time": "00:03:19"
    },
    {
      "role": "student",
      "text": "And not us.",
      "zh": "我們不會。",
      "ja": "私たちは違う。",
      "time": "00:03:22"
    },
    {
      "role": "student",
      "text": "Livy.",
      "zh": "利維。",
      "ja": "リヴィ。",
      "time": "00:03:24"
    },
    {
      "role": "student",
      "text": "Ah, I'm so excited.",
      "zh": "啊，我好興奮。",
      "ja": "ああ、すごく楽しみ。",
      "time": "00:03:25"
    },
    {
      "role": "student",
      "text": "Nice.",
      "zh": "不錯。",
      "ja": "いいね。",
      "time": "00:03:28"
    },
    {
      "role": "student",
      "text": "Don't hate me.",
      "zh": "別恨我。",
      "ja": "私を嫌わないで。",
      "time": "00:03:33"
    },
    {
      "role": "student",
      "text": "I'm so sorry I was late.",
      "zh": "對不起我遲到了。",
      "ja": "遅れてごめんね。",
      "time": "00:03:34"
    },
    {
      "role": "student",
      "text": "I'm so excited to finally get to spend some time with my favorite kiddos in the whole wide world.",
      "zh": "我很興奮終於能和我最喜歡的孩子們共度時光。",
      "ja": "世界で一番好きな子供たちとやっと時間を過ごせて嬉しい。",
      "time": "00:03:37"
    },
    {
      "role": "student",
      "text": "I was thinking about you because I went to the market and I found this.",
      "zh": "我在市場想起你，然後找到了這個。",
      "ja": "市場に行ってこれを見つけたから、あなたのことを考えてた。",
      "time": "00:03:42"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:03:46"
    },
    {
      "role": "student",
      "text": "Oh, come back.",
      "zh": "哦，回來。",
      "ja": "ああ、戻って。",
      "time": "00:03:47"
    },
    {
      "role": "student",
      "text": "You're you.",
      "zh": "你就是你。",
      "ja": "あなたはあなた。",
      "time": "00:03:48"
    },
    {
      "role": "student",
      "text": "I got it.",
      "zh": "我拿到了。",
      "ja": "わかった。",
      "time": "00:03:53"
    },
    {
      "role": "student",
      "text": "I'm driving, Dylan.",
      "zh": "我在開車，Dylan。",
      "ja": "運転してるよ、ディラン。",
      "time": "00:03:55"
    },
    {
      "role": "student",
      "text": "It's okay.",
      "zh": "沒關係。",
      "ja": "大丈夫。",
      "time": "00:03:56"
    },
    {
      "role": "student",
      "text": "Did you want to take the scenic room?",
      "zh": "你想走風景路線嗎？",
      "ja": "景色のいい道を通りたい？",
      "time": "00:03:57"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:03:59"
    },
    {
      "role": "student",
      "text": "Been for before and before.",
      "zh": "以前來過很多次。",
      "ja": "何度も来たことがある。",
      "time": "00:04:02"
    },
    {
      "role": "student",
      "text": "No, you have visited here before.",
      "zh": "不，你以前來過這裡。",
      "ja": "いいえ、ここには来たことがある。",
      "time": "00:04:04"
    },
    {
      "role": "student",
      "text": "You have not lived here before.",
      "zh": "但你以前沒住過這裡。",
      "ja": "でも住んだことはない。",
      "time": "00:04:06"
    },
    {
      "role": "student",
      "text": "There's the farmer's market and I have a booth there.",
      "zh": "那裡有農夫市集，我有個攤位。",
      "ja": "ファーマーズマーケットがあって、私のブースがある。",
      "time": "00:04:08"
    },
    {
      "role": "student",
      "text": "Our theater has the best movies.",
      "zh": "我們的劇院有最棒的電影。",
      "ja": "私たちの劇場は最高の映画がある。",
      "time": "00:04:10"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:04:12"
    },
    {
      "role": "student",
      "text": "I'm in charge of summer fest this year.",
      "zh": "我今年負責夏季節慶。",
      "ja": "今年のサマーフェストを担当している。",
      "time": "00:04:13"
    },
    {
      "role": "student",
      "text": "You guys can perform.",
      "zh": "你們可以表演。",
      "ja": "君たちも出演できるよ。",
      "time": "00:04:15"
    },
    {
      "role": "student",
      "text": "No.",
      "zh": "不行。",
      "ja": "いや。",
      "time": "00:04:16"
    },
    {
      "role": "student",
      "text": "I don't think so.",
      "zh": "我不這麼認為。",
      "ja": "そうは思わない。",
      "time": "00:04:17"
    },
    {
      "role": "student",
      "text": "Can we hurry, please?",
      "zh": "我們可以快點嗎？",
      "ja": "急いでくれない？",
      "time": "00:04:18"
    },
    {
      "role": "student",
      "text": "Sure.",
      "zh": "當然。",
      "ja": "もちろん。",
      "time": "00:04:20"
    },
    {
      "role": "student",
      "text": "Look at that.",
      "zh": "看看那個。",
      "ja": "あれを見て。",
      "time": "00:04:21"
    },
    {
      "role": "student",
      "text": "It's your high school.",
      "zh": "那是你的高中。",
      "ja": "君の高校だ。",
      "time": "00:04:23"
    },
    {
      "role": "student",
      "text": "Well, it will be when I register to get this fall.",
      "zh": "當我秋季註冊時，它將是。",
      "ja": "秋に登録したらそうなるよ。",
      "time": "00:04:24"
    },
    {
      "role": "student",
      "text": "Because there is no way your dad's getting in those doors.",
      "zh": "因為你爸絕對不會進那扇門。",
      "ja": "お父さんがあの扉を通るわけがない。",
      "time": "00:04:27"
    },
    {
      "role": "student",
      "text": "What?",
      "zh": "什麼？",
      "ja": "何？",
      "time": "00:04:30"
    },
    {
      "role": "student",
      "text": "What a dad did.",
      "zh": "爸爸做了什麼。",
      "ja": "お父さんがしたこと。",
      "time": "00:04:31"
    },
    {
      "role": "student",
      "text": "Well, let me tell you this.",
      "zh": "讓我告訴你這個。",
      "ja": "これを教えてあげよう。",
      "time": "00:04:32"
    },
    {
      "role": "student",
      "text": "Nobody used to be that I was a child of a foster sister.",
      "zh": "沒有人知道我曾是寄養姐妹的孩子。",
      "ja": "私は里親の妹の子供だった。",
      "time": "00:04:34"
    },
    {
      "role": "student",
      "text": "It wasn't anything harmful.",
      "zh": "這沒什麼害處。",
      "ja": "害はなかった。",
      "time": "00:04:39"
    },
    {
      "role": "student",
      "text": "When your mom came along, I mean, everything just changed.",
      "zh": "當你媽媽來了，一切都改變了。",
      "ja": "お母さんが来てから、すべてが変わった。",
      "time": "00:04:41"
    },
    {
      "role": "student",
      "text": "It went from being pranks to being these awesome adventures.",
      "zh": "從惡作劇變成了精彩的冒險。",
      "ja": "いたずらから素晴らしい冒険へと変わった。",
      "time": "00:04:43"
    },
    {
      "role": "student",
      "text": "They had the best time.",
      "zh": "他們玩得很開心。",
      "ja": "彼らは最高の時間を過ごした。",
      "time": "00:04:47"
    },
    {
      "role": "student",
      "text": "Well?",
      "zh": "那麼？",
      "ja": "さて？",
      "time": "00:04:53"
    },
    {
      "role": "student",
      "text": "Not anymore.",
      "zh": "不再是了。",
      "ja": "もう違う。",
      "time": "00:04:57"
    },
    {
      "role": "student",
      "text": "Understood.",
      "zh": "明白了。",
      "ja": "了解。",
      "time": "00:05:09"
    },
    {
      "role": "student",
      "text": "Thank you now.",
      "zh": "現在謝謝你。",
      "ja": "今ありがとう。",
      "time": "00:05:25"
    },
    {
      "role": "student",
      "text": "And here we are.",
      "zh": "我們到了。",
      "ja": "ここにいる。",
      "time": "00:05:28"
    },
    {
      "role": "student",
      "text": "We will clean all of this up tomorrow.",
      "zh": "我們明天會清理這些。",
      "ja": "これらは明日片付ける。",
      "time": "00:05:33"
    },
    {
      "role": "student",
      "text": "You're going to be okay standing your dad's old room.",
      "zh": "你站在你爸的舊房間會沒事的。",
      "ja": "お父さんの古い部屋に立っても大丈夫だよ。",
      "time": "00:05:42"
    },
    {
      "role": "student",
      "text": "That's fine.",
      "zh": "沒關係。",
      "ja": "大丈夫。",
      "time": "00:05:46"
    },
    {
      "role": "student",
      "text": "And here you go.",
      "zh": "給你。",
      "ja": "どうぞ。",
      "time": "00:05:47"
    },
    {
      "role": "student",
      "text": "Oh, you're here.",
      "zh": "哦，你來了。",
      "ja": "ああ、来たね。",
      "time": "00:05:52"
    },
    {
      "role": "student",
      "text": "This is so great.",
      "zh": "這真棒。",
      "ja": "これは素晴らしい。",
      "time": "00:05:54"
    },
    {
      "role": "student",
      "text": "It's so great.",
      "zh": "真是太棒了。",
      "ja": "とても素晴らしい。",
      "time": "00:05:55"
    },
    {
      "role": "student",
      "text": "It's so great.",
      "zh": "真是太棒了。",
      "ja": "とても素晴らしい。",
      "time": "00:05:56"
    }
  ]
}