{
  "meta": {
    "slug": "spectacular-sven-scenes",
    "category": "movie",
    "source_url": "https://www.youtube.com/watch?v=VqvHvwi32pk",
    "mode": "srt"
  },
  "dialogue": [
    {
      "role": "student",
      "text": "Hey, okay, I'm out!",
      "zh": "嘿，好吧，我出去了！",
      "ja": "やあ、よし、出るよ！",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Whoa!",
      "zh": "哇！",
      "ja": "わあ！",
      "time": "00:00:01"
    },
    {
      "role": "student",
      "text": "Oh, you're fine!",
      "zh": "哦，你沒事！",
      "ja": "ああ、大丈夫だよ！",
      "time": "00:00:02"
    },
    {
      "role": "student",
      "text": "No, Sven. I didn't get your carrots.",
      "zh": "不，斯文。我沒拿到你的胡蘿蔔。",
      "ja": "違うよ、スヴェン。君のニンジンは取ってないよ。",
      "time": "00:00:09"
    },
    {
      "role": "student",
      "text": "But I did find us a place to sleep.",
      "zh": "但我找到一個地方讓我們睡覺。",
      "ja": "でも、僕たちが寝る場所は見つけたよ。",
      "time": "00:00:12"
    },
    {
      "role": "student",
      "text": "And it's free.",
      "zh": "而且是免費的。",
      "ja": "しかも無料だ。",
      "time": "00:00:15"
    },
    {
      "role": "student",
      "text": "Rain dares are better than people.",
      "zh": "馴鹿比人類更好。",
      "ja": "トナカイは人間よりいいんだ。",
      "time": "00:00:16"
    },
    {
      "role": "student",
      "text": "Sven, don't you think that's true?",
      "zh": "斯文，你不覺得這是真的嗎？",
      "ja": "スヴェン、それは本当だと思わない？",
      "time": "00:00:20"
    },
    {
      "role": "student",
      "text": "Yeah, people will beat you and curse you and cheat you.",
      "zh": "是啊，人們會打你、詛咒你、欺騙你。",
      "ja": "そうだよ、人は君を殴り、呪い、騙すんだ。",
      "time": "00:00:23"
    },
    {
      "role": "student",
      "text": "Every one of them's bound, except you.",
      "zh": "他們每一個都被束縛，除了你。",
      "ja": "みんな縛られてる、君以外はね。",
      "time": "00:00:27"
    },
    {
      "role": "student",
      "text": "Oh, thanks, buddy.",
      "zh": "哦，謝了，夥伴。",
      "ja": "ああ、ありがとう、相棒。",
      "time": "00:00:29"
    },
    {
      "role": "student",
      "text": "Of course, I don't want to help her anymore.",
      "zh": "當然，我不想再幫她了。",
      "ja": "もちろん、もう彼女を助けたくない。",
      "time": "00:00:34"
    },
    {
      "role": "student",
      "text": "In fact, this whole thing has ruined me for helping anyone ever again.",
      "zh": "事實上，這整件事讓我再也不想幫任何人了。",
      "ja": "実際、この一件で誰も助けたくなくなった。",
      "time": "00:00:36"
    },
    {
      "role": "student",
      "text": "She'll die on her own.",
      "zh": "她會自己死去。",
      "ja": "彼女は自分で死ぬだろう。",
      "time": "00:00:41"
    },
    {
      "role": "student",
      "text": "I can live with that.",
      "zh": "我能接受這點。",
      "ja": "それなら仕方ない。",
      "time": "00:00:44"
    },
    {
      "role": "student",
      "text": "Here we go.",
      "zh": "我們走吧。",
      "ja": "さあ行こう。",
      "time": "00:00:44"
    },
    {
      "role": "student",
      "text": "But you won't get your new sled if she's dead.",
      "zh": "但如果她死了，你就拿不到新雪橇了。",
      "ja": "でも彼女が死んだら、新しいそりはもらえないよ。",
      "time": "00:00:45"
    },
    {
      "role": "student",
      "text": "Sometimes I really don't like you.",
      "zh": "有時我真的不喜歡你。",
      "ja": "時々本当に君が嫌いだ。",
      "time": "00:00:50"
    },
    {
      "role": "student",
      "text": "Groom! Hold up! We're coming!",
      "zh": "新郎！等一下！我們來了！",
      "ja": "花婿！待って！今行くよ！",
      "time": "00:00:52"
    },
    {
      "role": "student",
      "text": "You are?",
      "zh": "你是？",
      "ja": "君は？",
      "time": "00:00:55"
    },
    {
      "role": "student",
      "text": "I mean, turn!",
      "zh": "我是說，轉過來！",
      "ja": "いや、振り向いて！",
      "time": "00:00:56"
    },
    {
      "role": "student",
      "text": "Yeah, I'll let you tag along.",
      "zh": "好，我讓你跟著。",
      "ja": "うん、一緒に来ていいよ。",
      "time": "00:00:57"
    },
    {
      "role": "student",
      "text": "And you are...",
      "zh": "你是...",
      "ja": "君は…",
      "time": "00:00:59"
    },
    {
      "role": "student",
      "text": "Um, I'm Anna.",
      "zh": "嗯，我是安娜。",
      "ja": "えっと、私はアナです。",
      "time": "00:01:04"
    },
    {
      "role": "student",
      "text": "And who's the funky-looking donkey over there?",
      "zh": "那邊那隻奇怪樣子的驢子是誰？",
      "ja": "あの変な見た目のロバは誰？",
      "time": "00:01:06"
    },
    {
      "role": "student",
      "text": "That's Sven.",
      "zh": "那是斯文。",
      "ja": "それはスヴェンだよ。",
      "time": "00:01:08"
    },
    {
      "role": "student",
      "text": "Uh-huh.",
      "zh": "嗯哼。",
      "ja": "うんうん。",
      "time": "00:01:09"
    },
    {
      "role": "student",
      "text": "And who's the rain deer?",
      "zh": "那馴鹿是誰？",
      "ja": "そしてトナカイは誰？",
      "time": "00:01:10"
    },
    {
      "role": "student",
      "text": "Sven?",
      "zh": "斯文？",
      "ja": "スヴェン？",
      "time": "00:01:12"
    },
    {
      "role": "student",
      "text": "Oh, they're both.",
      "zh": "哦，他們兩個都是。",
      "ja": "ああ、両方だよ。",
      "time": "00:01:13"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好。",
      "ja": "わかった。",
      "time": "00:01:14"
    },
    {
      "role": "student",
      "text": "Make things easier for me.",
      "zh": "讓我好辦事。",
      "ja": "僕にとって楽にしてくれ。",
      "time": "00:01:15"
    },
    {
      "role": "student",
      "text": "I'll look at him trying to kiss my nose.",
      "zh": "我會看著他試圖親我的鼻子。",
      "ja": "彼が僕の鼻にキスしようとするのを見るよ。",
      "time": "00:01:17"
    },
    {
      "role": "student",
      "text": "I like you, too.",
      "zh": "我也喜歡你。",
      "ja": "僕も君が好きだよ。",
      "time": "00:01:18"
    },
    {
      "role": "student",
      "text": "Olaf, did Elsa build you?",
      "zh": "奧拉夫，是艾莎造你的嗎？",
      "ja": "オラフ、エルサが君を作ったの？",
      "time": "00:01:20"
    },
    {
      "role": "student",
      "text": "Yeah, why?",
      "zh": "是啊，怎麼了？",
      "ja": "うん、どうして？",
      "time": "00:01:22"
    },
    {
      "role": "student",
      "text": "Do you know where she is?",
      "zh": "你知道她在哪裡嗎？",
      "ja": "彼女がどこにいるか知ってる？",
      "time": "00:01:23"
    },
    {
      "role": "student",
      "text": "Yes, I say.",
      "zh": "是的，我說。",
      "ja": "はい、そう言った。",
      "time": "00:01:24"
    },
    {
      "role": "student",
      "text": "Yeah, why?",
      "zh": "是啊，怎麼了？",
      "ja": "うん、どうして？",
      "time": "00:01:25"
    },
    {
      "role": "student",
      "text": "Do you think you could show us the way?",
      "zh": "你能帶我們去嗎？",
      "ja": "道を案内してくれる？",
      "time": "00:01:26"
    },
    {
      "role": "student",
      "text": "Yeah, why?",
      "zh": "是啊，怎麼了？",
      "ja": "うん、どうして？",
      "time": "00:01:27"
    },
    {
      "role": "student",
      "text": "How does this work?",
      "zh": "這怎麼運作？",
      "ja": "これはどうやって動くの？",
      "time": "00:01:28"
    },
    {
      "role": "student",
      "text": "Ow!",
      "zh": "哎呦！",
      "ja": "痛っ！",
      "time": "00:01:29"
    },
    {
      "role": "student",
      "text": "Stop it, Sven.",
      "zh": "別這樣，斯文。",
      "ja": "やめて、スヴェン。",
      "time": "00:01:30"
    },
    {
      "role": "student",
      "text": "Trying to focus here.",
      "zh": "我在努力集中注意力。",
      "ja": "ここで集中しようとしてるんだ。",
      "time": "00:01:31"
    },
    {
      "role": "student",
      "text": "Oh...",
      "zh": "哦...",
      "ja": "ああ...",
      "time": "00:01:41"
    },
    {
      "role": "student",
      "text": "What is it, buddy?",
      "zh": "怎麼了，夥伴？",
      "ja": "どうしたんだ、相棒？",
      "time": "00:01:48"
    },
    {
      "role": "student",
      "text": "Hey.",
      "zh": "嘿。",
      "ja": "ねえ。",
      "time": "00:01:49"
    },
    {
      "role": "student",
      "text": "Watch it.",
      "zh": "小心點。",
      "ja": "気をつけて。",
      "time": "00:01:50"
    },
    {
      "role": "student",
      "text": "What's wrong with you?",
      "zh": "你怎麼了？",
      "ja": "どうしたんだ？",
      "time": "00:01:51"
    },
    {
      "role": "student",
      "text": "I don't understand you only need to talk like that.",
      "zh": "我不懂你為什麼只用那種方式說話。",
      "ja": "君がそんな話し方だけでいいなんてわからないよ。",
      "time": "00:01:52"
    },
    {
      "role": "student",
      "text": "Stop it!",
      "zh": "停下！",
      "ja": "やめて！",
      "time": "00:01:59"
    },
    {
      "role": "student",
      "text": "Put me down!",
      "zh": "放我下來！",
      "ja": "降ろして！",
      "time": "00:02:00"
    },
    {
      "role": "student",
      "text": "No, Sven.",
      "zh": "不，斯文。",
      "ja": "ダメだ、スヴェン。",
      "time": "00:02:03"
    },
    {
      "role": "student",
      "text": "We're not going back.",
      "zh": "我們不會回去的。",
      "ja": "戻らないよ。",
      "time": "00:02:04"
    },
    {
      "role": "student",
      "text": "She's with her true love.",
      "zh": "她和她的真愛在一起。",
      "ja": "彼女は本当の愛と一緒だ。",
      "time": "00:02:06"
    },
    {
      "role": "student",
      "text": "What the...",
      "zh": "什麼...",
      "ja": "なんだって...",
      "time": "00:02:14"
    },
    {
      "role": "student",
      "text": "Anna...",
      "zh": "安娜...",
      "ja": "アナ...",
      "time": "00:02:18"
    },
    {
      "role": "student",
      "text": "Oh, boy!",
      "zh": "喔，天啊！",
      "ja": "おお、やばい！",
      "time": "00:02:22"
    },
    {
      "role": "student",
      "text": "Oh, boy!",
      "zh": "喔，天啊！",
      "ja": "おお、やばい！",
      "time": "00:02:24"
    },
    {
      "role": "student",
      "text": "Okay, okay.",
      "zh": "好，好。",
      "ja": "わかった、わかった。",
      "time": "00:02:26"
    },
    {
      "role": "student",
      "text": "Here we are.",
      "zh": "我們到了。",
      "ja": "ここだ。",
      "time": "00:02:28"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:02:29"
    },
    {
      "role": "student",
      "text": "I owe you a sled.",
      "zh": "我欠你一台雪橇。",
      "ja": "そりを借りてるよ。",
      "time": "00:02:30"
    },
    {
      "role": "student",
      "text": "Oh.",
      "zh": "哦。",
      "ja": "ああ。",
      "time": "00:02:36"
    },
    {
      "role": "student",
      "text": "Are you serious?",
      "zh": "你認真的嗎？",
      "ja": "本気？",
      "time": "00:02:37"
    },
    {
      "role": "student",
      "text": "Yes!",
      "zh": "是的！",
      "ja": "はい！",
      "time": "00:02:39"
    },
    {
      "role": "student",
      "text": "In its the latest model.",
      "zh": "是最新款的。",
      "ja": "最新モデルだよ。",
      "time": "00:02:40"
    },
    {
      "role": "student",
      "text": "No, I can't accept this.",
      "zh": "不，我不能接受這個。",
      "ja": "いや、これは受け取れない。",
      "time": "00:02:41"
    },
    {
      "role": "student",
      "text": "You have to.",
      "zh": "你必須接受。",
      "ja": "受け取らなきゃ。",
      "time": "00:02:42"
    },
    {
      "role": "student",
      "text": "No returns.",
      "zh": "不退貨。",
      "ja": "返品不可。",
      "time": "00:02:43"
    },
    {
      "role": "student",
      "text": "No exchanges.",
      "zh": "不換貨。",
      "ja": "交換不可。",
      "time": "00:02:44"
    },
    {
      "role": "student",
      "text": "Queen's orders.",
      "zh": "女王的命令。",
      "ja": "女王の命令だ。",
      "time": "00:02:45"
    },
    {
      "role": "student",
      "text": "She's named you the official Airendale Icemaster and Deliber.",
      "zh": "她任命你為官方的艾倫戴爾冰雪大師和送貨員。",
      "ja": "彼女は君をエアレンデルの公式アイスマスター兼配達人に任命した。",
      "time": "00:02:46"
    },
    {
      "role": "student",
      "text": "Deliber.",
      "zh": "送貨員。",
      "ja": "配達人だ。",
      "time": "00:02:50"
    },
    {
      "role": "student",
      "text": "Hello.",
      "zh": "你好。",
      "ja": "こんにちは。",
      "time": "00:02:53"
    },
    {
      "role": "student",
      "text": "Some things never change.",
      "zh": "有些事情永遠不變。",
      "ja": "変わらないこともある。",
      "time": "00:03:10"
    },
    {
      "role": "student",
      "text": "Like the love that I feel for her.",
      "zh": "就像我對她的愛。",
      "ja": "彼女への愛のように。",
      "time": "00:03:13"
    },
    {
      "role": "student",
      "text": "Some things stay the same.",
      "zh": "有些事情保持不變。",
      "ja": "変わらずにいることもある。",
      "time": "00:03:15"
    },
    {
      "role": "student",
      "text": "My carriages are easier,",
      "zh": "我的馬車變得更輕鬆，",
      "ja": "僕の馬車は楽になった、",
      "time": "00:03:18"
    },
    {
      "role": "student",
      "text": "but if I commit and I go for it,",
      "zh": "但如果我決心去做，",
      "ja": "でも決めて挑めば、",
      "time": "00:03:20"
    },
    {
      "role": "student",
      "text": "I'll know what to say and do.",
      "zh": "我會知道該說什麼該做什麼。",
      "ja": "何を言い何をすべきか分かる。",
      "time": "00:03:23"
    },
    {
      "role": "student",
      "text": "Right?",
      "zh": "對吧？",
      "ja": "そうだろ？",
      "time": "00:03:26"
    },
    {
      "role": "student",
      "text": "Some things never change.",
      "zh": "有些事情永遠不變。",
      "ja": "変わらないこともある。",
      "time": "00:03:27"
    },
    {
      "role": "student",
      "text": "Sven, the pressure is all on you.",
      "zh": "斯文，壓力全在你身上。",
      "ja": "スヴェン、プレッシャーは全部君にかかってる。",
      "time": "00:03:31"
    },
    {
      "role": "student",
      "text": "Water has memory.",
      "zh": "水有記憶。",
      "ja": "水には記憶がある。",
      "time": "00:03:36"
    },
    {
      "role": "student",
      "text": "The water that makes up you and me has passed through at least",
      "zh": "組成你我身體的水，至少流經過",
      "ja": "君と僕を作る水は少なくとも",
      "time": "00:03:37"
    },
    {
      "role": "student",
      "text": "four humans and our animals before us.",
      "zh": "四個人類和我們的動物。",
      "ja": "4人の人間と僕たちの動物を通ってきた。",
      "time": "00:03:40"
    },
    {
      "role": "student",
      "text": "Mm.",
      "zh": "嗯。",
      "ja": "うん。",
      "time": "00:03:43"
    },
    {
      "role": "student",
      "text": "And remembers everything.",
      "zh": "並且記得一切。",
      "ja": "そしてすべてを覚えている。",
      "time": "00:03:45"
    },
    {
      "role": "student",
      "text": "Mm-hmm.",
      "zh": "嗯嗯。",
      "ja": "うんうん。",
      "time": "00:03:47"
    },
    {
      "role": "student",
      "text": "Mm-hmm.",
      "zh": "嗯嗯。",
      "ja": "うんうん。",
      "time": "00:03:48"
    },
    {
      "role": "student",
      "text": "The bend back.",
      "zh": "回彎。",
      "ja": "戻るんだ。",
      "time": "00:03:49"
    },
    {
      "role": "student",
      "text": "Mm-hmm.",
      "zh": "嗯嗯。",
      "ja": "うんうん。",
      "time": "00:03:50"
    },
    {
      "role": "student",
      "text": "Do you leave?",
      "zh": "你要離開嗎？",
      "ja": "君は去るのか？",
      "time": "00:03:52"
    },
    {
      "role": "student",
      "text": "I think I'll name you Gail.",
      "zh": "我想我會叫你蓋爾。",
      "ja": "君をゲイルと名付けよう。",
      "time": "00:03:53"
    },
    {
      "role": "student",
      "text": "Huh?",
      "zh": "嗯？",
      "ja": "え？",
      "time": "00:04:02"
    },
    {
      "role": "student",
      "text": "Rain dares are better than people.",
      "zh": "馴鹿比人類更好。",
      "ja": "トナカイは人間よりいいんだ。",
      "time": "00:04:06"
    },
    {
      "role": "student",
      "text": "Sven, why is love so?",
      "zh": "斯文，為什麼愛情這麼...",
      "ja": "スヴェン、なぜ愛はこんなに…",
      "time": "00:04:10"
    },
    {
      "role": "student",
      "text": "So hard.",
      "zh": "這麼難。",
      "ja": "難しいんだ。",
      "time": "00:04:12"
    },
    {
      "role": "student",
      "text": "You feel what you feel?",
      "zh": "你感受到你所感受到的嗎？",
      "ja": "感じるままに感じてる？",
      "time": "00:04:16"
    },
    {
      "role": "student",
      "text": "And those feelings are real.",
