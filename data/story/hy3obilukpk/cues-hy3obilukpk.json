  },
  {
    "time": "00:05:35",
    "en": "No.",
    "zh": "不。",
    "ja": "いいえ。"
  },
  {
    "time": "00:05:38",
    "en": "Next.",
    "zh": "下一位。",
    "ja": "次。"
  },
  {
    "time": "00:05:42",
    "en": "No.",
    "zh": "不。",
    "ja": "いいえ。"
  },
  {
    "time": "00:05:45",
    "en": "No.",
    "zh": "不。",
    "ja": "いいえ。"
  },
  {
    "time": "00:05:49",
    "en": "No.",
    "zh": "不。",
    "ja": "いいえ。"
  },
  {
    "time": "00:05:57",
    "en": "Your Majesty.",
    "zh": "陛下。",
    "ja": "陛下。"
  },
