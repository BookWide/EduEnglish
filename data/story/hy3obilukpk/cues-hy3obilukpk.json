[
  {
    "time": "00:00:00",
    "en": "Road At perplexity, the court cannot wait forever, the Kingdom needs a queen.",
    "zh": "在困惑中，宮廷不能永遠等待，王國需要一位女王。",
    "ja": "困惑の中で、宮廷は永遠に待てない、王国には女王が必要だ。",
    "source_url": "https://www.youtube.com/watch?v=hY3oBilUKPk"
  },
  {
    "time": "00:00:27",
    "en": "We asked Major of Wales.",
    "zh": "我們問了威爾斯少校。",
    "ja": "私たちはウェールズのメジャーに尋ねた。"
  },
  {
    "time": "00:00:28",
    "en": "You asked me to marry again for the sake of the kingdom.",
    "zh": "你叫我為了王國再婚。",
    "ja": "王国のためにもう一度結婚するように頼んだ。"
  },
  {
    "time": "00:00:32",
    "en": "I have finally found one who is worthy of the crown.",
    "zh": "我終於找到一位配得上王冠的人。",
    "ja": "ついに王冠にふさわしい人を見つけた。"
  },
  {
    "time": "00:00:37",
    "en": "There is only one woman in this world equal to the queen.",
    "zh": "這世上只有一個女人能與女王匹敵。",
    "ja": "この世に女王に匹敵する女性はただ一人だけだ。"
  },
  {
    "time": "00:00:41",
    "en": "You're majesty. Who might that be?",
    "zh": "陛下，那會是誰？",
    "ja": "陛下、それは誰でしょうか？"
  },
  {
    "time": "00:00:45",
    "en": "My daughter.",
    "zh": "我的女兒。",
    "ja": "私の娘だ。"
  },
  {
    "time": "00:00:49",
    "en": "Sire. That is unheard of.",
    "zh": "陛下，這是前所未聞的。",
    "ja": "陛下、それは前代未聞です。"
  },
  {
    "time": "00:00:52",
    "en": "I made a vow. I will not break it.",
    "zh": "我立了誓言，我不會違背它。",
    "ja": "誓いを立てた。破るつもりはない。"
  },
  {
    "time": "00:00:58",
    "en": "Sire.",
    "zh": "陛下。",
    "ja": "陛下。"
  },
  {
    "time": "00:01:16",
    "en": "You always hated this portrait.",
