    {
      "role": "student",
      "text": "Queen Elsa of Arindelle",
      "zh": "阿林黛爾的艾莎女王",
      "ja": "アレンデールのエルサ女王",
      "time": "00:03:05"
    },
    {
      "role": "teacher",
      "text": "Hi, Pimey",
      "zh": "嗨，派米",
      "ja": "やあ、パイミー",
      "time": "00:03:10"
    },
    {
      "role": "student",
      "text": "Oh, um, hi",
      "zh": "喔，嗯，嗨",
      "ja": "ああ、えっと、こんにちは",
      "time": "00:03:11"
    },
    {
      "role": "teacher",
      "text": "The Duke of Weasel Tower",
