  "dialogue": [
    {
      "role": "teacher",
      "text": "Anana, hey Anana, hey Anana",
      "zh": "阿娜娜，嘿阿娜娜，嘿阿娜娜",
      "ja": "アナナ、ヘイアナナ、ヘイアナナ",
      "time": "00:00:00"
    },
    {
      "role": "student",
      "text": "Your beauty star and tear, say to the eyes of hearts",
