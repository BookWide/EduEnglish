    },
    {
      "role": "teacher",
      "text": "I want to build a snowman",
      "zh": "我想堆雪人",
      "ja": "雪だるまを作りたい",
      "time": "00:01:25"
    },
    {
      "role": "student",
      "text": "Or ride our bike around the house",
      "zh": "或者騎著自行車繞著房子",
      "ja": "それか家の周りを自転車で走ろう",
      "time": "00:01:27"
    },
    {
      "role": "teacher",
      "text": "Calm down",
