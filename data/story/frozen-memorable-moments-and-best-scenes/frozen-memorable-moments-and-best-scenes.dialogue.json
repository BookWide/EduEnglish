    },
    {
      "role": "student",
      "text": "True love",
      "zh": "真愛",
      "ja": "真実の愛",
      "time": "00:06:04"
    },
    {
      "role": "teacher",
      "text": "Whoa",
      "zh": "哇",
      "ja": "おお",
      "time": "00:06:05"
    },
    {
      "role": "student",
      "text": "Whoa",
      "zh": "哇",
      "ja": "おお",
      "time": "00:06:07"
    },
    {
      "role": "teacher",
