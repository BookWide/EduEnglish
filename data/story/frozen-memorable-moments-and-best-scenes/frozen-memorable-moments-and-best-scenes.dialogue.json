      "text": "Mades!",
      "zh": "馬德斯！",
      "ja": "マデス！",
      "time": "00:00:35"
    },
    {
      "role": "student",
      "text": "Mades!",
      "zh": "馬德斯！",
      "ja": "マデス！",
      "time": "00:00:38"
    },
    {
      "role": "teacher",
      "text": "Take a look",
