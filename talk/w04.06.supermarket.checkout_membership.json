  "dialogue": [
    {
      "role": "teacher",
      "text": "Hi! Did you find everything you needed?",
      "zh": "你好！需要的東西都找到了嗎？",
      "ja": "こんにちは！必要なものはすべて見つかりましたか？"
    },
    {
      "role": "student",
      "text": "Yes, I did.",
      "zh": "有，都找到了。",
      "ja": "はい、見つかりました。"
    },
    {
      "role": "teacher",
      "text": "Do you have a membership card?",
      "zh": "你有會員卡嗎？",
      "ja": "会員カードはお持ちですか？"
    },
    {
      "role": "student",
      "text": "Not yet. Can I sign up?",
      "zh": "還沒有。我可以申請嗎？",
      "ja": "まだです。登録できますか？"
    },
    {
      "role": "teacher",
      "text": "Yes, it’s quick. Do you have a phone number?",
      "zh": "可以，很快。你有電話號碼嗎？",
      "ja": "はい、すぐできます。電話番号はありますか？"
    },
    {
      "role": "student",
      "text": "Yes, it’s 09xx-xxx-xxx.",
      "zh": "有，是 09xx-xxx-xxx。",
      "ja": "はい、09xx-xxx-xxx です。"
    },
    {
      "role": "teacher",
      "text": "Great. I’ll register you.",
      "zh": "很好，我幫你登記。",
      "ja": "ありがとうございます。登録します。"
    },
    {
      "role": "student",
      "text": "Thank you.",
      "zh": "謝謝你。",
      "ja": "ありがとうございます。"
    },
    {
      "role": "teacher",
      "text": "Would you like a bag?",
      "zh": "需要袋子嗎？",
      "ja": "袋は必要ですか？"
    },
    {
      "role": "student",
      "text": "Yes, one bag, please.",
      "zh": "要，一個袋子，謝謝。",
      "ja": "はい、袋を1つお願いします。"
    },
    {
      "role": "teacher",
      "text": "Your total is $463.",
      "zh": "總共是 463 元。",
      "ja": "合計は463ドルです。"
    },
    {
      "role": "student",
      "text": "Okay.",
      "zh": "好的。",
      "ja": "わかりました。"
    },
    {
      "role": "teacher",
      "text": "Cash or card?",
      "zh": "付現還是刷卡？",
      "ja": "現金とカード、どちらですか？"
    },
    {
      "role": "student",
      "text": "Card, please.",
      "zh": "刷卡，謝謝。",
      "ja": "カードでお願いします。"
    },
    {
      "role": "teacher",
      "text": "Please tap your card here.",
      "zh": "請把卡片在這裡感應。",
      "ja": "こちらにカードをタッチしてください。"
    },
    {
      "role": "student",
      "text": "(Taps card)",
      "zh": "（感應卡片）",
      "ja": "（カードをタッチする）"
    },
    {
      "role": "teacher",
      "text": "Approved.",
      "zh": "已核准。",
      "ja": "承認されました。"
    },
    {
      "role": "student",
      "text": "Great.",
      "zh": "太好了。",
      "ja": "いいですね。"
    },
    {
      "role": "teacher",
      "text": "Would you like a receipt?",
      "zh": "需要收據嗎？",
      "ja": "レシートは必要ですか？"
    },
    {
      "role": "student",
      "text": "Yes, please.",
      "zh": "好的，謝謝。",
      "ja": "はい、お願いします。"
    },
    {
      "role": "teacher",
      "text": "Do you want paper or digital?",
      "zh": "你要紙本還是電子收據？",
      "ja": "紙のレシートと電子レシート、どちらにしますか？"
    },
    {
      "role": "student",
      "text": "Paper is fine.",
      "zh": "紙本就好。",
      "ja": "紙で大丈夫です。"
    },
    {
      "role": "teacher",
      "text": "Here’s your receipt and your points today.",
      "zh": "這是你的收據和今天累積的點數。",
      "ja": "こちらがレシートと本日のポイントです。"
    },
    {
      "role": "student",
      "text": "Nice, thanks.",
      "zh": "不錯，謝謝。",
      "ja": "いいですね。ありがとうございます。"
    },
    {
      "role": "teacher",
      "text": "You earned a coupon for next time.",
      "zh": "你獲得一張下次可用的優惠券。",
      "ja": "次回使えるクーポンを獲得しました。"
    },
    {
      "role": "student",
      "text": "Awesome.",
      "zh": "太棒了。",
      "ja": "最高です。"
    },
    {
      "role": "teacher",
      "text": "Anything else I can help with?",
      "zh": "還有其他需要幫忙的嗎？",
      "ja": "ほかにお手伝いできることはありますか？"
    },
    {
      "role": "student",
      "text": "No, that’s all.",
      "zh": "不用，就這些。",
      "ja": "いいえ、以上です。"
    },
    {
      "role": "teacher",
      "text": "Have a great day!",
      "zh": "祝你今天愉快！",
      "ja": "よい一日を！"
    },
    {
      "role": "student",
      "text": "You too!",
      "zh": "你也是！",
      "ja": "あなたも！"
    }
  ]
}
