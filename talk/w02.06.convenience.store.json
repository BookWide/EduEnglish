  "dialogue": [
    {
      "role": "teacher",
      "text": "Hi, sorry for the wait.",
      "zh": "你好，讓你久等了。",
      "ja": "こんにちは。お待たせしてすみません。"
    },
    {
      "role": "student",
      "text": "No worries.",
      "zh": "沒關係。",
      "ja": "大丈夫です。"
    },
    {
      "role": "teacher",
      "text": "It’s a bit busy right now.",
      "zh": "現在有點忙。",
      "ja": "今は少し混んでいます。"
    },
    {
      "role": "student",
      "text": "I can see that.",
      "zh": "看得出來。",
      "ja": "そうですね。"
    },
    {
      "role": "teacher",
      "text": "Are you here to pay or pick up a package?",
      "zh": "你是要付款，還是取包裹？",
      "ja": "お支払いですか、それとも荷物の受け取りですか？"
    },
    {
